{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riso.build/schemas/release-readiness/answer-schema.json",
  "title": "Riso Canonical Copier Answers",
  "type": "object",
  "additionalProperties": true,
  "not": {
    "anyOf": [
      { "required": ["api_tracks"] },
      { "required": ["api_language"] },
      { "required": ["docs_site"] },
      { "required": ["mcp_language"] },
      { "required": ["saas_starter_module"] }
    ]
  },
  "properties": {
    "api_module": { "enum": ["enabled", "disabled"] },
    "api_languages": {
      "type": "array",
      "items": { "enum": ["python", "node", "go", "rust"] },
      "uniqueItems": true
    },
    "docs_module": { "enum": ["enabled", "disabled"] },
    "docs_framework": { "enum": ["sphinx-shibuya", "fumadocs", "docusaurus", "none"] },
    "mcp_module": { "enum": ["enabled", "disabled"] },
    "mcp_languages": {
      "type": "array",
      "items": { "enum": ["python", "typescript", "rust", "go"] },
      "uniqueItems": true
    },
    "saas_infra_module": { "enum": ["enabled", "disabled"] }
  }
}

