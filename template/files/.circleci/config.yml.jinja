{% if ci_platform == 'circleci' -%}
# CircleCI Configuration for {{ project_name }}
# Auto-generated by Riso template • DO NOT EDIT MANUALLY
# Component-first polyglot CI pipeline supporting Python, TypeScript, Rust, Go

version: 2.1

# ========================================
# Orbs - CircleCI Reusable Packages
# ========================================

orbs:
  {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages -%}
  python: circleci/python@2.1
  {% endif -%}
  {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
  node: circleci/node@5.2
  {% endif -%}
  {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
  rust: circleci/rust@1.6
  {% endif -%}
  {% if cli_module == 'enabled' and 'go' in cli_languages or api_module == 'enabled' and 'go' in api_languages or mcp_module == 'enabled' and 'go' in mcp_languages -%}
  go: circleci/go@1.11
  {% endif -%}

# ========================================
# Executors - Execution Environments
# ========================================

executors:
  {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages or docs_module == 'enabled' and docs_framework == 'sphinx-shibuya' -%}
  python-executor:
    docker:
      - image: cimg/python:3.12
    environment:
      QUALITY_PROFILE: "{{ quality_profile }}"
      PACKAGE_NAME: "{{ package_name }}"
  {% endif -%}

  {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
  node-executor:
    docker:
      - image: cimg/node:22.11
    environment:
      PNPM_HOME: /home/circleci/.local/share/pnpm
  {% endif -%}

  {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
  rust-executor:
    docker:
      - image: cimg/rust:1.85
  {% endif -%}

  {% if cli_module == 'enabled' and 'go' in cli_languages or api_module == 'enabled' and 'go' in api_languages or mcp_module == 'enabled' and 'go' in mcp_languages -%}
  go-executor:
    docker:
      - image: cimg/go:{{ go_version }}
  {% endif -%}

# ========================================
# Commands - Reusable Command Sequences
# ========================================

commands:
  {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages or docs_module == 'enabled' and docs_framework == 'sphinx-shibuya' -%}
  setup-uv:
    description: "Install and configure uv package manager"
    steps:
      - run:
          name: Install uv
          command: |
            curl -LsSf https://astral.sh/uv/install.sh | sh
            echo 'export PATH="$HOME/.cargo/bin:$PATH"' >> $BASH_ENV
      - restore_cache:
          keys:
            - uv-cache-{{ "{{" }} checksum "uv.lock" {{ "}}" }}
            - uv-cache-
      - run:
          name: Install Python dependencies
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv sync
      - save_cache:
          key: uv-cache-{{ "{{" }} checksum "uv.lock" {{ "}}" }}
          paths:
            - ~/.cache/uv
            - .venv
  {% endif -%}

  {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
  setup-pnpm:
    description: "Install and configure pnpm package manager"
    steps:
      - run:
          name: Enable corepack and pnpm
          command: |
            corepack enable
            corepack prepare pnpm@latest --activate
      - restore_cache:
          keys:
            - pnpm-cache-{{ "{{" }} checksum "pnpm-lock.yaml" {{ "}}" }}
            - pnpm-cache-
      - run:
          name: Install Node.js dependencies
          command: pnpm install --frozen-lockfile
      - save_cache:
          key: pnpm-cache-{{ "{{" }} checksum "pnpm-lock.yaml" {{ "}}" }}
          paths:
            - ~/.local/share/pnpm/store
            - node_modules
  {% endif -%}

# ========================================
# Jobs - Individual CI Tasks
# ========================================

jobs:
  {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages or docs_module == 'enabled' and docs_framework == 'sphinx-shibuya' -%}
  # ---------- Python Jobs ----------

  lint-python:
    executor: python-executor
    steps:
      - checkout
      - setup-uv
      - run:
          name: Run Ruff linter
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run ruff check .
      - run:
          name: Check code formatting
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run ruff format --check .
      {% if quality_profile == 'strict' -%}
      - run:
          name: Run mypy type checker
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run mypy .
      - run:
          name: Run Pylint static analysis
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run pylint src/
      {% endif -%}

  test-python:
    executor: python-executor
    {% if project_layout == 'monorepo' -%}
    parallelism: 3
    {% endif -%}
    steps:
      - checkout
      - setup-uv
      - run:
          name: Run pytest with coverage
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run pytest tests/ -v --cov --cov-report=xml --cov-report=html --junit-xml=test-results.xml
      - store_test_results:
          path: test-results.xml
      - store_artifacts:
          path: coverage.xml
      - store_artifacts:
          path: htmlcov
          destination: coverage-html

  {% if cli_module == 'enabled' and 'python' in cli_languages -%}
  test-cli:
    executor: python-executor
    steps:
      - checkout
      - setup-uv
      - run:
          name: Test CLI module
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run pytest tests/test_cli.py -v
  {% endif -%}

  {% if mcp_module == 'enabled' and 'python' in mcp_languages -%}
  test-mcp:
    executor: python-executor
    steps:
      - checkout
      - setup-uv
      - run:
          name: Test MCP module
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run pytest tests/test_mcp.py -v
  {% endif -%}

  {% endif -%}

  {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
  # ---------- Node.js Jobs ----------

  lint-node:
    executor: node-executor
    steps:
      - checkout
      - setup-pnpm
      - run:
          name: Run ESLint
          command: pnpm run lint
      - run:
          name: Run TypeScript type check
          command: pnpm run typecheck

  test-node:
    executor: node-executor
    steps:
      - checkout
      - setup-pnpm
      - run:
          name: Run tests with coverage
          command: pnpm run test --coverage
      - store_test_results:
          path: coverage
      - store_artifacts:
          path: coverage
          destination: coverage

  build-node:
    executor: node-executor
    steps:
      - checkout
      - setup-pnpm
      - run:
          name: Build application
          command: pnpm run build
      - persist_to_workspace:
          root: .
          paths:
            - dist/
            {% if saas_infra_module == 'enabled' -%}
            - .next/
            {% endif -%}
      - store_artifacts:
          path: dist
          destination: build-output

  {% if saas_infra_module == 'enabled' -%}
  test-e2e:
    executor: node-executor
    steps:
      - checkout
      - attach_workspace:
          at: .
      - setup-pnpm
      - run:
          name: Run E2E tests
          command: pnpm run test:e2e
      - store_artifacts:
          path: playwright-report
          destination: playwright-report
      - store_artifacts:
          path: test-results
          destination: test-results
  {% endif -%}

  {% endif -%}

  {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
  # ---------- Rust Jobs ----------

  lint-rust:
    executor: rust-executor
    steps:
      - checkout
      - rust/install:
          version: stable
      - run:
          name: Check formatting
          command: cargo fmt -- --check
      - run:
          name: Run clippy linter
          command: cargo clippy --all-targets --all-features -- -D warnings

  test-rust:
    executor: rust-executor
    steps:
      - checkout
      - rust/install:
          version: stable
      - restore_cache:
          keys:
            - cargo-cache-{{ "{{" }} checksum "Cargo.lock" {{ "}}" }}
            - cargo-cache-
      - run:
          name: Run tests
          command: cargo test --all-features --verbose
      - run:
          name: Run doc tests
          command: cargo test --doc
      - save_cache:
          key: cargo-cache-{{ "{{" }} checksum "Cargo.lock" {{ "}}" }}
          paths:
            - ~/.cargo
            - target

  build-rust:
    executor: rust-executor
    steps:
      - checkout
      - rust/install:
          version: stable
      - restore_cache:
          keys:
            - cargo-cache-{{ "{{" }} checksum "Cargo.lock" {{ "}}" }}
            - cargo-cache-
      - run:
          name: Build release binary
          command: cargo build --release
      - store_artifacts:
          path: target/release/{{ package_name | replace('_', '-') }}
          destination: {{ package_name | replace('_', '-') }}

  {% endif -%}

  {% if cli_module == 'enabled' and 'go' in cli_languages or api_module == 'enabled' and 'go' in api_languages or mcp_module == 'enabled' and 'go' in mcp_languages -%}
  # ---------- Go Jobs ----------

  lint-go:
    executor: go-executor
    steps:
      - checkout
      - go/load-cache
      - go/mod-download
      - run:
          name: Check formatting
          command: |
            if [ "$(gofmt -l . | wc -l)" -gt 0 ]; then
              echo "Go files are not formatted:"
              gofmt -l .
              exit 1
            fi
      - run:
          name: Run go vet
          command: go vet ./...
      - go/save-cache

  test-go:
    executor: go-executor
    steps:
      - checkout
      - go/load-cache
      - go/mod-download
      - run:
          name: Run tests with race detector
          command: go test -v -race -coverprofile=coverage.txt -covermode=atomic ./...
      - store_test_results:
          path: coverage.txt
      - store_artifacts:
          path: coverage.txt
          destination: coverage.txt
      - go/save-cache

  build-go:
    executor: go-executor
    steps:
      - checkout
      - go/load-cache
      - go/mod-download
      - run:
          name: Build binary
          command: go build -o {{ package_name | replace('_', '-') }} ./cmd/...
      - store_artifacts:
          path: {{ package_name | replace('_', '-') }}
          destination: {{ package_name | replace('_', '-') }}

  {% endif -%}

  {% if docs_module == 'enabled' -%}
  # ---------- Documentation Jobs ----------

  {% if docs_framework == 'sphinx-shibuya' -%}
  build-docs:
    executor: python-executor
    steps:
      - checkout
      - setup-uv
      - run:
          name: Build Sphinx documentation
          command: |
            export PATH="$HOME/.cargo/bin:$PATH"
            uv run sphinx-build docs/ public/
      - store_artifacts:
          path: public
          destination: docs
  {% elif docs_framework in ['fumadocs', 'docusaurus'] -%}
  build-docs:
    executor: node-executor
    steps:
      - checkout
      - setup-pnpm
      - run:
          name: Build documentation site
          command: |
            {% if docs_framework == 'fumadocs' -%}
            pnpm run docs:build
            mv docs/out public/
            {% elif docs_framework == 'docusaurus' -%}
            cd docs && pnpm run build
            mv build ../public/
            {% endif -%}
      - store_artifacts:
          path: public
          destination: docs
  {% endif -%}

  {% endif -%}

# ========================================
# Workflows - Job Orchestration
# ========================================

workflows:
  version: 2
  main:
    jobs:
      {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages or docs_module == 'enabled' and docs_framework == 'sphinx-shibuya' -%}
      # Python workflow
      - lint-python
      - test-python:
          requires:
            - lint-python
      {% if cli_module == 'enabled' and 'python' in cli_languages -%}
      - test-cli:
          requires:
            - lint-python
      {% endif -%}
      {% if mcp_module == 'enabled' and 'python' in mcp_languages -%}
      - test-mcp:
          requires:
            - lint-python
      {% endif -%}
      {% endif -%}

      {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
      # Node.js workflow
      - lint-node
      - test-node:
          requires:
            - lint-node
      - build-node:
          requires:
            - test-node
      {% if saas_infra_module == 'enabled' -%}
      - test-e2e:
          requires:
            - build-node
      {% endif -%}
      {% endif -%}

      {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
      # Rust workflow
      - lint-rust
      - test-rust:
          requires:
            - lint-rust
      - build-rust:
          requires:
            - test-rust
      {% endif -%}

      {% if cli_module == 'enabled' and 'go' in cli_languages or api_module == 'enabled' and 'go' in api_languages or mcp_module == 'enabled' and 'go' in mcp_languages -%}
      # Go workflow
      - lint-go
      - test-go:
          requires:
            - lint-go
      - build-go:
          requires:
            - test-go
      {% endif -%}

      {% if docs_module == 'enabled' -%}
      # Documentation workflow
      - build-docs
      {% endif -%}
{% endif -%}
