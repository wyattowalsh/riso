# =============================================================================
# Docker Build Context Exclusions for {{ project_name }}
# =============================================================================
# This file tells Docker which files/directories to exclude from the build
# context, reducing image size and build time.
#
# Pattern syntax:
#   - Use # for comments
#   - Use * for wildcard matching
#   - Use ** for recursive directory matching
#   - Use ! to negate exclusions (force include)

# =============================================================================
# Version Control & Git
# =============================================================================
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml
.gitmodules

