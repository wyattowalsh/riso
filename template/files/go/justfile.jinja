{% if 'go' in cli_languages or 'go' in api_languages %}
# {{ project_name }} justfile
# Go {{ go_version | default('1.24') }} project

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

# Run lint, test, and build
all: lint test build

build:
{% if cli_module == 'enabled' and 'go' in cli_languages %}
    go build -ldflags "-s -w" -o bin/{{ project_slug }} ./cli
{% endif %}
{% if api_module == 'enabled' and 'go' in api_languages %}
    go build -ldflags "-s -w" -o bin/{{ project_slug }}-api ./api
{% endif %}

{% if cli_module == 'enabled' and 'go' in cli_languages %}
build-cli:
    go build -ldflags "-s -w" -o bin/{{ project_slug }} ./cli

run-cli *ARGS:
    go run ./cli {% raw %}{{ARGS}}{% endraw %}
{% endif %}

{% if api_module == 'enabled' and 'go' in api_languages %}
build-api:
    go build -ldflags "-s -w" -o bin/{{ project_slug }}-api ./api

run-api:
    go run ./api

run-api-dev:
    air -c .air.toml
{% endif %}

test:
    go test -v -race -coverprofile=coverage.out ./...

test-short:
    go test -short -v ./...

coverage: test
    go tool cover -html=coverage.out -o coverage.html
    @echo "Coverage report generated: coverage.html"

lint:
    golangci-lint run --timeout=5m

lint-fix:
    golangci-lint run --fix --timeout=5m

fmt:
    go fmt ./...
    gofumpt -l -w .

vet:
    go vet ./...

mod-tidy:
    go mod tidy

mod-verify:
    go mod verify

mod-download:
    go mod download

clean:
    rm -rf bin/
    rm -f coverage.out coverage.html

install-tools:
    go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.8.0
    go install mvdan.cc/gofumpt@latest
{% if api_module == 'enabled' and 'go' in api_languages %}
    go install github.com/air-verse/air@latest
{% endif %}

docker-build:
    docker build -t {{ project_slug }}:latest .

docker-run:
{% if api_module == 'enabled' and 'go' in api_languages %}
    docker run -p 8080:8080 {{ project_slug }}:latest
{% else %}
    docker run {{ project_slug }}:latest
{% endif %}
{% endif %}