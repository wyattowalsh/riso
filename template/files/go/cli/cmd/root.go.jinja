{% if cli_module == 'enabled' and 'go' in cli_languages %}
// Package cmd provides CLI command definitions using Cobra.
package cmd

import (
	"context"
	"fmt"
	"log/slog"
	"os"
	"os/signal"
	"syscall"

	"github.com/spf13/cobra"

	"{{ project_slug }}/cli/internal/config"
	"{{ project_slug }}/cli/internal/logger"
)

var (
	// Build information (set by main).
	version   = "dev"
	buildTime = "unknown"
	commit    = "unknown"

	// Global flags.
	cfgFile string
	verbose bool
	jsonLog bool

	// Root command.
	rootCmd = &cobra.Command{
		Use:   "{{ project_slug }}",
		Short: "{{ project_name }} CLI",
		Long: `{{ project_name }} - A command-line interface built with Go {{ go_version | default('1.24') }}.

This CLI provides tools for managing and interacting with {{ project_name }}.`,
		PersistentPreRunE: func(cmd *cobra.Command, args []string) error {
			// Initialize logging
			logLevel := slog.LevelInfo
			if verbose {
				logLevel = slog.LevelDebug
			}

			var handler slog.Handler
			if jsonLog {
				handler = slog.NewJSONHandler(os.Stderr, &slog.HandlerOptions{
					Level:     logLevel,
					AddSource: verbose,
				})
			} else {
				handler = logger.NewPrettyHandler(os.Stderr, &slog.HandlerOptions{
					Level: logLevel,
				})
			}
			slog.SetDefault(slog.New(handler))

			// Load configuration
			cfg, err := config.Load(cfgFile)
			if err != nil {
				slog.Warn("Failed to load config file, using defaults", "error", err)
			}

			// Store config in context
			ctx := context.WithValue(cmd.Context(), config.ContextKey, cfg)
			cmd.SetContext(ctx)

			slog.Debug("CLI initialized",
				"version", version,
				"config_file", cfgFile,
				"verbose", verbose,
			)

			return nil
		},
		SilenceUsage:  true,
		SilenceErrors: true,
	}
)

// SetBuildInfo sets the build information from main.
func SetBuildInfo(v, bt, c string) {
	version = v
	buildTime = bt
	commit = c
}

// Execute runs the root command.
func Execute() error {
	// Set up context with signal handling
	ctx, cancel := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer cancel()

	return rootCmd.ExecuteContext(ctx)
}

func init() {
	// Global flags
	rootCmd.PersistentFlags().StringVarP(&cfgFile, "config", "c", "", "config file (default is $HOME/.{{ project_slug }}.yaml)")
	rootCmd.PersistentFlags().BoolVarP(&verbose, "verbose", "v", false, "enable verbose output")
	rootCmd.PersistentFlags().BoolVar(&jsonLog, "json", false, "output logs in JSON format")

	// Add subcommands
	rootCmd.AddCommand(versionCmd)
{% if api_module == 'enabled' and 'go' in api_languages %}
	rootCmd.AddCommand(serveCmd)
{% endif %}
}

// GetVersion returns the current version.
func GetVersion() string {
	return version
}

// GetBuildTime returns the build time.
func GetBuildTime() string {
	return buildTime
}

// GetCommit returns the commit hash.
func GetCommit() string {
	return commit
}
{% endif %}
