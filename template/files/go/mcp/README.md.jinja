## Adding Custom Tools

1. Create a new file in `internal/tools/`:

```go
package tools

import (
    "context"
    "log/slog"

    "github.com/modelcontextprotocol/go-sdk/mcp"
    "github.com/modelcontextprotocol/go-sdk/server"
)

// MyToolInput represents the input schema.
type MyToolInput struct {
    Name string `json:"name" description:"User's name"`
}

// MyToolOutput represents the output schema.
type MyToolOutput struct {
    Greeting string `json:"greeting"`
}

func RegisterMyTools(srv *server.Server, logger *slog.Logger) {
    srv.RegisterTool(
        mcp.Tool{
            Name:        "greet",
            Description: "Greet a user by name",
            InputSchema: mcp.GenerateSchema[MyToolInput](),
        },
        func(ctx context.Context, params map[string]any) (any, error) {
            input, err := mcp.ParseInput[MyToolInput](params)
            if err != nil {
                return nil, err
            }
            return MyToolOutput{
                Greeting: "Hello, " + input.Name + "!",
            }, nil
        },
    )
}
```

2. Register in `internal/mcp/server.go`:

```go
func (s *Server) registerTools() {
    tools.RegisterMyTools(s.mcp, s.logger)
}
```

## Adding Custom Resources

1. Create a new file in `internal/resources/`:

```go
package resources

import (
    "context"
    "encoding/json"
    "log/slog"

    "github.com/modelcontextprotocol/go-sdk/mcp"
    "github.com/modelcontextprotocol/go-sdk/server"
)

func RegisterConfigResource(srv *server.Server, logger *slog.Logger) {
    resource := mcp.Resource{
        URI:         "config://app",
        Name:        "Application Config",
        Description: "Get application configuration",
        MimeType:    "application/json",
    }

    srv.RegisterResource(resource, func(ctx context.Context) (mcp.ResourceContent, error) {
        config := map[string]any{
            "version": "1.0.0",
            "env":     "development",
        }
        data, _ := json.MarshalIndent(config, "", "  ")
        return mcp.ResourceContent{
            URI:      "config://app",
            MimeType: "application/json",
            Text:     string(data),
        }, nil
    })
}
```

