// RegisterDynamicResource registers a resource template for dynamic URIs.
//
// Example usage:
//
//	RegisterDynamicResource(srv, logger, "file://{path}", "Read file contents", func(ctx context.Context, params map[string]string) (string, error) {
//	    path := params["path"]
//	    return readFile(path)
//	})
func RegisterDynamicResource(
	srv *server.Server,
	logger *slog.Logger,
	uriTemplate string,
	description string,
	handler func(ctx context.Context, params map[string]string) (string, error),
) {
	template := mcp.ResourceTemplate{
		URITemplate: uriTemplate,
		Name:        uriTemplate,
		Description: description,
		MimeType:    "application/json",
	}

	srv.RegisterResourceTemplate(template, func(ctx context.Context, uri string, params map[string]string) (mcp.ResourceContent, error) {
		logger.Debug("reading dynamic resource", "uri", uri, "params", params)

		content, err := handler(ctx, params)
		if err != nil {
			logger.Error("failed to read dynamic resource",
				"uri", uri,
				"error", err,
			)
			return mcp.ResourceContent{}, err
		}

		logger.Debug("dynamic resource read successfully", "uri", uri)
		return mcp.ResourceContent{
			URI:      uri,
			MimeType: "application/json",
			Text:     content,
		}, nil
	})
}
{%- endif %}
