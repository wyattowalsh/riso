{%- if mcp_module == 'enabled' and 'go' in mcp_languages -%}
package mcp

import (
	"context"
	"log/slog"

	"github.com/modelcontextprotocol/go-sdk/mcp"
	"github.com/modelcontextprotocol/go-sdk/server"
)

// ResourceRegistration provides helper functions for registering MCP resources.

// RegisterResource is a helper for registering MCP resources.
//
// Example usage:
//
//	RegisterResource(srv, logger, "system://info", "System information", func(ctx context.Context) (string, error) {
//	    return `{"os": "linux"}`, nil
//	})
func RegisterResource(
	srv *server.Server,
	logger *slog.Logger,
	uri string,
	description string,
	handler func(ctx context.Context) (string, error),
) {
	resource := mcp.Resource{
		URI:         uri,
		Name:        uri,
		Description: description,
		MimeType:    "application/json",
	}

	srv.RegisterResource(resource, func(ctx context.Context) (mcp.ResourceContent, error) {
		logger.Debug("reading resource", "uri", uri)

		content, err := handler(ctx)
		if err != nil {
			logger.Error("failed to read resource",
				"uri", uri,
				"error", err,
			)
			return mcp.ResourceContent{}, err
		}

		logger.Debug("resource read successfully", "uri", uri)
		return mcp.ResourceContent{
			URI:      uri,
			MimeType: "application/json",
			Text:     content,
		}, nil
	})
}

// RegisterTextResource registers a resource that returns plain text.
