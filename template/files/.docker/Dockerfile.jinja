# syntax=docker/dockerfile:1.11

# =============================================================================
# Multi-stage Production Dockerfile for Riso-generated projects
# =============================================================================
# Supports: Python 3.11+, Node.js 20+, Rust 1.80+
# Security: Non-root users, health checks, minimal attack surface
# Performance: Multi-stage builds, layer caching, BuildKit optimizations
#
# Build stages:
# - builder-python: Python dependency installation with uv
# - builder-node: Node.js dependency installation with pnpm
# - builder-rust: Rust compilation with cargo
# - runtime-python: Minimal Python runtime
# - runtime-node: Minimal Node.js runtime
# - runtime-rust: Minimal Rust runtime
#
# Usage:
#   docker build -t {{ project_slug }}:latest .
#   docker build --target runtime-python -t {{ project_slug }}-api:latest .
#
# PRODUCTION NOTE: Pin base images with SHA256 digests for reproducibility:
#   python:3.12-slim-bookworm@sha256:abc123...
#   node:20-alpine@sha256:def456...
# Find digests: docker pull <image> && docker inspect <image> | grep -A1 RepoDigests

{%- if (cli_module == "enabled" and "python" in cli_languages) or (api_module == "enabled" and "python" in api_languages) or (mcp_module == "enabled" and "python" in mcp_languages) %}

# =============================================================================
# Python Builder Stage
# =============================================================================
FROM python:3.12-slim-bookworm AS builder-python

# Metadata labels (OCI annotations)
LABEL org.opencontainers.image.title="{{ project_name }}"
LABEL org.opencontainers.image.description="{{ project_name }} - Python services"
LABEL org.opencontainers.image.vendor="Riso Template"
{%- if ci_platform == "github-actions" %}
LABEL org.opencontainers.image.source="https://github.com/{{ project_slug }}"
{%- endif %}

# Install system dependencies needed for compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast, reproducible dependency management
RUN pip install --no-cache-dir uv==0.5.15

WORKDIR /build

# Copy dependency manifests first for optimal layer caching
COPY pyproject.toml uv.lock ./
{%- if project_layout == "single-package" %}
COPY README.md ./
{%- endif %}

# Install dependencies with uv (production only, frozen lockfile)
# BuildKit cache mount accelerates repeated builds
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    uv sync --frozen --no-dev --no-install-project

# Copy application source
COPY src/ ./src/
{%- if cli_module == "enabled" and "python" in cli_languages %}
COPY tests/ ./tests/
{%- endif %}

# Install the project itself
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    uv sync --frozen --no-dev

# =============================================================================
# Python Runtime Stage
# =============================================================================
FROM python:3.12-slim-bookworm AS runtime-python

# Metadata labels
LABEL org.opencontainers.image.title="{{ project_name }} - Python Runtime"
LABEL org.opencontainers.image.description="Production runtime for {{ project_name }} Python services"

# Install only runtime dependencies (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user with explicit UID/GID (security best practice)
# UID 1000 is standard for Kubernetes and cloud platforms
RUN groupadd --gid 1000 appuser && \
    useradd --uid 1000 --gid 1000 --shell /bin/bash --create-home appuser

WORKDIR /app

# Copy virtual environment and source from builder
COPY --from=builder-python --chown=1000:1000 /build/.venv /app/.venv
COPY --from=builder-python --chown=1000:1000 /build/src /app/src
{%- if cli_module == "enabled" and "python" in cli_languages %}
COPY --from=builder-python --chown=1000:1000 /build/tests /app/tests
{%- endif %}

# Environment variables
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONFAULTHANDLER=1

# Switch to non-root user
USER 1000:1000

{%- if api_module == "enabled" and "python" in api_languages %}
# Expose FastAPI port
EXPOSE 8000

# Health check for container orchestration
# Checks /health endpoint with retries and backoff
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health').read()" || exit 1

# Default command: Run FastAPI with uvicorn
CMD ["python", "-m", "uvicorn", "{{ package_name }}.api.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--workers", "4", \
     "--log-level", "info"]

{%- elif cli_module == "enabled" and "python" in cli_languages %}
# CLI application - no exposed ports
# Health check verifies CLI binary is functional
HEALTHCHECK --interval=60s --timeout=5s --retries=2 \
    CMD python -m {{ package_name }}.cli --version || exit 1

# Default command: Show CLI help
CMD ["python", "-m", "{{ package_name }}.cli", "--help"]

{%- elif mcp_module == "enabled" and "python" in mcp_languages %}
# MCP server - stdio mode (no HTTP ports)
# Health check verifies Python environment
HEALTHCHECK --interval=60s --timeout=5s --retries=2 \
    CMD python --version || exit 1

# Default command: Run MCP server
CMD ["python", "-m", "{{ package_name }}.mcp"]

{%- endif %}

{%- endif %}

{%- if (api_module == "enabled" and "node" in api_languages) or (mcp_module == "enabled" and "typescript" in mcp_languages) or (docs_module == "enabled" and docs_framework in ["fumadocs", "docusaurus"]) or saas_infra_module == "enabled" %}

# =============================================================================
# Node.js Builder Stage
# =============================================================================
FROM node:20-alpine AS builder-node

# Metadata labels
LABEL org.opencontainers.image.title="{{ project_name }} - Node.js Builder"

# Install pnpm using Corepack (built into Node 20+)
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /build

# Copy dependency manifests first for optimal layer caching
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
{%- if project_layout == "monorepo" %}
{%- if api_module == "enabled" and "node" in api_languages %}
COPY apps/api-node/package.json ./apps/api-node/
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}
COPY apps/docs-fumadocs/package.json ./apps/docs-fumadocs/
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}
COPY apps/docs-docusaurus/package.json ./apps/docs-docusaurus/
{%- endif %}
{%- if saas_infra_module == "enabled" %}
COPY apps/saas/package.json ./apps/saas/
{%- endif %}
{%- if shared_logic == "enabled" %}
COPY apps/shared/package.json ./apps/shared/
{%- endif %}
{%- endif %}

# Install dependencies with pnpm (production only)
# BuildKit cache mount for pnpm store
RUN --mount=type=cache,target=/root/.pnpm-store,sharing=locked \
    pnpm install --frozen-lockfile --prod=false

# Copy application source and config
COPY apps/ ./apps/
COPY tsconfig.json ./

# Build TypeScript applications
{%- if api_module == "enabled" and "node" in api_languages %}
RUN pnpm --filter api-node build
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}
RUN pnpm --filter docs-fumadocs build
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}
RUN pnpm --filter docs-docusaurus build
{%- endif %}
{%- if saas_infra_module == "enabled" %}
RUN pnpm --filter saas build
{%- endif %}

# Prune dev dependencies for smaller runtime image
RUN pnpm prune --prod

# =============================================================================
# Node.js Runtime Stage
# =============================================================================
FROM node:20-alpine AS runtime-node

# Metadata labels
LABEL org.opencontainers.image.title="{{ project_name }} - Node.js Runtime"
LABEL org.opencontainers.image.description="Production runtime for {{ project_name }} Node.js services"

# Install only runtime dependencies
RUN apk add --no-cache \
    curl \
    ca-certificates \
    dumb-init

# Create non-root user with explicit UID/GID
RUN addgroup -g 1000 appuser && \
    adduser -u 1000 -G appuser -s /bin/sh -D appuser

WORKDIR /app

# Enable pnpm via Corepack
RUN corepack enable

# Copy built artifacts and production dependencies from builder
COPY --from=builder-node --chown=1000:1000 /build/package.json /build/pnpm-workspace.yaml /build/pnpm-lock.yaml ./
COPY --from=builder-node --chown=1000:1000 /build/node_modules ./node_modules
{%- if api_module == "enabled" and "node" in api_languages %}
COPY --from=builder-node --chown=1000:1000 /build/apps/api-node/dist ./apps/api-node/dist
COPY --from=builder-node --chown=1000:1000 /build/apps/api-node/package.json ./apps/api-node/
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-fumadocs/.next ./apps/docs-fumadocs/.next
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-fumadocs/public ./apps/docs-fumadocs/public
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-fumadocs/package.json ./apps/docs-fumadocs/
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-fumadocs/next.config.mjs ./apps/docs-fumadocs/
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-docusaurus/build ./apps/docs-docusaurus/build
COPY --from=builder-node --chown=1000:1000 /build/apps/docs-docusaurus/package.json ./apps/docs-docusaurus/
{%- endif %}
{%- if saas_infra_module == "enabled" %}
COPY --from=builder-node --chown=1000:1000 /build/apps/saas/.next ./apps/saas/.next
COPY --from=builder-node --chown=1000:1000 /build/apps/saas/public ./apps/saas/public
COPY --from=builder-node --chown=1000:1000 /build/apps/saas/package.json ./apps/saas/
{%- endif %}
{%- if shared_logic == "enabled" %}
COPY --from=builder-node --chown=1000:1000 /build/apps/shared ./apps/shared
{%- endif %}

# Environment variables
ENV NODE_ENV=production \
    NODE_OPTIONS="--max-old-space-size=2048"

# Switch to non-root user
USER 1000:1000

{%- if api_module == "enabled" and "node" in api_languages %}
# Expose Fastify port
EXPOSE 3000

# Health check for Fastify API
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:3000/health || exit 1

# Default command: Run Fastify API with dumb-init for proper signal handling
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["node", "apps/api-node/dist/main.js"]

{%- elif docs_module == "enabled" and docs_framework == "fumadocs" %}
# Expose Next.js port
EXPOSE 3001

# Health check for Fumadocs
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:3001/api/health || exit 1

# Default command: Serve Fumadocs with Next.js
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["pnpm", "--filter", "docs-fumadocs", "start"]

{%- elif docs_module == "enabled" and docs_framework == "docusaurus" %}
# Expose Docusaurus port
EXPOSE 3002

# Health check for Docusaurus
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:3002 || exit 1

# Install serve for static hosting
RUN npm install -g serve

# Default command: Serve Docusaurus static build
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["serve", "-s", "apps/docs-docusaurus/build", "-l", "3002"]

{%- elif saas_infra_module == "enabled" %}
# Expose SaaS app port
EXPOSE 3000

# Health check for Next.js SaaS app
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Default command: Serve Next.js SaaS app
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["pnpm", "--filter", "saas", "start"]

{%- endif %}

{%- endif %}

{%- if (cli_module == "enabled" and "rust" in cli_languages) or (api_module == "enabled" and "rust" in api_languages) or (mcp_module == "enabled" and "rust" in mcp_languages) %}

# =============================================================================
# Rust Builder Stage
# =============================================================================
FROM rust:1.80-slim-bookworm AS builder-rust

# Metadata labels
LABEL org.opencontainers.image.title="{{ project_name }} - Rust Builder"

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy dependency manifests for layer caching
COPY Cargo.toml Cargo.lock ./
{%- if project_layout == "monorepo" %}
COPY apps/ ./apps/
{%- endif %}

# Create dummy main.rs for dependency caching
RUN mkdir -p src && \
    echo "fn main() {}" > src/main.rs && \
    cargo build --release && \
    rm -rf src

# Copy actual source code
COPY src/ ./src/

# Build release binary with optimizations
RUN cargo build --release --locked

# =============================================================================
# Rust Runtime Stage
# =============================================================================
FROM debian:bookworm-slim AS runtime-rust

# Metadata labels
LABEL org.opencontainers.image.title="{{ project_name }} - Rust Runtime"
LABEL org.opencontainers.image.description="Production runtime for {{ project_name }} Rust services"

# Install only runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3 \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user
RUN groupadd --gid 1000 appuser && \
    useradd --uid 1000 --gid 1000 --shell /bin/bash --create-home appuser

WORKDIR /app

# Copy only the compiled binary from builder
COPY --from=builder-rust --chown=1000:1000 /build/target/release/{{ project_slug }} /app/{{ project_slug }}

# Switch to non-root user
USER 1000:1000

{%- if api_module == "enabled" and "rust" in api_languages %}
# Expose Actix-web port
EXPOSE 8080

# Health check for Actix API
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Default command: Run Actix-web server
CMD ["/app/{{ project_slug }}"]

{%- elif cli_module == "enabled" and "rust" in cli_languages %}
# CLI application - health check verifies binary
HEALTHCHECK --interval=60s --timeout=5s --retries=2 \
    CMD /app/{{ project_slug }} --version || exit 1

# Default command: Show CLI help
CMD ["/app/{{ project_slug }}", "--help"]

{%- endif %}

{%- endif %}

{%- if api_module == "disabled" and cli_module == "disabled" and mcp_module == "disabled" and docs_module == "disabled" %}

# =============================================================================
# Minimal Baseline (No Modules Enabled)
# =============================================================================
FROM python:3.12-slim-bookworm AS runtime

LABEL org.opencontainers.image.title="{{ project_name }} - Baseline"
LABEL org.opencontainers.image.description="Minimal baseline runtime for {{ project_name }}"

# Create non-root user
RUN groupadd --gid 1000 appuser && \
    useradd --uid 1000 --gid 1000 --shell /bin/bash --create-home appuser

WORKDIR /app

USER 1000:1000

# Minimal runtime - shows Python version
CMD ["python", "--version"]

{%- endif %}
