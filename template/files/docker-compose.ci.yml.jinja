# =============================================================================
# Docker Compose CI Override for {{ project_name }}
# =============================================================================
# This file provides optimizations for CI/CD environments (GitHub Actions)
#
# Key optimizations:
# - Disables volume mounts (uses baked-in code from image)
# - Reduces healthcheck intervals for faster startup
# - Uses tmpfs for database storage (ephemeral, faster I/O)
# - BuildKit cache integration for GitHub Actions
# - Optimized for ephemeral runner environments
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.ci.yml up -d
#   docker compose -f docker-compose.yml -f docker-compose.ci.yml down
#
# Environment: GitHub Actions runners, GitLab CI, or any ephemeral CI environment

services:
{%- if api_module == "enabled" and "python" in api_languages %}

  api-python:
    build:
      cache_from:
        - type=gha  # GitHub Actions cache
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 5s
{%- endif %}

{%- if api_module == "enabled" and "node" in api_languages %}

  api-node:
    build:
      cache_from:
        - type=gha
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 5s
{%- endif %}

{%- if api_module == "enabled" and "rust" in api_languages %}

  api-rust:
    build:
      cache_from:
        - type=gha
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 5s
{%- endif %}

{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}

  docs-fumadocs:
    build:
      cache_from:
        - type=gha
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 10s
{%- endif %}

{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}

  docs-docusaurus:
    build:
      cache_from:
        - type=gha
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 10s
{%- endif %}

{%- if saas_infra_module == "enabled" %}

  saas:
    build:
      cache_from:
        - type=gha
      cache_to:
        - type=gha,mode=max
    volumes: []  # Disable volume mounts - use image code
    healthcheck:
      interval: 5s   # Faster healthchecks in CI
      timeout: 3s
      retries: 10
      start_period: 10s
{%- endif %}

{%- if include_databases == "yes" %}

  postgres:
    # Use tmpfs for faster I/O in CI (data is ephemeral)
    tmpfs:
      - /var/lib/postgresql/data
    # Override volumes to prevent persistent storage in CI
    volumes: []
    healthcheck:
      interval: 3s   # Very fast healthchecks for CI
      timeout: 2s
      retries: 10
      start_period: 3s
    environment:
      # Add CI-specific optimizations
      - POSTGRES_INITDB_ARGS=--nosync
      - POSTGRES_HOST_AUTH_METHOD=trust  # Skip password auth in CI

  redis:
    # Use tmpfs for faster I/O in CI (data is ephemeral)
    tmpfs:
      - /data
    # Override volumes to prevent persistent storage in CI
    volumes: []
    healthcheck:
      interval: 3s   # Very fast healthchecks for CI
      timeout: 2s
      retries: 10
      start_period: 2s
    command: >
      redis-server
      --requirepass $${REDIS_PASSWORD:-dev_password}
      --maxmemory 128mb
      --maxmemory-policy allkeys-lru
      --save ""
      --appendonly no
{%- endif %}

# =============================================================================
# CI-specific volume overrides (disable all persistent volumes)
# =============================================================================
{%- if include_databases == "yes" %}
volumes:
  postgres-data:
    driver_opts:
      type: tmpfs
      device: tmpfs
  redis-data:
    driver_opts:
      type: tmpfs
      device: tmpfs
{%- endif %}
