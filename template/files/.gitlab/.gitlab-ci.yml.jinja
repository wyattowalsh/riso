{% if ci_platform == 'gitlab-ci' -%}
# GitLab CI/CD Configuration for {{ project_name }}
# Auto-generated by Riso template • DO NOT EDIT MANUALLY
# Component-first polyglot CI pipeline supporting Python, TypeScript, Rust, Go

stages:
  - lint
  - test
  - build
  - deploy

variables:
  PIP_CACHE_DIR: "$CI_PROJECT_DIR/.cache/pip"
  UV_CACHE_DIR: "$CI_PROJECT_DIR/.cache/uv"
  {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
  PNPM_HOME: "$CI_PROJECT_DIR/.cache/pnpm"
  {% endif -%}
  {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
  CARGO_HOME: "$CI_PROJECT_DIR/.cache/cargo"
  {% endif -%}
  QUALITY_PROFILE: "{{ quality_profile }}"
  PACKAGE_NAME: "{{ package_name }}"

# Global cache configuration
cache:
  key:
    files:
      {% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages -%}
      - uv.lock
      {% endif -%}
      {% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
      - pnpm-lock.yaml
      {% endif -%}
      {% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
      - Cargo.lock
      {% endif %}
  paths:
    - .cache/

{% if cli_module == 'enabled' and 'python' in cli_languages or api_module == 'enabled' and 'python' in api_languages or mcp_module == 'enabled' and 'python' in mcp_languages or docs_module == 'enabled' and docs_framework == 'sphinx-shibuya' -%}
# ========================================
# Python Jobs
# ========================================

.python-base:
  image: python:3.12-slim
  before_script:
    - apt-get update && apt-get install -y curl git
    - curl -LsSf https://astral.sh/uv/install.sh | sh
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv sync
  cache:
    key: python-${CI_COMMIT_REF_SLUG}
    paths:
      - .cache/pip/
      - .cache/uv/
      - .venv/

lint:python:
  extends: .python-base
  stage: lint
  script:
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv run ruff check .
    - uv run ruff format --check .
{% if quality_profile == 'strict' %}
    - uv run mypy .
    - uv run pylint src/
{% endif %}
  artifacts:
    when: on_failure
    paths:
      - ruff-output.txt
      - mypy-output.txt
      - pylint-output.txt
    expire_in: 1 week

test:python:
  extends: .python-base
  stage: test
  script:
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv run pytest tests/ -v --cov --cov-report=xml --cov-report=html --junit-xml=test-results.xml
  coverage: '/TOTAL.*\s+(\d+%)/'
  artifacts:
    when: always
    paths:
      - coverage.xml
      - htmlcov/
      - test-results.xml
    reports:
      coverage_report:
        coverage_format: cobertura
        path: coverage.xml
      junit: test-results.xml
    expire_in: 30 days
{% if project_layout == 'monorepo' %}
  parallel:
    matrix:
      - PYTHON_VERSION: {{ python_versions | tojson }}
  image: python:${PYTHON_VERSION}-slim
{% endif %}

{% if cli_module == 'enabled' and 'python' in cli_languages -%}
test:cli:
  extends: .python-base
  stage: test
  script:
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv run pytest tests/test_cli.py -v
  artifacts:
    when: on_failure
    paths:
      - test-results.xml
    expire_in: 1 week
{% endif -%}

{% if mcp_module == 'enabled' and 'python' in mcp_languages -%}
test:mcp:
  extends: .python-base
  stage: test
  script:
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv run pytest tests/test_mcp.py -v
  artifacts:
    when: on_failure
    paths:
      - test-results.xml
    expire_in: 1 week
{% endif -%}

{% endif -%}

{% if api_module == 'enabled' and 'node' in api_languages or docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus'] or saas_infra_module == 'enabled' -%}
# ========================================
# Node.js Jobs
# ========================================

.node-base:
  image: node:22-alpine
  before_script:
    - corepack enable
    - pnpm install --frozen-lockfile
  cache:
    key: node-${CI_COMMIT_REF_SLUG}
    paths:
      - .cache/pnpm/
      - node_modules/

lint:node:
  extends: .node-base
  stage: lint
  script:
    - pnpm run lint
    - pnpm run typecheck
  artifacts:
    when: on_failure
    paths:
      - eslint-report.json
    expire_in: 1 week

test:node:
  extends: .node-base
  stage: test
  script:
    - pnpm run test --coverage
  artifacts:
    when: always
    paths:
      - coverage/
    reports:
      junit: coverage/junit.xml
    expire_in: 30 days
  coverage: '/Lines\s*:\s*(\d+\.\d+)%/'

build:node:
  extends: .node-base
  stage: build
  script:
    - pnpm run build
  artifacts:
    paths:
      - dist/
{% if saas_infra_module == 'enabled' %}
      - .next/
{% endif %}
    expire_in: 7 days
{% if project_layout == 'monorepo' %}
  parallel:
    matrix:
      - NODE_VERSION: ['20', '22']
  image: node:${NODE_VERSION}-alpine
{% endif %}

{% if saas_infra_module == 'enabled' -%}
test:e2e:
  extends: .node-base
  stage: test
  needs:
    - build:node
  script:
    - pnpm run test:e2e
  artifacts:
    when: on_failure
    paths:
      - playwright-report/
      - test-results/
    expire_in: 7 days
{% endif -%}

{% endif -%}

{% if cli_module == 'enabled' and 'rust' in cli_languages or api_module == 'enabled' and 'rust' in api_languages or mcp_module == 'enabled' and 'rust' in mcp_languages -%}
# ========================================
# Rust Jobs
# ========================================

.rust-base:
  image: rust:1.85-slim
  before_script:
    - apt-get update && apt-get install -y git pkg-config libssl-dev
    - rustup component add clippy rustfmt
  cache:
    key: rust-${CI_COMMIT_REF_SLUG}
    paths:
      - .cache/cargo/
      - target/

lint:rust:
  extends: .rust-base
  stage: lint
  script:
    - cargo fmt -- --check
    - cargo clippy --all-targets --all-features -- -D warnings
  artifacts:
    when: on_failure
    expire_in: 1 week

test:rust:
  extends: .rust-base
  stage: test
  script:
    - cargo test --all-features --verbose
    - cargo test --doc
  artifacts:
    when: on_failure
    paths:
      - target/debug/
    expire_in: 1 week

build:rust:
  extends: .rust-base
  stage: build
  script:
    - cargo build --release
  artifacts:
    paths:
      - target/release/{{ package_name | replace('_', '-') }}
    expire_in: 7 days

{% endif -%}

{% if cli_module == 'enabled' and 'go' in cli_languages or api_module == 'enabled' and 'go' in api_languages or mcp_module == 'enabled' and 'go' in mcp_languages -%}
# ========================================
# Go Jobs
# ========================================

.go-base:
  image: golang:{{ go_version }}-alpine
  before_script:
    - apk add --no-cache git make
  cache:
    key: go-${CI_COMMIT_REF_SLUG}
    paths:
      - .cache/go-build/
      - /go/pkg/mod/

lint:go:
  extends: .go-base
  stage: lint
  script:
    - go fmt ./...
    - go vet ./...
    - if [ "$(gofmt -l . | wc -l)" -gt 0 ]; then exit 1; fi
  artifacts:
    when: on_failure
    expire_in: 1 week

test:go:
  extends: .go-base
  stage: test
  script:
    - go test -v -race -coverprofile=coverage.txt -covermode=atomic ./...
  coverage: '/coverage: (\d+\.\d+)% of statements/'
  artifacts:
    when: always
    paths:
      - coverage.txt
    expire_in: 30 days

build:go:
  extends: .go-base
  stage: build
  script:
    - go build -o {{ package_name | replace('_', '-') }} ./cmd/...
  artifacts:
    paths:
      - {{ package_name | replace('_', '-') }}
    expire_in: 7 days

{% endif -%}

{% if docs_module == 'enabled' -%}
# ========================================
# Documentation Jobs
# ========================================

{% if docs_framework == 'sphinx-shibuya' -%}
pages:
  stage: deploy
  image: python:3.12-slim
  before_script:
    - curl -LsSf https://astral.sh/uv/install.sh | sh
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv sync
  script:
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv run sphinx-build docs/ public/
  artifacts:
    paths:
      - public/
  only:
    - main
{% elif docs_framework in ['fumadocs', 'docusaurus'] -%}
pages:
  extends: .node-base
  stage: deploy
  script:
{% if docs_framework == 'fumadocs' %}
    - pnpm run docs:build
    - mv docs/out public/
{% elif docs_framework == 'docusaurus' %}
    - cd docs && pnpm run build
    - mv build ../public/
{% endif %}
  artifacts:
    paths:
      - public/
  only:
    - main
{% endif -%}

{% endif -%}

# ========================================
# Container Build (if applicable)
# ========================================

{% if api_module == 'enabled' or cli_module == 'enabled' -%}
build:container:
  stage: build
  image: docker:24-dind
  services:
    - docker:24-dind
  variables:
    DOCKER_TLS_CERTDIR: "/certs"
  before_script:
    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY
  script:
    - docker build -t $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA -t $CI_REGISTRY_IMAGE:latest .
    - docker push $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA
    - docker push $CI_REGISTRY_IMAGE:latest
  only:
    - main
{% endif -%}

# ========================================
# Release Job (tagged commits only)
# ========================================

{% if changelog_module == 'enabled' -%}
release:
  stage: deploy
  image: node:22-alpine
  before_script:
    - apk add --no-cache git
  script:
    - npx semantic-release
  only:
    - main
  when: manual
{% endif -%}
{% endif -%}
