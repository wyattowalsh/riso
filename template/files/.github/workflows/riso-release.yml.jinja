{% if changelog_module == "enabled" -%}
# GitHub Actions workflow for automated releases
# Generated by Riso template - Feature 014: Changelog & Release Management
name: Release

on:
  push:
    branches:
      - main
{% if project_layout == "monorepo" %}
      - beta
      - alpha
{% endif %}
  workflow_dispatch:
    inputs:
      dry_run:
        description: 'Run release in dry-run mode (no publishing)'
        required: false
        type: boolean
        default: false

concurrency:
  group: {% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

permissions:
  contents: write
  issues: write
  pull-requests: write
  packages: write
  id-token: write

env:
  QUALITY_PROFILE: {{ quality_profile }}
  PACKAGE_NAME: {{ package_name }}

jobs:
  quality:
    name: Quality Gates
    runs-on: ubuntu-latest
    timeout-minutes: {% if quality_profile == 'strict' %}20{% else %}10{% endif %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v6

      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: '{{ python_versions[0] }}'

      - name: Set up uv
        uses: astral-sh/setup-uv@v6
        with:
          version: "latest"
          enable-cache: true
          cache-dependency-glob: "**/uv.lock"

      - name: Install dependencies
        run: uv sync

      - name: Run quality checks
        run: QUALITY_PROFILE={{ quality_profile }} uv run task quality

  release:
    name: Semantic Release
    runs-on: ubuntu-latest
    needs: [quality]
    timeout-minutes: 20
    if: {% raw %}github.ref == 'refs/heads/main' || github.ref == 'refs/heads/beta' || github.ref == 'refs/heads/alpha'{% endraw %}

    steps:
      - name: Checkout code
        uses: actions/checkout@v6
        with:
          fetch-depth: 0
          persist-credentials: false

      - name: Setup Node.js
        uses: actions/setup-node@v6
        with:
          node-version: '20'
{% if api_module == 'enabled' and 'node' in api_languages %}
          cache: 'pnpm'
{% endif %}

{% if api_module == 'enabled' and 'python' in api_languages %}
      - name: Setup Python
        uses: actions/setup-python@v6
        with:
          python-version: '{{ python_versions[0] }}'

      - name: Install uv
        uses: astral-sh/setup-uv@v6
        with:
          version: "latest"
          enable-cache: true
          cache-dependency-glob: "**/uv.lock"

      - name: Install Python dependencies
        run: uv sync
{% endif %}

{% if api_module == 'enabled' and 'node' in api_languages %}
      - name: Install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 8

      - name: Install Node dependencies
        run: pnpm install --frozen-lockfile
{% else %}
      - name: Install semantic-release dependencies
        run: |
          npm install -g semantic-release @semantic-release/changelog @semantic-release/git @semantic-release/github @semantic-release/exec @semantic-release/commit-analyzer @semantic-release/release-notes-generator
{% endif %}

      - name: Verify release prerequisites
        run: |
          echo "Verifying Git configuration..."
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
{% if api_module == 'enabled' and 'python' in api_languages %}
          echo "Verifying Python environment..."
          uv run python --version
          uv run python -c "import sys; print(f'Python {sys.version}')"
{% endif %}
          echo "Verifying semantic-release installation..."
{% if api_module == 'enabled' and 'node' in api_languages %}
          npx semantic-release --version
{% else %}
          semantic-release --version
{% endif %}

      - name: Run semantic-release
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
{% if api_module == 'enabled' and 'python' in api_languages %}
          PYPI_TOKEN: {% raw %}${{ secrets.PYPI_TOKEN }}{% endraw %}
{% endif %}
{% if api_module == 'enabled' and 'node' in api_languages %}
          NPM_TOKEN: {% raw %}${{ secrets.NPM_TOKEN }}{% endraw %}
{% endif %}
          DOCKER_HUB_USERNAME: {% raw %}${{ secrets.DOCKER_HUB_USERNAME }}{% endraw %}
          DOCKER_HUB_TOKEN: {% raw %}${{ secrets.DOCKER_HUB_TOKEN }}{% endraw %}
          DRY_RUN: {% raw %}${{ github.event.inputs.dry_run || 'false' }}{% endraw %}
        run: |
{% if api_module == 'enabled' and 'node' in api_languages %}
          if [ "$DRY_RUN" = "true" ]; then
            npx semantic-release --dry-run
          else
            npx semantic-release
          fi
{% else %}
          if [ "$DRY_RUN" = "true" ]; then
            semantic-release --dry-run
          else
            semantic-release
          fi
{% endif %}

      - name: Upload release artifacts
        if: {% raw %}success(){% endraw %}
        uses: actions/upload-artifact@v6
        with:
          name: release-artifacts
          path: |
{% if api_module == 'enabled' and 'python' in api_languages %}
            dist/
{% endif %}
{% if api_module == 'enabled' and 'node' in api_languages %}
            *.tgz
{% endif %}
            CHANGELOG.md
          retention-days: 90

      - name: Log release summary
        if: {% raw %}always(){% endraw %}
        run: |
          {
            echo "## Release Summary"
            echo ""
            echo "- **Branch**: {% raw %}${{ github.ref_name }}{% endraw %}"
            echo "- **Commit**: {% raw %}${{ github.sha }}{% endraw %}"
            echo "- **Dry Run**: $DRY_RUN"
          } >> "$GITHUB_STEP_SUMMARY"
          if [ -f "CHANGELOG.md" ]; then
            {
              echo ""
              echo "### Latest Changelog Entry"
              head -n 20 CHANGELOG.md
            } >> "$GITHUB_STEP_SUMMARY"
          fi
{% endif %}