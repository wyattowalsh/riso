{% if ci_platform == 'github-actions' %}
name: Quality Checks

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: {% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

env:
  QUALITY_PROFILE: {{ quality_profile }}
  PACKAGE_NAME: {{ package_name }}

jobs:
  python-quality:
    name: Python Quality Checks
    runs-on: ubuntu-latest
    timeout-minutes: {% if quality_profile == 'strict' %}20{% else %}10{% endif %}
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      
      - name: Cache Python dependencies
        uses: actions/cache@v4
        with:
          path: |
            ~/.cache/uv
            ~/.cache/pip
          key: {% raw %}${{ runner.os }}-py3.11-${{ hashFiles('**/uv.lock') }}{% endraw %}
          restore-keys: |
            {% raw %}${{ runner.os }}-py3.11-{% endraw %}
            {% raw %}${{ runner.os }}-{% endraw %}
      
      - name: Set up uv
        uses: astral-sh/setup-uv@v5
        with:
          version: "latest"
          enable-cache: true
          cache-dependency-glob: "**/uv.lock"
      
      - name: Install dependencies
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          uv sync
      
      - name: Run quality checks with retry
        uses: nick-fields/retry@v3
        with:
          timeout_minutes: {% if quality_profile == 'strict' %}18{% else %}8{% endif %}
          max_attempts: 3
          retry_wait_seconds: 30
          exponential_backoff: true
          command: |
            export PATH="$HOME/.local/bin:$PATH"
            QUALITY_PROFILE={{ quality_profile }} uv run task quality
      
      {% if cli_module == 'enabled' %}
      - name: Test CLI module
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          uv run pytest tests/test_cli.py -v
      {% endif %}
      
      {% if mcp_module == 'enabled' %}
      - name: Test MCP module
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          uv run pytest tests/test_mcp.py -v
      {% endif %}
      
      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-results-py3.11-{% raw %}${{ github.run_id }}{% endraw %}
          path: |
            test-results.xml
            htmlcov/
            .coverage
          retention-days: 90
      
      - name: Upload quality logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: quality-logs-py3.11-{% raw %}${{ github.run_id }}{% endraw %}
          path: |
            .riso/quality-durations.json
            ruff-output.txt
            ty-output.txt
            pylint-output.txt
          retention-days: 90
          if-no-files-found: warn

  {% if api_module == 'enabled' and 'node' in api_languages %}
  node-quality:
    name: Node.js Quality Checks
    runs-on: ubuntu-latest
    timeout-minutes: {% if quality_profile == 'strict' %}20{% else %}10{% endif %}
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
      
      - name: Enable corepack
        run: corepack enable
      
      - name: Cache pnpm dependencies
        uses: actions/cache@v4
        with:
          path: |
            node_modules
            .pnpm-store
          key: {% raw %}${{ runner.os }}-node-${{ hashFiles('**/pnpm-lock.yaml') }}{% endraw %}
          restore-keys: |
            {% raw %}${{ runner.os }}-node-{% endraw %}
      
      - name: Install dependencies
        run: pnpm install --frozen-lockfile
      
      - name: Run ESLint
        run: pnpm run lint
      
      - name: Run TypeScript check
        run: pnpm run type-check
      
      - name: Run tests
        run: pnpm test
      
      - name: Upload Node.js test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: node-test-results-{% raw %}${{ github.run_id }}{% endraw %}
          path: coverage/
          retention-days: 90
          if-no-files-found: warn
  {% endif %}

  {% if mcp_module == 'enabled' and 'rust' in mcp_languages %}
  rust-quality:
    name: Rust Quality Checks
    runs-on: ubuntu-latest
    timeout-minutes: 15
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install Rust toolchain
        uses: actions-rust-lang/setup-rust-toolchain@v1
        with:
          toolchain: stable
          components: clippy, rustfmt

      - name: Cache Cargo Dependencies
        uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/bin/
            ~/.cargo/registry/index/
            ~/.cargo/registry/cache/
            ~/.cargo/git/db/
            target/
          key: {% raw %}${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}{% endraw %}
          restore-keys: |
            {% raw %}${{ runner.os }}-cargo-{% endraw %}

      - name: Check formatting
        working-directory: {{ package_name | replace('_', '-') }}-mcp
        run: cargo fmt -- --check

      - name: Run clippy
        working-directory: {{ package_name | replace('_', '-') }}-mcp
        run: cargo clippy -- -D warnings

      - name: Run tests
        working-directory: {{ package_name | replace('_', '-') }}-mcp
        run: cargo test
  {% endif %}
{% endif %}
