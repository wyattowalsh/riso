# {{ project_name }} - Development Environment Setup (PowerShell)
# Generated by Riso Template
# Usage: .\scripts\setup\setup.ps1 [-CheckOnly] [-Install] [-Yes] [-Help]

[CmdletBinding()]
param(
    [switch]$CheckOnly,
    [switch]$Install,
    [switch]$Yes,
    [switch]$Help
)

# Script metadata
$ScriptName = "{{ project_name }} Setup"
$ScriptVersion = "1.0.0"

# Minimum versions
$PythonMinVersion = "3.11"
$UvMinVersion = "0.4"
{% if api_tracks in ['node', 'python+node'] or docs_site in ['fumadocs', 'docusaurus'] or saas_starter_module == 'enabled' -%}
$NodeMinVersion = "20"
$PnpmMinVersion = "8"
{% endif -%}
$PreCommitMinVersion = "3.0"

# Tool status tracking
$Tools = @(
    @{ Name = "python3"; Command = "python"; MinVersion = $PythonMinVersion; VersionFlag = "--version" }
    @{ Name = "uv"; Command = "uv"; MinVersion = $UvMinVersion; VersionFlag = "--version" }
{% if api_tracks in ['node', 'python+node'] or docs_site in ['fumadocs', 'docusaurus'] or saas_starter_module == 'enabled' %}
    @{ Name = "node"; Command = "node"; MinVersion = $NodeMinVersion; VersionFlag = "--version" }
    @{ Name = "pnpm"; Command = "pnpm"; MinVersion = $PnpmMinVersion; VersionFlag = "--version" }
{% endif %}
    @{ Name = "pre-commit"; Command = "pre-commit"; MinVersion = $PreCommitMinVersion; VersionFlag = "--version" }
{% if ci_platform == 'github-actions' %}
    @{ Name = "actionlint"; Command = "actionlint"; MinVersion = "1.0"; VersionFlag = "-version" }
{% endif %}
)

$MissingTools = @()
$FailedInstalls = @()

# Color output functions
function Write-Success {
    param([string]$Message)
    Write-Host "✓ [SUCCESS] $Message" -ForegroundColor Green
}

function Write-Info {
    param([string]$Message)
    Write-Host "ℹ [INFO] $Message" -ForegroundColor Blue
}

function Write-Warning {
    param([string]$Message)
    Write-Host "⚠ [WARN] $Message" -ForegroundColor Yellow
}

function Write-Failure {
    param([string]$Message)
    Write-Host "✗ [ERROR] $Message" -ForegroundColor Red
}

function Write-Section {
    param([string]$Message)
    Write-Host ""
    Write-Host "==> $Message" -ForegroundColor Cyan -NoNewline
    Write-Host ""
}

# Show help message
function Show-Help {
    Write-Host "$ScriptName v$ScriptVersion" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "USAGE:" -ForegroundColor Yellow
    Write-Host "    .\scripts\setup\setup.ps1 [OPTIONS]"
    Write-Host ""
    Write-Host "OPTIONS:" -ForegroundColor Yellow
    Write-Host "    -CheckOnly    Check for required tools without installing"
    Write-Host "    -Install      Install missing tools (prompts for confirmation)"
    Write-Host "    -Yes          Install missing tools without prompting (use with -Install)"
    Write-Host "    -Help         Show this help message"
    Write-Host ""
    Write-Host "EXAMPLES:" -ForegroundColor Yellow
    Write-Host "    # Check what tools are missing"
    Write-Host "    .\scripts\setup\setup.ps1"
    Write-Host ""
    Write-Host "    # Install missing tools (with prompts)"
    Write-Host "    .\scripts\setup\setup.ps1 -Install"
    Write-Host ""
    Write-Host "    # Install missing tools without prompts"
    Write-Host "    .\scripts\setup\setup.ps1 -Install -Yes"
    Write-Host ""
    Write-Host "EXIT CODES:" -ForegroundColor Yellow
    Write-Host "    0   All required tools present (or successfully installed)"
    Write-Host "    1   Missing tools or installation failed"
    Write-Host "    2   Invalid arguments"
    Write-Host ""
}

# Check if command exists
function Test-Command {
    param([string]$Command)
    $null = Get-Command $Command -ErrorAction SilentlyContinue
    return $?
}

# Get tool version
function Get-ToolVersion {
    param(
        [string]$Command,
        [string]$VersionFlag = "--version"
    )

    try {
        $output = & $Command $VersionFlag 2>&1 | Select-Object -First 1
        if ($output -match '(\d+\.\d+(\.\d+)?)') {
            return $matches[1]
        }
    }
    catch {
        return "unknown"
    }
    return "unknown"
}

# Compare versions (simple X.Y comparison)
function Test-VersionGte {
    param(
        [string]$Current,
        [string]$Required
    )

    if ($Current -eq "unknown") {
        return $true  # Allow unknown versions
    }

    $currentParts = $Current.Split('.')
    $requiredParts = $Required.Split('.')

    for ($i = 0; $i -lt [Math]::Min($currentParts.Length, $requiredParts.Length); $i++) {
        $c = [int]$currentParts[$i]
        $r = [int]$requiredParts[$i]

        if ($c -gt $r) { return $true }
        if ($c -lt $r) { return $false }
    }

    return $true
}

# Check all required tools
function Test-AllTools {
    Write-Section "Checking required tools"

    foreach ($tool in $Tools) {
        $toolName = $tool.Name
        $command = $tool.Command
        $minVersion = $tool.MinVersion
        $versionFlag = $tool.VersionFlag

        if (-not (Test-Command $command)) {
            $tool.Status = "missing"
            $tool.Version = "not installed"
            $script:MissingTools += $toolName
            continue
        }

        $currentVersion = Get-ToolVersion -Command $command -VersionFlag $versionFlag
        $tool.Version = $currentVersion

        if ($currentVersion -eq "unknown") {
            $tool.Status = "version-unknown"
            continue
        }

        if (Test-VersionGte -Current $currentVersion -Required $minVersion) {
            $tool.Status = "ok"
        }
        else {
            $tool.Status = "outdated"
            $tool.Version = "$currentVersion (need $minVersion+)"
            $script:MissingTools += $toolName
        }
    }

    Write-Host ""
}

# Show tool status table
function Show-ToolStatus {
    Write-Section "Tool Status"

    Write-Host ("{0,-15} {1,-20} {2,-12}" -f "Tool", "Version", "Status")
    Write-Host ("{0,-15} {1,-20} {2,-12}" -f "----", "-------", "------")

    foreach ($tool in $Tools) {
        $name = $tool.Name
        $version = if ($tool.Version) { $tool.Version } else { "unknown" }
        $status = if ($tool.Status) { $tool.Status } else { "unknown" }

        $statusText = switch ($status) {
            "ok" { Write-Host ("{0,-15} {1,-20} " -f $name, $version) -NoNewline; Write-Host "✓ OK" -ForegroundColor Green }
            "missing" { Write-Host ("{0,-15} {1,-20} " -f $name, $version) -NoNewline; Write-Host "✗ MISSING" -ForegroundColor Red }
            "outdated" { Write-Host ("{0,-15} {1,-20} " -f $name, $version) -NoNewline; Write-Host "⚠ OUTDATED" -ForegroundColor Yellow }
            "version-unknown" { Write-Host ("{0,-15} {1,-20} " -f $name, $version) -NoNewline; Write-Host "? UNKNOWN" -ForegroundColor Cyan }
            default { Write-Host ("{0,-15} {1,-20} ?" -f $name, $version) }
        }
    }

    Write-Host ""
}

# Install Python
function Install-Python {
    Write-Info "Installing Python..."

    if (Test-Command "winget") {
        try {
            winget install --id Python.Python.3.11 -e --source winget
            return $true
        }
        catch {
            Write-Failure "winget installation failed"
            return $false
        }
    }

    Write-Warning "winget not available. Please install Python manually from https://www.python.org/downloads/"
    return $false
}

# Install uv
function Install-Uv {
    Write-Info "Installing uv..."

    if (Test-Command "winget") {
        try {
            winget install --id astral-sh.uv -e --source winget
            return $true
        }
        catch {
            Write-Warning "winget installation failed, trying PowerShell installer..."
        }
    }

    # Fallback to PowerShell installer
    try {
        irm https://astral.sh/uv/install.ps1 | iex
        return $true
    }
    catch {
        Write-Failure "uv installation failed"
        return $false
    }
}

{% if api_tracks in ['node', 'python+node'] or docs_site in ['fumadocs', 'docusaurus'] or saas_starter_module == 'enabled' -%}
# Install Node.js
function Install-Node {
    Write-Info "Installing Node.js..."

    if (Test-Command "winget") {
        try {
            winget install --id OpenJS.NodeJS.LTS -e --source winget
            return $true
        }
        catch {
            Write-Failure "winget installation failed"
            return $false
        }
    }

    Write-Warning "winget not available. Please install Node.js manually from https://nodejs.org/"
    return $false
}

# Install pnpm
function Install-Pnpm {
    Write-Info "Installing pnpm..."

    # Try npm first (if Node.js is installed)
    if (Test-Command "npm") {
        try {
            npm install -g pnpm
            return $true
        }
        catch {
            Write-Failure "npm installation failed"
        }
    }

    # Try winget
    if (Test-Command "winget") {
        try {
            winget install --id pnpm.pnpm -e --source winget
            return $true
        }
        catch {
            Write-Failure "winget installation failed"
            return $false
        }
    }

    Write-Warning "Could not install pnpm. Please install manually from https://pnpm.io/installation"
    return $false
}
{% endif -%}

# Install pre-commit
function Install-PreCommit {
    Write-Info "Installing pre-commit..."

    if (-not (Test-Command "uv")) {
        Write-Failure "uv is required to install pre-commit"
        return $false
    }

    try {
        uv tool install pre-commit
        return $true
    }
    catch {
        Write-Failure "pre-commit installation failed"
        return $false
    }
}

{% if ci_platform == 'github-actions' -%}
# Install actionlint
function Install-Actionlint {
    Write-Info "Installing actionlint..."

    if (Test-Command "winget") {
        try {
            # Note: actionlint may not be in winget, provide alternative
            Write-Warning "actionlint installation via winget not available"
            Write-Info "Please install manually from https://github.com/rhysd/actionlint"
            return $false
        }
        catch {
            Write-Failure "Installation failed"
            return $false
        }
    }

    Write-Warning "Please install actionlint manually from https://github.com/rhysd/actionlint"
    return $false
}
{% endif -%}

# Install missing tools
function Install-MissingTools {
    Write-Section "Installing missing tools"

    $installCount = 0
    $failCount = 0

    foreach ($toolName in $script:MissingTools) {
        $success = switch ($toolName) {
            "python3" { Install-Python }
            "uv" { Install-Uv }
{% if api_tracks in ['node', 'python+node'] or docs_site in ['fumadocs', 'docusaurus'] or saas_starter_module == 'enabled' %}
            "node" { Install-Node }
            "pnpm" { Install-Pnpm }
{% endif %}
            "pre-commit" { Install-PreCommit }
{% if ci_platform == 'github-actions' %}
            "actionlint" { Install-Actionlint }
{% endif %}
            default {
                Write-Warning "Unknown tool: $toolName (skipping)"
                $false
            }
        }

        if ($success) {
            $installCount++
        }
        else {
            $failCount++
            $script:FailedInstalls += $toolName
        }
    }

    Write-Host ""
    Write-Info "Installation complete: $installCount succeeded, $failCount failed"

    return ($failCount -eq 0)
}

# Show next steps
function Show-NextSteps {
    Write-Section "Next Steps"

    if ($script:MissingTools.Count -eq 0) {
        Write-Success "All required tools are installed and ready!"
        Write-Host ""
        Write-Host "You can now:"
        Write-Host "  1. Install project dependencies:"
        Write-Host "     uv sync" -ForegroundColor Cyan
{% if api_tracks in ['node', 'python+node'] or docs_site in ['fumadocs', 'docusaurus'] or saas_starter_module == 'enabled' %}
        Write-Host "     pnpm install" -ForegroundColor Cyan
{% endif %}
        Write-Host ""
{% if cli_module == 'enabled' %}
        Write-Host "  2. Test the CLI:"
        Write-Host "     uv run python -m {{ package_name }}.cli --help" -ForegroundColor Cyan
        Write-Host ""
{% endif %}
{% if api_tracks in ['python', 'python+node'] %}
        Write-Host "  3. Start the API:"
        Write-Host "     uv run uvicorn {{ package_name }}.api.main:app --reload" -ForegroundColor Cyan
        Write-Host ""
{% endif %}
        Write-Host "  4. Run quality checks:"
        Write-Host "     make quality" -ForegroundColor Cyan
    }
    elseif (-not $Install) {
        Write-Warning "Missing tools detected. To install them:"
        Write-Host ""
        Write-Host "  .\scripts\setup\setup.ps1 -Install" -ForegroundColor Cyan
        Write-Host ""
        Write-Host "Or install manually:"
        foreach ($tool in $script:MissingTools) {
            Write-Host "  - $tool"
        }
    }
    else {
        if ($script:FailedInstalls.Count -gt 0) {
            Write-Failure "Some tools failed to install:"
            foreach ($tool in $script:FailedInstalls) {
                Write-Host "  - $tool"
            }
            Write-Host ""
{% if docs_site != 'none' %}
            Write-Host "Please install these tools manually. See: docs/development/setup.md"
{% endif %}
        }
    }
}

# Main execution
function Main {
    # Validate arguments
    if ($CheckOnly -and $Install) {
        Write-Failure "Cannot use -CheckOnly and -Install together"
        exit 2
    }

    if ($Yes -and -not $Install) {
        Write-Failure "-Yes can only be used with -Install"
        exit 2
    }

    if ($Help) {
        Show-Help
        exit 0
    }

    # Show header
    Write-Host ""
    Write-Host "$ScriptName v$ScriptVersion" -ForegroundColor Cyan
    Write-Host ""

    # Check all tools
    Test-AllTools

    # Show status
    Show-ToolStatus

    # All tools present
    if ($script:MissingTools.Count -eq 0) {
        Write-Success "All required tools are present!"
        Show-NextSteps
        exit 0
    }

    # Check-only mode
    if ($CheckOnly) {
        Write-Warning "$($script:MissingTools.Count) tool(s) missing or outdated"
        exit 1
    }

    # Default dry-run mode
    if (-not $Install) {
        Write-Warning "$($script:MissingTools.Count) tool(s) missing or outdated"
        Show-NextSteps
        exit 1
    }

    # Install mode - confirm with user
    if (-not $Yes) {
        Write-Warning "The following tools will be installed:"
        foreach ($tool in $script:MissingTools) {
            Write-Host "  - $tool"
        }
        Write-Host ""

        $response = Read-Host "Proceed with installation? [y/N]"
        if ($response -notmatch '^[yY]') {
            Write-Info "Installation cancelled by user"
            exit 1
        }
    }

    # Install missing tools
    $success = Install-MissingTools

    if ($success) {
        Write-Success "All tools installed successfully!"

        # Re-check tools
        $script:MissingTools = @()
        $script:FailedInstalls = @()
        Write-Host ""
        Test-AllTools
        Show-ToolStatus
        Show-NextSteps
        exit 0
    }
    else {
        Write-Failure "Installation completed with failures"
        Show-NextSteps
        exit 1
    }
}

# Run main
Main
