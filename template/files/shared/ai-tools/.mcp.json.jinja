{#- Claude Code MCP configuration (.mcp.json) -#}
{#- Used by: Claude Code (.mcp.json) -#}
{
  "mcpServers": {
{%- set servers = [] %}
{%- if ai_tools_mcp_thinking | default(true) %}
{%- set _ = servers.append('"sequential-thinking": {"type": "stdio", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]}') %}
{%- set _ = servers.append('"structured-thinking": {"type": "stdio", "command": "npx", "args": ["-y", "structured-thinking"]}') %}
{%- set _ = servers.append('"cascade-thinking": {"type": "stdio", "command": "npx", "args": ["-y", "cascade-thinking-mcp"]}') %}
{%- set _ = servers.append('"shannon-thinking": {"type": "stdio", "command": "npx", "args": ["-y", "server-shannon-thinking@latest"]}') %}
{%- set _ = servers.append('"lotus-wisdom-mcp": {"type": "stdio", "command": "npx", "args": ["-y", "lotus-wisdom-mcp"]}') %}
{%- set _ = servers.append('"think-strategies": {"type": "stdio", "command": "npx", "args": ["-y", "github:aaronsb/think-strategies"]}') %}
{%- set _ = servers.append('"crash": {"type": "stdio", "command": "npx", "args": ["-y", "crash-mcp"], "env": {"CRASH_STRICT_MODE": "false", "MAX_HISTORY_SIZE": "100"}}') %}
{%- endif %}
{%- if ai_tools_mcp_web | default(true) %}
{%- set _ = servers.append('"fetch": {"type": "stdio", "command": "npx", "args": ["mcp-fetch-server"]}') %}
{%- set _ = servers.append('"fetcher": {"type": "stdio", "command": "npx", "args": ["-y", "fetcher-mcp"]}') %}
{%- set _ = servers.append('"playwright": {"type": "stdio", "command": "npx", "args": ["@playwright/mcp@latest"]}') %}
{%- set _ = servers.append('"deepwiki": {"type": "stdio", "command": "npx", "args": ["-y", "mcp-remote", "https://mcp.deepwiki.com/mcp"]}') %}
{%- endif %}
{%- if ai_tools_mcp_documents | default(true) %}
{%- set _ = servers.append('"docling": {"type": "stdio", "command": "uvx", "args": ["--from=docling-mcp", "docling-mcp-server"]}') %}
{%- set _ = servers.append('"repomix": {"type": "stdio", "command": "npx", "args": ["-y", "repomix", "--mcp"]}') %}
{%- endif %}
{%- if ai_tools_mcp_utilities | default(true) %}
{%- set _ = servers.append('"memory": {"type": "stdio", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"]}') %}
{%- endif %}
{%- if ai_tools_mcp_search | default(false) %}
{%- set _ = servers.append('"brave-search": {"type": "stdio", "command": "npx", "args": ["-y", "@brave/brave-search-mcp-server"], "env": {"BRAVE_API_KEY": "${BRAVE_API_KEY}"}}') %}
{%- set _ = servers.append('"tavily": {"type": "stdio", "command": "npx", "args": ["-y", "tavily-mcp"], "env": {"TAVILY_API_KEY": "${TAVILY_API_KEY}"}}') %}
{%- set _ = servers.append('"context7": {"type": "stdio", "command": "npx", "args": ["-y", "@upstash/context7-mcp"], "env": {"CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"}}') %}
{%- endif %}
{%- if mcp_module == 'enabled' %}
{%- set _ = servers.append('"' ~ project_slug ~ '": {"type": "stdio", "command": "uv", "args": ["run", "--group", "mcp", "python", "-m", "' ~ package_name ~ '.mcp"], "timeout": 120000}') %}
{%- endif %}
    {{ servers | join(',\n    ') }}
  }
}
