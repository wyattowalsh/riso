# Pre-commit configuration for {{ project_name }}
# Generated by Riso template (profile: {{ quality_profile }})
# See https://pre-commit.com for more information
# Install hooks: make hooks (or: uv run pre-commit install --install-hooks)

default_stages: [pre-commit]
default_install_hook_types:
  - pre-commit
{% if changelog_module == 'enabled' or quality_profile == 'strict' %}
  - commit-msg
{% endif %}
{% if quality_profile == 'strict' %}
  - pre-push
{% endif %}

repos:
  # ============================================
  # Python Code Quality
  # ============================================
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.19
    hooks:
      - id: ruff
        name: ruff lint
{% if quality_profile == 'strict' %}
        args: [--fix, --exit-non-zero-on-fix, --select, ALL, --ignore, "E203,E266,E501"]
{% else %}
        args: [--fix, --exit-non-zero-on-fix]
{% endif %}
        types: [python]
        exclude: ^(\.venv|node_modules|dist|build|web/public)/
      - id: ruff-format
        name: ruff format
        types: [python]
        exclude: ^(\.venv|node_modules|dist|build|web/public)/

{% if quality_profile == 'strict' %}
  # Type checking and static analysis (strict profile)
  - repo: local
    hooks:
      - id: ty-check
        name: ty type check
        entry: uv run --group quality ty check --error-on-warning {{ package_name }}
        language: system
        types: [python]
        pass_filenames: false

      - id: pylint
        name: pylint static analysis
        entry: uv run --group quality pylint --errors-only
        language: system
        types: [python]
        files: ^({{ package_name }}|tests)/.*\.py$

  # Dead code detection (strict profile)
  - repo: https://github.com/jendrikseipp/vulture
    rev: v2.16
    hooks:
      - id: vulture
        name: vulture dead code
        args: [{{ package_name }}, --min-confidence, "80"]

{% endif %}
  # ============================================
  # Secrets Detection
  # ============================================
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.30.0
    hooks:
      - id: gitleaks
        name: gitleaks secrets scan

{% if (api_module == 'enabled' and 'node' in api_languages) or (docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus']) or saas_infra_module == 'enabled' %}
  # ============================================
  # Node.js Code Quality
  # ============================================
  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v3.7.4
    hooks:
      - id: prettier
        name: prettier format
        types_or: [javascript, jsx, ts, tsx, json, yaml]
{% if project_layout == 'monorepo' %}
        files: ^(apps|packages|node)/.*\.(js|jsx|ts|tsx|json|ya?ml|md)$
{% endif %}
        exclude: ^(node_modules|dist|build)/

  - repo: https://github.com/pre-commit/mirrors-eslint
    rev: v9.39.2
    hooks:
      - id: eslint
        name: eslint lint
        types_or: [javascript, jsx, ts, tsx]
{% if project_layout == 'monorepo' %}
        files: ^(apps|packages|node)/.*\.(js|jsx|ts|tsx)$
{% endif %}
        exclude: ^(node_modules|dist|build)/
        additional_dependencies:
          - eslint@9.39.2
          - typescript@5.9.3
          - "@typescript-eslint/parser@8.53.0"
          - "@typescript-eslint/eslint-plugin@8.53.0"

{% endif %}
  # ============================================
  # Shell Script Linting
  # ============================================
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.11.0.1
    hooks:
      - id: shellcheck
        name: shellcheck
        args: [--severity=warning]

  # ============================================
  # Spell Checking
  # ============================================
  - repo: https://github.com/codespell-project/codespell
    rev: v2.4.2
    hooks:
      - id: codespell
        name: codespell
        args:
          - --skip=*.lock,*.json,*.min.js,*.min.css,.git,node_modules,__pycache__
          - --ignore-words-list=crate,ot,te,nd

  # ============================================
  # Markdown Formatting
  # ============================================
  - repo: https://github.com/executablebooks/mdformat
    rev: 1.0.0
    hooks:
      - id: mdformat
        name: mdformat
        additional_dependencies:
          - mdformat-gfm
          - mdformat-frontmatter
          - mdformat-toc
        exclude: ^CHANGELOG\.md$

  # ============================================
  # General Quality Checks
  # ============================================
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v6.0.0
    hooks:
      - id: check-yaml
        name: check yaml
        args: [--unsafe]
      - id: check-toml
        name: check toml
      - id: check-json
        name: check json
      - id: end-of-file-fixer
        name: fix end of files
      - id: trailing-whitespace
        name: trim trailing whitespace
      - id: check-added-large-files
        name: check for large files
        args: [--maxkb=500]
      - id: check-merge-conflict
        name: check for merge conflicts
      - id: detect-private-key
        name: detect private keys
      - id: check-case-conflict
        name: check case conflicts
      - id: check-executables-have-shebangs
        name: check executables have shebangs

{% if ci_platform == 'github-actions' %}
  # ============================================
  # GitHub Actions Validation
  # ============================================
  - repo: https://github.com/rhysd/actionlint
    rev: v1.7.12
    hooks:
      - id: actionlint
        name: actionlint
        files: ^\.github/workflows/.*\.ya?ml$

  - repo: https://github.com/python-jsonschema/check-jsonschema
    rev: 0.37.3
    hooks:
      - id: check-github-workflows
        name: validate github workflows

{% endif %}
{% if changelog_module == 'enabled' or quality_profile == 'strict' %}
  # ============================================
  # Commit Message Validation
  # ============================================
  - repo: local
    hooks:
      - id: commitlint
        name: commitlint
        entry: scripts/hooks/commit-msg.sh
        language: system
        stages: [commit-msg]
        always_run: true

{% endif %}
{% if quality_profile == 'strict' %}
  # ============================================
  # Pre-push Hooks (strict profile)
  # ============================================
  - repo: local
    hooks:
      - id: pytest-prepush
        name: pytest (pre-push)
        entry: uv run --group test pytest tests -x -q --tb=short
        language: system
        pass_filenames: false
        stages: [pre-push]

      - id: pip-audit
        name: pip-audit security scan
        entry: uv run pip-audit
        language: system
        pass_filenames: false
        stages: [pre-push]

{% endif %}
# CI configuration for pre-commit.ci
ci:
  autofix_prs: true
  autoupdate_schedule: weekly
{% if quality_profile == 'strict' %}
  skip: [gitleaks]
{% else %}
  skip: [ty-check, pylint, vulture, pytest-prepush, pip-audit, gitleaks]
{% endif %}