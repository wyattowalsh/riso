//! Hello endpoint handler

use actix_web::{get, web, HttpResponse, Responder};
use serde::{Deserialize, Serialize};
use tracing::info;

use crate::models::ApiResponse;

#[derive(Debug, Deserialize)]
pub struct HelloQuery {
    name: Option<String>,
}

#[derive(Debug, Serialize)]
pub struct HelloData {
    message: String,
    timestamp: String,
}

/// Hello endpoint
///
/// Returns a greeting message.
///
/// # Query Parameters
///
/// * `name` - Optional name to greet (default: "World")
///
/// # Responses
///
/// * `200 OK` - Returns greeting message
#[get("/api/v1/hello")]
pub async fn hello(query: web::Query<HelloQuery>) -> impl Responder {
    let name = query.name.as_deref().unwrap_or("World");
    info!("Hello endpoint called with name: {}", name);

    let data = HelloData {
        message: format!("Hello, {}!", name),
        timestamp: chrono::Utc::now().to_rfc3339(),
    };

    let response = ApiResponse::success(data);

    HttpResponse::Ok().json(response)
}

#[cfg(test)]
mod tests {
    use super::*;
    use actix_web::{test, App};

    #[actix_web::test]
    async fn test_hello_default() {
        let app = test::init_service(App::new().service(hello)).await;
        let req = test::TestRequest::get().uri("/api/v1/hello").to_request();
        let resp = test::call_service(&app, req).await;
        assert!(resp.status().is_success());
    }

    #[actix_web::test]
    async fn test_hello_with_name() {
        let app = test::init_service(App::new().service(hello)).await;
        let req = test::TestRequest::get()
            .uri("/api/v1/hello?name=Rust")
            .to_request();
        let resp = test::call_service(&app, req).await;
        assert!(resp.status().is_success());
    }
}
