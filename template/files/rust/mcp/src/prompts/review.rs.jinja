//! Review prompts - code review templates.

use rmcp::{Server, prompt};
use serde::{Deserialize, Serialize};

#[derive(Deserialize)]
struct ReviewParams {
    code: String,
    language: Option<String>,
}

#[derive(Serialize)]
struct ReviewResult {
    messages: Vec<Message>,
}

#[derive(Serialize)]
struct Message {
    role: String,
    content: Content,
}

#[derive(Serialize)]
struct Content {
    #[serde(rename = "type")]
    msg_type: String,
    text: String,
}

/// Create a code review prompt
#[prompt]
async fn review_code(params: ReviewParams) -> Result<ReviewResult, String> {
    let language = params.language.unwrap_or_else(|| "rust".to_string());
    
    let text = format!(
        "Please review the following {} code for:\n\
        1. Bugs and potential runtime errors\n\
        2. Security vulnerabilities\n\
        3. Performance optimization opportunities\n\
        4. Code style and best practices conformance\n\
        \n\
        Code to review:\n\
        ```{}\n\
        {}\n\
        ```",
        language, language, params.code
    );

    Ok(ReviewResult {
        messages: vec![Message {
            role: "user".to_string(),
            content: Content {
                msg_type: "text".to_string(),
                text,
            },
        }],
    })
}

pub fn register(server: &Server) {
    server.register_prompt("review_code", review_code);
}
{%- endif %}
