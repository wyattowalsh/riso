{%- if mcp_module == 'enabled' and 'rust' in mcp_languages -%}
//! {{ project_name }} MCP Server
//!
//! Exposes {{ project_name }} functionality as MCP tools.

use clap::Parser;
use tracing::info;
use tracing_subscriber::{layer::SubscriberExt, util::SubscriberInitExt, EnvFilter};

mod config;
mod error;
mod tools;
mod resources;
mod prompts;

use config::Config;

const VERSION: &str = "1.0.0";
const SERVER_NAME: &str = "{{ package_name }}-mcp";

#[derive(Parser, Debug)]
#[command(name = SERVER_NAME, version = VERSION, about = "{{ project_name }} MCP Server")]
struct Args {
    /// Transport type: stdio, sse, or http
    #[arg(short, long, default_value = "{{ mcp_transport }}")]
    transport: String,

    /// Host for HTTP/SSE transports
    #[arg(short = 'H', long, default_value = "127.0.0.1")]
    host: String,

    /// Port for HTTP/SSE transports
    #[arg(short, long, default_value = "3000")]
    port: u16,
}

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    // Initialize logging
    tracing_subscriber::registry()
        .with(EnvFilter::try_from_default_env().unwrap_or_else(|_| "info".into()))
        .with(tracing_subscriber::fmt::layer().with_target(false))
        .init();

    let args = Args::parse();
    let _config = Config::load()?;

    info!("Starting {} v{} with {} transport", SERVER_NAME, VERSION, args.transport);

    match args.transport.as_str() {
        "stdio" => run_stdio().await,
        "sse" => run_sse(&args.host, args.port).await,
        "http" => run_http(&args.host, args.port).await,
        _ => Err(format!("Unknown transport: {}", args.transport).into()),
    }
}

{%- if mcp_transport in ['sse', 'http'] %}
use axum::{
    routing::{get, post},
    Router,
};
use std::net::SocketAddr;
use std::sync::Arc;
use tower_http::trace::TraceLayer;

mod transport;
{%- endif %}

// ... (existing imports kept or implied context)

// Helper to build the server
fn build_server() -> rmcp::Server {
    let server = rmcp::Server::builder()
        .name(SERVER_NAME)
        .version(VERSION)
        .build();

    tools::register(&server);
    resources::register(&server);
    prompts::register(&server);
    server
}

async fn run_stdio() -> Result<(), Box<dyn std::error::Error>> {
    let server = build_server();
    server.run_stdio().await?;
    Ok(())
}

async fn run_sse(host: &str, port: u16) -> Result<(), Box<dyn std::error::Error>> {
{%- if mcp_transport in ['sse', 'http'] %}
    let server = build_server();
    let state = Arc::new(transport::http::AppState { server: Arc::new(server) });

    let app = Router::new()
        .route("/sse", get(transport::sse::handle_sse))
        .route("/mcp", post(transport::http::handle_request))
        .layer(TraceLayer::new_for_http())
        .with_state(state);

    let addr: SocketAddr = format!("{}:{}", host, port).parse()?;
    tracing::info!("SSE server listening on {}", addr);
    
    let listener = tokio::net::TcpListener::bind(addr).await?;
    axum::serve(listener, app).await?;
    Ok(())
{%- else %}
    tracing::error!("SSE transport not enabled in this build. Please regenerate with mcp_transport='sse'.");
    std::process::exit(1);
{%- endif %}
}

async fn run_http(host: &str, port: u16) -> Result<(), Box<dyn std::error::Error>> {
{%- if mcp_transport in ['sse', 'http'] %}
    let server = build_server();
    let state = Arc::new(transport::http::AppState { server: Arc::new(server) });

    let app = Router::new()
        .route("/mcp", post(transport::http::handle_request))
        .layer(TraceLayer::new_for_http())
        .with_state(state);

    let addr: SocketAddr = format!("{}:{}", host, port).parse()?;
    tracing::info!("HTTP server listening on {}", addr);
    
    let listener = tokio::net::TcpListener::bind(addr).await?;
    axum::serve(listener, app).await?;
    Ok(())
{%- else %}
    tracing::error!("HTTP transport not enabled in this build. Please regenerate with mcp_transport='http'.");
    std::process::exit(1);
{%- endif %}
}
{%- endif %}
