//! MCP error types
//!
//! Maps {{ project_name }}-specific errors to MCP protocol error codes.

use thiserror::Error;

/// MCP error codes per JSON-RPC 2.0 specification
#[derive(Debug, Clone, Copy)]
#[repr(i32)]
pub enum McpErrorCode {
    // Standard JSON-RPC errors
    ParseError = -32700,
    InvalidRequest = -32600,
    MethodNotFound = -32601,
    InvalidParams = -32602,
    InternalError = -32603,

    // Custom codes (-32000 to -32099)
    OperationFailed = -32001,
    ValidationFailed = -32002,
    NotFound = -32003,
}

/// MCP error type
#[derive(Error, Debug)]
pub enum McpError {
    #[error("Operation failed: {operation} - {details}")]
    OperationFailed { operation: String, details: String },

    #[error("Validation failed: {0:?}")]
    ValidationFailed(Vec<String>),

    #[error("{resource} not found: {identifier}")]
    NotFound { resource: String, identifier: String },

    #[error("Internal error: {0}")]
    Internal(String),
}

impl McpError {
    pub fn code(&self) -> McpErrorCode {
        match self {
            McpError::OperationFailed { .. } => McpErrorCode::OperationFailed,
            McpError::ValidationFailed(_) => McpErrorCode::ValidationFailed,
            McpError::NotFound { .. } => McpErrorCode::NotFound,
            McpError::Internal(_) => McpErrorCode::InternalError,
        }
    }
}

pub type Result<T> = std::result::Result<T, McpError>;
{%- endif %}
