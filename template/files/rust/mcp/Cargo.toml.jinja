{%- if mcp_module == 'enabled' and mcp_language == 'rust' -%}
[package]
name = "{{ package_name }}-mcp"
version = "1.0.0"
edition = "2021"
description = "{{ project_name }} MCP Server"
authors = ["{{ author_name|default('Riso Maintainer', true) }}"]
license = "MIT"
rust-version = "1.75"

[dependencies]
rmcp = "0.11"
tokio = { version = "1.40", features = ["full"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
thiserror = "2.0"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
clap = { version = "4.5", features = ["derive", "env"] }
config = "0.14"
{%- if mcp_transport in ['sse', 'http'] %}
axum = { version = "0.7", features = ["macros"] }
tower = { version = "0.5", features = ["util"] }
tower-http = { version = "0.6", features = ["cors", "trace"] }
futures = "0.3"
{%- endif %}
{%- if mcp_example_tools %}
reqwest = { version = "0.12", features = ["json"] }
chrono = { version = "0.4", features = ["serde"] }
{%- endif %}

[dev-dependencies]
tokio-test = "0.4"

[[bin]]
name = "{{ package_name }}-mcp"
path = "src/main.rs"

[profile.release]
lto = true
codegen-units = 1
{%- endif %}
