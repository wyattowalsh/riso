{% if project_language == 'rust' %}
[package]
name = "{{ package_name }}"
version = "0.1.0"
edition = "2021"
description = "{{ project_name }}"
authors = ["{{ author_name|default('Riso Maintainer', true) }}"]
license = "MIT"
rust-version = "1.81"

[workspace]
members = [
    {%- if mcp_module == 'enabled' and mcp_language == 'rust' -%}"mcp"{%- endif -%}
]
resolver = "2"

[dependencies]
tokio = { version = "1.40", features = ["full"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
clap = { version = "4.5", features = ["derive", "env"] }
anyhow = "1.0"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

[dev-dependencies]
tokio-test = "0.4"
pretty_assertions = "1.4"

[profile.release]
strip = true
lto = true
codegen-units = 1
{% endif %}
