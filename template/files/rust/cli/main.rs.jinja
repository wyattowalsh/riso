{% if cli_module == 'enabled' and 'rust' in cli_languages %}
//! {{ project_name }} CLI
//!
//! A command-line interface built with Clap and Tokio.

use anyhow::Result;
use clap::Parser;
use tracing::info;
use tracing_subscriber::{fmt, prelude::*, EnvFilter};

mod commands;

#[derive(Parser)]
#[command(name = "{{ project_slug }}")]
#[command(author, version, about = "{{ project_description }}", long_about = None)]
#[command(propagate_version = true)]
struct Cli {
    /// Enable verbose logging
    #[arg(short, long, global = true)]
    verbose: bool,

    #[command(subcommand)]
    command: commands::Commands,
}

fn init_logging(verbose: bool) {
    let filter = if verbose {
        EnvFilter::new("debug")
    } else {
        EnvFilter::try_from_default_env().unwrap_or_else(|_| EnvFilter::new("info"))
    };

    tracing_subscriber::registry()
        .with(fmt::layer())
        .with(filter)
        .init();
}

#[tokio::main]
async fn main() -> Result<()> {
    let cli = Cli::parse();
    init_logging(cli.verbose);

    info!("Starting {} CLI", "{{ project_name }}");

    cli.command.execute().await
}
{% else %}
// CLI module is disabled
// Re-render the template with `cli_module=enabled` and `cli_language=rust` to scaffold the Rust CLI.
fn main() {
    eprintln!("CLI module is disabled for this render.");
    std::process::exit(1);
}
{% endif %}
