{% if project_language == 'rust' or 'rust' in cli_languages or 'rust' in api_languages %}
# {{ project_name }} Makefile
# Rust project — generated by Riso template

.PHONY: build test quality fmt fmt-check clippy clippy-all release clean update outdated audit help
{% if cli_module == 'enabled' and 'rust' in cli_languages %}
.PHONY: run-cli build-cli
{% endif %}
{% if api_module == 'enabled' and 'rust' in api_languages %}
.PHONY: run-api build-api run-api-dev
{% endif %}

build:
	cargo build

{% if cli_module == 'enabled' and 'rust' in cli_languages %}
run-cli:
	cargo run --bin {{ package_name }} -- $(ARGS)

build-cli:
	cargo build --release --bin {{ package_name }}
{% endif %}

{% if api_module == 'enabled' and 'rust' in api_languages %}
run-api:
	cargo run --bin {{ package_name }}-api

build-api:
	cargo build --release --bin {{ package_name }}-api

run-api-dev:
	RUST_LOG=debug HOST=127.0.0.1 PORT=8080 cargo run --bin {{ package_name }}-api
{% endif %}

test:
	cargo test

test-verbose:
	cargo test -- --nocapture

quality: fmt-check clippy test

fmt:
	cargo fmt

fmt-check:
	cargo fmt -- --check

clippy:
	cargo clippy -- -D warnings

clippy-all:
	cargo clippy --all-features -- -D warnings

release:
	cargo build --release

clean:
	cargo clean

update:
	cargo update

outdated:
	cargo outdated

audit:
	cargo audit

help:
	@echo "Available targets:"
	@echo "  build, test, quality, fmt, clippy, release, clean"
{% endif %}