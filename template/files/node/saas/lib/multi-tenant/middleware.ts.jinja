/**
 * Rewrite URL to include tenant in path (useful for multi-tenant routing)
 */
export function rewriteWithTenant(
  request: NextRequest,
  tenantSlug: string
): NextResponse {
  const url = request.nextUrl.clone();

  // Don't rewrite if already has tenant prefix
  if (url.pathname.startsWith(`/t/${tenantSlug}`)) {
    return NextResponse.next();
  }

  // Rewrite to tenant-prefixed path
  url.pathname = `/t/${tenantSlug}${url.pathname}`;

  return NextResponse.rewrite(url);
}

/**
 * Middleware config matcher
 */
export const tenantMiddlewareConfig = {
  matcher: [
    /*
     * Match all request paths except for the ones starting with:
     * - api/health (health check endpoints)
     * - api/webhooks (webhook endpoints)
     * - _next/static (static files)
     * - _next/image (image optimization files)
     * - favicon.ico (favicon file)
     * - public (public files)
     */
    '/((?!api/health|api/webhooks|_next/static|_next/image|favicon.ico|public).*)',
  ],
};

/**
 * Create tenant-aware API route handler
 */
export function withTenantAPI<T = unknown>(
  handler: (request: Request, tenant: TenantConfig) => Promise<Response>
) {
  return async function tenantAPIHandler(request: Request): Promise<Response> {
    const tenantSlug = getTenantFromRequest(request);

    if (!tenantSlug) {
      return new Response('Tenant not found', { status: 404 });
    }

    // Fetch tenant from database
    const tenant = await fetchTenantBySlug(tenantSlug);

    if (!tenant) {
      return new Response('Tenant not found', { status: 404 });
    }

    // Check tenant status
    if (tenant.status === 'suspended') {
      return new Response('Tenant is suspended', { status: 403 });
    }

    return handler(request, tenant);
  };
}

