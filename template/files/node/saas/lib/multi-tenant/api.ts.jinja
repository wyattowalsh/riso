/**
 * Multi-Tenancy API Client
 *
 * Client-side API functions for tenant operations.
 */

import type {
  TenantConfig,
  CreateTenantInput,
  UpdateTenantInput,
  TenantUsage,
  TenantExportOptions,
  TenantExportResult,
  TenantInvitation,
  TenantMember,
} from './types';

const API_BASE = '/api/tenants';

/**
 * Get current tenant from server
 */
export async function getCurrentTenant(): Promise<TenantConfig | null> {
  const response = await fetch(`${API_BASE}/current`, {
    credentials: 'include',
  });

  if (!response.ok) {
    if (response.status === 404) {
      return null;
    }
    throw new Error('Failed to fetch current tenant');
  }

  return response.json();
}

