## API Operations

### Create Tenant

```typescript
import { createTenant } from '@/lib/multi-tenant';

const tenant = await createTenant({
  name: 'Acme Corporation',
  slug: 'acme',
  tier: 'professional',
  ownerId: userId,
  features: {
    analytics: true,
    api: true,
  },
});
```

### Update Tenant

```typescript
import { updateTenant } from '@/lib/multi-tenant';

await updateTenant(tenantId, {
  name: 'Acme Corp',
  tier: 'enterprise',
  features: {
    sso: true,
  },
});
```

### Get Tenant Usage

```typescript
import { getTenantUsage } from '@/lib/multi-tenant';

const usage = await getTenantUsage(tenantId);

console.log(usage.users.current, '/', usage.users.max);
console.log(usage.storage.current, '/', usage.storage.max);
```

### Export Tenant Data

```typescript
import { exportTenantData } from '@/lib/multi-tenant';

const exportResult = await exportTenantData(tenantId, {
  format: 'zip',
  includeUsers: true,
  includeFiles: true,
  dateRange: {
    from: new Date('2024-01-01'),
    to: new Date('2024-12-31'),
  },
});

// Download from exportResult.downloadUrl
```

