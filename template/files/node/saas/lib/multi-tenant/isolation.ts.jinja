/**
 * Multi-Tenancy Data Isolation
 *
 * Provides row-level security (RLS) patterns and helpers for tenant data isolation.
 * Supports both Prisma and Drizzle ORMs with automatic tenant filtering.
 */

import type {
  TenantConfig,
  TenantIsolationConfig,
  TenantQueryBuilder,
} from './types';

const DEFAULT_ISOLATION_CONFIG: TenantIsolationConfig = {
  enableRLS: true,
  autoInject: true,
  tenantIdField: 'tenantId',
  excludedTables: ['_prisma_migrations', 'tenants', 'users'],
  strictMode: true,
};

/**
 * Tenant isolation context for database queries
 */
class TenantIsolationContext {
  private static instance: TenantIsolationContext;
  private currentTenant: TenantConfig | null = null;
  private config: TenantIsolationConfig;

  private constructor(config: Partial<TenantIsolationConfig> = {}) {
    this.config = { ...DEFAULT_ISOLATION_CONFIG, ...config };
  }

  static getInstance(config?: Partial<TenantIsolationConfig>): TenantIsolationContext {
    if (!TenantIsolationContext.instance) {
      TenantIsolationContext.instance = new TenantIsolationContext(config);
    }
    return TenantIsolationContext.instance;
  }

  setTenant(tenant: TenantConfig | null): void {
    this.currentTenant = tenant;
  }

  getTenant(): TenantConfig | null {
    return this.currentTenant;
  }

  getConfig(): TenantIsolationConfig {
    return this.config;
  }

  requireTenant(): TenantConfig {
    if (!this.currentTenant) {
      throw new Error('Tenant context is required but not set');
    }
    return this.currentTenant;
  }
}

/**
 * Initialize tenant isolation
 */
export function initTenantIsolation(
  config: Partial<TenantIsolationConfig> = {}
): TenantIsolationContext {
  return TenantIsolationContext.getInstance(config);
}

/**
 * Get current tenant isolation context
 */
export function getTenantContext(): TenantIsolationContext {
  return TenantIsolationContext.getInstance();
}

/**
 * Set current tenant for isolation
 */
export function setCurrentTenant(tenant: TenantConfig | null): void {
  getTenantContext().setTenant(tenant);
}

/**
 * Get current tenant
 */
export function getCurrentTenant(): TenantConfig | null {
  return getTenantContext().getTenant();
}

/**
 * Require tenant to be set
 */
export function requireTenant(): TenantConfig {
  return getTenantContext().requireTenant();
}

/**
 * Execute function with tenant context
 */
export async function withTenant<T>(
  tenant: TenantConfig,
  fn: () => Promise<T>
): Promise<T> {
  const context = getTenantContext();
  const previousTenant = context.getTenant();

  try {
    context.setTenant(tenant);
    return await fn();
  } finally {
    context.setTenant(previousTenant);
  }
}

/**
 * Prisma Extension for automatic tenant filtering
 *
 * Usage:
 * ```typescript
 * import { tenantExtension } from '@/lib/multi-tenant/isolation';
 * import { PrismaClient } from '@prisma/client';
 *
 * const prisma = new PrismaClient().$extends(tenantExtension);
 * ```
 */
export function createPrismaExtension(prisma: any) {
  const context = getTenantContext();
  const config = context.getConfig();

  return prisma.$extends({
    name: 'tenant-isolation',
    query: {
      $allModels: {
        async findMany({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          // Skip if tenant not set or table excluded
          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          // Inject tenant filter
          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async findFirst({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async findUnique({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          // For findUnique, add additional check after fetching
          const result = await query(args);

          if (result && result[config.tenantIdField] !== tenant.id) {
            if (config.strictMode) {
              throw new Error(`Access denied: Record belongs to different tenant`);
            }
            return null;
          }

          return result;
        },

        async create({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          // Inject tenant ID on create
          return query({
            ...args,
            data: {
              ...args.data,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async createMany({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          // Inject tenant ID for all records
          return query({
            ...args,
            data: Array.isArray(args.data)
              ? args.data.map((item: any) => ({
                  ...item,
                  [config.tenantIdField]: tenant.id,
                }))
              : {
                  ...args.data,
                  [config.tenantIdField]: tenant.id,
                },
          });
        },

        async update({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          // Add tenant filter to where clause
          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async updateMany({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async delete({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async deleteMany({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async count({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },

        async aggregate({ model, operation, args, query }: any) {
          const tenant = context.getTenant();

          if (!tenant || config.excludedTables?.includes(model)) {
            return query(args);
          }

          return query({
            ...args,
            where: {
              ...args.where,
              [config.tenantIdField]: tenant.id,
            },
          });
        },
      },
    },
  });
}

/**
 * Drizzle helper for tenant-scoped queries
 */
export function createDrizzleHelper<T extends Record<string, any>>(
  db: any,
  table: any
) {
  const context = getTenantContext();
  const config = context.getConfig();

  return {
    /**
     * Select with automatic tenant filtering
     */
    select(): TenantQueryBuilder<T> {
      const tenant = context.requireTenant();
      const tenantField = config.tenantIdField as keyof T;

      let query = db.select().from(table).where({ [tenantField]: tenant.id });
      let conditions: Partial<T> = {};
      let ordering: { field: keyof T; direction: 'asc' | 'desc' } | null = null;
      let limitValue: number | null = null;
      let offsetValue: number | null = null;

      const builder: TenantQueryBuilder<T> = {
        where(conds: Partial<T>) {
          conditions = { ...conditions, ...conds };
          return builder;
        },

        orderBy(field: keyof T, direction: 'asc' | 'desc') {
          ordering = { field, direction };
          return builder;
        },

        limit(count: number) {
          limitValue = count;
          return builder;
        },

        offset(count: number) {
          offsetValue = count;
          return builder;
        },

        async execute(): Promise<T[]> {
          // Build and execute query with Drizzle
          // This is a simplified version - adapt to your Drizzle setup
          return query;
        },

        async first(): Promise<T | null> {
          const results = await builder.limit(1).execute();
          return results[0] || null;
        },

        async count(): Promise<number> {
          // Execute count query
          return 0; // Placeholder
        },
      };

      return builder;
    },

    /**
     * Insert with automatic tenant ID
     */
    async insert(data: Omit<T, 'tenantId' | 'id'>): Promise<T> {
      const tenant = context.requireTenant();
      const tenantField = config.tenantIdField as keyof T;

      return db.insert(table).values({
        ...data,
        [tenantField]: tenant.id,
      });
    },

    /**
     * Update with tenant filtering
     */
    async update(id: string, data: Partial<T>): Promise<T> {
      const tenant = context.requireTenant();
      const tenantField = config.tenantIdField as keyof T;

      return db
        .update(table)
        .set(data)
        .where({ id, [tenantField]: tenant.id });
    },

    /**
     * Delete with tenant filtering
     */
    async delete(id: string): Promise<void> {
      const tenant = context.requireTenant();
      const tenantField = config.tenantIdField as keyof T;

      await db.delete(table).where({ id, [tenantField]: tenant.id });
    },
  };
}

/**
 * SQL query builder with tenant filtering
 */
export function buildTenantQuery(
  baseQuery: string,
  tenantIdField: string = 'tenant_id'
): string {
  const tenant = requireTenant();

  // Check if query already has WHERE clause
  const hasWhere = /\bWHERE\b/i.test(baseQuery);

  if (hasWhere) {
    return `${baseQuery} AND ${tenantIdField} = '${tenant.id}'`;
  } else {
    return `${baseQuery} WHERE ${tenantIdField} = '${tenant.id}'`;
  }
}

/**
 * Validate tenant access to resource
 */
export function validateTenantAccess(
  resourceTenantId: string,
  strictMode: boolean = true
): boolean {
  const tenant = getCurrentTenant();

  if (!tenant) {
    if (strictMode) {
      throw new Error('Tenant context not set');
    }
    return false;
  }

  if (resourceTenantId !== tenant.id) {
    if (strictMode) {
      throw new Error('Access denied: Resource belongs to different tenant');
    }
    return false;
  }

  return true;
}

/**
 * Higher-order function for tenant-scoped API handlers
 */
export function withTenantIsolation<TArgs extends any[], TReturn>(
  fn: (...args: TArgs) => Promise<TReturn>
) {
  return async (...args: TArgs): Promise<TReturn> => {
    const tenant = requireTenant();
    return fn(...args);
  };
}
