## Schema Conversion Examples

### Enum Handling

**Drizzle:**
```typescript
export const roleEnum = pgEnum('role', ['owner', 'admin', 'member']);

export const users = pgTable('users', {
  role: roleEnum('role').default('member'),
});
```

**Prisma:**
```prisma
enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id   String @id @default(cuid())
  role Role   @default(MEMBER)
}
```

### JSON with Type Safety

**Drizzle:**
```typescript
export const users = pgTable('users', {
  metadata: json('metadata')
    .$type<{ theme: 'light' | 'dark'; notifications: boolean }>()
    .default({})
});
```

**Prisma:**
```prisma
model User {
  metadata Json? @default("{}")
}

// In TypeScript:
type UserMetadata = { theme: 'light' | 'dark'; notifications: boolean };
```

### Complex Relations

**Drizzle:**
```typescript
export const users = pgTable('users', { id: text('id').primaryKey(), ... });
export const organizations = pgTable('organizations', { id: text('id').primaryKey(), ... });
export const memberships = pgTable('organization_memberships', {
  userId: text('user_id').references(() => users.id),
  organizationId: text('organization_id').references(() => organizations.id),
});

export const usersRelations = relations(users, ({ many }) => ({
  memberships: many(memberships),
}));
export const organizationsRelations = relations(organizations, ({ many }) => ({
  memberships: many(memberships),
}));
export const membershipsRelations = relations(memberships, ({ one }) => ({
  user: one(users),
  organization: one(organizations),
}));
```

**Prisma:**
```prisma
model User {
  id          String   @id @default(cuid())
  memberships OrganizationMembership[]
}

model Organization {
  id          String   @id @default(cuid())
  memberships OrganizationMembership[]
}

model OrganizationMembership {
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@id([userId, organizationId])
}
```

