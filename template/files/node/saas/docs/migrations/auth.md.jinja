## User Data Migration

### Export from Source Provider

**Export from Clerk:**
```typescript
import { clerkClient } from '@clerk/nextjs/server';
import * as fs from 'fs';

async function exportClerkUsers() {
  const users = await clerkClient.users.getUserList({ limit: 1000 });

  const exported = users.map(user => ({
    clerkId: user.id,
    email: user.emailAddresses[0]?.emailAddress,
    name: user.fullName,
    image: user.profileImageUrl,
    createdAt: user.createdAt,
  }));

  fs.writeFileSync('clerk-users.json', JSON.stringify(exported, null, 2));
  console.log(`Exported ${exported.length} users`);
}
```

**Export from Auth.js:**
```typescript
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
import * as fs from 'fs';

async function exportAuthJsUsers() {
  const users = await prisma.user.findMany({
    include: { accounts: true },
  });

  fs.writeFileSync('authjs-users.json', JSON.stringify(users, null, 2));
  console.log(`Exported ${users.length} users`);
}
{% endif %}
```

### Import to Target Provider

**Import to Clerk:**
```typescript
import { clerkClient } from '@clerk/nextjs/server';
import * as fs from 'fs';

interface ExportedUser {
  email: string;
  name?: string;
  image?: string;
}

async function importUsersToClerk() {
  const users: ExportedUser[] = JSON.parse(
    fs.readFileSync('users.json', 'utf-8')
  );

  for (const user of users) {
    try {
      await clerkClient.users.createUser({
        emailAddress: [user.email],
        firstName: user.name?.split(' ')[0],
        lastName: user.name?.split(' ')[1],
        profileImageUrl: user.image,
        skipPasswordRequirement: true,
      });
    } catch (error) {
      console.error(`Failed to import ${user.email}:`, error);
    }
  }
}
```

**Import to Auth.js:**
```typescript
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
import * as fs from 'fs';

async function importUsersToAuthJs() {
  const users = JSON.parse(fs.readFileSync('users.json', 'utf-8'));

  for (const user of users) {
    await prisma.user.create({
      data: {
        email: user.email,
        name: user.name,
        image: user.image,
        emailVerified: new Date(),
      },
    });
  }
}
{% endif %}
```

### Handle Password Hashes

Never transfer password hashes between providers. Instead:

1. **Invalidate old passwords** - Users must reset passwords on new provider
2. **Send password reset emails** - Clerk/Auth.js can do this automatically
3. **Require email verification** - Confirm ownership before granting access

```typescript
// After importing users, trigger password resets
async function sendPasswordResets(users: User[]) {
  for (const user of users) {
    // Auth.js: Send custom reset email
    // Clerk: Use Clerk Dashboard to send reset invitations
    // Better Auth: Use built-in reset flow
  }
}
```

