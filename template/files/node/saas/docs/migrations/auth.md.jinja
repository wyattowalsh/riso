### Step 7: Sync User Data from Clerk

Create a sync script:

```typescript
// scripts/sync-clerk-users.ts
import { clerkClient } from '@clerk/nextjs/server';
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/database/client';
import { users } from '@/db/schema';
{% endif %}

async function syncUsers() {
  const clerkUsers = await clerkClient.users.getUserList({ limit: 1000 });

  for (const clerkUser of clerkUsers) {
    const email = clerkUser.emailAddresses[0]?.emailAddress;

    if (!email) continue;

    {% if saas_orm == "prisma" %}
    await prisma.user.upsert({
      where: { email },
      update: {
        name: clerkUser.fullName,
        image: clerkUser.profileImageUrl,
        externalClerkId: clerkUser.id,
      },
      create: {
        email,
        name: clerkUser.fullName,
        image: clerkUser.profileImageUrl,
        externalClerkId: clerkUser.id,
        emailVerified: new Date(),
      },
    });
    {% elif saas_orm == "drizzle" %}
    await db.insert(users).values({
      email,
      name: clerkUser.fullName,
      image: clerkUser.profileImageUrl,
      externalClerkId: clerkUser.id,
      emailVerified: new Date(),
    }).onConflictDoUpdate({
      target: [users.email],
      set: {
        name: clerkUser.fullName,
        image: clerkUser.profileImageUrl,
        externalClerkId: clerkUser.id,
      },
    });
    {% endif %}
  }
}
```

### Step 8: Set Up Clerk Webhooks

Clerk webhooks sync user changes to your database.

1. Go to Clerk Dashboard → Webhooks
2. Create endpoint: `https://yourapp.com/api/webhooks/clerk`
3. Subscribe to: `user.created`, `user.updated`, `user.deleted`

Create `/app/api/webhooks/clerk/route.ts`:

```typescript
import { Webhook } from 'svix';
import { headers } from 'next/headers';
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/database/client';
import { users } from '@/db/schema';
{% endif %}

export async function POST(req: Request) {
  const payload = await req.text();
  const headersList = await headers();

  const svixHeaders = {
    'svix-id': headersList.get('svix-id')!,
    'svix-timestamp': headersList.get('svix-timestamp')!,
    'svix-signature': headersList.get('svix-signature')!,
  };

  const wh = new Webhook(process.env.CLERK_WEBHOOK_SECRET!);
  const event = wh.verify(payload, svixHeaders);

  const eventData = event.data as any;

  switch (event.type) {
    case 'user.created':
    case 'user.updated': {
      const email = eventData.email_addresses[0]?.email_address;

      if (email) {
        {% if saas_orm == "prisma" %}
        await prisma.user.upsert({
          where: { email },
          update: {
            name: eventData.first_name + ' ' + eventData.last_name,
            image: eventData.profile_image_url,
            externalClerkId: eventData.id,
          },
          create: {
            email,
            name: eventData.first_name + ' ' + eventData.last_name,
            image: eventData.profile_image_url,
            externalClerkId: eventData.id,
            emailVerified: new Date(),
          },
        });
        {% elif saas_orm == "drizzle" %}
        await db.insert(users).values({
          email,
          name: eventData.first_name + ' ' + eventData.last_name,
          image: eventData.profile_image_url,
          externalClerkId: eventData.id,
          emailVerified: new Date(),
        }).onConflictDoUpdate({
          target: [users.email],
          set: {
            name: eventData.first_name + ' ' + eventData.last_name,
            image: eventData.profile_image_url,
            externalClerkId: eventData.id,
          },
        });
        {% endif %}
      }
      break;
    }

    case 'user.deleted': {
      const clerkId = eventData.id;
      {% if saas_orm == "prisma" %}
      await prisma.user.deleteMany({
        where: { externalClerkId: clerkId },
      });
      {% elif saas_orm == "drizzle" %}
      await db.delete(users).where(
        eq(users.externalClerkId, clerkId)
      );
      {% endif %}
      break;
    }
  }

  return Response.json({ success: true });
}
```

