# Internationalization (i18n) Module

Complete internationalization solution for {{ project_name }} using [next-intl](https://next-intl-docs.vercel.app/).

## Features

- 🌍 Multi-language support with type safety
- 🔄 Automatic locale detection (URL, cookie, Accept-Language header)
- 🎯 URL-based locale routing (`/en/...`, `/es/...`)
- 📅 Date and number formatting utilities
- 🎨 RTL (right-to-left) language support preparation
- 🔧 TypeScript integration for type-safe translations
- 🚀 Server and client component support

## Quick Start

### 1. Basic Usage in Components

#### Client Components

```tsx
'use client';

import { useTranslations } from '@/i18n';

export function WelcomeMessage() {
  const t = useTranslations('common');

  return (
    <div>
      <h1>{t('welcome')}</h1>
      <p>{t('hello', { name: 'John' })}</p>
    </div>
  );
}
```

#### Server Components

```tsx
import { getTranslations } from '@/i18n';

export default async function Page() {
  const t = await getTranslations('common');

  return (
    <div>
      <h1>{t('welcome')}</h1>
      <p>{t('loading')}</p>
    </div>
  );
}
```

### 2. Get Current Locale

#### Client Component

```tsx
'use client';

import { useLocale } from '@/i18n';

export function LocaleDisplay() {
  const locale = useLocale();
  return <div>Current locale: {locale}</div>;
}
```

#### Server Component

```tsx
import { getLocale } from '@/i18n';

export default async function Page() {
  const locale = await getLocale();
  return <div>Current locale: {locale}</div>;
}
```

### 3. Language Switcher

```tsx
'use client';

import { useRouter, usePathname } from 'next/navigation';
import { useLocale } from '@/i18n';
import { locales, localeLabels } from '@/i18n/config';

export function LanguageSwitcher() {
  const router = useRouter();
  const pathname = usePathname();
  const currentLocale = useLocale();

  const switchLocale = (newLocale: string) => {
    // Replace locale in pathname
    const segments = pathname.split('/');
    segments[1] = newLocale;
    router.push(segments.join('/'));
  };

  return (
    <select
      value={currentLocale}
      onChange={(e) => switchLocale(e.target.value)}
    >
      {locales.map((locale) => (
        <option key={locale} value={locale}>
          {localeLabels[locale]}
        </option>
      ))}
    </select>
  );
}
```

