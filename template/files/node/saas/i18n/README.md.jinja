## Configuration

### Adding a New Locale

1. Update `i18n/config.ts`:

```typescript
export const locales = ['en', 'es', 'fr'] as const;

export const localeLabels: Record<Locale, string> = {
  en: 'English',
  es: 'Español',
  fr: 'Français',
};

export const localeMetadata: Record<Locale, LocaleMetadata> = {
  // ... existing locales
  fr: {
    dir: 'ltr',
    name: 'French',
    territory: 'FR',
  },
};
```

2. Create message file `i18n/messages/fr.json`:

```json
{
  "common": {
    "welcome": "Bienvenue",
    "hello": "Bonjour, {name}",
    // ... other translations
  }
}
```

### Changing Default Locale

Edit `i18n/config.ts`:

```typescript
export const defaultLocale: Locale = 'es'; // Change from 'en'
```

### Locale Prefix Strategy

Choose how locales appear in URLs by editing `i18n/config.ts`:

```typescript
// Always show locale: /en/about, /es/about
export const localePrefix = 'always' as const;

// Only show non-default: /about, /es/about
export const localePrefix = 'as-needed' as const;

// Never show in URL (cookie/header only)
export const localePrefix = 'never' as const;
```

## Translation Organization

Organize translations into logical namespaces:

```json
{
  "common": {
    "save": "Save",
    "cancel": "Cancel"
  },
  "navigation": {
    "home": "Home",
    "about": "About"
  },
  "auth": {
    "signIn": "Sign in",
    "signOut": "Sign out"
  }
}
```

Access namespaced translations:

```tsx
const t = useTranslations('navigation');
console.log(t('home')); // "Home"
```

## Advanced Features

### Date Formatting

```tsx
import { useLocale } from '@/i18n';

export function DateDisplay() {
  const locale = useLocale();
  const date = new Date();

  return (
    <div>
      {new Intl.DateTimeFormat(locale, {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      }).format(date)}
    </div>
  );
}
```

### Number Formatting

```tsx
import { useLocale } from '@/i18n';

export function PriceDisplay({ amount }: { amount: number }) {
  const locale = useLocale();

  return (
    <div>
      {new Intl.NumberFormat(locale, {
        style: 'currency',
        currency: 'USD'
      }).format(amount)}
    </div>
  );
}
```

### Pluralization

```json
{
  "items": {
    "zero": "No items",
    "one": "One item",
    "other": "{count} items"
  }
}
```

```tsx
const t = useTranslations('common');
t('items', { count: 0 }); // "No items"
t('items', { count: 1 }); // "One item"
t('items', { count: 5 }); // "5 items"
```

### Rich Text Formatting

```json
{
  "welcome": "Welcome to <bold>{name}</bold>!"
}
```

```tsx
const t = useTranslations('common');

<p>
  {t.rich('welcome', {
    name: 'Acme',
    bold: (chunks) => <strong>{chunks}</strong>
  })}
</p>
```

## Middleware Integration

The i18n middleware is automatically configured in `middleware.ts`. To customize:

```typescript
import { i18nMiddleware, config as i18nConfig } from '@/i18n/middleware';
import { NextRequest, NextResponse } from 'next/server';

export function middleware(request: NextRequest) {
  // Run i18n middleware first
  const i18nResponse = i18nMiddleware(request);

  // Add custom logic
  if (request.nextUrl.pathname.startsWith('/admin')) {
    // Custom admin logic
  }

  return i18nResponse;
}

export const config = i18nConfig;
```

## RTL Language Support

For RTL (right-to-left) languages like Arabic or Hebrew:

1. Update locale metadata in `i18n/config.ts`:

```typescript
export const localeMetadata: Record<Locale, LocaleMetadata> = {
  ar: {
    dir: 'rtl',
    name: 'Arabic',
    territory: 'SA',
  },
};
```

2. Apply direction in your layout:

```tsx
import { getLocale } from '@/i18n';
import { localeMetadata } from '@/i18n/config';

export default async function Layout({ children }: { children: React.ReactNode }) {
  const locale = await getLocale();
  const direction = localeMetadata[locale].dir;

  return (
    <html lang={locale} dir={direction}>
      <body>{children}</body>
    </html>
  );
}
```

