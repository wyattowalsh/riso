{% if saas_infra_module == "enabled" and saas_cicd == "github-actions" %}
name: E2E Tests

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

concurrency:
  group: {% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

env:
  NODE_VERSION: '20'
  PNPM_VERSION: '8'

jobs:
  # ============================================================================
  # E2E Tests with Playwright
  # ============================================================================
  e2e:
    name: E2E Tests
    runs-on: ubuntu-latest
    timeout-minutes: 30

    strategy:
      fail-fast: false
      matrix:
        shard: [1, 2, 3, 4]

    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_USER: test
          POSTGRES_PASSWORD: test
          POSTGRES_DB: test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v3
        with:
          version: {{ '${{ env.PNPM_VERSION }}' }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: {{ '${{ env.NODE_VERSION }}' }}
          cache: 'pnpm'

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Setup Playwright browsers cache
        uses: actions/cache@v4
        with:
          path: ~/.cache/ms-playwright
          key: {% raw %}${{ runner.os }}-playwright-${{ hashFiles('**/pnpm-lock.yaml') }}{% endraw %}
          restore-keys: |
            {% raw %}${{ runner.os }}-playwright-{% endraw %}

      - name: Install Playwright browsers
        run: pnpm exec playwright install --with-deps chromium firefox webkit

      {% if saas_orm == "prisma" %}
      - name: Generate Prisma Client
        run: pnpm run db:generate
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test

      - name: Run database migrations
        run: pnpm run db:push
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test

      - name: Seed database
        run: pnpm run db:seed
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test
      {% elif saas_orm == "drizzle" %}
      - name: Run database migrations
        run: pnpm run db:migrate
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test

      - name: Seed database
        run: pnpm run db:seed
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test
      {% endif %}

      - name: Start dev server
        run: pnpm run dev &
        timeout-minutes: 5
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test
          NODE_ENV: test
          {% if saas_auth_provider == "clerk" %}
          NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: {{ '${{ secrets.CLERK_PUBLISHABLE_KEY }}' }}
          CLERK_SECRET_KEY: {{ '${{ secrets.CLERK_SECRET_KEY }}' }}
          {% elif saas_auth_provider == "auth0" %}
          AUTH0_SECRET: {{ '${{ secrets.AUTH0_SECRET }}' }}
          AUTH0_BASE_URL: http://localhost:3000
          AUTH0_ISSUER_BASE_URL: {{ '${{ secrets.AUTH0_ISSUER_BASE_URL }}' }}
          AUTH0_CLIENT_ID: {{ '${{ secrets.AUTH0_CLIENT_ID }}' }}
          AUTH0_CLIENT_SECRET: {{ '${{ secrets.AUTH0_CLIENT_SECRET }}' }}
          {% elif saas_auth_provider == "next-auth" %}
          NEXTAUTH_SECRET: {{ '${{ secrets.NEXTAUTH_SECRET }}' }}
          NEXTAUTH_URL: http://localhost:3000
          {% endif %}
          {% if saas_payment == "stripe" %}
          STRIPE_SECRET_KEY: {{ '${{ secrets.STRIPE_SECRET_KEY }}' }}
          NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: {{ '${{ secrets.STRIPE_PUBLISHABLE_KEY }}' }}
          {% elif saas_payment == "lemonsqueezy" %}
          LEMONSQUEEZY_API_KEY: {{ '${{ secrets.LEMONSQUEEZY_API_KEY }}' }}
          NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID: {{ '${{ secrets.LEMONSQUEEZY_STORE_ID }}' }}
          {% endif %}

      - name: Wait for dev server
        run: |
          echo "Waiting for server to be ready on http://localhost:3000..."
          for i in {1..60}; do
            if curl -f http://localhost:3000 > /dev/null 2>&1; then
              echo "? Server is ready!"
              exit 0
            fi
            echo "Attempt $i/60: Server not ready yet, waiting..."
            sleep 2
          done
          echo "✗ Server failed to start"
          exit 1

      - name: Run E2E tests (Shard {% raw %}${{ matrix.shard }}{% endraw %}/4)
        run: pnpm run test:e2e -- --shard={% raw %}${{ matrix.shard }}{% endraw %}/4
        env:
          DATABASE_URL: postgresql://test:test@localhost:5432/test
          BASE_URL: http://localhost:3000
          NODE_ENV: test
          {% if saas_auth_provider == "clerk" %}
          NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: {{ '${{ secrets.CLERK_PUBLISHABLE_KEY }}' }}
          CLERK_SECRET_KEY: {{ '${{ secrets.CLERK_SECRET_KEY }}' }}
          {% elif saas_auth_provider == "auth0" %}
          AUTH0_SECRET: {{ '${{ secrets.AUTH0_SECRET }}' }}
          AUTH0_BASE_URL: http://localhost:3000
          AUTH0_ISSUER_BASE_URL: {{ '${{ secrets.AUTH0_ISSUER_BASE_URL }}' }}
          AUTH0_CLIENT_ID: {{ '${{ secrets.AUTH0_CLIENT_ID }}' }}
          AUTH0_CLIENT_SECRET: {{ '${{ secrets.AUTH0_CLIENT_SECRET }}' }}
          {% elif saas_auth_provider == "next-auth" %}
          NEXTAUTH_SECRET: {{ '${{ secrets.NEXTAUTH_SECRET }}' }}
          NEXTAUTH_URL: http://localhost:3000
          {% endif %}
          {% if saas_payment == "stripe" %}
          STRIPE_SECRET_KEY: {{ '${{ secrets.STRIPE_SECRET_KEY }}' }}
          NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: {{ '${{ secrets.STRIPE_PUBLISHABLE_KEY }}' }}
          {% elif saas_payment == "lemonsqueezy" %}
          LEMONSQUEEZY_API_KEY: {{ '${{ secrets.LEMONSQUEEZY_API_KEY }}' }}
          NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID: {{ '${{ secrets.LEMONSQUEEZY_STORE_ID }}' }}
          {% endif %}

      - name: Upload Playwright report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: playwright-report-shard-{% raw %}${{ matrix.shard }}{% endraw %}
          path: playwright-report/
          retention-days: 30

      - name: Upload Playwright videos
        uses: actions/upload-artifact@v4
        if: failure()
        with:
          name: playwright-videos-shard-{% raw %}${{ matrix.shard }}{% endraw %}
          path: test-results/
          retention-days: 7

  # ============================================================================
  # Merge E2E test reports
  # ============================================================================
  e2e-report:
    name: E2E Test Report
    runs-on: ubuntu-latest
    if: always()
    needs: [e2e]

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: all-reports

      - name: Publish test results summary
        uses: actions/github-script@v7
        if: always()
        with:
          script: |
            const fs = require('fs');
            let passedTests = 0;
            let failedTests = 0;

            // Try to find and parse test results
            const reportsDir = './all-reports';
            if (fs.existsSync(reportsDir)) {
              try {
                const files = fs.readdirSync(reportsDir, { recursive: true });
                console.log('Found artifacts:', files);
              } catch (e) {
                console.log('Could not read reports:', e.message);
              }
            }

            const summary = `
## E2E Test Results
- **Status**: {% raw %}${{ needs.e2e.result }}{% endraw %}
- **Artifacts**: Check the playwright-report artifacts for detailed results
            `.trim();

            core.summary
              .addHeading('E2E Test Summary')
              .addRaw(summary)
              .write();
{% endif %}
