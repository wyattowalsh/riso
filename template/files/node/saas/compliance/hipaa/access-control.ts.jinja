/**
 * Access event types for HIPAA audit trail
 */
export enum AccessEventType {
  READ = 'READ',
  CREATE = 'CREATE',
  UPDATE = 'UPDATE',
  DELETE = 'DELETE',
  EXPORT = 'EXPORT',
  PRINT = 'PRINT',
  SHARE = 'SHARE',
}

/**
 * Access outcome for audit logging
 */
export enum AccessOutcome {
  SUCCESS = 'SUCCESS',
  FAILURE = 'FAILURE',
  DENIED = 'DENIED',
}

/**
 * HIPAA audit log entry structure
 */
export interface HIPAAAuditLog {
  id: string;
  timestamp: Date;
  userId: string;
  userName?: string;
  userRole?: string;
  patientId?: string;
  eventType: AccessEventType;
  outcome: AccessOutcome;
  resourceType: string;
  resourceId: string;
  phiAccessed: string[]; // List of PHI fields accessed
  purpose: string;
  ipAddress: string;
  userAgent?: string;
  sessionId?: string;
  denialReason?: string;
  dataModified?: boolean;
  exportFormat?: string;
  recipientUserId?: string; // For SHARE events
}

/**
 * Creates a HIPAA-compliant audit log entry
 *
 * @param entry - Audit log entry data
 * @returns Formatted audit log
 */
export async function createAuditLog(entry: Omit<HIPAAAuditLog, 'id' | 'timestamp'>): Promise<HIPAAAuditLog> {
  const auditLog: HIPAAAuditLog = {
    id: generateAuditId(),
    timestamp: new Date(),
    ...entry,
  };

  // Store audit log in immutable storage
  await storeAuditLog(auditLog);

  return auditLog;
}

