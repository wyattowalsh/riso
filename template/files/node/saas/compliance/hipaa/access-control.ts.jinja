/**
 * Generates unique audit log ID
 */
function generateAuditId(): string {
  return `audit_${Date.now()}_${Math.random().toString(36).substring(2, 15)}`;
}

/**
 * Middleware for automatic PHI access logging
 *
 * @param userId - User accessing PHI
 * @param patientId - Patient whose PHI is being accessed
 * @param eventType - Type of access event
 * @param resourceType - Type of resource (e.g., 'MedicalRecord', 'LabResult')
 * @param resourceId - Specific resource ID
 * @param purpose - Purpose of access
 * @returns Audit log function
 */
export function auditPHIAccess(
  userId: string,
  patientId: string,
  eventType: AccessEventType,
  resourceType: string,
  resourceId: string,
  purpose: string
) {
  return async (
    outcome: AccessOutcome,
    phiAccessed: string[],
    metadata?: {
      ipAddress?: string;
      userAgent?: string;
      sessionId?: string;
      denialReason?: string;
      dataModified?: boolean;
    }
  ) => {
    await createAuditLog({
      userId,
      patientId,
      eventType,
      outcome,
      resourceType,
      resourceId,
      phiAccessed,
      purpose,
      ipAddress: metadata?.ipAddress || 'unknown',
      userAgent: metadata?.userAgent,
      sessionId: metadata?.sessionId,
      denialReason: metadata?.denialReason,
      dataModified: metadata?.dataModified,
    });
  };
}

