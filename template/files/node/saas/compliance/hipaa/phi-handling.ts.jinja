/**
 * Minimum Necessary Standard - limits PHI disclosure to minimum needed
 *
 * @param requestedFields - Fields requested by user
 * @param purpose - Purpose of the request
 * @returns Filtered list of fields that meet minimum necessary standard
 */
export function applyMinimumNecessary(
  requestedFields: PHIFieldType[],
  purpose: string
): PHIFieldType[] {
  // Implement minimum necessary logic based on purpose
  // For example, billing may only need name and account number,
  // not full medical history

  const purposeFieldMap: Record<string, PHIFieldType[]> = {
    billing: [PHI_FIELD_TYPES.NAME, PHI_FIELD_TYPES.ACCOUNT_NUMBER, PHI_FIELD_TYPES.HEALTH_PLAN_ID],
    scheduling: [PHI_FIELD_TYPES.NAME, PHI_FIELD_TYPES.PHONE, PHI_FIELD_TYPES.DATE_OF_BIRTH],
    treatment: requestedFields, // Treatment typically needs all requested fields
  };

  const allowedFields = purposeFieldMap[purpose.toLowerCase()] || [];
  return requestedFields.filter(field => allowedFields.includes(field));
}

/**
 * De-identifies PHI data by removing direct identifiers
 * Useful for creating de-identified datasets for research
 *
 * @param data - Data containing PHI
 * @returns De-identified version of the data
 */
export function deIdentifyPHI<T extends Record<string, any>>(data: T): Partial<T> {
  const directIdentifiers = [
    PHI_FIELD_TYPES.NAME,
    PHI_FIELD_TYPES.ADDRESS,
    PHI_FIELD_TYPES.SSN,
    PHI_FIELD_TYPES.MRN,
    PHI_FIELD_TYPES.PHONE,
    PHI_FIELD_TYPES.EMAIL,
    PHI_FIELD_TYPES.PHOTO,
    PHI_FIELD_TYPES.BIOMETRIC_DATA,
  ];

  const deidentified = { ...data };

  for (const field of Object.keys(deidentified)) {
    if (directIdentifiers.includes(field as PHIFieldType)) {
      delete deidentified[field];
    }
  }

  return deidentified;
}
