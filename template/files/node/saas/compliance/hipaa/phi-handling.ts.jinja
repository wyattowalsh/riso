/**
 * PHI data fields that require special handling under HIPAA
 */
export const PHI_FIELD_TYPES = {
  // Demographic identifiers
  NAME: 'name',
  ADDRESS: 'address',
  DATE_OF_BIRTH: 'dateOfBirth',
  PHONE: 'phone',
  EMAIL: 'email',
  SSN: 'ssn',
  MRN: 'medicalRecordNumber',

  // Medical identifiers
  HEALTH_PLAN_ID: 'healthPlanId',
  ACCOUNT_NUMBER: 'accountNumber',
  CERTIFICATE_NUMBER: 'certificateNumber',
  DEVICE_IDENTIFIER: 'deviceIdentifier',
  BIOMETRIC_DATA: 'biometricData',

  // Clinical data
  DIAGNOSIS: 'diagnosis',
  TREATMENT: 'treatment',
  PRESCRIPTION: 'prescription',
  LAB_RESULT: 'labResult',
  MEDICAL_HISTORY: 'medicalHistory',

  // Images and documents
  PHOTO: 'photo',
  MEDICAL_IMAGE: 'medicalImage',
  VOICE_RECORDING: 'voiceRecording',
} as const;

export type PHIFieldType = typeof PHI_FIELD_TYPES[keyof typeof PHI_FIELD_TYPES];

/**
 * Marks a data object as containing PHI for audit trail purposes
 */
export interface PHIMetadata {
  containsPHI: true;
  phiFields: PHIFieldType[];
  purpose: string;
  accessedBy: string;
  accessedAt: Date;
  retentionPeriod?: number; // in days
}

/**
 * Redacts PHI fields from an object for logging or display
 *
 * @param data - The data object to redact
 * @param fieldsToRedact - Array of field names to redact
 * @returns A new object with specified fields redacted
 */
export function redactPHI<T extends Record<string, any>>(
  data: T,
  fieldsToRedact: (keyof T)[]
): T {
  const redacted = { ...data };

  for (const field of fieldsToRedact) {
    if (field in redacted) {
      redacted[field] = '[REDACTED]' as any;
    }
  }

  return redacted;
}

