{% if saas_infra_module == "enabled" and saas_gdpr_tools %}
/**
 * GDPR Data Deletion (Right to be Forgotten)
 *
 * Allows users to request deletion of all their personal data.
 * Implements Article 17 of GDPR with proper cascading and retention policies.
 */

{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/prisma';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/db';
{% endif %}

export interface DeletionOptions {
  gracePeriodDays?: number;      // Days before permanent deletion (default: 30)
  notifyUser?: boolean;            // Send deletion confirmation email
  preserveAnonymized?: boolean;    // Keep anonymized data for analytics
}

export interface DeletionResult {
  success: boolean;
  scheduledFor?: Date;             // When permanent deletion will occur
  message: string;
}

/**
 * Request account deletion with grace period
 */
export async function deleteUserAccount(
  userId: string,
  options: DeletionOptions = {}
): Promise<DeletionResult> {
  const {
    gracePeriodDays = 30,
    notifyUser = true,
    preserveAnonymized = true,
  } = options;

  try {
{% if saas_orm == "prisma" %}
    // Verify user exists
    const user = await prisma.user.findUnique({
      where: { id: userId },
      select: { id: true, email: true, name: true },
    });

    if (!user) {
      return {
        success: false,
        message: 'User not found',
      };
    }

    // Schedule deletion
    const scheduledFor = new Date();
    scheduledFor.setDate(scheduledFor.getDate() + gracePeriodDays);

    // Mark account for deletion
    await prisma.user.update({
      where: { id: userId },
      data: {
        deletionScheduledAt: scheduledFor,
        deletionRequestedAt: new Date(),
      },
    });

    // Log the deletion request
    await prisma.auditLog.create({
      data: {
        userId,
        eventType: 'account.deletion.requested',
        timestamp: new Date(),
        metadata: {
          scheduledFor: scheduledFor.toISOString(),
          gracePeriodDays,
        },
      },
    });

    // Send notification email
    if (notifyUser) {
      await sendDeletionNotification(user.email, scheduledFor);
    }

    return {
      success: true,
      scheduledFor,
      message: `Account deletion scheduled for ${scheduledFor.toLocaleDateString()}. You can cancel this within the grace period.`,
    };
{% elif saas_orm == "drizzle" %}
    // TODO: Implement with Drizzle ORM
    throw new Error('Drizzle implementation pending');
{% endif %}
  } catch (error) {
    console.error('Account deletion request failed:', error);
    return {
      success: false,
      message: 'Failed to schedule account deletion. Please try again or contact support.',
    };
  }
}

/**
 * Cancel a scheduled deletion (during grace period)
 */
export async function cancelDeletion(userId: string): Promise<DeletionResult> {
  try {
{% if saas_orm == "prisma" %}
    const user = await prisma.user.findUnique({
      where: { id: userId },
      select: { deletionScheduledAt: true },
    });

    if (!user?.deletionScheduledAt) {
      return {
        success: false,
        message: 'No deletion scheduled for this account',
      };
    }

    // Check if still within grace period
    if (new Date() > user.deletionScheduledAt) {
      return {
        success: false,
        message: 'Grace period has expired. Account has been deleted.',
      };
    }

    // Cancel deletion
    await prisma.user.update({
      where: { id: userId },
      data: {
        deletionScheduledAt: null,
        deletionRequestedAt: null,
      },
    });

    // Log cancellation
    await prisma.auditLog.create({
      data: {
        userId,
        eventType: 'account.deletion.cancelled',
        timestamp: new Date(),
      },
    });

    return {
      success: true,
      message: 'Account deletion cancelled successfully',
    };
{% elif saas_orm == "drizzle" %}
    throw new Error('Drizzle implementation pending');
{% endif %}
  } catch (error) {
    console.error('Deletion cancellation failed:', error);
    return {
      success: false,
      message: 'Failed to cancel deletion. Please contact support.',
    };
  }
}

/**
 * Permanently delete user data (executed after grace period)
 * This should be called by a scheduled job
 */
export async function executePermanentDeletion(
  userId: string,
  preserveAnonymized: boolean = true
): Promise<void> {
{% if saas_orm == "prisma" %}
  const user = await prisma.user.findUnique({
    where: { id: userId },
  });

  if (!user) {
    throw new Error('User not found');
  }

  // Use a transaction to ensure data consistency
  await prisma.$transaction(async (tx) => {
    // 1. Delete or anonymize sensitive data
    if (preserveAnonymized) {
      // Anonymize instead of delete for analytics
      await tx.user.update({
        where: { id: userId },
        data: {
          email: `deleted-${userId}@anonymous.local`,
          name: 'Deleted User',
          phone: null,
          // Clear other PII fields
        },
      });
    } else {
      // Cascading deletes
{% if saas_tenancy_model == "b2b-teams" %}
      // Delete organization memberships
      await tx.organizationMember.deleteMany({
        where: { userId },
      });
{% endif %}

      // Delete sessions
      await tx.session.deleteMany({
        where: { userId },
      });

      // Delete subscriptions
      await tx.subscription.deleteMany({
        where: { userId },
      });

      // Delete consent records
      await tx.consentRecord.deleteMany({
        where: { userId },
      });

      // Delete audit logs (or anonymize them)
      await tx.auditLog.deleteMany({
        where: { userId },
      });

      // Delete user profile
      await tx.profile.delete({
        where: { userId },
      });

      // Finally, delete the user
      await tx.user.delete({
        where: { id: userId },
      });
    }

    // 2. Delete from external services
    await deleteFromExternalServices(userId);

    // 3. Create final audit record (stored separately)
    await tx.deletionAudit.create({
      data: {
        userId,
        email: user.email,
        deletedAt: new Date(),
        preservedAnonymized: preserveAnonymized,
      },
    });
  });
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  throw new Error('Drizzle implementation pending');
{% endif %}
}

/**
 * Delete user data from external services
 */
async function deleteFromExternalServices(userId: string): Promise<void> {
{% if saas_auth_provider == "clerk" %}
  // Delete from Clerk
  try {
    const { clerkClient } = await import('@clerk/nextjs/server');
    await clerkClient.users.deleteUser(userId);
  } catch (error) {
    console.error('Failed to delete user from Clerk:', error);
  }
{% endif %}

{% if saas_storage == "r2" %}
  // Delete user files from R2
  try {
    const { S3Client, ListObjectsV2Command, DeleteObjectsCommand } = await import('@aws-sdk/client-s3');
    const s3 = new S3Client({
      region: 'auto',
      endpoint: process.env.R2_ENDPOINT,
      credentials: {
        accessKeyId: process.env.R2_ACCESS_KEY_ID!,
        secretAccessKey: process.env.R2_SECRET_ACCESS_KEY!,
      },
    });

    const prefix = `users/${userId}/`;
    const listCommand = new ListObjectsV2Command({
      Bucket: process.env.R2_BUCKET_NAME,
      Prefix: prefix,
    });

    const { Contents } = await s3.send(listCommand);
    if (Contents && Contents.length > 0) {
      const deleteCommand = new DeleteObjectsCommand({
        Bucket: process.env.R2_BUCKET_NAME,
        Delete: {
          Objects: Contents.map(obj => ({ Key: obj.Key! })),
        },
      });
      await s3.send(deleteCommand);
    }
  } catch (error) {
    console.error('Failed to delete user files from R2:', error);
  }
{% elif saas_storage == "supabase-storage" %}
  // Delete user files from Supabase Storage
  try {
    const { createClient } = await import('@supabase/supabase-js');
    const supabase = createClient(
      process.env.NEXT_PUBLIC_SUPABASE_URL!,
      process.env.SUPABASE_SERVICE_ROLE_KEY!
    );

    await supabase.storage.from('user-files').remove([`${userId}/*`]);
  } catch (error) {
    console.error('Failed to delete user files from Supabase:', error);
  }
{% endif %}

{% if saas_analytics == "posthog" %}
  // Delete from PostHog
  try {
    const response = await fetch(`https://app.posthog.com/api/person/${userId}`, {
      method: 'DELETE',
      headers: {
        'Authorization': `Bearer ${process.env.POSTHOG_API_KEY}`,
      },
    });
    if (!response.ok) {
      console.error('PostHog deletion failed:', await response.text());
    }
  } catch (error) {
    console.error('Failed to delete user from PostHog:', error);
  }
{% endif %}
}

/**
 * Send deletion notification email
 */
async function sendDeletionNotification(
  email: string,
  scheduledFor: Date
): Promise<void> {
{% if saas_email == "resend" %}
  const { Resend } = await import('resend');
  const resend = new Resend(process.env.RESEND_API_KEY);

  await resend.emails.send({
    from: 'privacy@{{ project_slug }}.com',
    to: email,
    subject: 'Account Deletion Scheduled',
    html: `
      <h1>Account Deletion Scheduled</h1>
      <p>Your account deletion has been scheduled for <strong>${scheduledFor.toLocaleDateString()}</strong>.</p>
      <p>If you change your mind, you can cancel this deletion by logging in before this date.</p>
      <p>After this date, all your data will be permanently deleted and cannot be recovered.</p>
      <p>If you did not request this, please contact our support team immediately.</p>
    `,
  });
{% elif saas_email == "postmark" %}
  const { ServerClient } = await import('postmark');
  const client = new ServerClient(process.env.POSTMARK_API_TOKEN);

  await client.sendEmail({
    From: 'privacy@{{ project_slug }}.com',
    To: email,
    Subject: 'Account Deletion Scheduled',
    HtmlBody: `
      <h1>Account Deletion Scheduled</h1>
      <p>Your account deletion has been scheduled for <strong>${scheduledFor.toLocaleDateString()}</strong>.</p>
      <p>If you change your mind, you can cancel this deletion by logging in before this date.</p>
      <p>After this date, all your data will be permanently deleted and cannot be recovered.</p>
      <p>If you did not request this, please contact our support team immediately.</p>
    `,
  });
{% endif %}
}

/**
 * Get list of users scheduled for deletion
 * Used by cleanup job
 */
export async function getUsersScheduledForDeletion(): Promise<Array<{ id: string; email: string; scheduledFor: Date }>> {
{% if saas_orm == "prisma" %}
  const users = await prisma.user.findMany({
    where: {
      deletionScheduledAt: {
        lte: new Date(),
      },
    },
    select: {
      id: true,
      email: true,
      deletionScheduledAt: true,
    },
  });

  return users.map(u => ({
    id: u.id,
    email: u.email,
    scheduledFor: u.deletionScheduledAt!,
  }));
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  return [];
{% endif %}
}
{% endif %}
