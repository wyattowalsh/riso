## Database Schema

Add these tables to your database schema:

### Prisma Schema

```prisma
{% if saas_orm == "prisma" %}
// Consent records
model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences Json     // { essential: true, analytics: false, ... }
  version     String   // Consent policy version
  timestamp   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([userId])
  @@index([timestamp])
}

// Audit logs
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType  String   // AuditEventType
  timestamp  DateTime @default(now())
  actor      String?  // Who performed the action
  ipAddress  String?
  userAgent  String?
  resource   String?  // What was accessed/modified
  legalBasis String?  // GDPR legal basis
  metadata   Json?

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
}

// Deletion audit (survives user deletion)
model DeletionAudit {
  id                  String   @id @default(cuid())
  userId              String   // Original user ID
  email               String
  deletedAt           DateTime @default(now())
  preservedAnonymized Boolean

  @@index([userId])
  @@index([deletedAt])
}

// Add to User model
model User {
  // ... existing fields
  deletionScheduledAt  DateTime?
  deletionRequestedAt  DateTime?
  consentRecords       ConsentRecord[]
  auditLogs            AuditLog[]
}
```
