export async function POST(request: Request) {
  const session = await auth();
  if (!session) return new Response('Unauthorized', { status: 401 });

  const result = await deleteUserAccount(session.user.id);
  return Response.json(result);
}

export async function DELETE(request: Request) {
  const session = await auth();
  if (!session) return new Response('Unauthorized', { status: 401 });

  const result = await cancelDeletion(session.user.id);
  return Response.json(result);
}
```

## Privacy Settings UI

Add a privacy settings page:

```tsx
// app/(dashboard)/settings/privacy/page.tsx
'use client';

import { useState } from 'react';
import { exportUserData, deleteUserAccount } from '@/compliance/gdpr';

export default function PrivacySettingsPage() {
  const [exportFormat, setExportFormat] = useState<'json' | 'csv'>('json');

  const handleExport = async () => {
    const data = await exportUserData(session.user.id, exportFormat);
    // Trigger download
    const blob = new Blob([data], {
      type: exportFormat === 'json' ? 'application/json' : 'text/csv'
    });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `data-export.${exportFormat}`;
    a.click();
  };

  const handleDelete = async () => {
    if (!confirm('Are you sure? This will delete your account in 30 days.')) return;
    const result = await deleteUserAccount(session.user.id);
    alert(result.message);
  };

  return (
    <div className="space-y-6">
      <section>
        <h2>Export Your Data</h2>
        <p>Download a copy of all your personal data.</p>
        <select value={exportFormat} onChange={(e) => setExportFormat(e.target.value)}>
          <option value="json">JSON</option>
          <option value="csv">CSV</option>
        </select>
        <button onClick={handleExport}>Export Data</button>
      </section>

      <section>
        <h2>Delete Your Account</h2>
        <p>Permanently delete your account and all associated data.</p>
        <button onClick={handleDelete} className="bg-red-600">
          Delete Account
        </button>
      </section>
    </div>
  );
}
```

