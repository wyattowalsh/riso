/**
 * Log consent change event
 */
export async function logConsentChange(
  userId: string,
  previousPreferences: Record<string, boolean>,
  newPreferences: Record<string, boolean>,
  ipAddress?: string,
  userAgent?: string
): Promise<void> {
{% if saas_orm == "prisma" %}
  // Determine what changed
  const changes: Record<string, { from: boolean; to: boolean }> = {};
  for (const [key, value] of Object.entries(newPreferences)) {
    if (previousPreferences[key] !== value) {
      changes[key] = {
        from: previousPreferences[key],
        to: value,
      };
    }
  }

  // Determine event type
  const granted = Object.values(newPreferences).some(v => v === true);
  const withdrawn = Object.values(newPreferences).every(v => v === false);
  const eventType = withdrawn ? 'consent.withdrawn' : granted ? 'consent.granted' : 'consent.updated';

  await prisma.auditLog.create({
    data: {
      userId,
      eventType,
      timestamp: new Date(),
      ipAddress,
      userAgent,
      metadata: {
        previousPreferences,
        newPreferences,
        changes,
      },
    },
  });
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
{% endif %}
}

