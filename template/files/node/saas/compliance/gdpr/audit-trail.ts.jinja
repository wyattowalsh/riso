{% endif %}
}

/**
 * Get audit trail for a specific user
 */
export async function getAuditTrail(
  userId: string,
  options?: {
    eventTypes?: AuditEventType[];
    startDate?: Date;
    endDate?: Date;
    limit?: number;
    offset?: number;
  }
): Promise<AuditEvent[]> {
{% if saas_orm == "prisma" %}
  const { eventTypes, startDate, endDate, limit = 100, offset = 0 } = options || {};

  const where: any = { userId };

  if (eventTypes && eventTypes.length > 0) {
    where.eventType = { in: eventTypes };
  }

  if (startDate || endDate) {
    where.timestamp = {};
    if (startDate) where.timestamp.gte = startDate;
    if (endDate) where.timestamp.lte = endDate;
  }

  const logs = await prisma.auditLog.findMany({
    where,
    orderBy: { timestamp: 'desc' },
    take: limit,
    skip: offset,
  });

  return logs.map(log => ({
    id: log.id,
    userId: log.userId,
    eventType: log.eventType as AuditEventType,
    timestamp: log.timestamp,
    actor: log.actor || undefined,
    ipAddress: log.ipAddress || undefined,
    userAgent: log.userAgent || undefined,
    resource: log.resource || undefined,
    legalBasis: log.legalBasis || undefined,
    metadata: log.metadata as Record<string, any> || undefined,
  }));
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  return [];
{% endif %}
}

/**
 * Get processing activities summary for compliance reporting
 */
export async function getProcessingActivitiesReport(
  startDate: Date,
  endDate: Date
): Promise<Array<{
  purpose: string;
  legalBasis: string;
  dataCategories: string[];
  count: number;
}>> {
{% if saas_orm == "prisma" %}
  const activities = await prisma.auditLog.findMany({
    where: {
      eventType: { in: ['processing.started', 'processing.completed'] },
      timestamp: {
        gte: startDate,
        lte: endDate,
      },
    },
    select: {
      legalBasis: true,
      metadata: true,
    },
  });

  // Group by purpose and legal basis
  const grouped = new Map<string, {
    purpose: string;
    legalBasis: string;
    dataCategories: Set<string>;
    count: number;
  }>();

  for (const activity of activities) {
    const metadata = activity.metadata as any;
    const key = `${metadata.purpose}-${activity.legalBasis}`;

    if (!grouped.has(key)) {
      grouped.set(key, {
        purpose: metadata.purpose,
        legalBasis: activity.legalBasis || 'unknown',
        dataCategories: new Set(metadata.dataCategories || []),
        count: 0,
      });
    }

    const entry = grouped.get(key)!;
    entry.count++;
    if (metadata.dataCategories) {
      metadata.dataCategories.forEach((cat: string) => entry.dataCategories.add(cat));
    }
  }

  return Array.from(grouped.values()).map(entry => ({
    purpose: entry.purpose,
    legalBasis: entry.legalBasis,
    dataCategories: Array.from(entry.dataCategories),
    count: entry.count,
  }));
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  return [];
{% endif %}
}

/**
 * Get consent history for a user
 */
export async function getConsentHistory(
  userId: string,
  limit: number = 50
): Promise<Array<{
  timestamp: Date;
  preferences: Record<string, boolean>;
  version: string;
  ipAddress?: string;
}>> {
{% if saas_orm == "prisma" %}
  const records = await prisma.consentRecord.findMany({
    where: { userId },
    orderBy: { timestamp: 'desc' },
    take: limit,
  });

  return records.map(record => ({
    timestamp: record.timestamp,
    preferences: record.preferences as Record<string, boolean>,
    version: record.version,
    ipAddress: record.ipAddress || undefined,
  }));
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  return [];
{% endif %}
}

/**
 * Generate GDPR compliance report
 */
export async function generateComplianceReport(
  startDate: Date,
  endDate: Date
): Promise<{
  totalUsers: number;
  activeConsents: number;
  dataExports: number;
  deletionRequests: number;
  processingActivities: Array<any>;
}> {
{% if saas_orm == "prisma" %}
  const [
    totalUsers,
    activeConsents,
    dataExports,
    deletionRequests,
  ] = await Promise.all([
    prisma.user.count(),
    prisma.consentRecord.count({
      where: {
        timestamp: { gte: startDate, lte: endDate },
      },
    }),
    prisma.auditLog.count({
      where: {
        eventType: 'data.exported',
        timestamp: { gte: startDate, lte: endDate },
      },
    }),
    prisma.auditLog.count({
      where: {
        eventType: 'data.deleted',
        timestamp: { gte: startDate, lte: endDate },
      },
    }),
  ]);

  const processingActivities = await getProcessingActivitiesReport(startDate, endDate);

  return {
    totalUsers,
    activeConsents,
    dataExports,
    deletionRequests,
    processingActivities,
  };
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
  return {
    totalUsers: 0,
    activeConsents: 0,
    dataExports: 0,
    deletionRequests: 0,
    processingActivities: [],
  };
{% endif %}
}
{% endif %}
