{% if saas_infra_module == "enabled" and saas_gdpr_tools %}
/**
 * GDPR Audit Trail
 *
 * Tracks all access to personal data and consent changes for compliance.
 * Implements Article 30 (Records of Processing Activities) requirements.
 */

{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/prisma';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/db';
{% endif %}

export type AuditEventType =
  | 'data.accessed'          // PII was accessed/viewed
  | 'data.modified'          // PII was updated
  | 'data.exported'          // User requested data export
  | 'data.deleted'           // User requested deletion
  | 'consent.granted'        // User granted consent
  | 'consent.withdrawn'      // User withdrew consent
  | 'consent.updated'        // User updated consent preferences
  | 'account.created'        // Account creation
  | 'account.login'          // User logged in
  | 'account.deleted'        // Account deletion completed
  | 'processing.started'     // Data processing started
  | 'processing.completed';  // Data processing completed

export interface AuditEvent {
  id: string;
  userId: string;
  eventType: AuditEventType;
  timestamp: Date;
  actor?: string;            // Who performed the action (userId, system, admin)
  ipAddress?: string;
  userAgent?: string;
  resource?: string;         // What data was accessed/modified
  legalBasis?: string;       // Legal basis for processing
  metadata?: Record<string, any>;
}

/**
 * Log data access event
 */
export async function logDataAccess(
  userId: string,
  resource: string,
  actor?: string,
  metadata?: Record<string, any>
): Promise<void> {
{% if saas_orm == "prisma" %}
  await prisma.auditLog.create({
    data: {
      userId,
      eventType: 'data.accessed',
      timestamp: new Date(),
      actor: actor || userId,
      resource,
      metadata: metadata || {},
    },
  });
{% elif saas_orm == "drizzle" %}
  // TODO: Implement with Drizzle ORM
{% endif %}
}

