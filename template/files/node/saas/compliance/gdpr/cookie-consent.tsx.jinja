{% if saas_infra_module == "enabled" and saas_gdpr_tools %}
'use client';

import { useState, useEffect } from 'react';
import { X, Cookie, Settings } from 'lucide-react';
import type { ConsentPreferences, ConsentRecord } from './types';

const CONSENT_STORAGE_KEY = 'gdpr_consent';
const CONSENT_VERSION = '1.0.0';

/**
 * Default consent preferences (only essential cookies enabled)
 */
const DEFAULT_PREFERENCES: ConsentPreferences = {
  essential: true,
  analytics: false,
  marketing: false,
  preferences: false,
};

/**
 * Cookie Consent Banner Component
 *
 * Displays a GDPR-compliant cookie consent banner with granular controls.
 * Stores consent preferences in localStorage and tracks consent history.
 */
export function CookieConsent() {
  const [isVisible, setIsVisible] = useState(false);
  const [showDetails, setShowDetails] = useState(false);
  const [preferences, setPreferences] = useState<ConsentPreferences>(DEFAULT_PREFERENCES);

  useEffect(() => {
    // Check if user has already provided consent
    const stored = localStorage.getItem(CONSENT_STORAGE_KEY);
    if (!stored) {
      setIsVisible(true);
    } else {
      try {
        const record: ConsentRecord = JSON.parse(stored);
        setPreferences(record.preferences);
        applyConsent(record.preferences);
      } catch (error) {
        console.error('Failed to parse consent record:', error);
        setIsVisible(true);
      }
    }
  }, []);

  /**
   * Apply consent preferences by enabling/disabling tracking scripts
   */
  const applyConsent = (prefs: ConsentPreferences) => {
    // Analytics
    if (prefs.analytics) {
      enableAnalytics();
    } else {
      disableAnalytics();
    }

    // Marketing
    if (prefs.marketing) {
      enableMarketing();
    } else {
      disableMarketing();
    }

    // Preferences
    if (prefs.preferences) {
      enablePreferences();
    } else {
      disablePreferences();
    }
  };

  /**
   * Save consent preferences
   */
  const saveConsent = async (prefs: ConsentPreferences) => {
    const record: ConsentRecord = {
      userId: getUserId(), // Get from auth context
      preferences: prefs,
      timestamp: new Date(),
      version: CONSENT_VERSION,
    };

    // Store locally
    localStorage.setItem(CONSENT_STORAGE_KEY, JSON.stringify(record));

    // Store in database for audit trail
    try {
      await fetch('/api/gdpr/consent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(record),
      });
    } catch (error) {
      console.error('Failed to save consent to database:', error);
    }

    applyConsent(prefs);
    setIsVisible(false);
  };

  /**
   * Accept all cookies
   */
  const acceptAll = () => {
    const allAccepted: ConsentPreferences = {
      essential: true,
      analytics: true,
      marketing: true,
      preferences: true,
    };
    setPreferences(allAccepted);
    saveConsent(allAccepted);
  };

  /**
   * Accept only essential cookies
   */
  const acceptEssential = () => {
    saveConsent(DEFAULT_PREFERENCES);
  };

  /**
   * Save custom preferences
   */
  const saveCustom = () => {
    saveConsent(preferences);
  };

  if (!isVisible) return null;

  return (
    <div className="fixed inset-x-0 bottom-0 z-50 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 shadow-lg">
      <div className="max-w-7xl mx-auto p-6">
        <div className="flex items-start justify-between gap-4">
          <div className="flex items-start gap-3 flex-1">
            <Cookie className="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" />
            <div className="flex-1">
              <h3 className="font-semibold text-lg mb-2">
                Cookie Preferences
              </h3>
              <p className="text-sm text-gray-600 dark:text-gray-400 mb-4">
                We use cookies to enhance your experience, analyze site traffic, and personalize content.
                You can customize your cookie preferences or accept our recommended settings.
              </p>

              {showDetails && (
                <div className="space-y-3 mb-4 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
                  <CookieCategory
                    title="Essential Cookies"
                    description="Required for the website to function properly. Cannot be disabled."
                    enabled={true}
                    locked={true}
                    onChange={() => {}}
                  />
                  <CookieCategory
                    title="Analytics Cookies"
                    description="Help us understand how visitors interact with our website."
                    enabled={preferences.analytics}
                    onChange={(enabled) => setPreferences({ ...preferences, analytics: enabled })}
                  />
                  <CookieCategory
                    title="Marketing Cookies"
                    description="Used to track visitors across websites for advertising purposes."
                    enabled={preferences.marketing}
                    onChange={(enabled) => setPreferences({ ...preferences, marketing: enabled })}
                  />
                  <CookieCategory
                    title="Preference Cookies"
                    description="Remember your settings and preferences for a better experience."
                    enabled={preferences.preferences}
                    onChange={(enabled) => setPreferences({ ...preferences, preferences: enabled })}
                  />
                </div>
              )}

              <div className="flex flex-wrap gap-3">
                <button
                  onClick={acceptAll}
                  className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium"
                >
                  Accept All
                </button>
                <button
                  onClick={acceptEssential}
                  className="px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium"
                >
                  Essential Only
                </button>
                <button
                  onClick={() => setShowDetails(!showDetails)}
                  className="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors flex items-center gap-2"
                >
                  <Settings className="w-4 h-4" />
                  Customize
                </button>
                {showDetails && (
                  <button
                    onClick={saveCustom}
                    className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
                  >
                    Save Preferences
                  </button>
                )}
              </div>
            </div>
          </div>
          <button
            onClick={acceptEssential}
            className="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
            aria-label="Decline all non-essential cookies"
          >
            <X className="w-5 h-5" />
          </button>
        </div>
      </div>
    </div>
  );
}

/**
 * Individual cookie category toggle
 */
interface CookieCategoryProps {
  title: string;
  description: string;
  enabled: boolean;
  locked?: boolean;
  onChange: (enabled: boolean) => void;
}

function CookieCategory({ title, description, enabled, locked, onChange }: CookieCategoryProps) {
  return (
    <div className="flex items-start justify-between gap-4">
      <div className="flex-1">
        <h4 className="font-medium text-sm mb-1">{title}</h4>
        <p className="text-xs text-gray-600 dark:text-gray-400">{description}</p>
      </div>
      <label className="relative inline-flex items-center cursor-pointer">
        <input
          type="checkbox"
          checked={enabled}
          onChange={(e) => onChange(e.target.checked)}
          disabled={locked}
          className="sr-only peer"
        />
        <div className={`w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 ${locked ? 'opacity-50 cursor-not-allowed' : ''}`}></div>
      </label>
    </div>
  );
}

/**
 * Analytics enablement functions
 */
function enableAnalytics() {
{% if saas_analytics == "posthog" %}
  // Enable PostHog
  if (typeof window !== 'undefined' && (window as any).posthog) {
    (window as any).posthog.opt_in_capturing();
  }
{% elif saas_analytics == "amplitude" %}
  // Enable Amplitude
  if (typeof window !== 'undefined' && (window as any).amplitude) {
    (window as any).amplitude.setOptOut(false);
  }
{% endif %}
}

function disableAnalytics() {
{% if saas_analytics == "posthog" %}
  // Disable PostHog
  if (typeof window !== 'undefined' && (window as any).posthog) {
    (window as any).posthog.opt_out_capturing();
  }
{% elif saas_analytics == "amplitude" %}
  // Disable Amplitude
  if (typeof window !== 'undefined' && (window as any).amplitude) {
    (window as any).amplitude.setOptOut(true);
  }
{% endif %}
}

/**
 * Marketing enablement functions
 */
function enableMarketing() {
  // Enable marketing pixels (Google Ads, Facebook Pixel, etc.)
  console.log('Marketing cookies enabled');
}

function disableMarketing() {
  // Disable marketing pixels
  console.log('Marketing cookies disabled');
}

/**
 * Preferences enablement functions
 */
function enablePreferences() {
  console.log('Preference cookies enabled');
}

function disablePreferences() {
  console.log('Preference cookies disabled');
}

/**
 * Get current user ID (integrate with your auth system)
 */
function getUserId(): string {
  // TODO: Integrate with {{ saas_auth_provider }} to get actual user ID
  return 'anonymous';
}
{% endif %}
