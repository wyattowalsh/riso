/**
 * Generates SOC 2 compliance report
 *
 * @param startDate - Report start date
 * @param endDate - Report end date
 * @returns Compliance report
 */
export async function generateComplianceReport(startDate: Date, endDate: Date) {
  const logs = await queryAuditLogs({ startDate, endDate });

  // Calculate key metrics for SOC 2 compliance
  const authenticationEvents = logs.filter(log =>
    [SOC2EventType.USER_LOGIN, SOC2EventType.USER_LOGOUT, SOC2EventType.LOGIN_FAILED].includes(log.eventType)
  );

  const failedLogins = logs.filter(log => log.eventType === SOC2EventType.LOGIN_FAILED);
  const accessDenied = logs.filter(log => log.eventType === SOC2EventType.ACCESS_DENIED);
  const permissionChanges = logs.filter(log =>
    [SOC2EventType.ROLE_ASSIGNED, SOC2EventType.ROLE_REVOKED, SOC2EventType.PERMISSION_GRANTED, SOC2EventType.PERMISSION_REVOKED].includes(
      log.eventType
    )
  );

  return {
    period: {
      start: startDate,
      end: endDate,
    },
    summary: {
      totalEvents: logs.length,
      uniqueUsers: new Set(logs.map(log => log.userId).filter(Boolean)).size,
      criticalEvents: logs.filter(log => log.severity === AuditSeverity.CRITICAL).length,
      errorEvents: logs.filter(log => log.severity === AuditSeverity.ERROR).length,
      warningEvents: logs.filter(log => log.severity === AuditSeverity.WARNING).length,
    },
    authentication: {
      totalLogins: authenticationEvents.filter(log => log.eventType === SOC2EventType.USER_LOGIN).length,
      failedLogins: failedLogins.length,
      mfaUsageRate:
        authenticationEvents.filter(log => log.metadata?.mfaUsed).length /
        (authenticationEvents.length || 1),
    },
    accessControl: {
      accessDenied: accessDenied.length,
      permissionChanges: permissionChanges.length,
      dataExports: logs.filter(log => log.eventType === SOC2EventType.DATA_EXPORT).length,
    },
    dataActivity: {
      reads: logs.filter(log => log.eventType === SOC2EventType.DATA_READ).length,
      creates: logs.filter(log => log.eventType === SOC2EventType.DATA_CREATE).length,
      updates: logs.filter(log => log.eventType === SOC2EventType.DATA_UPDATE).length,
      deletes: logs.filter(log => log.eventType === SOC2EventType.DATA_DELETE).length,
    },
    security: {
      suspiciousActivity: logs.filter(log => log.eventType === SOC2EventType.SUSPICIOUS_ACTIVITY).length,
      securityAlerts: logs.filter(log => log.eventType === SOC2EventType.SECURITY_ALERT).length,
    },
  };
}

/**
 * Detects anomalous behavior patterns for SOC 2 continuous monitoring
 *
 * @param userId - User to analyze
 * @param timeWindow - Time window in hours
 * @returns Anomaly detection results
 */
export async function detectAnomalies(
  userId: string,
  timeWindow: number = 24
): Promise<{
  anomalies: Array<{
    type: string;
    severity: AuditSeverity;
    description: string;
    count: number;
  }>;
}> {
  const endDate = new Date();
  const startDate = new Date(endDate.getTime() - timeWindow * 60 * 60 * 1000);

  const logs = await queryAuditLogs({ userId, startDate, endDate });

  const anomalies: Array<{ type: string; severity: AuditSeverity; description: string; count: number }> = [];

  // Check for failed login attempts
  const failedLogins = logs.filter(log => log.eventType === SOC2EventType.LOGIN_FAILED);
  if (failedLogins.length >= 5) {
    anomalies.push({
      type: 'multiple_failed_logins',
      severity: AuditSeverity.WARNING,
      description: `${failedLogins.length} failed login attempts`,
      count: failedLogins.length,
    });
  }

  // Check for unusual access patterns
  const uniqueIPs = new Set(logs.map(log => log.ipAddress));
  if (uniqueIPs.size >= 5) {
    anomalies.push({
      type: 'multiple_ip_addresses',
      severity: AuditSeverity.WARNING,
      description: `Access from ${uniqueIPs.size} different IP addresses`,
      count: uniqueIPs.size,
    });
  }

  // Check for data exports
  const exports = logs.filter(log => log.eventType === SOC2EventType.DATA_EXPORT);
  if (exports.length >= 3) {
    anomalies.push({
      type: 'multiple_exports',
      severity: AuditSeverity.ERROR,
      description: `${exports.length} data exports in ${timeWindow} hours`,
      count: exports.length,
    });
  }

  // Check for permission escalation
  const permissionChanges = logs.filter(log =>
    [SOC2EventType.ROLE_ASSIGNED, SOC2EventType.PERMISSION_GRANTED].includes(log.eventType)
  );
  if (permissionChanges.length >= 2) {
    anomalies.push({
      type: 'permission_escalation',
      severity: AuditSeverity.ERROR,
      description: `${permissionChanges.length} permission changes`,
      count: permissionChanges.length,
    });
  }

  // Check for after-hours activity (outside 6 AM - 10 PM)
  const afterHours = logs.filter(log => {
    const hour = log.timestamp.getHours();
    return hour < 6 || hour > 22;
  });
  if (afterHours.length >= 10) {
    anomalies.push({
      type: 'after_hours_activity',
      severity: AuditSeverity.WARNING,
      description: `${afterHours.length} events outside business hours`,
      count: afterHours.length,
    });
  }

  return { anomalies };
}
