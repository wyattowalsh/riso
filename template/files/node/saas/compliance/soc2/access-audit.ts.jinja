/**
 * Helper function for logging user authentication events
 */
export async function logAuthenticationEvent(
  eventType: SOC2EventType.USER_LOGIN | SOC2EventType.USER_LOGOUT | SOC2EventType.LOGIN_FAILED,
  userId: string,
  metadata: {
    ipAddress: string;
    userAgent?: string;
    sessionId?: string;
    mfaUsed?: boolean;
    failureReason?: string;
  }
): Promise<void> {
  const severity = eventType === SOC2EventType.LOGIN_FAILED ? AuditSeverity.WARNING : AuditSeverity.INFO;

  await createAuditLog({
    eventType,
    severity,
    userId,
    action: eventType.toLowerCase().replace(/_/g, ' '),
    outcome: eventType === SOC2EventType.LOGIN_FAILED ? 'failure' : 'success',
    ipAddress: metadata.ipAddress,
    userAgent: metadata.userAgent,
    sessionId: metadata.sessionId,
    errorMessage: metadata.failureReason,
    metadata: {
      mfaUsed: metadata.mfaUsed,
    },
  });
}

/**
 * Helper function for logging data access events
 */
export async function logDataAccess(
  eventType: SOC2EventType.DATA_READ | SOC2EventType.DATA_CREATE | SOC2EventType.DATA_UPDATE | SOC2EventType.DATA_DELETE,
  userId: string,
  resource: {
    type: string;
    id: string;
    name?: string;
  },
  metadata: {
    ipAddress: string;
    userAgent?: string;
    sessionId?: string;
    changedFields?: string[];
    previousValues?: Record<string, any>;
    newValues?: Record<string, any>;
  }
): Promise<void> {
  await createAuditLog({
    eventType,
    severity: eventType === SOC2EventType.DATA_DELETE ? AuditSeverity.WARNING : AuditSeverity.INFO,
    userId,
    resourceType: resource.type,
    resourceId: resource.id,
    resourceName: resource.name,
    action: `${eventType.split('_')[1].toLowerCase()} ${resource.type}`,
    outcome: 'success',
    ipAddress: metadata.ipAddress,
    userAgent: metadata.userAgent,
    sessionId: metadata.sessionId,
    changedFields: metadata.changedFields,
    previousValues: metadata.previousValues,
    newValues: metadata.newValues,
  });
}

/**
 * Helper function for logging permission changes
 */
export async function logPermissionChange(
  eventType: SOC2EventType.ROLE_ASSIGNED | SOC2EventType.ROLE_REVOKED | SOC2EventType.PERMISSION_GRANTED | SOC2EventType.PERMISSION_REVOKED,
  adminUserId: string,
  targetUserId: string,
  details: {
    role?: string;
    permission?: string;
    ipAddress: string;
  }
): Promise<void> {
  await createAuditLog({
    eventType,
    severity: AuditSeverity.WARNING, // Permission changes are always notable
    userId: adminUserId,
    action: `${eventType.toLowerCase().replace(/_/g, ' ')} for user ${targetUserId}`,
    outcome: 'success',
    ipAddress: details.ipAddress,
    metadata: {
      targetUserId,
      role: details.role,
      permission: details.permission,
    },
  });
}

/**
 * Helper function for logging security events
 */
export async function logSecurityEvent(
  eventType: SOC2EventType.ACCESS_DENIED | SOC2EventType.SUSPICIOUS_ACTIVITY | SOC2EventType.SECURITY_ALERT,
  details: {
    userId?: string;
    action: string;
    reason: string;
    ipAddress: string;
    severity?: AuditSeverity;
    metadata?: Record<string, any>;
  }
): Promise<void> {
  await createAuditLog({
    eventType,
    severity: details.severity || AuditSeverity.ERROR,
    userId: details.userId,
    action: details.action,
    outcome: 'denied',
    errorMessage: details.reason,
    ipAddress: details.ipAddress,
    metadata: details.metadata,
  });
}

