/**
 * Access control event types for SOC 2 audit
 */
export enum SOC2EventType {
  // User access events
  USER_LOGIN = 'USER_LOGIN',
  USER_LOGOUT = 'USER_LOGOUT',
  LOGIN_FAILED = 'LOGIN_FAILED',
  PASSWORD_CHANGED = 'PASSWORD_CHANGED',
  MFA_ENABLED = 'MFA_ENABLED',
  MFA_DISABLED = 'MFA_DISABLED',

  // Data access events
  DATA_READ = 'DATA_READ',
  DATA_CREATE = 'DATA_CREATE',
  DATA_UPDATE = 'DATA_UPDATE',
  DATA_DELETE = 'DATA_DELETE',
  DATA_EXPORT = 'DATA_EXPORT',

  // Permission changes
  ROLE_ASSIGNED = 'ROLE_ASSIGNED',
  ROLE_REVOKED = 'ROLE_REVOKED',
  PERMISSION_GRANTED = 'PERMISSION_GRANTED',
  PERMISSION_REVOKED = 'PERMISSION_REVOKED',

  // Security events
  ACCESS_DENIED = 'ACCESS_DENIED',
  SUSPICIOUS_ACTIVITY = 'SUSPICIOUS_ACTIVITY',
  SECURITY_ALERT = 'SECURITY_ALERT',

  // System changes
  CONFIG_CHANGED = 'CONFIG_CHANGED',
  SYSTEM_SETTING_CHANGED = 'SYSTEM_SETTING_CHANGED',

  // Administrative actions
  USER_CREATED = 'USER_CREATED',
  USER_DELETED = 'USER_DELETED',
  USER_SUSPENDED = 'USER_SUSPENDED',
  USER_REACTIVATED = 'USER_REACTIVATED',
}

/**
 * Severity levels for audit events
 */
export enum AuditSeverity {
  INFO = 'INFO',
  WARNING = 'WARNING',
  ERROR = 'ERROR',
  CRITICAL = 'CRITICAL',
}

/**
 * SOC 2 audit log entry
 */
export interface SOC2AuditLog {
  id: string;
  timestamp: Date;
  eventType: SOC2EventType;
  severity: AuditSeverity;

  // Actor information
  userId?: string;
  userName?: string;
  userEmail?: string;
  userRole?: string;
  impersonatedBy?: string; // For admin impersonation

  // Resource information
  resourceType?: string;
  resourceId?: string;
  resourceName?: string;

  // Access context
  ipAddress: string;
  userAgent?: string;
  sessionId?: string;
  requestId?: string;

  // Action details
  action: string;
  outcome: 'success' | 'failure' | 'denied';
  errorMessage?: string;

  // Metadata
  metadata?: Record<string, any>;
  changedFields?: string[]; // Fields modified in update operations
  previousValues?: Record<string, any>; // Previous values for audit trail
  newValues?: Record<string, any>; // New values for audit trail
}

/**
 * Creates a SOC 2-compliant audit log entry
 *
 * @param entry - Audit log entry data
 * @returns Formatted audit log
 */
export async function createAuditLog(entry: Omit<SOC2AuditLog, 'id' | 'timestamp'>): Promise<SOC2AuditLog> {
  const auditLog: SOC2AuditLog = {
    id: generateAuditId(),
    timestamp: new Date(),
    ...entry,
  };

  // Store audit log
  await storeAuditLog(auditLog);

  // Trigger alerts for critical events
  if (entry.severity === AuditSeverity.CRITICAL) {
    await alertSecurityTeam(auditLog);
  }

  return auditLog;
}

