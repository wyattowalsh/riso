{% if saas_infra_module == "enabled" and saas_runtime == "nextjs-16" %}
/**
 * Next.js Middleware
 *
 * Runs on every request before the route handler.
 * Used for authentication, tracing, logging, security headers{% if saas_i18n %}, internationalization{% endif %}, and request processing.
 *
 * Learn more: https://nextjs.org/docs/app/building-your-application/routing/middleware
 */

{% if saas_i18n %}
import createMiddleware from 'next-intl/middleware';
import { locales, defaultLocale, localePrefix } from '@/i18n/config';
{% endif %}
{% if saas_auth_provider == 'clerk' %}
import { authMiddleware } from '@clerk/nextjs';
{% elif saas_auth_provider == 'authjs' %}
import { auth } from '@/lib/auth';
{% endif %}
{% if saas_observability_otel or saas_observability_structured_logging %}
import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';
{% endif %}
{% if saas_observability_structured_logging %}
import { logger } from '@/lib/observability/logger';
import { nanoid } from 'nanoid';
{% endif %}
import { withSecurityHeaders } from '@/config/security-headers';

{% if saas_i18n %}
// Create i18n middleware
const intlMiddleware = createMiddleware({
  locales,
  defaultLocale,
  localePrefix,
});
{% endif %}

{% if saas_auth_provider == 'clerk' %}
export default authMiddleware({
  // Public routes that don't require authentication
  publicRoutes: [
    '/',{% if saas_i18n %}
    '/:locale',
    '/:locale/sign-in(.*)',
    '/:locale/sign-up(.*)',{% else %}
    '/sign-in(.*)',
    '/sign-up(.*)',{% endif %}
    '/api/webhooks(.*)',
    '/api/health',
  ],

  // Routes that should be ignored by the middleware
  ignoredRoutes: [
    '/api/health',
  ],

  {% if saas_observability_structured_logging or saas_observability_otel or saas_i18n %}
  // Custom middleware function
  async beforeAuth(req) {
    {% if saas_i18n %}
    // Apply i18n middleware first for locale detection
    const intlResponse = intlMiddleware(req);
    if (intlResponse) return intlResponse;
    {% endif %}

    {% if saas_observability_structured_logging %}
    // Add correlation ID to request
    const correlationId = req.headers.get('x-correlation-id') || nanoid();
    logger.info({
      msg: 'Incoming request',
      method: req.method,
      url: req.url,
      correlationId,
      userAgent: req.headers.get('user-agent'),
    });
    {% endif %}

    {% if saas_observability_otel %}
    // OpenTelemetry tracing happens automatically via instrumentation
    {% endif %}
  },

  async afterAuth(auth, req) {
    {% if saas_observability_structured_logging %}
    if (auth.userId) {
      logger.info({
        msg: 'Authenticated request',
        userId: auth.userId,
        url: req.url,
      });
    }
    {% endif %}

    // Apply security headers to response
    const response = NextResponse.next();
    return withSecurityHeaders(req, response);
  },
  {% endif %}
});

{% elif saas_auth_provider == 'authjs' %}
export default auth((req) => {
  {% if saas_i18n %}
  // Apply i18n middleware first for locale detection
  const intlResponse = intlMiddleware(req);
  if (intlResponse) return intlResponse;
  {% endif %}

  const isAuthenticated = !!req.auth;
  {% if saas_i18n %}
  // Extract locale from pathname
  const pathSegments = req.nextUrl.pathname.split('/').filter(Boolean);
  const locale = locales.includes(pathSegments[0] as any) ? pathSegments[0] : defaultLocale;
  const pathWithoutLocale = '/' + pathSegments.slice(locales.includes(pathSegments[0] as any) ? 1 : 0).join('/');

  const isAuthPage = pathWithoutLocale.startsWith('/sign-in') ||
                      pathWithoutLocale.startsWith('/sign-up');
  const isPublicPage = pathWithoutLocale === '/' ||
                        req.nextUrl.pathname.startsWith('/api/webhooks') ||
                        req.nextUrl.pathname === '/api/health';
  {% else %}
  const isAuthPage = req.nextUrl.pathname.startsWith('/sign-in') ||
                      req.nextUrl.pathname.startsWith('/sign-up');
  const isPublicPage = req.nextUrl.pathname === '/' ||
                        req.nextUrl.pathname.startsWith('/api/webhooks') ||
                        req.nextUrl.pathname === '/api/health';
  {% endif %}

  {% if saas_observability_structured_logging %}
  // Add correlation ID and logging
  const correlationId = req.headers.get('x-correlation-id') || nanoid();
  logger.info({
    msg: 'Incoming request',
    method: req.method,
    url: req.nextUrl.pathname,
    correlationId,
    isAuthenticated,
    userId: req.auth?.user?.id,
  });
  {% endif %}

  // Redirect unauthenticated users to sign-in
  if (!isAuthenticated && !isAuthPage && !isPublicPage) {
    {% if saas_i18n %}
    const signInUrl = new URL(`/${locale}/sign-in`, req.nextUrl.origin);
    {% else %}
    const signInUrl = new URL('/sign-in', req.nextUrl.origin);
    {% endif %}
    signInUrl.searchParams.set('callbackUrl', req.nextUrl.pathname);
    return Response.redirect(signInUrl);
  }

  // Redirect authenticated users away from auth pages
  if (isAuthenticated && isAuthPage) {
    {% if saas_i18n %}
    return Response.redirect(new URL(`/${locale}/dashboard`, req.nextUrl.origin));
    {% else %}
    return Response.redirect(new URL('/dashboard', req.nextUrl.origin));
    {% endif %}
  }

  // Apply security headers to response
  const response = NextResponse.next();
  return withSecurityHeaders(req, response);
});

{% else %}
export function middleware(req: NextRequest) {
  {% if saas_i18n %}
  // Apply i18n middleware first for locale detection
  const intlResponse = intlMiddleware(req);
  if (intlResponse) return intlResponse;
  {% endif %}

  {% if saas_observability_structured_logging %}
  // Add correlation ID and logging
  const correlationId = req.headers.get('x-correlation-id') || nanoid();

  logger.info({
    msg: 'Incoming request',
    method: req.method,
    url: req.nextUrl.pathname,
    correlationId,
    userAgent: req.headers.get('user-agent'),
  });

  // Add correlation ID to response headers and apply security headers
  const response = NextResponse.next();
  response.headers.set('x-correlation-id', correlationId);
  return withSecurityHeaders(req, response);
  {% else %}
  // Apply security headers to response
  const response = NextResponse.next();
  return withSecurityHeaders(req, response);
  {% endif %}
}
{% endif %}

export const config = {
  matcher: [
    {% if saas_i18n %}
    /*
     * Match all request paths except for the ones starting with:
     * - api (API routes, handled separately)
     * - _next/static (static files)
     * - _next/image (image optimization files)
     * - favicon.ico (favicon file)
     * - Files with extensions (images, fonts, etc.)
     */
    '/((?!api|_next/static|_next/image|_vercel|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot|otf)$).*)',
    {% else %}
    /*
     * Match all request paths except for the ones starting with:
     * - _next/static (static files)
     * - _next/image (image optimization files)
     * - favicon.ico (favicon file)
     * - public folder
     */
    '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
    {% endif %}
  ],
};
{% endif %}
