/**
 * Check authentication service status
 */
async function checkAuthService(): Promise<ServiceCheck> {
  {% if saas_auth_provider == 'clerk' %}
  // Clerk is external SaaS
  const apiKey = process.env.CLERK_SECRET_KEY;
  return {
    status: apiKey ? 'external' : 'unknown',
    details: {
      provider: 'Clerk',
      configured: !!apiKey,
    },
  };
  {% elif saas_auth_provider == 'authjs' %}
  // Auth.js is self-hosted, depends on database
  return {
    status: 'external',
    details: {
      provider: 'NextAuth.js',
      selfHosted: true,
    },
  };
  {% else %}
  return {
    status: 'unknown',
    details: { note: 'Auth service not configured' },
  };
  {% endif %}
}

/**
 * Check system memory usage
 */
function checkMemory(): {
  used: number;
  total: number;
  percentage: number;
} {
  const used = process.memoryUsage().heapUsed;
  const total = process.memoryUsage().heapTotal;
  const percentage = used / total;

  return {
    used: Math.round(used / 1024 / 1024), // MB
    total: Math.round(total / 1024 / 1024), // MB
    percentage: Math.round(percentage * 10000) / 100, // %
  };
}

/**
 * Basic liveness probe - just check if the process is running
 */
export async function checkLiveness(): Promise<HealthCheckResponse> {
  const startTime = Date.now();

  return {
    status: 'healthy',
    timestamp: new Date().toISOString(),
    version: process.env.npm_package_version || '0.1.0',
    uptime: process.uptime(),
    latency: Date.now() - startTime,
    checks: {
      process: {
        status: 'up',
        details: { uptime: process.uptime() },
      },
    },
  };
}

/**
 * Readiness probe - check if the app is ready to accept traffic
 * Verifies critical dependencies are available
 */
export async function checkReadiness(): Promise<HealthCheckResponse> {
  const startTime = Date.now();
  const checks: Record<string, ServiceCheck> = {};
  let overallStatus: HealthStatus = 'healthy';

  // Check critical dependencies
  const databaseCheck = await checkDatabase();
  checks.database = databaseCheck;

  if (databaseCheck.status === 'down') {
    overallStatus = 'unhealthy';
  } else if (databaseCheck.status === 'degraded') {
    overallStatus = 'degraded';
  }

  const memory = checkMemory();

  return {
    status: overallStatus,
    timestamp: new Date().toISOString(),
    version: process.env.npm_package_version || '0.1.0',
    uptime: process.uptime(),
    latency: Date.now() - startTime,
    memory,
    checks,
  };
}

/**
 * Comprehensive health check - includes all service checks
 *
 * @param detailed - If true, includes additional diagnostic information
 */
export async function checkHealth(detailed = false): Promise<HealthCheckResponse> {
  const startTime = Date.now();
  const checks: Record<string, ServiceCheck> = {};
  let overallStatus: HealthStatus = 'healthy';

  // Check database (critical)
  const databaseCheck = await checkDatabase();
  checks.database = databaseCheck;

  if (databaseCheck.status === 'down') {
    overallStatus = 'unhealthy';
  } else if (databaseCheck.status === 'degraded' && overallStatus === 'healthy') {
    overallStatus = 'degraded';
  }

  // Check cache if configured
  if (detailed) {
    const cacheCheck = await checkCache();
    checks.cache = cacheCheck;

    if (cacheCheck.status === 'down' && overallStatus === 'healthy') {
      overallStatus = 'degraded';
    }
  }

  // Check external services (detailed only)
  if (detailed) {
    checks.authentication = await checkAuthService();
    checks.billing = await checkBillingService();
    checks.email = await checkEmailService();
  }

  const memory = checkMemory();
  const totalLatency = Date.now() - startTime;

  // Check memory threshold
  if (memory.percentage > CONFIG.MEMORY_USAGE_THRESHOLD) {
    if (overallStatus === 'healthy') {
      overallStatus = 'degraded';
    }
  }

  // Check total latency SLA
  if (totalLatency > CONFIG.TOTAL_LATENCY_THRESHOLD && overallStatus === 'healthy') {
    overallStatus = 'degraded';
  }

  return {
    status: overallStatus,
    timestamp: new Date().toISOString(),
    version: process.env.npm_package_version || '0.1.0',
    uptime: process.uptime(),
    latency: totalLatency,
    memory,
    checks,
  };
}

