/**
 * Health Check Utility Module
 *
 * Provides comprehensive health checking for SaaS application including:
 * - Database connectivity and latency monitoring
 * - Cache/Redis connection status
 * - External service dependencies (billing, email, analytics)
 * - Memory and CPU usage thresholds
 * - Response time SLA compliance
 */

{% if saas_orm == 'prisma' %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == 'drizzle' %}
import { db } from '@/lib/database/client';
{% endif %}

/**
 * Health check status levels
 */
export type HealthStatus = 'healthy' | 'degraded' | 'unhealthy';

/**
 * Individual service check result
 */
export interface ServiceCheck {
  status: 'up' | 'down' | 'degraded' | 'external' | 'unknown';
  latency?: number;
  error?: string;
  details?: Record<string, unknown>;
}

/**
 * Overall health check response
 */
export interface HealthCheckResponse {
  status: HealthStatus;
  timestamp: string;
  version: string;
  uptime?: number;
  latency?: number;
  checks: Record<string, ServiceCheck>;
  memory?: {
    used: number;
    total: number;
    percentage: number;
  };
}

/**
 * Configuration constants
 */
const CONFIG = {
  // SLA thresholds (milliseconds)
  DB_LATENCY_THRESHOLD: 100,
  CACHE_LATENCY_THRESHOLD: 50,
  MEMORY_USAGE_THRESHOLD: 0.9, // 90%
  TOTAL_LATENCY_THRESHOLD: 2000,

  // Timeout for external service pings (milliseconds)
  SERVICE_TIMEOUT: 5000,
  DB_TIMEOUT: 5000,
};

/**
 * Check database connectivity and measure latency
 */
async function checkDatabase(): Promise<ServiceCheck> {
  const startTime = Date.now();

  try {
    const timeoutPromise = new Promise((_, reject) =>
      setTimeout(
        () => reject(new Error('Database query timeout')),
        CONFIG.DB_TIMEOUT
      )
    );

    {% if saas_orm == 'prisma' %}
    const dbPromise = prisma.$queryRaw`SELECT 1`;
    {% elif saas_orm == 'drizzle' %}
    const dbPromise = db.execute('SELECT 1');
    {% endif %}

    await Promise.race([dbPromise, timeoutPromise]);

    const latency = Date.now() - startTime;
    const isDegraded = latency > CONFIG.DB_LATENCY_THRESHOLD;

    return {
      status: isDegraded ? 'degraded' : 'up',
      latency,
      details: {
        threshold: CONFIG.DB_LATENCY_THRESHOLD,
        slaCompliant: !isDegraded,
      },
    };
  } catch (error) {
    return {
      status: 'down',
      latency: Date.now() - startTime,
      error: error instanceof Error ? error.message : 'Database connection failed',
    };
  }
}

/**
 * Check cache/Redis connectivity if available
 */
async function checkCache(): Promise<ServiceCheck> {
  {% if saas_cache == 'redis' or saas_cache == 'upstash' %}
  try {
    const startTime = Date.now();

    // Attempt to check cache connectivity
    // Implementation depends on your cache setup
    {% if saas_rate_limiting == 'upstash' %}
    // For Upstash Redis via @upstash/redis
    // This is a placeholder - actual implementation depends on your setup
    const latency = Date.now() - startTime;
    const isDegraded = latency > CONFIG.CACHE_LATENCY_THRESHOLD;

    return {
      status: isDegraded ? 'degraded' : 'up',
      latency,
      details: {
        threshold: CONFIG.CACHE_LATENCY_THRESHOLD,
        slaCompliant: !isDegraded,
      },
    };
    {% else %}
    // Generic Redis check
    const latency = Date.now() - startTime;
    return {
      status: 'up',
      latency,
    };
    {% endif %}
  } catch (error) {
    return {
      status: 'down',
      error: error instanceof Error ? error.message : 'Cache connection failed',
    };
  }
  {% else %}
  return {
    status: 'unknown',
    details: { note: 'Cache not configured' },
  };
  {% endif %}
}

/**
 * Check external billing service (Stripe, Paddle, etc.)
 */
async function checkBillingService(): Promise<ServiceCheck> {
  {% if saas_billing_provider == 'stripe' or saas_billing_provider == 'paddle' or saas_billing_provider == 'lemonsqueezy' %}
  try {
    const apiKey = process.env.{% if saas_billing_provider == 'stripe' %}STRIPE_SECRET_KEY{% elif saas_billing_provider == 'paddle' %}PADDLE_API_KEY{% else %}LEMON_SQUEEZY_API_KEY{% endif %};

    if (!apiKey) {
      return {
        status: 'unknown',
        details: { note: 'Billing service API key not configured' },
      };
    }

    // External service - we can only verify API key exists
    // Full connectivity check would require actual API call
    return {
      status: 'external',
      details: {
        provider: '{% if saas_billing_provider == 'stripe' %}Stripe{% elif saas_billing_provider == 'paddle' %}Paddle{% else %}Lemon Squeezy{% endif %}',
        configured: true,
      },
    };
  } catch (error) {
    return {
      status: 'unknown',
      error: error instanceof Error ? error.message : 'Failed to check billing service',
    };
  }
  {% else %}
  return {
    status: 'unknown',
    details: { note: 'Billing service not configured' },
  };
  {% endif %}
}

