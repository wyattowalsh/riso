{% if saas_infra_module == "enabled" and saas_admin_dashboard and saas_billing_module == 'enabled' %}
/**
 * Admin Subscriptions Management Page
 *
 * Complete subscription management interface for admins with:
 * - Data table with sorting and filtering
 * - Summary metrics (MRR, active subscriptions, churn)
 * - Subscription lifecycle actions (view, cancel, change plan)
 * - Provider-specific fields and operations
 */

import { Suspense } from 'react';
{% if saas_runtime == 'nextjs-16' %}
import { redirect } from 'next/navigation';
{% endif %}
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/database/client';
import { subscriptions, users } from '@/db/schema';
import { eq, desc } from 'drizzle-orm';
{% endif %}
import { requireUserId, requireAdminRole } from '@/lib/auth/helpers';
{% if saas_ui_framework == 'shadcn-ui' %}
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@/components/ui/table';
import { Badge } from '@/components/ui/badge';
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu';
{% endif %}
import { PageHeader } from '@/components/layouts/dashboard';
import { DashboardLayout } from '@/components/layouts/dashboard';
import SubscriptionsClient from './client';

// ============================================================================
// Type Definitions
// ============================================================================

interface SubscriptionRow {
  id: string;
  customerId: string;
  customerName: string;
  customerEmail: string;
  planId: string;
  planName: string;
  status: 'active' | 'canceled' | 'past_due' | 'paused';
  amount: number;
  currency: string;
  startDate: Date;
  nextBillingDate: Date | null;
  canceledAt: Date | null;
  {% if saas_billing_provider == 'stripe' %}
  stripeSubscriptionId?: string;
  stripeCustomerId?: string;
  {% endif %}
  {% if saas_billing_provider == 'paddle' %}
  paddleSubscriptionId?: string;
  paddleCustomerId?: string;
  {% endif %}
  {% if saas_billing_provider == 'lemonsqueezy' %}
  lemonSqueezySubscriptionId?: string;
  lemonSqueezyCustomerId?: string;
  {% endif %}
  metadata?: Record<string, any>;
}

interface MetricsData {
  totalMRR: number;
  activeSubscriptions: number;
  churnedThisMonth: number;
  averageSubscriptionValue: number;
}

// ============================================================================
// Server Component - Fetch Data
// ============================================================================

async function SubscriptionsContent() {
  // Authentication and authorization
  const userId = await requireUserId();
  const isAdmin = await requireAdminRole();

  if (!isAdmin) {
    redirect('/unauthorized');
  }

  // Fetch subscriptions
  {% if saas_orm == "prisma" %}
  const subscriptionData = await prisma.subscription.findMany({
    include: {
      user: {
        select: {
          id: true,
          email: true,
          name: true,
        },
      },
      plan: {
        select: {
          id: true,
          name: true,
          amount: true,
          currency: true,
        },
      },
    },
    orderBy: {
      createdAt: 'desc',
    },
  });

  // Fetch plans for filter options
  const plans = await prisma.plan.findMany({
    select: {
      id: true,
      name: true,
    },
  });
  {% elif saas_orm == "drizzle" %}
  // Using Drizzle ORM with subscriptions table
  const subscriptionData = await db
    .select()
    .from(subscriptions)
    .orderBy(desc(subscriptions.createdAt));

  // Fetch plans for filter options
  const plans = await db
    .selectDistinct({
      id: subscriptions.planId,
      name: subscriptions.planName,
    })
    .from(subscriptions);
  {% endif %}

  // Format subscription data
  const formattedSubscriptions: SubscriptionRow[] = subscriptionData.map((sub) => ({
    id: sub.id,
    customerId: sub.userId,
    customerName: sub.user?.name || 'Unknown',
    customerEmail: sub.user?.email || '',
    planId: sub.plan?.id || sub.planId,
    planName: sub.plan?.name || sub.planName || 'Unknown',
    status: sub.status as 'active' | 'canceled' | 'past_due' | 'paused',
    amount: sub.plan?.amount || sub.amount,
    currency: sub.plan?.currency || sub.currency || 'USD',
    startDate: sub.startDate,
    nextBillingDate: sub.nextBillingDate,
    canceledAt: sub.canceledAt,
    {% if saas_billing_provider == 'stripe' %}
    stripeSubscriptionId: sub.stripeSubscriptionId,
    stripeCustomerId: sub.stripeCustomerId,
    {% endif %}
    {% if saas_billing_provider == 'paddle' %}
    paddleSubscriptionId: sub.paddleSubscriptionId,
    paddleCustomerId: sub.paddleCustomerId,
    {% endif %}
    {% if saas_billing_provider == 'lemonsqueezy' %}
    lemonSqueezySubscriptionId: sub.lemonSqueezySubscriptionId,
    lemonSqueezyCustomerId: sub.lemonSqueezyCustomerId,
    {% endif %}
    metadata: sub.metadata,
  }));

  // Calculate metrics
  const now = new Date();
  const monthAgo = new Date(now.getFullYear(), now.getMonth() - 1, now.getDate());

  const metrics: MetricsData = {
    totalMRR: formattedSubscriptions
      .filter((s) => s.status === 'active')
      .reduce((sum, s) => sum + s.amount, 0),
    activeSubscriptions: formattedSubscriptions.filter(
      (s) => s.status === 'active'
    ).length,
    churnedThisMonth: formattedSubscriptions.filter(
      (s) => s.status === 'canceled' && s.canceledAt && s.canceledAt >= monthAgo
    ).length,
    averageSubscriptionValue:
      formattedSubscriptions.filter((s) => s.status === 'active').length > 0
        ? formattedSubscriptions
            .filter((s) => s.status === 'active')
            .reduce((sum, s) => sum + s.amount, 0) /
          formattedSubscriptions.filter((s) => s.status === 'active').length
        : 0,
  };

  return (
    <DashboardLayout>
      <div className="space-y-8">
        {/* Page Header */}
        <PageHeader
          title="Subscriptions"
          description="Manage customer subscriptions, plans, and billing status"
        />

        {/* Summary Cards */}
        <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Total MRR</CardTitle>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                className="h-4 w-4 text-muted-foreground"
              >
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">
                ${(metrics.totalMRR / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
              </div>
              <p className="text-xs text-muted-foreground">
                Monthly Recurring Revenue
              </p>
            </CardContent>
          </Card>

          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Active Subscriptions</CardTitle>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                className="h-4 w-4 text-muted-foreground"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M22 16c0 .5-.37 1-.5 1.5M22 16h-2.5M22 16c0 -.5.37-1 .5-1.5" />
              </svg>
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">{metrics.activeSubscriptions}</div>
              <p className="text-xs text-muted-foreground">
                Active subscriptions
              </p>
            </CardContent>
          </Card>

          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Churned This Month</CardTitle>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                className="h-4 w-4 text-muted-foreground"
              >
                <polyline points="23 6 13.5 15.5 8 10 1 17" />
                <polyline points="17 6 23 6 23 12" />
              </svg>
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">{metrics.churnedThisMonth}</div>
              <p className="text-xs text-muted-foreground">
                Canceled in the last 30 days
              </p>
            </CardContent>
          </Card>

          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Avg Subscription Value</CardTitle>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                className="h-4 w-4 text-muted-foreground"
              >
                <line x1="12" y1="2" x2="12" y2="22" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">
                ${(metrics.averageSubscriptionValue / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
              </div>
              <p className="text-xs text-muted-foreground">
                Per active subscription
              </p>
            </CardContent>
          </Card>
        </div>

        {/* Subscriptions Table */}
        <Card>
          <CardHeader>
            <CardTitle>All Subscriptions</CardTitle>
            <CardDescription>
              Manage and monitor all customer subscriptions
            </CardDescription>
          </CardHeader>
          <CardContent>
            <Suspense fallback={<div>Loading subscriptions...</div>}>
              <SubscriptionsClient
                subscriptions={formattedSubscriptions}
                plans={plans}
              />
            </Suspense>
          </CardContent>
        </Card>
      </div>
    </DashboardLayout>
  );
}

// ============================================================================
// Page Component
// ============================================================================

export const metadata = {
  title: 'Subscriptions | Admin',
  description: 'Manage customer subscriptions and billing',
};

export default function SubscriptionsPage() {
  return (
    <Suspense fallback={<div>Loading...</div>}>
      <SubscriptionsContent />
    </Suspense>
  );
}
{% endif %}
