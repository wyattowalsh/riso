{% if saas_infra_module == "enabled" and saas_admin_dashboard and saas_runtime == "nextjs-16" %}
import type { Metadata } from 'next';
import Link from 'next/link';
import { requireUserId } from '@/lib/auth/helpers';
{% if saas_orm == "prisma" %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == "drizzle" %}
import { db } from '@/lib/database/client';
import { users, subscriptions } from '@/db/schema';
import { count, sql } from 'drizzle-orm';
{% endif %}
{% if saas_observability_structured_logging %}
import { logger } from '@/lib/observability/logger';
{% endif %}
import { PageHeader } from '@/components/layouts/dashboard';

export const metadata: Metadata = {
  title: 'Admin Dashboard | {{ project_name }}',
  description: 'Admin dashboard for {{ project_name }}',
};

// ============================================================================
// Types
// ============================================================================

interface DashboardStats {
  totalUsers: number;
  activeSubscriptions: number;
  mrr: number;
  recentSignups: {
    id: string;
    email: string;
    name: string | null;
    createdAt: Date;
  }[];
}

// ============================================================================
// Stats Fetching
// ============================================================================

async function getDashboardStats(): Promise<DashboardStats> {
  {% if saas_observability_structured_logging %}
  logger.info('Fetching admin dashboard stats');
  {% endif %}

  try {
    {% if saas_orm == "prisma" %}
    // Fetch total users
    const totalUsers = await prisma.user.count();

    // Fetch active subscriptions
    {% if saas_billing_module == 'enabled' %}
    const activeSubscriptions = await prisma.subscription.count({
      where: {
        status: {
          in: ['active', 'trialing'],
        },
      },
    });

    // Fetch MRR (Monthly Recurring Revenue)
    const subscriptionData = await prisma.subscription.findMany({
      where: {
        status: {
          in: ['active', 'trialing'],
        },
      },
      select: {
        monthlyAmount: true,
      },
    });

    const mrr = subscriptionData.reduce((sum, sub) => sum + (sub.monthlyAmount || 0), 0);
    {% else %}
    const activeSubscriptions = 0;
    const mrr = 0;
    {% endif %}

    // Fetch recent signups (last 5 users)
    const recentSignups = await prisma.user.findMany({
      take: 5,
      orderBy: { createdAt: 'desc' },
      select: {
        id: true,
        email: true,
        name: true,
        createdAt: true,
      },
    });

    {% elif saas_orm == "drizzle" %}
    // Fetch total users
    const [{ userCount }] = await db
      .select({ userCount: count() })
      .from(users);

    const totalUsers = userCount || 0;

    // Fetch active subscriptions and MRR
    {% if saas_billing_module == 'enabled' %}
    const [subscriptionStats] = await db
      .select({
        activeCount: count(),
        totalMrr: sql<number>`coalesce(sum(monthly_amount), 0)`,
      })
      .from(subscriptions)
      .where(
        sql`status in ('active', 'trialing')`
      );

    const activeSubscriptions = subscriptionStats.activeCount || 0;
    const mrr = subscriptionStats.totalMrr || 0;
    {% else %}
    const activeSubscriptions = 0;
    const mrr = 0;
    {% endif %}

    // Fetch recent signups (last 5 users)
    const recentSignups = await db
      .select({
        id: users.id,
        email: users.email,
        name: users.name,
        createdAt: users.createdAt,
      })
      .from(users)
      .orderBy(sql`created_at desc`)
      .limit(5);

    {% endif %}

    {% if saas_observability_structured_logging %}
    logger.info({
      totalUsers,
      activeSubscriptions,
      mrr,
      recentCount: recentSignups.length,
    }, 'Dashboard stats fetched successfully');
    {% endif %}

    return {
      totalUsers,
      activeSubscriptions,
      mrr,
      recentSignups,
    };
  } catch (error) {
    {% if saas_observability_structured_logging %}
    logger.error({ error }, 'Failed to fetch dashboard stats');
    {% endif %}
    throw error;
  }
}

// ============================================================================
// Stat Card Component
// ============================================================================

interface StatCardProps {
  title: string;
  value: string | number;
  description?: string;
  icon?: React.ReactNode;
}

function StatCard({ title, value, description, icon }: StatCardProps) {
  return (
    <div className="rounded-lg border bg-white p-6 shadow-sm">
      <div className="flex items-center justify-between">
        <div className="flex-1">
          <p className="text-sm font-medium text-gray-600">{title}</p>
          <p className="mt-2 text-3xl font-bold text-gray-900">{value}</p>
          {description && (
            <p className="mt-1 text-xs text-gray-500">{description}</p>
          )}
        </div>
        {icon && (
          <div className="text-gray-400 ml-4">
            {icon}
          </div>
        )}
      </div>
    </div>
  );
}

// ============================================================================
// Quick Links Component
// ============================================================================

interface QuickLink {
  title: string;
  description: string;
  href: string;
  icon: React.ReactNode;
}

function QuickLinksCard({ links }: { links: QuickLink[] }) {
  return (
    <div className="rounded-lg border bg-white p-6 shadow-sm">
      <h3 className="font-semibold text-gray-900 mb-4">Quick Links</h3>
      <div className="space-y-3">
        {links.map((link) => (
          <Link
            key={link.href}
            href={link.href}
            className="flex items-center gap-3 rounded-md p-3 hover:bg-gray-50 transition-colors"
          >
            <div className="text-gray-400">{link.icon}</div>
            <div className="flex-1 min-w-0">
              <p className="text-sm font-medium text-gray-900">{link.title}</p>
              <p className="text-xs text-gray-600 truncate">{link.description}</p>
            </div>
            <svg
              className="h-4 w-4 text-gray-400 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
            </svg>
          </Link>
        ))}
      </div>
    </div>
  );
}

// ============================================================================
// Recent Signups Component
// ============================================================================

interface RecentSignupsProps {
  signups: DashboardStats['recentSignups'];
}

function RecentSignupsCard({ signups }: RecentSignupsProps) {
  return (
    <div className="rounded-lg border bg-white p-6 shadow-sm">
      <div className="flex items-center justify-between mb-4">
        <h3 className="font-semibold text-gray-900">Recent Sign-ups</h3>
        <Link
          href="/admin/users"
          className="text-sm text-blue-600 hover:text-blue-700"
        >
          View all
        </Link>
      </div>

      {signups.length === 0 ? (
        <p className="text-sm text-gray-500 py-8 text-center">No recent sign-ups</p>
      ) : (
        <div className="divide-y">
          {signups.map((signup) => (
            <div key={signup.id} className="flex items-center justify-between py-3 first:pt-0 last:pb-0">
              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium text-gray-900 truncate">
                  {signup.name || signup.email}
                </p>
                <p className="text-xs text-gray-600 truncate">{signup.email}</p>
              </div>
              <div className="text-xs text-gray-500 ml-4 whitespace-nowrap">
                {new Date(signup.createdAt).toLocaleDateString()}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

