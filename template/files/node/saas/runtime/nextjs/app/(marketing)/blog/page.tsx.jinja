{% if saas_infra_module == "enabled" and saas_blog and saas_runtime == "nextjs-16" %}
import type { Metadata } from 'next';
import { getAllPosts, getAllTags } from '@/lib/blog';
import { PostCard } from '@/components/blog/post-card';

const baseUrl = process.env.NEXT_PUBLIC_APP_URL ?? 'http://localhost:3000';

export const metadata: Metadata = {
  title: 'Blog | {{ project_name }}',
  description: 'Latest news, tutorials, and updates from {{ project_name }}',
  alternates: {
    canonical: `${baseUrl}/blog`,
    types: {
      'application/rss+xml': `${baseUrl}/api/blog/rss`,
    },
  },
  openGraph: {
    title: '{{ project_name }} Blog',
    description: 'Latest news, tutorials, and updates from {{ project_name }}',
    url: `${baseUrl}/blog`,
    siteName: '{{ project_name }}',
    type: 'website',
    locale: 'en_US',
  },
  twitter: {
    card: 'summary_large_image',
    title: '{{ project_name }} Blog',
    description: 'Latest news, tutorials, and updates from {{ project_name }}',
  },
};

export default function BlogPage() {
  const posts = getAllPosts();
  const tags = getAllTags();

  return (
    <div className="container mx-auto px-4 py-12">
      <div className="max-w-4xl mx-auto">
        <header className="mb-12">
          <h1 className="text-4xl font-bold tracking-tight mb-4">Blog</h1>
          <p className="text-lg text-muted-foreground">
            Latest news, tutorials, and updates from the {{ project_name }} team.
          </p>
        </header>

        {tags.length > 0 && (
          <div className="flex flex-wrap gap-2 mb-8">
            {tags.map((tag) => (
              <span
                key={tag}
                className="px-3 py-1 text-sm rounded-full bg-muted"
              >
                {tag}
              </span>
            ))}
          </div>
        )}

        <div className="grid gap-6">
          {posts.map((post) => (
            <PostCard key={post.slug} post={post} />
          ))}
        </div>

        {posts.length === 0 && (
          <div className="text-center py-12">
            <p className="text-muted-foreground">
              No blog posts yet. Check back soon!
            </p>
          </div>
        )}
      </div>
    </div>
  );
}
{% endif %}
