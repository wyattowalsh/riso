{% if saas_infra_module == "enabled" and saas_runtime == "nextjs-16" %}
import { NextResponse, type NextRequest } from 'next/server';
{% if saas_orm == 'prisma' %}
import { prisma } from '@/lib/database/client';
{% elif saas_orm == 'drizzle' %}
import { db } from '@/lib/database/client';
{% endif %}
import { checkHealth, checkReadiness, checkLiveness, type HealthCheckResponse } from '@/lib/health';

export const dynamic = 'force-dynamic';

/**
 * Health Check Endpoint - Basic health status
 *
 * GET /api/health - Basic health check (cached for 30s)
 * GET /api/health/detailed - Comprehensive service checks (uncached)
 * GET /api/health/ready - Readiness probe (dependency checks)
 * GET /api/health/live - Liveness probe (process alive check)
 *
 * Returns the health status of the application and its dependencies.
 * Used for monitoring, load balancers, and deployment verification.
 */
export async function GET(request: NextRequest) {
  const pathname = request.nextUrl.pathname;

  try {
    if (pathname.endsWith('/detailed')) {
      const health = await checkHealth(true);
      const statusCode = health.status === 'healthy' ? 200 : health.status === 'degraded' ? 503 : 503;
      return NextResponse.json(health, { status: statusCode });
    }

    if (pathname.endsWith('/ready')) {
      const health = await checkReadiness();
      const statusCode = health.status === 'healthy' ? 200 : 503;
      return NextResponse.json(health, { status: statusCode });
    }

    if (pathname.endsWith('/live')) {
      const health = await checkLiveness();
      return NextResponse.json(health, { status: 200 });
    }

    // Default: basic health check (default endpoint)
    const health = await checkHealth(false);
    const statusCode = health.status === 'healthy' ? 200 : health.status === 'degraded' ? 503 : 503;
    return NextResponse.json(health, { status: statusCode });
  } catch (error) {
    const errorHealth: HealthCheckResponse = {
      status: 'unhealthy',
      timestamp: new Date().toISOString(),
      version: process.env.npm_package_version || '0.1.0',
      checks: {
        internal: {
          status: 'unhealthy',
          error: error instanceof Error ? error.message : 'Unknown error',
        },
      },
    };
    return NextResponse.json(errorHealth, { status: 503 });
  }
}
{% endif %}
