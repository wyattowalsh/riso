/**
 * Example 7: Custom metrics export
 *
 * Usage:
 * ```typescript
 * import { collectHealthMetrics } from './middleware.example';
 *
 * const metrics = await collectHealthMetrics();
 * // Send to your metrics backend (Prometheus, CloudWatch, etc)
 * ```
 */
export async function collectHealthMetrics(): Promise<{
  timestamp: number;
  uptime: number;
  memory: { used: number; total: number; percentage: number };
  database: { latency: number; healthy: boolean };
  services: Record<string, string>;
}> {
  const health = await checkHealth(true);

  return {
    timestamp: Date.now(),
    uptime: health.uptime || 0,
    memory: health.memory || { used: 0, total: 0, percentage: 0 },
    database: {
      latency: health.checks.database?.latency || 0,
      healthy: health.checks.database?.status === 'up',
    },
    services: Object.fromEntries(Object.entries(health.checks).map(([k, v]) => [k, v.status])),
  };
}

/**
 * Example 8: Kubernetes probe handler
 *
 * For use in Kubernetes health check configuration
 */
export function kubernetesProbeHandler(probeType: 'liveness' | 'readiness' | 'startup') {
  switch (probeType) {
    case 'liveness':
      return {
        url: '/api/health/live',
        initialDelaySeconds: 10,
        periodSeconds: 10,
      };
    case 'readiness':
      return {
        url: '/api/health/ready',
        initialDelaySeconds: 5,
        periodSeconds: 5,
      };
    case 'startup':
      return {
        url: '/api/health',
        initialDelaySeconds: 0,
        periodSeconds: 1,
        failureThreshold: 30, // 30 seconds to start
      };
  }
}

