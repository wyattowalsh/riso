/**
 * Example: Health Check Monitoring Middleware
 *
 * This file demonstrates how to integrate health checking into your application.
 * Copy and adapt as needed for your monitoring setup.
 */

import { NextResponse, type NextRequest } from 'next/server';
import { healthCheckCache, healthCheckHistory, formatHealthLog, generateHealthReport } from '@/lib/health-utils';
import { checkHealth } from '@/lib/health';

/**
 * Example 1: Logging middleware that tracks health checks
 *
 * Add to your middleware.ts:
 * ```typescript
 * export const config = {
 *   matcher: ['/api/health/:path*'],
 * };
 *
 * export async function middleware(request: NextRequest) {
 *   const health = await checkHealth();
 *   console.log(formatHealthLog(health));
 *   return NextResponse.next();
 * }
 * ```
 */
export async function healthLoggingMiddleware(request: NextRequest): Promise<NextResponse> {
  const startTime = Date.now();

  // Execute the actual health check
  const health = await checkHealth();

  // Log the result
  const duration = Date.now() - startTime;
  console.log(`[HEALTH] ${formatHealthLog(health)} (${duration}ms)`);

  return NextResponse.next();
}

/**
 * Example 2: Circuit breaker pattern using health checks
 *
 * Usage in your route handlers:
 * ```typescript
 * if (await isCircuitOpen()) {
 *   return new Response('Service unavailable', { status: 503 });
 * }
 * ```
 */
const circuitBreakerState = {
  isOpen: false,
  openedAt: 0,
  resetTimeout: 60000, // 1 minute
};

export async function isCircuitOpen(): Promise<boolean> {
  const health = await checkHealth(true);

  if (health.status === 'unhealthy') {
    circuitBreakerState.isOpen = true;
    circuitBreakerState.openedAt = Date.now();
  } else if (
    circuitBreakerState.isOpen &&
    Date.now() - circuitBreakerState.openedAt > circuitBreakerState.resetTimeout
  ) {
    // Reset circuit if health has recovered
    circuitBreakerState.isOpen = false;
  }

  return circuitBreakerState.isOpen;
}

/**
 * Example 3: Health-based request prioritization
 *
 * Lower priority for degraded systems
 */
export function getRequestPriority(health: Awaited<ReturnType<typeof checkHealth>>): 'high' | 'normal' | 'low' {
  if (health.status === 'healthy') return 'high';
  if (health.status === 'degraded') return 'normal';
  return 'low';
}

/**
 * Example 4: Dashboard data endpoint
 *
 * Add route handler at /api/monitoring/dashboard:
 * ```typescript
 * import { generateHealthReport } from '@/lib/health-utils';
 *
 * export async function GET() {
