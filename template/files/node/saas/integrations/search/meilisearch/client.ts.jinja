// ============================================================================
// Task Management
// ============================================================================

/**
 * Wait for a task to complete
 *
 * @example
 * ```ts
 * const task = await addDocuments('products', documents);
 * await waitForTask(task.taskUid);
 * console.log('Documents indexed!');
 * ```
 */
export async function waitForTask(
  taskUid: number,
  options?: {
    timeOutMs?: number;
    intervalMs?: number;
  }
): Promise<Task> {
  return await meilisearch.waitForTask(taskUid, {
    timeOutMs: options?.timeOutMs ?? 60000, // 60 seconds default
    intervalMs: options?.intervalMs ?? 50,
  });
}

/**
 * Get task by UID
 */
export async function getTask(taskUid: number): Promise<Task> {
  return await meilisearch.getTask(taskUid);
}

/**
 * Get all tasks
 */
export async function getTasks(options?: {
  limit?: number;
  from?: number;
  status?: string[];
}): Promise<{ results: Task[]; limit: number; from: number; next: number | null }> {
  return await meilisearch.getTasks({
    limit: options?.limit,
    from: options?.from,
    statuses: options?.status,
  });
}

