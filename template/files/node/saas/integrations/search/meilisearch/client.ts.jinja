/**
 * Check if Meilisearch is healthy
 */
export async function healthCheck(): Promise<{ status: 'available' | 'unavailable' }> {
  try {
    const health = await meilisearch.health();
    return { status: health.status };
  } catch (error) {
    return { status: 'unavailable' };
  }
}

/**
 * Get Meilisearch version
 */
export async function getVersion(): Promise<{ commitSha: string; commitDate: string; pkgVersion: string }> {
  return await meilisearch.getVersion();
}

// ============================================================================
// Error Handling
// ============================================================================

/**
 * Handle Meilisearch errors
 */
export function handleMeilisearchError(error: any): never {
  {% if saas_observability_structured_logging %}
  logger.error({
    msg: 'Meilisearch error',
    error: error.message,
    code: error.code,
    type: error.type,
  });
  {% endif %}

  throw new MeilisearchError(
    error.message || 'Meilisearch operation failed',
    error.code,
    error.type,
    error.link
  );
}

// ============================================================================
// Utility Functions
// ============================================================================

/**
 * Generate filters from object
 *
 * @example
 * ```ts
 * const filter = generateFilters({
 *   category: 'electronics',
 *   'price<': 1000,
 *   inStock: true,
 * });
 * // Returns: "category = 'electronics' AND price < 1000 AND inStock = true"
 * ```
 */
export function generateFilters(filters: Record<string, any>): string {
  return Object.entries(filters)
    .map(([key, value]) => {
      // Handle operators in key (e.g., 'price<')
      const match = key.match(/^([a-zA-Z_][a-zA-Z0-9_]*)([<>=!]+)?$/);
      if (!match) return null;

      const [, field, operator = '='] = match;

      if (typeof value === 'string') {
        return `${field} ${operator} "${value}"`;
      }
      return `${field} ${operator} ${value}`;
    })
    .filter(Boolean)
    .join(' AND ');
}

/**
 * Build sort array from object
 *
 * @example
 * ```ts
 * const sort = buildSort({ price: 'asc', rating: 'desc' });
 * // Returns: ['price:asc', 'rating:desc']
 * ```
 */
export function buildSort(sort: Record<string, 'asc' | 'desc'>): string[] {
  return Object.entries(sort).map(([field, order]) => `${field}:${order}`);
}

