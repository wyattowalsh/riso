/**
 * Meilisearch Client
 *
 * Modern search patterns:
 * - Lightning-fast search (<50ms typical)
 * - Typo tolerance
 * - Faceted search
 * - Geo search
 * - Multi-tenancy
 * - Real-time indexing
 *
 * @see https://www.meilisearch.com/docs
 */

import { MeiliSearch, Index } from 'meilisearch';
{% if saas_observability_structured_logging %}
import { logger } from '@/lib/observability/logger';
{% endif %}
import type {
  SearchParams,
  SearchResult,
  IndexConfig,
  Task,
  IndexStats,
  MultiSearchQuery,
  MultiSearchResult,
  MeilisearchError,
} from './types';

// ============================================================================
// Client Initialization
// ============================================================================

/**
 * Meilisearch client singleton
 * Initialized with environment variables
 */
export const meilisearch = new MeiliSearch({
  host: process.env.NEXT_PUBLIC_MEILISEARCH_URL || 'http://127.0.0.1:7700',
  apiKey: process.env.MEILISEARCH_API_KEY,
  requestConfig: {
    headers: {
      'Content-Type': 'application/json',
    },
  },
});

/**
 * Get index by name
 * Creates index if it doesn't exist
 */
export async function getIndex<T = Record<string, any>>(
  indexName: string,
  primaryKey?: string
): Promise<Index<T>> {
  try {
    const index = meilisearch.index<T>(indexName);
    await index.fetchInfo();
    return index;
  } catch (error: any) {
    if (error.code === 'index_not_found') {
      {% if saas_observability_structured_logging %}
      logger.info({
        msg: 'Creating new Meilisearch index',
        indexName,
        primaryKey,
      });
      {% endif %}
      const task = await meilisearch.createIndex(indexName, { primaryKey });
      await meilisearch.waitForTask(task.taskUid);
      return meilisearch.index<T>(indexName);
    }
    throw error;
  }
}

// ============================================================================
// Search Operations
// ============================================================================

/**
 * Search documents in an index
 *
 * @example
 * ```ts
 * const results = await search('products', 'laptop', {
 *   filter: 'price < 1000 AND category = "electronics"',
 *   limit: 20,
 *   attributesToHighlight: ['title', 'description'],
 *   sort: ['price:asc'],
 * });
 * ```
 */
export async function search<T = Record<string, any>>(
  indexName: string,
  query: string,
  params?: SearchParams
): Promise<SearchResult<T>> {
  const index = await getIndex<T>(indexName);

  {% if saas_observability_structured_logging %}
  const startTime = Date.now();
  {% endif %}

  const result = await index.search(query, {
    filter: params?.filter,
    attributesToSearchOn: params?.attributesToSearchOn,
    attributesToRetrieve: params?.attributesToRetrieve,
    attributesToHighlight: params?.attributesToHighlight,
    attributesToCrop: params?.attributesToCrop,
    cropLength: params?.cropLength ?? 200,
    cropMarker: params?.cropMarker ?? '...',
    highlightPreTag: params?.highlightPreTag ?? '<mark>',
    highlightPostTag: params?.highlightPostTag ?? '</mark>',
    facets: params?.facets,
    offset: params?.offset ?? 0,
    limit: params?.limit ?? 20,
    sort: params?.sort,
    showMatchesPosition: params?.showMatchesPosition ?? false,
    matchingStrategy: params?.matchingStrategy,
  });

  {% if saas_observability_structured_logging %}
  logger.debug({
    msg: 'Search executed',
    indexName,
    query,
    hits: result.hits.length,
    totalHits: result.estimatedTotalHits,
    durationMs: Date.now() - startTime,
  });
  {% endif %}

  return result as SearchResult<T>;
}

/**
 * Multi-index search
 * Search across multiple indexes simultaneously
 *
 * @example
 * ```ts
 * const results = await multiSearch([
 *   { indexUid: 'products', params: { query: 'laptop' } },
 *   { indexUid: 'articles', params: { query: 'laptop', limit: 5 } },
 * ]);
 * ```
 */
export async function multiSearch<T = Record<string, any>>(
  queries: MultiSearchQuery[]
): Promise<MultiSearchResult<T>> {
  const results = await meilisearch.multiSearch({
    queries: queries.map((q) => ({
      indexUid: q.indexUid,
      q: q.params.query,
      ...q.params,
    })),
  });

  return results as MultiSearchResult<T>;
}

/**
 * Search with autocomplete/instant results
 * Optimized for quick responses
 */
export async function instantSearch<T = Record<string, any>>(
  indexName: string,
  query: string,
  limit: number = 10
): Promise<SearchResult<T>> {
  return search<T>(indexName, query, {
    limit,
    attributesToHighlight: ['*'],
    attributesToCrop: ['*'],
    cropLength: 100,
  });
}

// ============================================================================
// Document Management
// ============================================================================

/**
 * Add or replace documents
 *
 * @example
 * ```ts
 * await addDocuments('products', [
 *   { id: '1', title: 'Laptop', price: 999 },
 *   { id: '2', title: 'Mouse', price: 29 },
 * ]);
 * ```
 */
export async function addDocuments<T = Record<string, any>>(
  indexName: string,
  documents: T[],
  primaryKey?: string
): Promise<Task> {
  const index = await getIndex<T>(indexName, primaryKey);
  const task = await index.addDocuments(documents, { primaryKey });

  {% if saas_observability_structured_logging %}
  logger.info({
    msg: 'Documents added to index',
    indexName,
    documentCount: documents.length,
    taskUid: task.taskUid,
  });
  {% endif %}

  return task;
}

/**
 * Update documents
 * Merges with existing documents
 */
export async function updateDocuments<T = Record<string, any>>(
  indexName: string,
  documents: Partial<T>[],
  primaryKey?: string
): Promise<Task> {
  const index = await getIndex<T>(indexName, primaryKey);
  const task = await index.updateDocuments(documents, { primaryKey });

  {% if saas_observability_structured_logging %}
  logger.info({
    msg: 'Documents updated in index',
    indexName,
    documentCount: documents.length,
    taskUid: task.taskUid,
  });
  {% endif %}

  return task;
}

/**
 * Get document by ID
 */
export async function getDocument<T = Record<string, any>>(
  indexName: string,
  documentId: string
): Promise<T> {
  const index = await getIndex<T>(indexName);
  return await index.getDocument(documentId);
}

/**
 * Get multiple documents
 */
export async function getDocuments<T = Record<string, any>>(
  indexName: string,
  options?: {
    offset?: number;
    limit?: number;
    fields?: string[];
  }
): Promise<{ results: T[]; offset: number; limit: number; total: number }> {
  const index = await getIndex<T>(indexName);
  return await index.getDocuments({
    offset: options?.offset,
    limit: options?.limit,
    fields: options?.fields,
  });
}

/**
 * Delete document by ID
 */
export async function deleteDocument(
  indexName: string,
  documentId: string
): Promise<Task> {
  const index = await getIndex(indexName);
  const task = await index.deleteDocument(documentId);

  {% if saas_observability_structured_logging %}
  logger.info({
    msg: 'Document deleted from index',
    indexName,
    documentId,
    taskUid: task.taskUid,
  });
  {% endif %}

  return task;
}

/**
 * Delete multiple documents by IDs
 */
export async function deleteDocuments(
  indexName: string,
  documentIds: string[]
): Promise<Task> {
  const index = await getIndex(indexName);
  const task = await index.deleteDocuments(documentIds);

  {% if saas_observability_structured_logging %}
  logger.info({
    msg: 'Documents deleted from index',
    indexName,
    documentCount: documentIds.length,
    taskUid: task.taskUid,
  });
  {% endif %}

  return task;
}

/**
 * Delete documents by filter
 *
 * @example
 * ```ts
 * await deleteDocumentsByFilter('products', 'category = "outdated"');
 * ```
 */
export async function deleteDocumentsByFilter(
  indexName: string,
  filter: string
): Promise<Task> {
  const index = await getIndex(indexName);
  const task = await index.deleteDocuments({ filter });

  {% if saas_observability_structured_logging %}
  logger.info({
    msg: 'Documents deleted by filter',
    indexName,
    filter,
    taskUid: task.taskUid,
  });
  {% endif %}

  return task;
}

/**
 * Delete all documents in an index
 */
export async function deleteAllDocuments(indexName: string): Promise<Task> {
  const index = await getIndex(indexName);
  const task = await index.deleteAllDocuments();

  {% if saas_observability_structured_logging %}
  logger.warn({
    msg: 'All documents deleted from index',
