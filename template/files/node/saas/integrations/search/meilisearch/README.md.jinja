## API Routes

Create an API route to handle search requests:

```typescript
// app/api/search/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { search } from '@/integrations/search/meilisearch';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { indexName, query, ...params } = body;

    if (!indexName || !query) {
      return NextResponse.json(
        { error: 'Missing required fields' },
        { status: 400 }
      );
    }

    const results = await search(indexName, query, params);

    return NextResponse.json(results);
  } catch (error: any) {
    return NextResponse.json(
      { error: error.message },
      { status: 500 }
    );
  }
}
```

## Document Management

### Adding Documents

```typescript
import { addDocuments, waitForTask } from '@/integrations/search/meilisearch';

// Add new documents
const task = await addDocuments('products', newProducts);
await waitForTask(task.taskUid);
```

### Updating Documents

```typescript
import { updateDocuments, waitForTask } from '@/integrations/search/meilisearch';

// Update existing documents (partial updates)
const task = await updateDocuments('products', [
  { id: '1', price: 899 },
  { id: '2', inStock: false },
]);
await waitForTask(task.taskUid);
```

### Deleting Documents

```typescript
import { deleteDocument, deleteDocuments, deleteDocumentsByFilter } from '@/integrations/search/meilisearch';

// Delete single document
await deleteDocument('products', '1');

// Delete multiple documents
await deleteDocuments('products', ['1', '2', '3']);

// Delete by filter
await deleteDocumentsByFilter('products', 'category = "outdated"');
```

## Filtering

Meilisearch supports powerful filter expressions:

```typescript
// Equality
filter: 'category = "electronics"'

// Comparison
filter: 'price < 1000'
filter: 'rating >= 4.5'

// Multiple conditions (AND)
filter: 'category = "electronics" AND price < 1000 AND inStock = true'

// Multiple conditions (OR)
filter: 'category = "electronics" OR category = "computers"'

// Complex expressions
filter: '(category = "electronics" OR category = "computers") AND price < 1000'

// Arrays (IN)
filter: 'tags IN ["featured", "new-arrival"]'

// Date ranges
filter: 'createdAt > 1640995200 AND createdAt < 1672531199'
```

You can also use the helper function:

```typescript
import { generateFilters } from '@/integrations/search/meilisearch';

const filter = generateFilters({
  category: 'electronics',
  'price<': 1000,
  inStock: true,
});
// Returns: "category = 'electronics' AND price < 1000 AND inStock = true"
```

