# Meilisearch Integration

Lightning-fast, typo-tolerant search integration for {{ project_name }}.

## Overview

This integration provides a complete Meilisearch implementation with:

- **Lightning Fast**: Sub-50ms search response times
- **Typo Tolerance**: Automatic spelling correction
- **Faceted Search**: Filter by categories, tags, and custom attributes
- **Highlighting**: Search term highlighting in results
- **React Hooks**: Ready-to-use hooks for client-side search
- **Type Safety**: Full TypeScript support
- **Real-time Indexing**: Instant document updates
- **Multi-Index Search**: Search across multiple indexes simultaneously

## Installation

1. Install Meilisearch server:

```bash
# Docker (recommended)
docker run -d \
  --name meilisearch \
  -p 7700:7700 \
  -e MEILI_MASTER_KEY="your-master-key" \
  -v $(pwd)/meili_data:/meili_data \
  getmeili/meilisearch:latest

# Or via Homebrew (macOS)
brew install meilisearch
brew services start meilisearch

# Or download binary
curl -L https://install.meilisearch.com | sh
./meilisearch --master-key="your-master-key"
```

2. Add environment variables:

```env
# .env.local
NEXT_PUBLIC_MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_API_KEY=your-master-key
```

3. Install the Meilisearch client:

```bash
pnpm add meilisearch
```

## Quick Start

### 1. Index Your Data

```typescript
import { addDocuments, configureIndex } from '@/integrations/search/meilisearch';

// Define your document structure
interface Product {
  id: string;
  title: string;
  description: string;
  category: string;
  price: number;
  inStock: boolean;
  tags: string[];
}

// Configure the index
await configureIndex('products', {
  searchableAttributes: ['title', 'description', 'tags'],
  filterableAttributes: ['category', 'price', 'inStock'],
  sortableAttributes: ['price', 'createdAt'],
  rankingRules: [
    'words',
    'typo',
    'proximity',
    'attribute',
    'sort',
    'exactness',
  ],
});

// Add documents
const products: Product[] = [
  {
    id: '1',
    title: 'Wireless Laptop',
    description: 'High-performance laptop for developers',
    category: 'electronics',
    price: 999,
    inStock: true,
    tags: ['laptop', 'computer', 'tech'],
  },
  // ... more products
];

const task = await addDocuments('products', products);
await waitForTask(task.taskUid);
```

### 2. Search (Server-Side)

```typescript
import { search } from '@/integrations/search/meilisearch';

// Basic search
const results = await search('products', 'laptop');

// Advanced search with filters and sorting
const results = await search('products', 'laptop', {
  filter: 'price < 1000 AND inStock = true',
  sort: ['price:asc'],
  limit: 20,
  attributesToHighlight: ['title', 'description'],
});

console.log(`Found ${results.estimatedTotalHits} results`);
results.hits.forEach((product) => {
  console.log(product._formatted?.title); // Highlighted title
});
```

### 3. Search (Client-Side with React)

```tsx
'use client';

import { useSearch } from '@/integrations/search/meilisearch';

export function ProductSearch() {
  const {
    results,
    isLoading,
    error,
    totalHits,
    search,
  } = useSearch({
    indexName: 'products',
    debounceMs: 300,
    filter: 'inStock = true',
    limit: 20,
    attributesToHighlight: ['title', 'description'],
  });

  return (
    <div>
      <input
        type="search"
        onChange={(e) => search(e.target.value)}
        placeholder="Search products..."
        className="w-full px-4 py-2 border rounded-lg"
      />

      {isLoading && (
        <div className="mt-4">Loading...</div>
      )}

      {error && (
        <div className="mt-4 text-red-600">
          Error: {error.message}
        </div>
      )}

      {!isLoading && results.length > 0 && (
        <div className="mt-4">
          <p className="text-gray-600">
            Found {totalHits} results
          </p>
          <div className="grid gap-4 mt-4">
            {results.map((product) => (
              <div key={product.id} className="p-4 border rounded-lg">
                <h3
                  dangerouslySetInnerHTML={{ '{{' }}
                    __html: product._formatted?.title || product.title,
                  {{ '}}' }}
                />
                <p
                  className="text-gray-600"
                  dangerouslySetInnerHTML={{ '{{' }}
                    __html: product._formatted?.description || product.description,
                  {{ '}}' }}
                />
                <p className="text-lg font-bold mt-2">
                  ${product.price}
                </p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}
```

## Advanced Usage

### Faceted Search

```tsx
import { useFacets } from '@/integrations/search/meilisearch';

export function FacetedProductSearch() {
  const {
    results,
    facets,
    selectedFacets,
    toggleFacet,
    clearFacets,
    isLoading,
  } = useFacets({
    indexName: 'products',
    query: 'laptop',
    facetAttributes: ['category', 'brand', 'price_range'],
  });

  return (
    <div className="flex gap-6">
      {/* Sidebar with facets */}
      <aside className="w-64">
        <h3>Filters</h3>
        {Object.entries(facets).map(([facetName, values]) => (
          <div key={facetName} className="mt-4">
            <h4 className="font-semibold capitalize">{facetName}</h4>
            <ul className="mt-2 space-y-2">
              {Object.entries(values).map(([value, count]) => (
                <li key={value}>
                  <label className="flex items-center gap-2">
                    <input
                      type="checkbox"
                      checked={selectedFacets[facetName]?.includes(value)}
                      onChange={() => toggleFacet(facetName, value)}
                    />
                    <span>{value}</span>
                    <span className="text-gray-500">({count})</span>
                  </label>
                </li>
              ))}
            </ul>
          </div>
        ))}
        <button
          onClick={clearFacets}
          className="mt-4 text-sm text-blue-600"
        >
          Clear all filters
        </button>
      </aside>

      {/* Results */}
      <main className="flex-1">
        {isLoading ? (
          <div>Loading...</div>
        ) : (
          <div className="grid gap-4">
            {results.map((product) => (
              <ProductCard key={product.id} product={product} />
            ))}
          </div>
        )}
      </main>
    </div>
  );
}
```

