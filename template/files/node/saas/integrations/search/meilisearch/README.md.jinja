if (health.status === 'unavailable') {
  console.error('Meilisearch is not available');
}
```

### Task Status

```typescript
import { getTask } from '@/integrations/search/meilisearch';

const task = await getTask(taskUid);
console.log(`Task status: ${task.status}`);
if (task.error) {
  console.error(`Task error: ${task.error.message}`);
}
```

### Index Stats

```typescript
import { getIndexStats } from '@/integrations/search/meilisearch';

const stats = await getIndexStats('products');
console.log(`Documents: ${stats.numberOfDocuments}`);
console.log(`Is indexing: ${stats.isIndexing}`);
```

