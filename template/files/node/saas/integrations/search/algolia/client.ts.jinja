// ============================================================================
// Error Handling
// ============================================================================

export class AlgoliaError extends Error {
  constructor(
    message: string,
    public code?: string,
    public statusCode?: number
  ) {
    super(message);
    this.name = 'AlgoliaError';
  }
}

/**
 * Handle Algolia API errors
 */
export function handleAlgoliaError(error: unknown): never {
  if (error instanceof Error) {
    throw new AlgoliaError(error.message);
  }

  throw error;
}

