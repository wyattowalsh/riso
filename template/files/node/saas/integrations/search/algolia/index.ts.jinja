/**
 * Algolia Search Integration
 *
 * Modern search solution for 2025
 *
 * @example
 * ```ts
 * // Client-side search
 * import { useInstantSearch } from '@/integrations/search/algolia';
 *
 * function ProductSearch() {
 *   const { query, setQuery, hits, isSearching } = useInstantSearch({
 *     indexName: 'products',
 *   });
 *
 *   return (
 *     <div>
 *       <input value={query} onChange={(e) => setQuery(e.target.value)} />
 *       {hits.map((hit) => (
 *         <div key={hit.objectID}>{hit.name}</div>
 *       ))}
 *     </div>
 *   );
 * }
 * ```
 *
 * @example
 * ```ts
 * // Server-side indexing
 * import { saveObject, saveObjects } from '@/integrations/search/algolia';
 *
 * // Index single object
 * await saveObject({
 *   indexName: 'products',
 *   object: {
 *     objectID: 'prod_123',
 *     name: 'MacBook Pro',
 *     price: 2499,
 *   },
 * });
 *
 * // Batch index multiple objects
 * await saveObjects({
 *   indexName: 'products',
 *   objects: products,
 * });
 * ```
 */

