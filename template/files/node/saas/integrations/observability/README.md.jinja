# Observability Module

Comprehensive observability solution for {{ project_name }} with logging, tracing, metrics, error tracking, and performance monitoring.

## Features

{% if saas_observability_structured_logging %}
- **Structured Logging**: JSON logging with pino, correlation IDs, and automatic context enrichment
{% endif %}
{% if saas_observability_otel %}
- **Distributed Tracing**: OpenTelemetry instrumentation for end-to-end request tracing
- **Custom Metrics**: Business metrics (signups, payments, API usage) and performance metrics
{% endif %}
{% if saas_observability_sentry %}
- **Error Tracking**: Sentry integration with breadcrumbs, user context, and source maps
{% endif %}
- **Performance Monitoring**: Core Web Vitals (LCP, FID, CLS) and custom performance measurements
- **Request Correlation**: Track requests across services with correlation IDs

## Quick Start

### 1. Installation

```bash
npm install --save \
{% if saas_observability_structured_logging %}
  pino pino-pretty \
{% endif %}
{% if saas_observability_otel %}
  @opentelemetry/api \
  @opentelemetry/sdk-node \
  @opentelemetry/auto-instrumentations-node \
  @opentelemetry/exporter-trace-otlp-http \
  @opentelemetry/exporter-metrics-otlp-http \
  @opentelemetry/sdk-metrics \
  @opentelemetry/resources \
  @opentelemetry/semantic-conventions \
{% endif %}
{% if saas_observability_sentry %}
  @sentry/nextjs \
{% endif %}
  web-vitals
```

### 2. Environment Variables

Create a `.env.local` file:

```bash
# Logging
LOG_LEVEL=info  # debug, info, warn, error

{% if saas_observability_otel %}
# OpenTelemetry
OTEL_SERVICE_NAME={{ project_slug }}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATE=1.0
OTEL_METRIC_EXPORT_INTERVAL=60000
{% endif %}

{% if saas_observability_sentry %}
# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_REPLAYS_ERROR_SAMPLE_RATE=1.0
{% endif %}
```

### 3. Initialize Observability

Create `instrumentation.ts` in your project root:

```typescript
// instrumentation.ts
export async function register() {
  if (process.env.NEXT_RUNTIME === 'nodejs') {
    {% if saas_observability_otel %}
    // Initialize OpenTelemetry first (auto-instrumentation)
    const { initializeTracing } = await import('./lib/observability/tracing');
    const { initializeMetrics } = await import('./lib/observability/metrics');

    initializeTracing();
    initializeMetrics();
    {% endif %}

    {% if saas_observability_sentry %}
    // Initialize Sentry
    const { initializeSentry } = await import('./lib/observability/error-tracking');
    initializeSentry();
    {% endif %}
  }

  {% if saas_observability_sentry %}
  if (process.env.NEXT_RUNTIME === 'edge') {
    // Edge runtime Sentry initialization
    const { initializeSentry } = await import('./lib/observability/error-tracking');
    initializeSentry();
  }
  {% endif %}
}
```

Enable instrumentation in `next.config.js`:

```javascript
/** @type {import('next').NextConfig} */
const nextConfig = {
  experimental: {
    instrumentationHook: true,
  },
  // ... other config
};

module.exports = nextConfig;
```

### 4. Track Web Vitals (Client-Side)

In your root layout (`app/layout.tsx`):

```typescript
'use client';

import { useEffect } from 'react';
import { trackWebVitals } from '@/lib/observability';

export default function RootLayout({ children }: { children: React.ReactNode }) {
  useEffect(() => {
    trackWebVitals((metric) => {
      // Automatically sent to configured observability platforms
      console.log(metric);
    });
  }, []);

  return (
    <html lang="en">
      <body>{children}</body>
    </html>
  );
}
```

## Usage Examples

{% if saas_observability_structured_logging %}
### Logging

```typescript
import { logger, createLogger, logError } from '@/lib/observability';

// Basic logging
logger.info('User logged in');
logger.warn({ msg: 'Rate limit approaching', remaining: 5 });

// Child logger with context
const paymentLogger = createLogger({ module: 'billing' });
paymentLogger.info({ msg: 'Processing payment', amount: 9.99 });

// Error logging
try {
  await processPayment(data);
} catch (error) {
  logError('Payment failed', error, { userId: user.id });
}

// Performance timing
import { startTimer } from '@/lib/observability';

const timer = startTimer('database-query');
const users = await db.users.findMany();
timer.done({ rowCount: users.length });
```
{% endif %}

{% if saas_observability_otel %}
### Tracing

```typescript
import { withSpan, createSpan, traceHandler } from '@/lib/observability/tracing';

// Automatic API route tracing
export const GET = traceHandler('GET /api/users', async (request) => {
  const users = await db.users.findMany();
  return Response.json(users);
});

// Manual span creation
const result = await withSpan('process-checkout', async (span) => {
  span.setAttributes({
    'checkout.items': cartItems.length,
    'checkout.total': total,
  });

  return await processCheckout(cart);
});

// Database tracing
import { traceDatabase } from '@/lib/observability/tracing';

const users = await traceDatabase(
  'users.findMany',
  { operation: 'SELECT', table: 'users' },
  () => db.users.findMany()
);

// External API tracing
import { traceExternalApi } from '@/lib/observability/tracing';

const intent = await traceExternalApi(
  'stripe.createPaymentIntent',
  {
    service: 'stripe',
    operation: 'POST /v1/payment_intents',
  },
  () => stripe.paymentIntents.create({ amount: 9900, currency: 'usd' })
);
```

