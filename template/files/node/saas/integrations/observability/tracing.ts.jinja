{% if saas_infra_module == "enabled" and saas_observability_otel %}
/**
 * OpenTelemetry Tracing
 *
 * Distributed tracing with OpenTelemetry SDK.
 * Features:
 * - Automatic HTTP/fetch instrumentation
 * - Custom span creation
 * - Trace context propagation
 * - Integration with {% if saas_observability_sentry %}Sentry and {% endif %}logging
 *
 * @see https://opentelemetry.io
 */

import { trace, context, SpanStatusCode, type Span } from '@opentelemetry/api';
import { NodeSDK } from '@opentelemetry/sdk-node';
import { getNodeAutoInstrumentations } from '@opentelemetry/auto-instrumentations-node';
import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';
import { Resource } from '@opentelemetry/resources';
import {
  ATTR_SERVICE_NAME,
  ATTR_SERVICE_VERSION,
  ATTR_DEPLOYMENT_ENVIRONMENT,
} from '@opentelemetry/semantic-conventions';
import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';
{% if saas_observability_structured_logging %}
import { logger } from './logger';
{% endif %}
import type { SpanAttributes, SpanOptions } from './types';

// ============================================================================
// Configuration
// ============================================================================

const isDev = process.env.NODE_ENV !== 'production';

const OTEL_CONFIG = {
  serviceName: process.env.OTEL_SERVICE_NAME || '{{ project_slug }}',
  serviceVersion: process.env.npm_package_version || '1.0.0',
  environment: process.env.NODE_ENV || 'development',
  endpoint: process.env.OTEL_EXPORTER_OTLP_ENDPOINT || 'http://localhost:4318/v1/traces',
  sampleRate: parseFloat(process.env.OTEL_SAMPLE_RATE || '1.0'),
} as const;

// ============================================================================
// SDK Initialization
// ============================================================================

let sdk: NodeSDK | null = null;

/**
 * Initialize OpenTelemetry instrumentation
 *
 * Call this once at application startup, before any other imports.
 *
 * @example
 * ```ts
 * // instrumentation.ts
 * import { initializeTracing } from './observability/tracing';
 * initializeTracing();
 * ```
 */
export function initializeTracing(): void {
  if (sdk) {
    {% if saas_observability_structured_logging %}
    logger.warn('OpenTelemetry already initialized');
    {% endif %}
    return;
  }

  try {
    const resource = new Resource({
      [ATTR_SERVICE_NAME]: OTEL_CONFIG.serviceName,
      [ATTR_SERVICE_VERSION]: OTEL_CONFIG.serviceVersion,
      [ATTR_DEPLOYMENT_ENVIRONMENT]: OTEL_CONFIG.environment,
      {% if saas_hosting == 'vercel' %}
      'vercel.region': process.env.VERCEL_REGION,
      'vercel.deployment_id': process.env.VERCEL_DEPLOYMENT_ID,
      {% elif saas_hosting == 'cloudflare' %}
      'cloudflare.datacenter': process.env.CF_RAY?.split('-')[1],
      {% endif %}
    });

    const traceExporter = new OTLPTraceExporter({
      url: OTEL_CONFIG.endpoint,
      headers: {},
    });

    sdk = new NodeSDK({
      resource,
      spanProcessors: [new BatchSpanProcessor(traceExporter)],
      instrumentations: [
        getNodeAutoInstrumentations({
          // Fine-tune auto-instrumentation
          '@opentelemetry/instrumentation-fs': {
            enabled: false, // Usually too noisy
          },
          '@opentelemetry/instrumentation-http': {
            enabled: true,
            ignoreIncomingRequestHook: (req) => {
              // Don't trace health checks
              const url = req.url || '';
              return url.includes('/health') || url.includes('/_next/static');
            },
          },
          '@opentelemetry/instrumentation-fetch': {
            enabled: true,
          },
          {% if saas_database == 'postgres' %}
          '@opentelemetry/instrumentation-pg': {
            enabled: true,
          },
          {% endif %}
        }),
      ],
      // Sample rate for tracing (1.0 = 100%)
      // In production, consider lower values to reduce overhead
      // spanLimits: {
      //   attributeValueLengthLimit: 4096,
      // },
    });

    sdk.start();

    {% if saas_observability_structured_logging %}
    logger.info({
      msg: 'OpenTelemetry initialized',
      service: OTEL_CONFIG.serviceName,
      version: OTEL_CONFIG.serviceVersion,
      endpoint: OTEL_CONFIG.endpoint,
    });
    {% endif %}

    // Graceful shutdown
    process.on('SIGTERM', async () => {
      try {
        await sdk?.shutdown();
        {% if saas_observability_structured_logging %}
        logger.info('OpenTelemetry shut down successfully');
        {% endif %}
      } catch (error) {
        {% if saas_observability_structured_logging %}
        logger.error({ msg: 'Error shutting down OpenTelemetry', error });
        {% endif %}
      }
    });
  } catch (error) {
    {% if saas_observability_structured_logging %}
    logger.error({ msg: 'Failed to initialize OpenTelemetry', error });
    {% endif %}
  }
}

// ============================================================================
// Tracer Instance
// ============================================================================

const tracer = trace.getTracer(
  OTEL_CONFIG.serviceName,
  OTEL_CONFIG.serviceVersion
);

// ============================================================================
// Span Management
// ============================================================================

/**
 * Get the currently active span
 */
export function getActiveSpan(): Span | undefined {
  return trace.getActiveSpan();
}

/**
 * Create a new span
 *
 * @example
 * ```ts
 * const span = createSpan('database-query', {
 *   attributes: {
 *     'db.operation': 'SELECT',
 *     'db.table': 'users',
 *   },
 * });
 *
 * try {
 *   const result = await db.query('SELECT * FROM users');
 *   span.setStatus({ code: SpanStatusCode.OK });
 *   return result;
 * } catch (error) {
 *   recordException(span, error);
 *   throw error;
 * } finally {
 *   span.end();
 * }
 * ```
 */
export function createSpan(name: string, options?: SpanOptions): Span {
  return tracer.startSpan(name, {
    attributes: options?.attributes,
    kind: options?.kind,
    links: options?.links,
  });
}

/**
 * Execute a function within a new span context
 *
 * The span is automatically ended when the function completes.
 * Errors are automatically recorded and re-thrown.
 *
 * @example
 * ```ts
 * const result = await withSpan('process-payment', async (span) => {
 *   span.setAttributes({
 *     'payment.amount': 9.99,
 *     'payment.currency': 'USD',
 *   });
 *
 *   return await processPayment(paymentData);
 * });
 * ```
 */
export async function withSpan<T>(
  name: string,
  fn: (span: Span) => Promise<T>,
  options?: SpanOptions
): Promise<T> {
  const span = createSpan(name, options);

  try {
    const result = await context.with(trace.setSpan(context.active(), span), () =>
      fn(span)
    );
    span.setStatus({ code: SpanStatusCode.OK });
    return result;
  } catch (error) {
    recordException(span, error);
    span.setStatus({
      code: SpanStatusCode.ERROR,
      message: error instanceof Error ? error.message : 'Unknown error',
    });
    throw error;
  } finally {
    span.end();
  }
}

/**
 * Set attributes on the active span
 */
export function setTraceAttributes(attributes: SpanAttributes): void {
  const span = getActiveSpan();
  if (span) {
    span.setAttributes(attributes);
  }
}

/**
 * Record an exception on a span
 */
export function recordException(span: Span, error: Error | unknown): void {
  if (error instanceof Error) {
    span.recordException(error);
    span.setStatus({
      code: SpanStatusCode.ERROR,
      message: error.message,
    });
  } else {
    span.recordException(new Error(String(error)));
    span.setStatus({
      code: SpanStatusCode.ERROR,
      message: String(error),
    });
  }
}

// ============================================================================
// Higher-Order Tracing Utilities
// ============================================================================

/**
 * Trace an HTTP request handler
 *
 * @example
 * ```ts
 * export const GET = traceHandler('GET /api/users', async (request) => {
 *   const users = await db.users.findMany();
 *   return Response.json(users);
 * });
 * ```
 */
export function traceHandler<T extends (...args: any[]) => Promise<Response>>(
  name: string,
  handler: T
): T {
  return (async (...args: any[]) => {
    return withSpan(name, async (span) => {
      const request = args[0] as Request;

      // Add request attributes
      span.setAttributes({
        'http.method': request.method,
        'http.url': request.url,
        'http.route': name,
      });

      const response = await handler(...args);

      // Add response attributes
      span.setAttributes({
        'http.status_code': response.status,
      });

      return response;
    });
  }) as T;
}

/**
 * Trace a database operation
 *
 * @example
 * ```ts
 * const users = await traceDatabase('users.findMany', {
 *   operation: 'SELECT',
 *   table: 'users',
 * }, async () => {
 *   return db.users.findMany();
 * });
 * ```
 */
export async function traceDatabase<T>(
  name: string,
  attributes: {
    operation: string;
    table: string;
    query?: string;
  },
  fn: () => Promise<T>
): Promise<T> {
  return withSpan(
    `db.${attributes.table}.${attributes.operation.toLowerCase()}`,
    async (span) => {
      span.setAttributes({
        'db.system': '{{ saas_database }}',
        'db.operation': attributes.operation,
        'db.table': attributes.table,
        ...(attributes.query && { 'db.statement': attributes.query }),
      });

      const result = await fn();

      // Add result metadata if available
      if (Array.isArray(result)) {
        span.setAttribute('db.result.count', result.length);
      }

      return result;
    },
    { kind: 'client' }
  );
}

/**
 * Trace an external API call
 *
 * @example
 * ```ts
 * const data = await traceExternalApi('stripe.createPaymentIntent', {
 *   service: 'stripe',
 *   operation: 'POST /v1/payment_intents',
 * }, async () => {
 *   return stripe.paymentIntents.create({ amount: 9900, currency: 'usd' });
 * });
 * ```
 */
export async function traceExternalApi<T>(
  name: string,
  attributes: {
    service: string;
    operation: string;
    url?: string;
  },
  fn: () => Promise<T>
): Promise<T> {
  return withSpan(
    `external.${attributes.service}`,
    async (span) => {
      span.setAttributes({
        'peer.service': attributes.service,
        'http.operation': attributes.operation,
        ...(attributes.url && { 'http.url': attributes.url }),
      });

      return await fn();
    },
    { kind: 'client' }
  );
}

// ============================================================================
// Context Propagation
// ============================================================================

/**
 * Extract trace context from HTTP headers
 *
 * Use this for distributed tracing across services.
 */
export function extractTraceContext(headers: Headers): void {
  // OpenTelemetry automatically handles W3C Trace Context headers
  // This is provided for custom implementations if needed
  const traceparent = headers.get('traceparent');
  if (traceparent) {
    // W3C Trace Context format: version-traceid-spanid-flags
    {% if saas_observability_structured_logging %}
    logger.debug({ msg: 'Extracted trace context', traceparent });
    {% endif %}
  }
}

/**
 * Inject trace context into HTTP headers
 *
 * Use this when making outbound HTTP requests to propagate trace context.
 */
export function injectTraceContext(headers: Headers): Headers {
  const span = getActiveSpan();
  if (span) {
    const spanContext = span.spanContext();
    const traceparent = `00-${spanContext.traceId}-${spanContext.spanId}-${spanContext.traceFlags.toString(16).padStart(2, '0')}`;
    headers.set('traceparent', traceparent);
  }
  return headers;
}

// ============================================================================
// Type Exports
// ============================================================================

export type { Span, SpanAttributes, SpanOptions };
{% endif %}
