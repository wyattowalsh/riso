/**
 * Record feature usage
 *
 * @example
 * ```ts
 * recordFeatureUsage('dashboard', 'export-data', 'user123');
 * ```
 */
export function recordFeatureUsage(
  feature: string,
  action: string,
  userId: string
): void {
  recordCounter('feature.usage', 1, {
    feature,
    action,
  });
}

// ============================================================================
// System Metrics
// ============================================================================

/**
 * Record system resource usage
 * Call this periodically (e.g., every minute) to track resource consumption
 */
export function recordSystemMetrics(): void {
  if (typeof process !== 'undefined' && process.memoryUsage) {
    const memory = process.memoryUsage();

    recordGauge('system.memory.heap.used', memory.heapUsed);
    recordGauge('system.memory.heap.total', memory.heapTotal);
    recordGauge('system.memory.rss', memory.rss);
    recordGauge('system.memory.external', memory.external);
  }

  if (typeof process !== 'undefined' && process.cpuUsage) {
    const cpu = process.cpuUsage();
    recordGauge('system.cpu.user', cpu.user);
    recordGauge('system.cpu.system', cpu.system);
  }
}

// ============================================================================
// Type Exports
// ============================================================================

export type { MetricAttributes, MetricOptions };
