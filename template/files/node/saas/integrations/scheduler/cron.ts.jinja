{% elif saas_jobs == 'inngest' %}
import { Inngest } from 'inngest';
{% if saas_observability_structured_logging %}
import { logger } from '@/lib/observability/logger';
{% endif %}

// ============================================================================
// Scheduled Tasks with Inngest
// ============================================================================

export const inngest = new Inngest({ id: '{{ project_slug }}' });

/**
 * Daily subscription check - runs at midnight UTC
 */
export const dailySubscriptionCheck = inngest.createFunction(
  { id: 'daily-subscription-check' },
  { cron: '0 0 * * *' },
  async ({ step }) => {
    {% if saas_observability_structured_logging %}
    logger.info({ msg: 'Running daily subscription check' });
    {% endif %}
    
    const results = await step.run('check-subscriptions', async () => {
      {% if saas_orm == 'prisma' %}
      const { prisma } = await import('@/lib/database/client');
      
      const trialEndingSoon = await prisma.subscription.findMany({
        where: {
          status: 'trialing',
          trialEndsAt: {
            gte: new Date(),
            lte: new Date(Date.now() + 3 * 24 * 60 * 60 * 1000),
          },
        },
        include: { user: true },
      });
      
      return { trialsEndingSoon: trialEndingSoon.length };
      {% elif saas_orm == 'drizzle' %}
      return { trialsEndingSoon: 0 };
      {% endif %}
    });
    
    // Send notifications for trials ending soon
    {% if saas_email != 'none' %}
    if (results.trialsEndingSoon > 0) {
      await step.run('send-trial-reminders', async () => {
        // Send reminder emails
      });
    }
    {% endif %}
    
    return results;
  }
);

