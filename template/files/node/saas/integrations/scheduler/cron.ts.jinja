/**
 * Hourly cleanup - runs every hour
 * Cleans up expired sessions, old logs, etc.
 */
export const hourlyCleanup = schedules.task({
  id: 'hourly-cleanup',
  cron: '0 * * * *', // Every hour
  run: async () => {
    {% if saas_orm == 'prisma' %}
    const { prisma } = await import('@/lib/database/client');
    
    // Delete expired password reset tokens
    const deletedTokens = await prisma.passwordResetToken?.deleteMany({
      where: {
        expiresAt: { lt: new Date() },
      },
    });
    
    // Delete old audit logs (older than 90 days)
    const deletedLogs = await prisma.auditLog?.deleteMany({
      where: {
        createdAt: { lt: new Date(Date.now() - 90 * 24 * 60 * 60 * 1000) },
      },
    });
    {% endif %}
    
    return { 
      deletedTokens: deletedTokens?.count || 0,
      deletedLogs: deletedLogs?.count || 0,
    };
  },
});

