/**
 * Hourly cleanup
 */
export const hourlyCleanup = inngest.createFunction(
  { id: 'hourly-cleanup' },
  { cron: '0 * * * *' },
  async ({ step }) => {
    const results = await step.run('cleanup', async () => {
      {% if saas_orm == 'prisma' %}
