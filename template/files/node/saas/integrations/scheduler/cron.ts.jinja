      const deletedTokens = await prisma.passwordResetToken?.deleteMany({
        where: { expiresAt: { lt: new Date() } },
      });
      
      return { deletedTokens: deletedTokens?.count || 0 };
      {% else %}
      return { deletedTokens: 0 };
      {% endif %}
    });
    
    return results;
  }
);

