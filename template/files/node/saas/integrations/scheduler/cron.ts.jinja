/**
 * Daily subscription check - runs at midnight UTC
 * Checks for expiring trials and failed payments
 */
export const dailySubscriptionCheck = schedules.task({
  id: 'daily-subscription-check',
  cron: '0 0 * * *', // Every day at midnight UTC
  run: async () => {
    {% if saas_observability_structured_logging %}
    logger.info({ msg: 'Running daily subscription check' });
    {% endif %}
    
    {% if saas_orm == 'prisma' %}
    const { prisma } = await import('@/lib/database/client');
    
    // Find trials ending in 3 days
    const trialEndingSoon = await prisma.subscription.findMany({
      where: {
        status: 'trialing',
        trialEndsAt: {
          gte: new Date(),
          lte: new Date(Date.now() + 3 * 24 * 60 * 60 * 1000),
        },
      },
      include: { user: true },
    });
    
    // Find past due subscriptions
    const pastDue = await prisma.subscription.findMany({
      where: {
        status: 'past_due',
        updatedAt: {
          lte: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000), // 7 days old
        },
      },
      include: { user: true },
    });
    {% elif saas_orm == 'drizzle' %}
    const { db } = await import('@/lib/database/client');
    const { subscriptions, users } = await import('@/db/schema');
    const { eq, and, gte, lte } = await import('drizzle-orm');
    
    const trialEndingSoon = await db.select()
      .from(subscriptions)
      .innerJoin(users, eq(subscriptions.userId, users.id))
      .where(
        and(
          eq(subscriptions.status, 'trialing'),
          gte(subscriptions.trialEndsAt, new Date()),
          lte(subscriptions.trialEndsAt, new Date(Date.now() + 3 * 24 * 60 * 60 * 1000))
        )
      );
    {% endif %}
    
    {% if saas_observability_structured_logging %}
    logger.info({ 
      msg: 'Subscription check complete',
      trialsEndingSoon: trialEndingSoon?.length || 0,
    });
    {% endif %}
    
    return {
      trialsEndingSoon: trialEndingSoon?.length || 0,
    };
  },
});

