{% if saas_infra_module == "enabled" and saas_tenancy_model == 'b2b-teams' %}
import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Link,
  Preview,
  Section,
  Text,
} from '@react-email/components';

const baseUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000';
const appName = '{{ project_name }}';

const styles = {
  main: {
    backgroundColor: '#f6f9fc',
    fontFamily: '-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Ubuntu,sans-serif',
  },
  container: {
    backgroundColor: '#ffffff',
    margin: '0 auto',
    padding: '20px 0 48px',
    marginBottom: '64px',
  },
  heading: {
    fontSize: '32px',
    lineHeight: '1.3',
    fontWeight: '700',
    color: '#484848',
  },
  paragraph: {
    fontSize: '16px',
    lineHeight: '26px',
    color: '#484848',
  },
  button: {
    backgroundColor: '#5469d4',
    borderRadius: '4px',
    color: '#fff',
    fontSize: '16px',
    textDecoration: 'none',
    textAlign: 'center' as const,
    display: 'block',
    padding: '12px 24px',
  },
  hr: {
    borderColor: '#e6ebf1',
    margin: '20px 0',
  },
  footer: {
    color: '#8898aa',
    fontSize: '12px',
    lineHeight: '16px',
  },
  highlight: {
    backgroundColor: '#f0f4ff',
    padding: '16px',
    borderRadius: '4px',
    borderLeft: '4px solid #5469d4',
    marginTop: '16px',
    marginBottom: '16px',
  },
};

export interface TeamInviteEmailProps {
  inviteeEmail: string;
  inviterName: string;
  teamName: string;
  inviteLink: string;
  expiresIn?: string;
}

export function TeamInviteEmail({
  inviteeEmail,
  inviterName,
  teamName,
  inviteLink,
  expiresIn = '7 days',
}: TeamInviteEmailProps) {
  return (
    <Html>
      <Head />
      <Preview>{`${inviterName} invited you to join ${teamName} on ${appName}`}</Preview>
      <Body style={styles.main}>
        <Container style={styles.container}>
          <Heading style={styles.heading}>You're invited!</Heading>

          <Text style={styles.paragraph}>
            <strong>{inviterName}</strong> has invited you to join the{' '}
            <strong>{teamName}</strong> team on <strong>{appName}</strong>.
          </Text>

          <Section style={styles.highlight}>
            <Text style={% raw %}{{ margin: '0', fontSize: '14px', color: '#5469d4', fontWeight: '600' }}{% endraw %}>
              INVITATION DETAILS
            </Text>
            <Text style={% raw %}{{ margin: '12px 0 0 0', fontSize: '15px', color: '#484848' }}{% endraw %}>
              Team: <strong>{teamName}</strong>
              <br />
              Invited by: <strong>{inviterName}</strong>
              <br />
              Expires in: <strong>{expiresIn}</strong>
            </Text>
          </Section>

          <Text style={styles.paragraph}>
            Click the button below to accept the invitation and start collaborating
            with your team.
          </Text>

          <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
            <Button style={styles.button} href={inviteLink}>
              Accept Invitation
            </Button>
          </Section>

          <Text style={% raw %}{{ ...styles.paragraph, fontSize: '14px', color: '#8898aa' }}{% endraw %}>
            This invitation will expire in <strong>{expiresIn}</strong>. If you don't
            accept by then, you'll need to ask {inviterName} to send a new invitation.
          </Text>

          <Hr style={styles.hr} />

          <Text style={% raw %}{{ ...styles.footer, marginBottom: '12px' }}{% endraw %}>
            If the button above doesn't work, copy and paste this link into your browser:
          </Text>
          <Text style={styles.footer}>
            <Link href={inviteLink} style={% raw %}{{ color: '#5469d4', textDecoration: 'underline' }}{% endraw %}>
              {inviteLink}
            </Link>
          </Text>

          <Hr style={styles.hr} />

          <Text style={styles.paragraph}>
            If you weren't expecting this invitation or have any questions, feel free
            to reach out to <strong>{inviterName}</strong> or contact our support team.
          </Text>

          <Text style={styles.paragraph}>
            Welcome to {appName}!
            <br />
            Best,
            <br />
            The {appName} Team
          </Text>

          <Hr style={styles.hr} />
          <Text style={styles.footer}>
            © {new Date().getFullYear()} {appName}. All rights reserved.
          </Text>
        </Container>
      </Body>
    </Html>
  );
}
{% endif %}
