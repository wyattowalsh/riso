{% if saas_infra_module == "enabled" and saas_email != 'none' %}
/**
 * Password Reset Email Template
 *
 * Sent when a user requests to reset their password.
 * Includes a secure reset link with expiration time.
 *
 * @see https://react.email
 */

import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Link,
  Preview,
  Section,
  Text,
} from '@react-email/components';

const baseUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000';
const appName = '{{ project_name }}';

const styles = {
  main: {
    backgroundColor: '#f6f9fc',
    fontFamily: '-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Ubuntu,sans-serif',
  },
  container: {
    backgroundColor: '#ffffff',
    margin: '0 auto',
    padding: '20px 0 48px',
    marginBottom: '64px',
    maxWidth: '600px',
  },
  heading: {
    fontSize: '32px',
    lineHeight: '1.3',
    fontWeight: '700',
    color: '#484848',
    margin: '24px 0 16px',
  },
  paragraph: {
    fontSize: '16px',
    lineHeight: '26px',
    color: '#484848',
    margin: '12px 0',
  },
  button: {
    backgroundColor: '#5469d4',
    borderRadius: '4px',
    color: '#fff',
    fontSize: '16px',
    fontWeight: '600',
    textDecoration: 'none',
    textAlign: 'center' as const,
    display: 'block',
    padding: '12px 24px',
    width: '100%',
    maxWidth: '200px',
    margin: '0 auto',
  },
  section: {
    margin: '32px 0',
  },
  warningBox: {
    backgroundColor: '#fff3cd',
    border: '1px solid #ffc107',
    borderRadius: '4px',
    padding: '16px',
    margin: '20px 0',
  },
  warningText: {
    fontSize: '14px',
    lineHeight: '20px',
    color: '#856404',
    margin: '0',
  },
  hr: {
    borderColor: '#e6ebf1',
    margin: '20px 0',
  },
  footer: {
    color: '#8898aa',
    fontSize: '12px',
    lineHeight: '16px',
    margin: '8px 0',
    wordBreak: 'break-all' as const,
  },
  link: {
    color: '#5469d4',
    textDecoration: 'underline',
  },
  codeBlock: {
    backgroundColor: '#f6f9fc',
    border: '1px solid #e6ebf1',
    borderRadius: '4px',
    padding: '12px',
    fontSize: '12px',
    fontFamily: 'monospace',
    lineHeight: '16px',
    overflowWrap: 'break-word' as const,
    margin: '12px 0',
  },
};

export interface PasswordResetEmailProps {
  userName: string;
  resetLink: string;
  expiresIn?: string;
}

export function PasswordResetEmail({
  userName,
  resetLink,
  expiresIn = '1 hour',
}: PasswordResetEmailProps) {
  return (
    <Html>
      <Head />
      <Preview>Reset your {appName} password</Preview>
      <Body style={styles.main}>
        <Container style={styles.container}>
          <Heading style={styles.heading}>Reset your password</Heading>

          <Text style={styles.paragraph}>Hi {userName},</Text>

          <Text style={styles.paragraph}>
            We received a request to reset the password for your {appName} account.
          </Text>

          <Text style={styles.paragraph}>
            Click the button below to choose a new password. The link will expire in {expiresIn}.
          </Text>

          <Section style={styles.section}>
            <Button style={styles.button} href={resetLink}>
              Reset Password
            </Button>
          </Section>

          <Hr style={styles.hr} />

          <div style={styles.warningBox}>
            <Text style={styles.warningText}>
              <strong>Security Notice:</strong> If you didn't request this password reset,
              please ignore this email. Your account remains secure, and no changes will be
              made without your action.
            </Text>
          </div>

          <Text style={styles.paragraph}>
            If the button above doesn't work, copy and paste this link into your browser:
          </Text>

          <div style={styles.codeBlock}>
            <Link href={resetLink} style={styles.link}>
              {resetLink}
            </Link>
          </div>

          <Text style={styles.paragraph}>
            <strong>Link expires in:</strong> {expiresIn}
          </Text>

          <Text style={styles.paragraph}>
            For security reasons, we never send passwords via email. Make sure to create
            a strong, unique password when resetting your account.
          </Text>

          <Hr style={styles.hr} />

          <Text style={styles.footer}>
            © {new Date().getFullYear()} {appName}. All rights reserved.
          </Text>
          <Text style={styles.footer}>
            <Link href={`${baseUrl}/unsubscribe`} style={styles.link}>
              Unsubscribe
            </Link>
            {' '} | {' '}
            <Link href={`${baseUrl}/privacy`} style={styles.link}>
              Privacy Policy
            </Link>
            {' '} | {' '}
            <Link href={`${baseUrl}/security`} style={styles.link}>
              Security
            </Link>
          </Text>
        </Container>
      </Body>
    </Html>
  );
}
{% endif %}
