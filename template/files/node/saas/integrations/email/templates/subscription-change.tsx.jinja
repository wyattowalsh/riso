{% if saas_infra_module == "enabled" and saas_billing_module == 'enabled' %}
import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Preview,
  Section,
  Text,
} from '@react-email/components';

const baseUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000';
const appName = '{{ project_name }}';

const styles = {
  main: {
    backgroundColor: '#f6f9fc',
    fontFamily: '-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Ubuntu,sans-serif',
  },
  container: {
    backgroundColor: '#ffffff',
    margin: '0 auto',
    padding: '20px 0 48px',
    marginBottom: '64px',
  },
  heading: {
    fontSize: '32px',
    lineHeight: '1.3',
    fontWeight: '700',
    color: '#484848',
  },
  paragraph: {
    fontSize: '16px',
    lineHeight: '26px',
    color: '#484848',
  },
  button: {
    backgroundColor: '#5469d4',
    borderRadius: '4px',
    color: '#fff',
    fontSize: '16px',
    textDecoration: 'none',
    textAlign: 'center' as const,
    display: 'block',
    padding: '12px 24px',
  },
  hr: {
    borderColor: '#e6ebf1',
    margin: '20px 0',
  },
  footer: {
    color: '#8898aa',
    fontSize: '12px',
    lineHeight: '16px',
  },
  highlight: {
    backgroundColor: '#f0f4ff',
    padding: '16px',
    borderRadius: '4px',
    borderLeft: '4px solid #5469d4',
    marginTop: '16px',
    marginBottom: '16px',
  },
};

export interface SubscriptionChangeEmailProps {
  userName: string;
  changeType: 'upgraded' | 'downgraded' | 'canceled' | 'renewed';
  planName: string;
  previousPlanName?: string;
  effectiveDate: string;
  nextBillingDate?: string;
  billingAmount?: string;
  currency?: string;
  billingPortalLink: string;
}

export function SubscriptionChangeEmail({
  userName,
  changeType,
  planName,
  previousPlanName,
  effectiveDate,
  nextBillingDate,
  billingAmount,
  currency = 'USD',
  billingPortalLink,
}: SubscriptionChangeEmailProps) {
  const headingMessages = {
    upgraded: `You've upgraded to ${planName}`,
    downgraded: `You've downgraded to ${planName}`,
    canceled: 'Your subscription has been canceled',
    renewed: `Your ${planName} subscription has been renewed`,
  };

  const previewMessages = {
    upgraded: `Subscription upgraded to ${planName}`,
    downgraded: `Subscription downgraded to ${planName}`,
    canceled: 'Subscription canceled',
    renewed: `${planName} subscription renewed`,
  };

  return (
    <Html>
      <Head />
      <Preview>{previewMessages[changeType]}</Preview>
      <Body style={styles.main}>
        <Container style={styles.container}>
          <Heading style={styles.heading}>{headingMessages[changeType]}</Heading>

          <Text style={styles.paragraph}>Hi {userName},</Text>

          {changeType === 'upgraded' && (
            <>
              <Text style={styles.paragraph}>
                Your subscription has been successfully upgraded to the{' '}
                <strong>{planName}</strong> plan. You now have access to all the
                premium features and benefits.
              </Text>
              {previousPlanName && (
                <Text style={styles.paragraph}>
                  You're being upgraded from your previous <strong>{previousPlanName}</strong> plan.
                  This change is effective immediately as of <strong>{effectiveDate}</strong>.
                </Text>
              )}
              {billingAmount && nextBillingDate && (
                <Section style={styles.highlight}>
                  <Text style={% raw %}{{ margin: '0', fontSize: '14px', color: '#5469d4', fontWeight: '600' }}{% endraw %}>
                    BILLING INFORMATION
                  </Text>
                  <Text style={% raw %}{{ margin: '12px 0 0 0', fontSize: '15px', color: '#484848' }}{% endraw %}>
                    New plan: <strong>{planName}</strong>
                    <br />
                    Effective date: <strong>{effectiveDate}</strong>
                    <br />
                    Next billing: <strong>{nextBillingDate}</strong> ({currency} {billingAmount})
                  </Text>
                </Section>
              )}
            </>
          )}

          {changeType === 'downgraded' && (
            <>
              <Text style={styles.paragraph}>
                Your subscription has been downgraded to the <strong>{planName}</strong> plan.
                This change is effective immediately as of <strong>{effectiveDate}</strong>.
              </Text>
              {previousPlanName && (
                <Text style={styles.paragraph}>
                  You're being downgraded from your previous <strong>{previousPlanName}</strong> plan.
                  You'll retain access to all features on your new plan level.
                </Text>
              )}
              {billingAmount && nextBillingDate && (
                <Section style={styles.highlight}>
                  <Text style={% raw %}{{ margin: '0', fontSize: '14px', color: '#5469d4', fontWeight: '600' }}{% endraw %}>
                    BILLING INFORMATION
                  </Text>
                  <Text style={% raw %}{{ margin: '12px 0 0 0', fontSize: '15px', color: '#484848' }}{% endraw %}>
                    New plan: <strong>{planName}</strong>
                    <br />
                    Effective date: <strong>{effectiveDate}</strong>
                    <br />
                    Next billing: <strong>{nextBillingDate}</strong> ({currency} {billingAmount})
                  </Text>
                </Section>
              )}
            </>
          )}

          {changeType === 'canceled' && (
            <>
              <Text style={styles.paragraph}>
                Your subscription has been canceled. You'll continue to have access
                to all your data and features until <strong>{effectiveDate}</strong>.
              </Text>
              <Text style={styles.paragraph}>
                After that date, your account will be downgraded to our free plan
                (if available). You won't be charged again.
              </Text>
              <Section style={styles.highlight}>
                <Text style={% raw %}{{ margin: '0', fontSize: '14px', color: '#484848' }}{% endraw %}>
                  Cancellation effective: <strong>{effectiveDate}</strong>
                </Text>
              </Section>
              <Text style={styles.paragraph}>
                We'd love to have you back if you change your mind. You can reactivate
                your subscription anytime through your account settings.
              </Text>
            </>
          )}

          {changeType === 'renewed' && (
            <>
              <Text style={styles.paragraph}>
                Your <strong>{planName}</strong> subscription has been successfully renewed!
                Your service will continue without interruption.
              </Text>
              <Section style={styles.highlight}>
                <Text style={% raw %}{{ margin: '0', fontSize: '14px', color: '#5469d4', fontWeight: '600' }}{% endraw %}>
                  RENEWAL INFORMATION
                </Text>
                <Text style={% raw %}{{ margin: '12px 0 0 0', fontSize: '15px', color: '#484848' }}{% endraw %}>
                  Plan: <strong>{planName}</strong>
                  <br />
                  Renewal date: <strong>{effectiveDate}</strong>
                  <br />
                  {nextBillingDate && (
                    <>
                      Next billing: <strong>{nextBillingDate}</strong>
                      <br />
                    </>
                  )}
                  {billingAmount && (
                    <>
                      Amount: <strong>{currency} {billingAmount}</strong>
                    </>
                  )}
                </Text>
              </Section>
            </>
          )}

          <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
            <Button style={styles.button} href={billingPortalLink}>
              View Subscription Details
            </Button>
          </Section>

          <Text style={styles.paragraph}>
            You can manage your subscription, update your payment method, or view your
            billing history anytime in your account settings.
          </Text>

          <Text style={styles.paragraph}>
            If you have any questions or need assistance, please don't hesitate to
            contact our support team. We're here to help!
          </Text>

          <Text style={styles.paragraph}>
            Thank you for being a {appName} customer!
            <br />
            Best,
            <br />
            The {appName} Team
          </Text>

          <Hr style={styles.hr} />
          <Text style={styles.footer}>
            © {new Date().getFullYear()} {appName}. All rights reserved.
          </Text>
        </Container>
      </Body>
    </Html>
  );
}
{% endif %}
