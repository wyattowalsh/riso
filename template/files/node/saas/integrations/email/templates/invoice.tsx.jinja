{% if saas_infra_module == "enabled" and saas_billing_module == 'enabled' %}
import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Link,
  Preview,
  Section,
  Table,
  Text,
} from '@react-email/components';

const baseUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000';
const appName = '{{ project_name }}';

const styles = {
  main: {
    backgroundColor: '#f6f9fc',
    fontFamily: '-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Ubuntu,sans-serif',
  },
  container: {
    backgroundColor: '#ffffff',
    margin: '0 auto',
    padding: '20px 0 48px',
    marginBottom: '64px',
  },
  heading: {
    fontSize: '32px',
    lineHeight: '1.3',
    fontWeight: '700',
    color: '#484848',
  },
  subheading: {
    fontSize: '20px',
    lineHeight: '1.3',
    fontWeight: '600',
    color: '#484848',
  },
  paragraph: {
    fontSize: '16px',
    lineHeight: '26px',
    color: '#484848',
  },
  label: {
    fontSize: '14px',
    lineHeight: '1.5',
    color: '#8898aa',
    fontWeight: '600',
  },
  value: {
    fontSize: '14px',
    lineHeight: '1.5',
    color: '#484848',
  },
  button: {
    backgroundColor: '#5469d4',
    borderRadius: '4px',
    color: '#fff',
    fontSize: '16px',
    textDecoration: 'none',
    textAlign: 'center' as const,
    display: 'block',
    padding: '12px 24px',
  },
  hr: {
    borderColor: '#e6ebf1',
    margin: '20px 0',
  },
  footer: {
    color: '#8898aa',
    fontSize: '12px',
    lineHeight: '16px',
  },
  table: {
    width: '100%',
    borderCollapse: 'collapse' as const,
  },
  tableCell: {
    padding: '12px',
    borderBottom: '1px solid #e6ebf1',
    fontSize: '14px',
  },
  tableCellHeader: {
    padding: '12px',
    borderBottom: '1px solid #e6ebf1',
    fontSize: '14px',
    fontWeight: '600',
    backgroundColor: '#f6f9fc',
    color: '#484848',
  },
  totalRow: {
    fontSize: '16px',
    fontWeight: '600',
    color: '#484848',
  },
};

interface InvoiceLineItem {
  description: string;
  quantity: number;
  unitPrice: string;
  amount: string;
}

interface InvoiceEmailProps {
  customerName: string;
  invoiceNumber: string;
  invoiceDate: string;
  dueDate: string;
  currency: string;
  lineItems: InvoiceLineItem[];
  subtotal: string;
  tax: string;
  total: string;
  paymentMethod?: string;
  invoiceLink: string;
  downloadPdfLink: string;
}

export function InvoiceEmail({
  customerName,
  invoiceNumber,
  invoiceDate,
  dueDate,
  currency,
  lineItems,
  subtotal,
  tax,
  total,
  paymentMethod,
  invoiceLink,
  downloadPdfLink,
}: InvoiceEmailProps) {
  return (
    <Html>
      <Head />
      <Preview>{`Invoice ${invoiceNumber} from ${appName}`}</Preview>
      <Body style={styles.main}>
        <Container style={styles.container}>
          <Heading style={styles.heading}>Invoice</Heading>
          <Text style={styles.paragraph}>Hi {customerName},</Text>
          <Text style={styles.paragraph}>
            Thank you for your business! Your invoice is ready.
          </Text>

          <Hr style={styles.hr} />

          <Section style={% raw %}{{ marginBottom: '32px' }}{% endraw %}>
            <Table style={styles.table}>
              <tbody>
                <tr>
                  <td style={% raw %}{{ ...styles.label, width: '50%' }}{% endraw %}>
                    Invoice Number
                  </td>
                  <td style={styles.value}>{invoiceNumber}</td>
                </tr>
                <tr>
                  <td style={styles.label}>Invoice Date</td>
                  <td style={styles.value}>{invoiceDate}</td>
                </tr>
                <tr>
                  <td style={styles.label}>Due Date</td>
                  <td style={styles.value}>{dueDate}</td>
                </tr>
              </tbody>
            </Table>
          </Section>

          <Heading style={styles.subheading}>Charges</Heading>

          <Table style={styles.table}>
            <thead>
              <tr>
                <th style={styles.tableCellHeader}>Description</th>
                <th style={% raw %}{{ ...styles.tableCellHeader, textAlign: 'center' }}{% endraw %}>
                  Quantity
                </th>
                <th style={% raw %}{{ ...styles.tableCellHeader, textAlign: 'right' }}{% endraw %}>
                  Unit Price
                </th>
                <th style={% raw %}{{ ...styles.tableCellHeader, textAlign: 'right' }}{% endraw %}>
                  Amount
                </th>
              </tr>
            </thead>
            <tbody>
              {lineItems.map((item, index) => (
                <tr key={index}>
                  <td style={styles.tableCell}>{item.description}</td>
                  <td style={% raw %}{{ ...styles.tableCell, textAlign: 'center' }}{% endraw %}>
                    {item.quantity}
                  </td>
                  <td style={% raw %}{{ ...styles.tableCell, textAlign: 'right' }}{% endraw %}>
                    {currency} {item.unitPrice}
                  </td>
                  <td style={% raw %}{{ ...styles.tableCell, textAlign: 'right' }}{% endraw %}>
                    {currency} {item.amount}
                  </td>
                </tr>
              ))}
            </tbody>
          </Table>

          <Section style={% raw %}{{ textAlign: 'right', marginTop: '24px', marginBottom: '24px' }}{% endraw %}>
            <Table style={styles.table}>
              <tbody>
                <tr>
                  <td style={% raw %}{{ ...styles.label, textAlign: 'right', width: '50%' }}{% endraw %}>
                    Subtotal
                  </td>
                  <td style={% raw %}{{ ...styles.value, textAlign: 'right', paddingLeft: '24px' }}{% endraw %}>
                    {currency} {subtotal}
                  </td>
                </tr>
                <tr>
                  <td style={% raw %}{{ ...styles.label, textAlign: 'right' }}{% endraw %}>
                    Tax
                  </td>
                  <td style={% raw %}{{ ...styles.value, textAlign: 'right', paddingLeft: '24px' }}{% endraw %}>
                    {currency} {tax}
                  </td>
                </tr>
                <tr>
                  <td style={% raw %}{{ ...styles.totalRow, textAlign: 'right', paddingTop: '12px', borderTop: '2px solid #484848' }}{% endraw %}>
                    Total
                  </td>
                  <td style={% raw %}{{ ...styles.totalRow, textAlign: 'right', paddingLeft: '24px', paddingTop: '12px', borderTop: '2px solid #484848' }}{% endraw %}>
                    {currency} {total}
                  </td>
                </tr>
              </tbody>
            </Table>
          </Section>

          {paymentMethod && (
            <>
              <Hr style={styles.hr} />
              <Section style={% raw %}{{ marginBottom: '32px' }}{% endraw %}>
                <Text style={styles.label}>Payment Method</Text>
                <Text style={styles.value}>{paymentMethod}</Text>
              </Section>
            </>
          )}

          <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
            <Button style={styles.button} href={downloadPdfLink}>
              Download Invoice (PDF)
            </Button>
          </Section>

          <Text style={styles.paragraph}>
            You can also{' '}
            <Link href={invoiceLink} style={% raw %}{{ color: '#5469d4' }}{% endraw %}>
              view this invoice online
            </Link>
            .
          </Text>

          <Text style={styles.paragraph}>
            If you have any questions about this invoice or need to make changes,
            please don't hesitate to contact us.
          </Text>

          <Text style={styles.paragraph}>
            Best,
            <br />
            The {appName} Team
          </Text>

          <Hr style={styles.hr} />
          <Text style={styles.footer}>
            © {new Date().getFullYear()} {appName}. All rights reserved.
          </Text>
        </Container>
      </Body>
    </Html>
  );
}
{% endif %}
