{% if saas_starter_module == "enabled" %}
/**
 * Transactional Email Templates
 * 
 * Pre-built email templates for common SaaS scenarios.
 * Uses React Email for type-safe, component-based emails.
 * 
 * Templates included:
 * - Welcome email (new user signup)
 * - Team invitation
 * - Password reset
 * - Payment failed
 * - Subscription updated
 * 
 * @see https://react.email
 */

import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Section,
  Text,
} from '@react-email/components';

// ============================================================================
// Shared Styles & Components
// ============================================================================

const baseUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000';
const appName = '{{ project_name }}';

const styles = {
  main: {
    backgroundColor: '#f6f9fc',
    fontFamily: '-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Ubuntu,sans-serif',
  },
  container: {
    backgroundColor: '#ffffff',
    margin: '0 auto',
    padding: '20px 0 48px',
    marginBottom: '64px',
  },
  heading: {
    fontSize: '32px',
    lineHeight: '1.3',
    fontWeight: '700',
    color: '#484848',
  },
  paragraph: {
    fontSize: '16px',
    lineHeight: '26px',
    color: '#484848',
  },
  button: {
    backgroundColor: '#5469d4',
    borderRadius: '4px',
    color: '#fff',
    fontSize: '16px',
    textDecoration: 'none',
    textAlign: 'center' as const,
    display: 'block',
    padding: '12px 24px',
  },
  hr: {
    borderColor: '#e6ebf1',
    margin: '20px 0',
  },
  footer: {
    color: '#8898aa',
    fontSize: '12px',
    lineHeight: '16px',
  },
};

interface EmailLayoutProps {
  preview: string;
  children: React.ReactNode;
}

export function EmailLayout({ preview, children }: EmailLayoutProps) {
  return (
    <Html>
      <Head />
      <Preview>{preview}</Preview>
      <Body style={styles.main}>
        <Container style={styles.container}>
          {children}
          <Hr style={styles.hr} />
          <Text style={styles.footer}>
            © {new Date().getFullYear()} {appName}. All rights reserved.
          </Text>
        </Container>
      </Body>
    </Html>
  );
}

// ============================================================================
// Welcome Email
// ============================================================================

export interface WelcomeEmailProps {
  userName: string;
  userEmail: string;
}

export function WelcomeEmail({ userName, userEmail }: WelcomeEmailProps) {
  return (
    <EmailLayout preview={`Welcome to ${appName}!`}>
      <Heading style={styles.heading}>Welcome to {appName}!</Heading>
      <Text style={styles.paragraph}>Hi {userName},</Text>
      <Text style={styles.paragraph}>
        Thanks for signing up for {appName}. We're excited to have you on board!
      </Text>
      <Text style={styles.paragraph}>
        Your account has been created with the email address: <strong>{userEmail}</strong>
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={`${baseUrl}/dashboard`}>
          Go to Dashboard
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        If you have any questions, just reply to this email—we're always happy to help.
      </Text>
      <Text style={styles.paragraph}>
        Best,
        <br />
        The {appName} Team
      </Text>
    </EmailLayout>
  );
}

// ============================================================================
// Team Invitation Email
// ============================================================================

{% if saas_tenancy_model == 'b2b-teams' %}
export interface TeamInviteEmailProps {
  inviterName: string;
  teamName: string;
  inviteLink: string;
  expiresIn?: string;
}

export function TeamInviteEmail({
  inviterName,
  teamName,
  inviteLink,
  expiresIn = '7 days',
}: TeamInviteEmailProps) {
  return (
    <EmailLayout preview={`${inviterName} invited you to join ${teamName}`}>
      <Heading style={styles.heading}>You're invited to join {teamName}</Heading>
      <Text style={styles.paragraph}>
        <strong>{inviterName}</strong> has invited you to join their team on {appName}.
      </Text>
      <Text style={styles.paragraph}>
        Click the button below to accept the invitation and join the team.
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={inviteLink}>
          Accept Invitation
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        This invitation will expire in {expiresIn}. If you weren't expecting this
        invitation, you can safely ignore this email.
      </Text>
      <Hr style={styles.hr} />
      <Text style={styles.footer}>
        If the button doesn't work, copy and paste this link into your browser:
        <br />
        <Link href={inviteLink}>{inviteLink}</Link>
      </Text>
    </EmailLayout>
  );
}
{% endif %}

// ============================================================================
// Password Reset Email
// ============================================================================

{% if saas_auth == 'authjs' %}
export interface PasswordResetEmailProps {
  userName: string;
  resetLink: string;
  expiresIn?: string;
}

export function PasswordResetEmail({
  userName,
  resetLink,
  expiresIn = '1 hour',
}: PasswordResetEmailProps) {
  return (
    <EmailLayout preview={`Reset your ${appName} password`}>
      <Heading style={styles.heading}>Reset your password</Heading>
      <Text style={styles.paragraph}>Hi {userName},</Text>
      <Text style={styles.paragraph}>
        We received a request to reset your password. Click the button below to
        choose a new password.
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={resetLink}>
          Reset Password
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        This link will expire in {expiresIn}. If you didn't request a password
        reset, you can safely ignore this email.
      </Text>
      <Hr style={styles.hr} />
      <Text style={styles.footer}>
        If the button doesn't work, copy and paste this link into your browser:
        <br />
        <Link href={resetLink}>{resetLink}</Link>
      </Text>
    </EmailLayout>
  );
}
{% endif %}

// ============================================================================
// Payment Failed Email
// ============================================================================

{% if saas_billing != 'none' %}
export interface PaymentFailedEmailProps {
  userName: string;
  amount: string;
  currency: string;
  lastFourDigits: string;
  retryDate: string;
  updatePaymentLink: string;
}

export function PaymentFailedEmail({
  userName,
  amount,
  currency,
  lastFourDigits,
  retryDate,
  updatePaymentLink,
}: PaymentFailedEmailProps) {
  return (
    <EmailLayout preview={`Action required: Payment failed for ${appName}`}>
      <Heading style={styles.heading}>Payment failed</Heading>
      <Text style={styles.paragraph}>Hi {userName},</Text>
      <Text style={styles.paragraph}>
        We were unable to process your payment of{' '}
        <strong>
          {currency} {amount}
        </strong>{' '}
        using the card ending in <strong>{lastFourDigits}</strong>.
      </Text>
      <Text style={styles.paragraph}>
        We'll automatically retry the payment on <strong>{retryDate}</strong>.
        To avoid any interruption to your service, please update your payment
        method.
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={updatePaymentLink}>
          Update Payment Method
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        If you have any questions about your billing, please don't hesitate to
        contact us.
      </Text>
    </EmailLayout>
  );
}

// ============================================================================
// Subscription Updated Email
// ============================================================================

export interface SubscriptionUpdatedEmailProps {
  userName: string;
  planName: string;
  changeType: 'upgraded' | 'downgraded' | 'canceled' | 'renewed';
  effectiveDate: string;
  billingPortalLink: string;
}

export function SubscriptionUpdatedEmail({
  userName,
  planName,
  changeType,
  effectiveDate,
  billingPortalLink,
}: SubscriptionUpdatedEmailProps) {
  const messages = {
    upgraded: `You've upgraded to the ${planName} plan`,
    downgraded: `You've downgraded to the ${planName} plan`,
    canceled: `Your subscription has been canceled`,
    renewed: `Your ${planName} subscription has been renewed`,
  };

  return (
    <EmailLayout preview={messages[changeType]}>
      <Heading style={styles.heading}>{messages[changeType]}</Heading>
      <Text style={styles.paragraph}>Hi {userName},</Text>
      <Text style={styles.paragraph}>
        {changeType === 'canceled' ? (
          <>
            Your subscription has been canceled and will end on{' '}
            <strong>{effectiveDate}</strong>. You'll continue to have access
            until then.
          </>
        ) : changeType === 'renewed' ? (
          <>
            Your {planName} subscription has been successfully renewed. Your
            next billing date is <strong>{effectiveDate}</strong>.
          </>
        ) : (
          <>
            Your plan change to <strong>{planName}</strong> is now active as of{' '}
            <strong>{effectiveDate}</strong>.
          </>
        )}
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={billingPortalLink}>
          View Billing Details
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        Thank you for being a {appName} customer!
      </Text>
    </EmailLayout>
  );
}
{% endif %}

// ============================================================================
// Email Sending Utility
// ============================================================================

{% if saas_email == 'resend' %}
import { Resend } from 'resend';

const resend = new Resend(process.env.RESEND_API_KEY);

export async function sendEmail<T extends React.ReactElement>({
  to,
  subject,
  template,
}: {
  to: string | string[];
  subject: string;
  template: T;
}) {
  return resend.emails.send({
    from: process.env.EMAIL_FROM || `${appName} <noreply@${new URL(baseUrl).hostname}>`,
    to,
    subject,
    react: template,
  });
}
{% elif saas_email == 'postmark' %}
import { ServerClient } from 'postmark';
import { render } from '@react-email/render';

const postmark = new ServerClient(process.env.POSTMARK_API_KEY!);

export async function sendEmail<T extends React.ReactElement>({
  to,
  subject,
  template,
}: {
  to: string | string[];
  subject: string;
  template: T;
}) {
  const html = render(template);
  const recipients = Array.isArray(to) ? to.join(',') : to;
  
  return postmark.sendEmail({
    From: process.env.EMAIL_FROM || `${appName} <noreply@${new URL(baseUrl).hostname}>`,
    To: recipients,
    Subject: subject,
    HtmlBody: html,
  });
}
{% endif %}
{% endif %}
