{% if saas_billing_module == 'enabled' %}
export interface PaymentFailedEmailProps {
  userName: string;
  amount: string;
  currency: string;
  lastFourDigits: string;
  retryDate: string;
  updatePaymentLink: string;
}

export function PaymentFailedEmail({
  userName,
  amount,
  currency,
  lastFourDigits,
  retryDate,
  updatePaymentLink,
}: PaymentFailedEmailProps) {
  return (
    <EmailLayout preview={`Action required: Payment failed for ${appName}`}>
      <Heading style={styles.heading}>Payment failed</Heading>
      <Text style={styles.paragraph}>Hi {userName},</Text>
      <Text style={styles.paragraph}>
        We were unable to process your payment of{' '}
        <strong>
          {currency} {amount}
        </strong>{' '}
        using the card ending in <strong>{lastFourDigits}</strong>.
      </Text>
      <Text style={styles.paragraph}>
        We'll automatically retry the payment on <strong>{retryDate}</strong>.
        To avoid any interruption to your service, please update your payment
        method.
      </Text>
      <Section style={% raw %}{{ textAlign: 'center', margin: '32px 0' }}{% endraw %}>
        <Button style={styles.button} href={updatePaymentLink}>
          Update Payment Method
        </Button>
      </Section>
      <Text style={styles.paragraph}>
        If you have any questions about your billing, please don't hesitate to
        contact us.
      </Text>
    </EmailLayout>
  );
}

