{% if saas_infra_module == "enabled" and saas_ai_features == 'full' %}
/**
 * Embedding Generation Service
 *
 * Multi-provider embedding generation:
 * - OpenAI embeddings (text-embedding-3-small/large)
 * - Anthropic voyage embeddings
 * - Batch processing for efficiency
 * - Automatic retry and error handling
 * - Token usage tracking
 *
 * @see https://platform.openai.com/docs/guides/embeddings
 */

import { env } from '@/config/env';
import type {
  EmbeddingRequest,
  EmbeddingResponse,
  EmbeddingProvider,
  EmbeddingConfig,
  EmbeddingError,
} from './types';

// ============================================================================
// Configuration
// ============================================================================

const DEFAULT_CONFIGS: Record<EmbeddingProvider, EmbeddingConfig> = {
  openai: {
    provider: 'openai',
    model: 'text-embedding-3-small',
    dimensions: 1536,
    maxTokens: 8191,
    batchSize: 100,
  },
  anthropic: {
    provider: 'anthropic',
    model: 'voyage-2',
    dimensions: 1024,
    maxTokens: 16000,
    batchSize: 50,
  },
  cohere: {
    provider: 'cohere',
    model: 'embed-english-v3.0',
    dimensions: 1024,
    maxTokens: 512,
    batchSize: 96,
  },
};

// ============================================================================
// OpenAI Embeddings
// ============================================================================

{% if saas_ai == "openai" %}
import OpenAI from 'openai';

const openai = new OpenAI({
  apiKey: env.OPENAI_API_KEY,
});

/**
 * Generate embeddings using OpenAI
 *
 * @example
 * ```ts
 * const embeddings = await generateOpenAIEmbeddings({
 *   texts: ['Hello world', 'Another text'],
 *   model: 'text-embedding-3-small',
 * });
 * ```
 */
export async function generateOpenAIEmbeddings(
  request: EmbeddingRequest
): Promise<EmbeddingResponse> {
  const config = DEFAULT_CONFIGS.openai;
  const model = request.model || config.model;
  const batchSize = request.batchSize || config.batchSize;

  try {
    // Process in batches to avoid rate limits
    const batches = chunkArray(request.texts, batchSize);
    const allEmbeddings: number[][] = [];
    let totalTokens = 0;

    for (const batch of batches) {
      const response = await openai.embeddings.create({
        model,
        input: batch,
        encoding_format: 'float',
      });

      allEmbeddings.push(...response.data.map((item) => item.embedding));
      totalTokens += response.usage.total_tokens;
    }

    return {
      embeddings: allEmbeddings.map((vector) => ({
        vector,
        model,
        dimensions: vector.length,
      })),
      usage: {
        totalTokens,
      },
    };
  } catch (error) {
    throw new EmbeddingError(
      `Failed to generate OpenAI embeddings: ${error instanceof Error ? error.message : 'Unknown error'}`,
      { error, model }
    );
  }
}
{% endif %}

// ============================================================================
// Anthropic/Voyage Embeddings
// ============================================================================

{% if saas_ai == "anthropic" %}
/**
 * Generate embeddings using Anthropic Voyage
 *
 * Note: Anthropic uses Voyage AI for embeddings
 *
 * @example
 * ```ts
 * const embeddings = await generateAnthropicEmbeddings({
 *   texts: ['Hello world', 'Another text'],
 * });
 * ```
 */
export async function generateAnthropicEmbeddings(
  request: EmbeddingRequest
): Promise<EmbeddingResponse> {
  const config = DEFAULT_CONFIGS.anthropic;
  const model = request.model || config.model;
  const batchSize = request.batchSize || config.batchSize;

  try {
    // Voyage AI API (used by Anthropic)
    const batches = chunkArray(request.texts, batchSize);
    const allEmbeddings: number[][] = [];
    let totalTokens = 0;

    for (const batch of batches) {
      const response = await fetch('https://api.voyageai.com/v1/embeddings', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${env.VOYAGE_API_KEY || env.ANTHROPIC_API_KEY}`,
        },
        body: JSON.stringify({
          model,
          input: batch,
        }),
      });

      if (!response.ok) {
        throw new Error(`Voyage API error: ${response.statusText}`);
      }

      const data = await response.json();
      allEmbeddings.push(...data.data.map((item: any) => item.embedding));
      totalTokens += data.usage.total_tokens;
    }

    return {
      embeddings: allEmbeddings.map((vector) => ({
        vector,
        model,
        dimensions: vector.length,
      })),
      usage: {
        totalTokens,
      },
    };
  } catch (error) {
    throw new EmbeddingError(
      `Failed to generate Anthropic embeddings: ${error instanceof Error ? error.message : 'Unknown error'}`,
      { error, model }
    );
  }
}
{% endif %}

// ============================================================================
// Unified Interface
// ============================================================================

/**
 * Generate embeddings using the configured provider
 *
 * @example
 * ```ts
 * const embeddings = await generateEmbeddings({
 *   texts: ['Document 1', 'Document 2'],
 *   model: 'text-embedding-3-small',
 * });
 * ```
 */
export async function generateEmbeddings(
  request: EmbeddingRequest
): Promise<EmbeddingResponse> {
  const provider = getEmbeddingProvider();

  switch (provider) {
    {% if saas_ai == "openai" %}
    case 'openai':
      return generateOpenAIEmbeddings(request);
    {% endif %}
    {% if saas_ai == "anthropic" %}
    case 'anthropic':
      return generateAnthropicEmbeddings(request);
    {% endif %}
    default:
      throw new Error(`Unsupported embedding provider: ${provider}`);
  }
}

/**
 * Generate a single embedding
 */
export async function generateEmbedding(text: string): Promise<number[]> {
  const response = await generateEmbeddings({ texts: [text] });
  return response.embeddings[0].vector;
}

// ============================================================================
// Utility Functions
// ============================================================================

/**
 * Get the configured embedding provider
 */
function getEmbeddingProvider(): EmbeddingProvider {
  {% if saas_ai == "openai" %}
  return 'openai';
  {% elif saas_ai == "anthropic" %}
  return 'anthropic';
  {% else %}
  return 'openai'; // default
  {% endif %}
}

/**
 * Get embedding configuration
 */
export function getEmbeddingConfig(): EmbeddingConfig {
  const provider = getEmbeddingProvider();
  return DEFAULT_CONFIGS[provider];
}

/**
 * Split array into chunks
 */
function chunkArray<T>(array: T[], size: number): T[][] {
  const chunks: T[][] = [];
  for (let i = 0; i < array.length; i += size) {
    chunks.push(array.slice(i, i + size));
  }
  return chunks;
}

/**
 * Calculate cosine similarity between two vectors
 */
export function cosineSimilarity(a: number[], b: number[]): number {
  if (a.length !== b.length) {
    throw new Error('Vectors must have the same length');
  }

  let dotProduct = 0;
  let normA = 0;
  let normB = 0;

  for (let i = 0; i < a.length; i++) {
    dotProduct += a[i] * b[i];
    normA += a[i] * a[i];
    normB += b[i] * b[i];
  }

  return dotProduct / (Math.sqrt(normA) * Math.sqrt(normB));
}

/**
 * Normalize a vector to unit length
 */
export function normalizeVector(vector: number[]): number[] {
  const norm = Math.sqrt(vector.reduce((sum, val) => sum + val * val, 0));
  return vector.map((val) => val / norm);
}

/**
 * Estimate token count for text
 * Rough approximation: ~4 characters per token
 */
export function estimateTokenCount(text: string): number {
  return Math.ceil(text.length / 4);
}

/**
 * Validate embedding dimensions
 */
export function validateEmbedding(
  embedding: number[],
  expectedDimensions: number
): boolean {
  return embedding.length === expectedDimensions;
}

// ============================================================================
// Error Class
// ============================================================================

class EmbeddingError extends Error {
  constructor(
    message: string,
    public details?: any
  ) {
    super(message);
    this.name = 'EmbeddingError';
  }
}

// ============================================================================
// Exports
// ============================================================================

export { DEFAULT_CONFIGS, type EmbeddingProvider };
{% endif %}
