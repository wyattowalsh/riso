## Usage

### Document Ingestion

```typescript
import { ingestDocument } from '@/integrations/ai/rag';

// Single document
const result = await ingestDocument({
  content: 'Your document content here...',
  metadata: {
    source: 'docs/guide.md',
    sourceType: 'file',
    title: 'User Guide',
    author: 'John Doe',
    tags: ['guide', 'tutorial'],
    userId: 'user-123',
    organizationId: 'org-456',
  },
  options: {
    chunking: {
      strategy: { type: 'recursive', size: 1000, overlap: 200 },
      minChunkSize: 100,
    },
  },
});

console.log(`Ingested ${result.chunks} chunks`);
console.log(`Token usage: ${result.usage.totalTokens}`);
```

### Batch Ingestion

```typescript
import { ingestDocumentsBatch } from '@/integrations/ai/rag';

const documents = [
  { content: '...', metadata: { source: 'doc1.txt', sourceType: 'file' } },
  { content: '...', metadata: { source: 'doc2.txt', sourceType: 'file' } },
];

const result = await ingestDocumentsBatch({
  documents,
  parallel: true, // Process in parallel
});

console.log(`Processed ${result.totalDocuments} documents`);
console.log(`Total chunks: ${result.totalChunks}`);
```

### Query with RAG

```typescript
import { queryRAG } from '@/integrations/ai/rag';

const response = await queryRAG({
  query: 'How do I implement authentication?',
  userId: 'user-123',
  conversationId: 'conv-456', // Optional: for conversation history
  filter: {
    // Optional: filter by metadata
    organizationId: 'org-456',
    tags: ['auth', 'security'],
  },
});

console.log('Answer:', response.answer);
console.log('Sources:', response.sources);
console.log('Usage:', response.usage);
```

### Streaming Responses

```typescript
import { streamRAG } from '@/integrations/ai/rag';

for await (const chunk of streamRAG({
  query: 'Explain the payment flow',
  userId: 'user-123',
})) {
  switch (chunk.type) {
    case 'sources':
      // Show retrieved documents
      console.log('Sources:', chunk.sources.length);
      break;

    case 'content':
      // Stream text to UI
      process.stdout.write(chunk.content);
      break;

    case 'metadata':
      // Final usage stats
      console.log('\nTokens:', chunk.metadata.usage.totalTokens);
      break;

    case 'done':
      console.log('\nDone!');
      break;
  }
}
```

### Advanced Retrieval

```typescript
import { retrieveHybrid, retrieveMultiQuery } from '@/integrations/ai/rag';

// Hybrid search (vector + keyword)
const hybrid = await retrieveHybrid({
  query: 'authentication security',
  keywords: ['auth', 'oauth', '2fa', 'security'],
  vectorWeight: 0.7, // 70% vector, 30% keyword
  limit: 10,
});

// Multi-query retrieval
const multiQuery = await retrieveMultiQuery({
  query: 'user authentication',
  queryVariations: [
    'user authentication',
    'how to authenticate users',
    'login implementation',
    'auth setup guide',
  ],
  limit: 5,
});
```

