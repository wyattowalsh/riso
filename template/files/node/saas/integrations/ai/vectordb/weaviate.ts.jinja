/**
 * Weaviate Vector Store Implementation
 *
 * GraphQL-based vector search engine:
 * - Schema-based data modeling
 * - Built-in vectorizers
 * - Hybrid search (vector + keyword + filters)
 * - Multi-tenancy support
 * - Real-time CRUD operations
 *
 * @see https://weaviate.io/developers/weaviate
 */

import weaviate, { type WeaviateClient } from 'weaviate-ts-client';
import { generateEmbedding, generateEmbeddings } from './embeddings';
import type {
  IVectorStore,
  VectorDocument,
  VectorSearchResult,
  VectorSearchOptions,
  WeaviateConfig,
  VectorStoreError,
  ConnectionError,
} from './types';

// ============================================================================
// Weaviate Vector Store
// ============================================================================

export class WeaviateStore implements IVectorStore {
  private client: WeaviateClient;
  private className: string;
  private config: WeaviateConfig;

  constructor(config: WeaviateConfig) {
    this.config = {
      className: config.className || config.indexName,
      vectorizer: 'none', // We handle embeddings ourselves
      metric: 'cosine',
      ...config,
    };

    this.className = this.config.className!;

    try {
      const url = config.url || process.env.WEAVIATE_URL || 'http://localhost:8080';

      this.client = weaviate.client({
        scheme: url.startsWith('https') ? 'https' : 'http',
        host: url.replace(/^https?:\/\//, ''),
        apiKey: config.apiKey
          ? weaviate.apiKey(config.apiKey || process.env.WEAVIATE_API_KEY!)
          : undefined,
      });
    } catch (error) {
      throw new ConnectionError(
        `Failed to initialize Weaviate: ${error instanceof Error ? error.message : 'Unknown error'}`,
        { error, config: this.config }
      );
    }
  }

  // ============================================================================
  // Schema Management
  // ============================================================================

  /**
   * Ensure class (collection) exists
   */
  private async ensureClass(): Promise<void> {
    try {
      const schema = await this.client.schema.getter().do();
      const classExists = schema.classes?.some((c) => c.class === this.className);

      if (!classExists) {
        await this.client.schema
          .classCreator()
          .withClass({
            class: this.className,
            vectorizer: this.config.vectorizer,
            properties: [
              {
                name: 'content',
                dataType: ['text'],
                description: 'Document content',
              },
              {
                name: 'metadata',
                dataType: ['object'],
                description: 'Document metadata',
              },
            ],
          })
          .do();
      }
    } catch (error) {
      throw new VectorStoreError(
        `Class creation failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'SCHEMA_ERROR',
        { error }
      );
    }
  }

  // ============================================================================
  // Upsert Operations
  // ============================================================================

  /**
   * Upsert documents with automatic embedding generation
   */
  async upsert(documents: VectorDocument[]): Promise<void> {
    await this.ensureClass();

    try {
      // Separate documents with and without embeddings
      const docsNeedingEmbeddings = documents.filter((doc) => !doc.embedding);
      const docsWithEmbeddings = documents.filter((doc) => doc.embedding);

      // Generate embeddings
      let newEmbeddings: number[][] = [];
      if (docsNeedingEmbeddings.length > 0) {
        const texts = docsNeedingEmbeddings.map((doc) => doc.content);
        newEmbeddings = await generateEmbeddings(texts);
      }

      // Create batch
      let batch = this.client.batch.objectsBatcher();

      // Add documents with generated embeddings
      docsNeedingEmbeddings.forEach((doc, i) => {
        batch = batch.withObject({
          class: this.className,
          id: doc.id,
          properties: {
            content: doc.content,
            metadata: doc.metadata || {},
          },
          vector: newEmbeddings[i],
        });
      });

      // Add documents with existing embeddings
      docsWithEmbeddings.forEach((doc) => {
        batch = batch.withObject({
          class: this.className,
          id: doc.id,
          properties: {
            content: doc.content,
            metadata: doc.metadata || {},
          },
          vector: doc.embedding,
        });
      });

      // Execute batch
      await batch.do();
    } catch (error) {
      throw new VectorStoreError(
        `Upsert failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'UPSERT_ERROR',
        { error, documentCount: documents.length }
      );
    }
  }

  // ============================================================================
  // Search Operations
  // ============================================================================

  /**
   * Search by vector similarity
   */
  async search(
    query: number[],
    options: VectorSearchOptions = {}
  ): Promise<VectorSearchResult[]> {
    const {
      topK = 10,
      threshold = 0.0,
      filter,
      includeVectors = false,
    } = options;

    try {
      let queryBuilder = this.client.graphql
        .get()
        .withClassName(this.className)
        .withNearVector({
          vector: query,
          certainty: threshold,
        })
        .withFields('content metadata _additional { id certainty }')
        .withLimit(topK);

      // Add where filter if provided
      if (filter && Object.keys(filter).length > 0) {
        const whereFilters = Object.entries(filter).map(([key, value]) => ({
          path: ['metadata', key],
          operator: 'Equal',
          valueText: String(value),
        }));

        queryBuilder = queryBuilder.withWhere({
          operator: 'And',
          operands: whereFilters,
        });
      }

      if (includeVectors) {
        queryBuilder = queryBuilder.withFields(
          'content metadata _additional { id certainty vector }'
        );
      }

      const response = await queryBuilder.do();

      const results = response.data.Get[this.className] || [];

      return results.map((item: any) => ({
        id: item._additional.id,
        content: item.content,
        score: item._additional.certainty,
        metadata: item.metadata,
      }));
    } catch (error) {
      throw new VectorStoreError(
        `Search failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'SEARCH_ERROR',
        { error, options }
      );
    }
  }

  /**
   * Search by text (generates embedding automatically)
   */
  async searchByText(
    text: string,
    options: VectorSearchOptions = {}
  ): Promise<VectorSearchResult[]> {
    const embedding = await generateEmbedding(text);
    return this.search(embedding, options);
  }

  // ============================================================================
  // Delete Operations
  // ============================================================================

  /**
   * Delete documents by IDs
   */
  async delete(ids: string[]): Promise<void> {
    try {
      for (const id of ids) {
        await this.client.data.deleter().withClassName(this.className).withId(id).do();
      }
    } catch (error) {
      throw new VectorStoreError(
        `Delete failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_ERROR',
        { error, ids }
      );
    }
  }

  /**
   * Delete documents matching a filter
   */
  async deleteByFilter(filter: Record<string, unknown>): Promise<number> {
    try {
      // Query for matching documents
      const whereFilters = Object.entries(filter).map(([key, value]) => ({
        path: ['metadata', key],
        operator: 'Equal',
        valueText: String(value),
      }));

      const response = await this.client.graphql
        .get()
        .withClassName(this.className)
        .withFields('_additional { id }')
        .withWhere({
          operator: 'And',
          operands: whereFilters,
        })
        .withLimit(10000)
        .do();

      const results = response.data.Get[this.className] || [];
      const ids = results.map((item: any) => item._additional.id);

      if (ids.length > 0) {
        await this.delete(ids);
      }

      return ids.length;
    } catch (error) {
      throw new VectorStoreError(
        `Delete by filter failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_FILTER_ERROR',
        { error, filter }
      );
    }
  }

  // ============================================================================
  // Retrieval Operations
  // ============================================================================

  /**
   * Get document by ID
   */
  async get(id: string): Promise<VectorDocument | null> {
    try {
      const response = await this.client.data
        .getterById()
        .withClassName(this.className)
        .withId(id)
        .withVector()
        .do();

      if (!response) {
        return null;
      }

      return {
        id: response.id,
        content: response.properties.content,
        embedding: response.vector,
        metadata: response.properties.metadata,
      };
    } catch (error) {
      // Weaviate throws on not found
      if (error instanceof Error && error.message.includes('404')) {
        return null;
      }
      throw new VectorStoreError(
        `Get document failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'GET_ERROR',
        { error, id }
      );
    }
  }

  /**
   * Get multiple documents by IDs
   */
  async getMany(ids: string[]): Promise<VectorDocument[]> {
    const documents: VectorDocument[] = [];

    for (const id of ids) {
      const doc = await this.get(id);
      if (doc) {
        documents.push(doc);
      }
    }

    return documents;
  }

  // ============================================================================
  // Utility Operations
  // ============================================================================

  /**
   * Count documents in class
   */
  async count(filter?: Record<string, unknown>): Promise<number> {
    try {
      let aggregateQuery = this.client.graphql
        .aggregate()
        .withClassName(this.className)
        .withFields('meta { count }');

      if (filter && Object.keys(filter).length > 0) {
        const whereFilters = Object.entries(filter).map(([key, value]) => ({
          path: ['metadata', key],
          operator: 'Equal',
          valueText: String(value),
        }));

        aggregateQuery = aggregateQuery.withWhere({
          operator: 'And',
          operands: whereFilters,
        });
      }

      const response = await aggregateQuery.do();
      return response.data.Aggregate[this.className]?.[0]?.meta?.count || 0;
    } catch (error) {
      throw new VectorStoreError(
        `Count failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'COUNT_ERROR',
        { error, filter }
      );
    }
  }

  /**
   * Delete all documents in class
   */
  async deleteAll(): Promise<void> {
    try {
      // Weaviate doesn't have bulk delete, so we delete the class and recreate
      await this.client.schema.classDeleter().withClassName(this.className).do();
      await this.ensureClass();
    } catch (error) {
      throw new VectorStoreError(
        `Delete all failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_ALL_ERROR',
        { error }
      );
    }
  }
}

// ============================================================================
// Factory Function
// ============================================================================

export function createVectorStore(config: WeaviateConfig): IVectorStore {
  return new WeaviateStore(config);
}

// ============================================================================
// Error Classes
// ============================================================================

class VectorStoreError extends Error {
  constructor(
    message: string,
    public code?: string,
    public details?: unknown
  ) {
    super(message);
    this.name = 'VectorStoreError';
  }
}

class ConnectionError extends Error {
  constructor(message: string, public details?: unknown) {
    super(message);
    this.name = 'ConnectionError';
  }
}

// ============================================================================
// Exports
// ============================================================================

export { WeaviateStore };
export type { WeaviateConfig };
{% endif %}
