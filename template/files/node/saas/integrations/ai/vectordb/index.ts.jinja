/**
 * Vector Database Integration
 *
 * Unified interface for multiple vector database providers.
 * Choose the provider that fits your needs:
 *
 * - **Pinecone**: Serverless, cloud-native, auto-scaling
 * - **Qdrant**: Open-source, self-hosted or cloud, high-performance
 * - **Weaviate**: GraphQL-based, schema-driven, hybrid search
 *
 * All implementations follow the IVectorStore interface for easy switching.
 *
 * @example
 * ```ts
 * import { createVectorStore } from '@/integrations/ai/vectordb';
 *
 * const store = createVectorStore({
 *   indexName: 'my-documents',
 *   dimension: 1536,
 * });
 *
 * await store.upsert([
 *   { id: '1', content: 'First doc' },
 *   { id: '2', content: 'Second doc' },
 * ]);
 *
 * const results = await store.searchByText('query text', { topK: 5 });
 * ```
 */

