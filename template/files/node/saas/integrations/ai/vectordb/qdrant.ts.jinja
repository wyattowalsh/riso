/**
 * Qdrant Vector Store Implementation
 *
 * Open-source vector database with cloud and self-hosted options:
 * - High-performance similarity search
 * - Rich filtering with payload
 * - Quantization for efficiency
 * - Clustering and sharding
 * - GraphQL API support
 *
 * @see https://qdrant.tech/documentation/
 */

import { QdrantClient } from '@qdrant/js-client-rest';
import { generateEmbedding, generateEmbeddings } from './embeddings';
import type {
  IVectorStore,
  VectorDocument,
  VectorSearchResult,
  VectorSearchOptions,
  QdrantConfig,
  VectorStoreError,
  ConnectionError,
} from './types';

// ============================================================================
// Qdrant Vector Store
// ============================================================================

export class QdrantStore implements IVectorStore {
  private client: QdrantClient;
  private collectionName: string;
  private config: QdrantConfig;

  constructor(config: QdrantConfig) {
    this.config = {
      metric: 'cosine',
      ...config,
    };

    this.collectionName = config.indexName;

    try {
      const url = config.url || process.env.QDRANT_URL || 'http://localhost:6333';

      this.client = new QdrantClient({
        url,
        apiKey: config.apiKey || process.env.QDRANT_API_KEY,
        port: config.grpcPort,
        https: config.https,
      });
    } catch (error) {
      throw new ConnectionError(
        `Failed to initialize Qdrant: ${error instanceof Error ? error.message : 'Unknown error'}`,
        { error, config: this.config }
      );
    }
  }

  // ============================================================================
  // Collection Management
  // ============================================================================

  /**
   * Ensure collection exists, create if not
   */
  private async ensureCollection(): Promise<void> {
    try {
      const collections = await this.client.getCollections();
      const exists = collections.collections.some(
        (c) => c.name === this.collectionName
      );

      if (!exists) {
        await this.client.createCollection(this.collectionName, {
          vectors: {
            size: this.config.dimension,
            distance: this.mapMetricToDistance(this.config.metric || 'cosine'),
          },
        });
      }
    } catch (error) {
      throw new VectorStoreError(
        `Collection creation failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'COLLECTION_ERROR',
        { error }
      );
    }
  }

  private mapMetricToDistance(metric: string): 'Cosine' | 'Euclid' | 'Dot' {
    switch (metric) {
      case 'cosine':
        return 'Cosine';
      case 'euclidean':
        return 'Euclid';
      case 'dot_product':
        return 'Dot';
      default:
        return 'Cosine';
    }
  }

  // ============================================================================
  // Upsert Operations
  // ============================================================================

  /**
   * Upsert documents with automatic embedding generation
   *
   * @example
   * ```ts
   * await store.upsert([
   *   {
   *     id: 'doc-1',
   *     content: 'Document content',
   *     metadata: { category: 'tech', userId: '123' },
   *   },
   * ]);
   * ```
   */
  async upsert(documents: VectorDocument[]): Promise<void> {
    await this.ensureCollection();

    try {
      // Separate documents with and without embeddings
      const docsNeedingEmbeddings = documents.filter((doc) => !doc.embedding);
      const docsWithEmbeddings = documents.filter((doc) => doc.embedding);

      // Generate embeddings for documents that need them
      let newEmbeddings: number[][] = [];
      if (docsNeedingEmbeddings.length > 0) {
        const texts = docsNeedingEmbeddings.map((doc) => doc.content);
        newEmbeddings = await generateEmbeddings(texts);
      }

      // Prepare points for Qdrant
      const points = [
        ...docsNeedingEmbeddings.map((doc, i) => ({
          id: doc.id,
          vector: newEmbeddings[i],
          payload: {
            content: doc.content,
            ...doc.metadata,
          },
        })),
        ...docsWithEmbeddings.map((doc) => ({
          id: doc.id,
          vector: doc.embedding!,
          payload: {
            content: doc.content,
            ...doc.metadata,
          },
        })),
      ];

      // Upsert points
      await this.client.upsert(this.collectionName, {
        wait: true,
        points,
      });
    } catch (error) {
      throw new VectorStoreError(
        `Upsert failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'UPSERT_ERROR',
        { error, documentCount: documents.length }
      );
    }
  }

  // ============================================================================
  // Search Operations
  // ============================================================================

  /**
   * Search by vector similarity
   *
   * @example
   * ```ts
   * const results = await store.search(queryEmbedding, {
   *   topK: 10,
   *   threshold: 0.7,
   *   filter: { category: 'tech' },
   * });
   * ```
   */
  async search(
    query: number[],
    options: VectorSearchOptions = {}
  ): Promise<VectorSearchResult[]> {
    const {
      topK = 10,
      threshold = 0.0,
      filter,
      includeVectors = false,
    } = options;

    try {
      const searchParams: any = {
        vector: query,
        limit: topK,
        score_threshold: threshold,
        with_payload: true,
        with_vector: includeVectors,
      };

      // Add filter if provided
      if (filter && Object.keys(filter).length > 0) {
        searchParams.filter = {
          must: Object.entries(filter).map(([key, value]) => ({
            key,
            match: { value },
          })),
        };
      }

      const response = await this.client.search(this.collectionName, searchParams);

      return response.map((point) => ({
        id: point.id as string,
        content: (point.payload?.content as string) || '',
        score: point.score,
        metadata: point.payload,
      }));
    } catch (error) {
      throw new VectorStoreError(
        `Search failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'SEARCH_ERROR',
        { error, options }
      );
    }
  }

  /**
   * Search by text (generates embedding automatically)
   */
  async searchByText(
    text: string,
    options: VectorSearchOptions = {}
  ): Promise<VectorSearchResult[]> {
    const embedding = await generateEmbedding(text);
    return this.search(embedding, options);
  }

  // ============================================================================
  // Delete Operations
  // ============================================================================

  /**
   * Delete documents by IDs
   */
  async delete(ids: string[]): Promise<void> {
    try {
      await this.client.delete(this.collectionName, {
        wait: true,
        points: ids,
      });
    } catch (error) {
      throw new VectorStoreError(
        `Delete failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_ERROR',
        { error, ids }
      );
    }
  }

  /**
   * Delete documents matching a filter
   */
  async deleteByFilter(filter: Record<string, unknown>): Promise<number> {
    try {
      // Qdrant doesn't return count directly, so we search first
      const matches = await this.client.scroll(this.collectionName, {
        filter: {
          must: Object.entries(filter).map(([key, value]) => ({
            key,
            match: { value },
          })),
        },
        limit: 10000,
        with_payload: false,
        with_vector: false,
      });

      const ids = matches.points.map((p) => p.id as string);

      if (ids.length > 0) {
        await this.delete(ids);
      }

      return ids.length;
    } catch (error) {
      throw new VectorStoreError(
        `Delete by filter failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_FILTER_ERROR',
        { error, filter }
      );
    }
  }

  // ============================================================================
  // Retrieval Operations
  // ============================================================================

  /**
   * Get document by ID
   */
  async get(id: string): Promise<VectorDocument | null> {
    try {
      const response = await this.client.retrieve(this.collectionName, {
        ids: [id],
        with_payload: true,
        with_vector: true,
      });

      if (response.length === 0) {
        return null;
      }

      const point = response[0];
      return {
        id: point.id as string,
        content: (point.payload?.content as string) || '',
        embedding: point.vector as number[],
        metadata: point.payload,
      };
    } catch (error) {
      throw new VectorStoreError(
        `Get document failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'GET_ERROR',
        { error, id }
      );
    }
  }

  /**
   * Get multiple documents by IDs
   */
  async getMany(ids: string[]): Promise<VectorDocument[]> {
    try {
      const response = await this.client.retrieve(this.collectionName, {
        ids,
        with_payload: true,
        with_vector: true,
      });

      return response.map((point) => ({
        id: point.id as string,
        content: (point.payload?.content as string) || '',
        embedding: point.vector as number[],
        metadata: point.payload,
      }));
    } catch (error) {
      throw new VectorStoreError(
        `Get many failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'GET_MANY_ERROR',
        { error, ids }
      );
    }
  }

  // ============================================================================
  // Utility Operations
  // ============================================================================

  /**
   * Count documents in collection
   */
  async count(filter?: Record<string, unknown>): Promise<number> {
    try {
      if (!filter) {
        const info = await this.client.getCollection(this.collectionName);
        return info.points_count || 0;
      }

      // Count with filter
      const response = await this.client.count(this.collectionName, {
        filter: {
          must: Object.entries(filter).map(([key, value]) => ({
            key,
            match: { value },
          })),
        },
        exact: true,
      });

      return response.count;
    } catch (error) {
      throw new VectorStoreError(
        `Count failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'COUNT_ERROR',
        { error, filter }
      );
    }
  }

  /**
   * Delete all documents in collection
   */
  async deleteAll(): Promise<void> {
    try {
      await this.client.delete(this.collectionName, {
        wait: true,
        filter: {}, // Empty filter deletes all
      });
    } catch (error) {
      throw new VectorStoreError(
        `Delete all failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
        'DELETE_ALL_ERROR',
        { error }
      );
    }
  }
}

// ============================================================================
// Factory Function
// ============================================================================

export function createVectorStore(config: QdrantConfig): IVectorStore {
  return new QdrantStore(config);
}

// ============================================================================
// Error Classes
// ============================================================================

class VectorStoreError extends Error {
  constructor(
    message: string,
    public code?: string,
    public details?: unknown
  ) {
    super(message);
    this.name = 'VectorStoreError';
  }
}

class ConnectionError extends Error {
  constructor(message: string, public details?: unknown) {
    super(message);
    this.name = 'ConnectionError';
  }
}

// ============================================================================
// Exports
// ============================================================================

export { QdrantStore };
export type { QdrantConfig };
{% endif %}
