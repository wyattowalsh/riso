{% if saas_infra_module == "enabled" and saas_realtime == "pusher" %}
/**
 * Pusher Real-time Client
 * 
 * Provides real-time communication for features like:
 * - Live notifications
 * - Collaborative editing
 * - Presence indicators
 * - Live updates
 * 
 * @see https://pusher.com/docs/channels/
 */

import Pusher from 'pusher';
import PusherClient from 'pusher-js';
{% if saas_observability_structured_logging %}
import { logger } from '@/lib/observability/logger';
{% endif %}

// ============================================================================
// Server-Side Client (for sending events)
// ============================================================================

/**
 * Server-side Pusher client
 * Use this to trigger events from your API routes
 */
export const pusherServer = new Pusher({
  appId: process.env.PUSHER_APP_ID!,
  key: process.env.NEXT_PUBLIC_PUSHER_KEY!,
  secret: process.env.PUSHER_SECRET!,
  cluster: process.env.NEXT_PUBLIC_PUSHER_CLUSTER!,
  useTLS: true,
});

// ============================================================================
// Client-Side Setup (for receiving events)
// ============================================================================

/**
 * Create a Pusher client instance for the browser
 * Call this once in your app's root component
 */
export function createPusherClient(): PusherClient {
  return new PusherClient(process.env.NEXT_PUBLIC_PUSHER_KEY!, {
    cluster: process.env.NEXT_PUBLIC_PUSHER_CLUSTER!,
    forceTLS: true,
  });
}

// ============================================================================
// Channel Types
// ============================================================================

export const CHANNEL_TYPES = {
  /** Public channel - anyone can subscribe */
  public: (name: string) => name,
  /** Private channel - requires authentication */
  private: (name: string) => `private-${name}`,
  /** Presence channel - shows who's online */
  presence: (name: string) => `presence-${name}`,
} as const;

// ============================================================================
// Event Types
// ============================================================================

export const EVENTS = {
  // Notification events
  notification: {
    new: 'notification:new',
    read: 'notification:read',
  },
  
  // User events
  user: {
    updated: 'user:updated',
    deleted: 'user:deleted',
  },
  
  {% if saas_tenancy_model == 'b2b-teams' %}
  // Team events
  team: {
    memberJoined: 'team:member-joined',
    memberLeft: 'team:member-left',
    memberUpdated: 'team:member-updated',
    inviteSent: 'team:invite-sent',
  },
  {% endif %}
  
  // Subscription events
  subscription: {
    updated: 'subscription:updated',
    canceled: 'subscription:canceled',
  },
  
  // Generic events
  data: {
    created: 'data:created',
    updated: 'data:updated',
    deleted: 'data:deleted',
  },
} as const;

// ============================================================================
// Server-Side Event Triggers
// ============================================================================

/**
 * Send a notification to a specific user
 */
export async function sendUserNotification(
  userId: string,
  notification: {
    id: string;
    type: string;
    title: string;
    body: string;
    actionUrl?: string;
  }
): Promise<void> {
  const channel = CHANNEL_TYPES.private(`user-${userId}`);
  
  {% if saas_observability_structured_logging %}
  logger.debug({
    msg: 'Sending Pusher notification',
    userId,
    notificationType: notification.type,
  });
  {% endif %}
  
  await pusherServer.trigger(channel, EVENTS.notification.new, notification);
}

{% if saas_tenancy_model == 'b2b-teams' %}
/**
 * Broadcast to all members of an organization
 */
export async function broadcastToOrganization(
  organizationId: string,
  eventName: string,
  data: Record<string, unknown>
): Promise<void> {
  const channel = CHANNEL_TYPES.private(`org-${organizationId}`);
  
  {% if saas_observability_structured_logging %}
  logger.debug({
    msg: 'Broadcasting to organization',
    organizationId,
    eventName,
  });
  {% endif %}
  
  await pusherServer.trigger(channel, eventName, data);
}

/**
 * Send team member update event
 */
export async function sendTeamMemberEvent(
  organizationId: string,
  event: 'joined' | 'left' | 'updated',
  member: {
    userId: string;
    name: string;
    role: string;
  }
): Promise<void> {
  const channel = CHANNEL_TYPES.presence(`org-${organizationId}`);
  const eventName = {
    joined: EVENTS.team.memberJoined,
    left: EVENTS.team.memberLeft,
    updated: EVENTS.team.memberUpdated,
  }[event];
  
  await pusherServer.trigger(channel, eventName, member);
}
{% endif %}

// ============================================================================
// Presence Channel Authentication
// ============================================================================

/**
 * Authenticate a user for private/presence channels
 * Use this in your auth endpoint
 * 
 * @example
 * ```ts
 * // In app/api/pusher/auth/route.ts
 * export async function POST(req: Request) {
 *   const { socket_id, channel_name } = await req.json();
 *   const user = await getCurrentUser();
 *   
 *   const auth = authenticatePusherChannel(socket_id, channel_name, {
 *     id: user.id,
 *     name: user.name,
 *   });
 *   
 *   return Response.json(auth);
 * }
 * ```
 */
export function authenticatePusherChannel(
  socketId: string,
  channelName: string,
  userData?: {
    id: string;
    name?: string;
    email?: string;
    image?: string;
  }
): { auth: string; channel_data?: string } {
  // For presence channels, include user data
  if (channelName.startsWith('presence-') && userData) {
    return pusherServer.authorizeChannel(socketId, channelName, {
      user_id: userData.id,
      user_info: {
        name: userData.name,
        email: userData.email,
        image: userData.image,
      },
    });
  }
  
  // For private channels, just authenticate
  return pusherServer.authorizeChannel(socketId, channelName);
}

// ============================================================================
// React Hook (Client-Side)
// ============================================================================

/**
 * React hook for subscribing to Pusher events
 * 
 * @example
 * ```tsx
 * function NotificationBell() {
 *   const [notifications, setNotifications] = useState([]);
 *   
 *   usePusherSubscription(
 *     `private-user-${userId}`,
 *     'notification:new',
 *     (data) => {
 *       setNotifications(prev => [data, ...prev]);
 *     }
 *   );
 *   
 *   return <Bell count={notifications.length} />;
 * }
 * ```
 */
export function usePusherSubscriptionCode(): string {
  return `
import { useEffect, useRef } from 'react';
import PusherClient from 'pusher-js';

let pusherInstance: PusherClient | null = null;

function getPusher(): PusherClient {
  if (!pusherInstance) {
    pusherInstance = new PusherClient(process.env.NEXT_PUBLIC_PUSHER_KEY!, {
      cluster: process.env.NEXT_PUBLIC_PUSHER_CLUSTER!,
      forceTLS: true,
      authEndpoint: '/api/pusher/auth',
    });
  }
  return pusherInstance;
}

export function usePusherSubscription<T>(
  channelName: string,
  eventName: string,
  callback: (data: T) => void
) {
  const savedCallback = useRef(callback);
  
  useEffect(() => {
    savedCallback.current = callback;
  }, [callback]);
  
  useEffect(() => {
    const pusher = getPusher();
    const channel = pusher.subscribe(channelName);
    
    const handler = (data: T) => {
      savedCallback.current(data);
    };
    
    channel.bind(eventName, handler);
    
    return () => {
      channel.unbind(eventName, handler);
      pusher.unsubscribe(channelName);
    };
  }, [channelName, eventName]);
}
`.trim();
}

// ============================================================================
// Type Exports
// ============================================================================

export type PusherEventCallback<T = unknown> = (data: T) => void;

export interface NotificationPayload {
  id: string;
  type: string;
  title: string;
  body: string;
  actionUrl?: string;
  createdAt: string;
}

