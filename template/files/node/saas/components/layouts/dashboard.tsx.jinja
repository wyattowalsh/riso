// ============================================================================
// Sidebar Component
// ============================================================================

interface SidebarProps {
  navigation: NavItem[];
  collapsed: boolean;
  onCollapse: (collapsed: boolean) => void;
  {% if saas_tenancy_model == 'b2b-teams' %}
  organizationName?: string;
  organizationLogo?: string;
  {% endif %}
}

function Sidebar({ 
  navigation, 
  collapsed, 
  onCollapse,
  {% if saas_tenancy_model == 'b2b-teams' %}
  organizationName,
  organizationLogo,
  {% endif %}
}: SidebarProps) {
  {% if saas_runtime == 'nextjs-16' %}
  const pathname = usePathname();
  {% elif saas_runtime == 'remix-2' %}
  const { pathname } = useLocation();
  {% endif %}

  return (
    <aside
      className={`fixed inset-y-0 left-0 z-50 flex flex-col bg-gray-900 transition-all duration-300 ${
        collapsed ? 'w-16' : 'w-64'
      }`}
    >
      {/* Logo / Org */}
      <div className="flex h-16 items-center justify-between px-4">
        {% if saas_tenancy_model == 'b2b-teams' %}
        {!collapsed && (
          <div className="flex items-center gap-2">
            {organizationLogo ? (
              <img src={organizationLogo} alt="" className="h-8 w-8 rounded" />
            ) : (
              <div className="flex h-8 w-8 items-center justify-center rounded bg-indigo-600 text-white font-bold">
                {organizationName?.charAt(0) || 'O'}
              </div>
            )}
            <span className="text-white font-semibold truncate">
              {organizationName || '{{ project_name }}'}
            </span>
          </div>
        )}
        {% else %}
        {!collapsed && (
          <span className="text-white font-semibold">{{ project_name }}</span>
        )}
        {% endif %}
        <button
          onClick={() => onCollapse(!collapsed)}
          className="text-gray-400 hover:text-white"
        >
          <svg
            className={`h-5 w-5 transition-transform ${collapsed ? 'rotate-180' : ''}`}
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
          </svg>
        </button>
      </div>

      {/* Navigation */}
      <nav className="flex-1 space-y-1 px-2 py-4">
        {navigation.map((item) => {
          const isActive = pathname === item.href || pathname.startsWith(item.href + '/');
          
          return (
            <Link
              key={item.href}
              href={item.href}
              className={`group flex items-center gap-3 rounded-md px-2 py-2 text-sm font-medium transition-colors ${
                isActive
                  ? 'bg-gray-800 text-white'
                  : 'text-gray-300 hover:bg-gray-700 hover:text-white'
              }`}
              title={collapsed ? item.title : undefined}
            >
              {item.icon}
              {!collapsed && (
                <>
                  <span className="flex-1">{item.title}</span>
                  {item.badge && (
                    <span className="rounded-full bg-indigo-600 px-2 py-0.5 text-xs text-white">
                      {item.badge}
                    </span>
                  )}
                </>
              )}
            </Link>
          );
        })}
      </nav>
    </aside>
  );
}

// ============================================================================
// Header Component
// ============================================================================

interface HeaderProps {
  user?: User;
  sidebarCollapsed: boolean;
}

function Header({ user, sidebarCollapsed }: HeaderProps) {
  return (
    <header
      className={`fixed top-0 right-0 z-40 flex h-16 items-center justify-between border-b bg-white px-4 transition-all duration-300 ${
        sidebarCollapsed ? 'left-16' : 'left-64'
      }`}
    >
      {/* Breadcrumb / Search could go here */}
      <div className="flex-1" />

      {/* User Menu */}
      {user && (
        {% if saas_ui_framework == 'shadcn-ui' %}
        <DropdownMenu>
          <DropdownMenuTrigger asChild>
            <Button variant="ghost" className="relative h-8 w-8 rounded-full">
              <Avatar className="h-8 w-8">
                <AvatarImage src={user.avatar} alt={user.name} />
                <AvatarFallback>{user.name.charAt(0)}</AvatarFallback>
              </Avatar>
            </Button>
          </DropdownMenuTrigger>
          <DropdownMenuContent className="w-56" align="end" forceMount>
            <DropdownMenuLabel className="font-normal">
              <div className="flex flex-col space-y-1">
                <p className="text-sm font-medium leading-none">{user.name}</p>
                <p className="text-xs leading-none text-muted-foreground">{user.email}</p>
              </div>
            </DropdownMenuLabel>
            <DropdownMenuSeparator />
            <DropdownMenuItem asChild>
              <Link href="/dashboard/settings">Settings</Link>
            </DropdownMenuItem>
            <DropdownMenuItem asChild>
              <Link href="/dashboard/billing">Billing</Link>
            </DropdownMenuItem>
            <DropdownMenuSeparator />
            <DropdownMenuItem className="text-red-600">
              Sign out
            </DropdownMenuItem>
          </DropdownMenuContent>
        </DropdownMenu>
        {% else %}
        <div className="relative">
          <button className="flex items-center gap-2 rounded-full bg-gray-100 p-1 pr-3 hover:bg-gray-200">
            <div className="flex h-8 w-8 items-center justify-center rounded-full bg-indigo-600 text-white">
              {user.avatar ? (
                <img src={user.avatar} alt="" className="h-8 w-8 rounded-full" />
              ) : (
                user.name.charAt(0)
              )}
            </div>
            <span className="text-sm font-medium">{user.name}</span>
          </button>
        </div>
        {% endif %}
      )}
    </header>
  );
}

// ============================================================================
// Mobile Menu
// ============================================================================

interface MobileMenuProps {
  navigation: NavItem[];
  isOpen: boolean;
  onClose: () => void;
}

function MobileMenu({ navigation, isOpen, onClose }: MobileMenuProps) {
  {% if saas_runtime == 'nextjs-16' %}
  const pathname = usePathname();
  {% elif saas_runtime == 'remix-2' %}
  const { pathname } = useLocation();
  {% endif %}

  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-50 lg:hidden">
      {/* Backdrop */}
      <div className="fixed inset-0 bg-gray-600/75" onClick={onClose} />
      
      {/* Menu */}
      <div className="fixed inset-y-0 left-0 flex w-full max-w-xs flex-col bg-gray-900">
        <div className="flex h-16 items-center justify-between px-4">
          <span className="text-white font-semibold">{{ project_name }}</span>
          <button onClick={onClose} className="text-gray-400 hover:text-white">
            <svg className="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <nav className="flex-1 space-y-1 px-2 py-4">
          {navigation.map((item) => {
            const isActive = pathname === item.href;
            return (
              <Link
                key={item.href}
                href={item.href}
                onClick={onClose}
                className={`flex items-center gap-3 rounded-md px-2 py-2 text-sm font-medium ${
                  isActive
                    ? 'bg-gray-800 text-white'
                    : 'text-gray-300 hover:bg-gray-700 hover:text-white'
                }`}
              >
                {item.icon}
                <span>{item.title}</span>
              </Link>
            );
          })}
        </nav>
      </div>
    </div>
  );
}

// ============================================================================
// Main Dashboard Layout
// ============================================================================

export function DashboardLayout({
  children,
  user,
  navigation = defaultNavigation,
  {% if saas_tenancy_model == 'b2b-teams' %}
  organizationName,
  organizationLogo,
  {% endif %}
}: DashboardLayoutProps) {
  const [sidebarCollapsed, setSidebarCollapsed] = React.useState(false);
  const [mobileMenuOpen, setMobileMenuOpen] = React.useState(false);

  return (
    <div className="min-h-screen bg-gray-100">
      {/* Desktop Sidebar */}
      <div className="hidden lg:block">
        <Sidebar
          navigation={navigation}
          collapsed={sidebarCollapsed}
          onCollapse={setSidebarCollapsed}
          {% if saas_tenancy_model == 'b2b-teams' %}
          organizationName={organizationName}
          organizationLogo={organizationLogo}
          {% endif %}
        />
      </div>

      {/* Mobile Menu */}
      <MobileMenu
        navigation={navigation}
        isOpen={mobileMenuOpen}
        onClose={() => setMobileMenuOpen(false)}
      />

      {/* Header */}
      <Header user={user} sidebarCollapsed={sidebarCollapsed} />

      {/* Mobile header */}
      <div className="fixed top-0 left-0 right-0 z-40 flex h-16 items-center justify-between border-b bg-white px-4 lg:hidden">
        <button
          onClick={() => setMobileMenuOpen(true)}
          className="text-gray-500 hover:text-gray-700"
        >
          <svg className="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <span className="font-semibold">{{ project_name }}</span>
        <div className="w-6" /> {/* Spacer */}
      </div>

      {/* Main Content */}
      <main
        className={`pt-16 transition-all duration-300 ${
          sidebarCollapsed ? 'lg:pl-16' : 'lg:pl-64'
        }`}
      >
        <div className="p-4 sm:p-6 lg:p-8">{children}</div>
      </main>
    </div>
  );
}

// ============================================================================
// Page Header Component
// ============================================================================

export interface PageHeaderProps {
  title: string;
  description?: string;
  actions?: React.ReactNode;
}

export function PageHeader({ title, description, actions }: PageHeaderProps) {
  return (
    <div className="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 className="text-2xl font-bold tracking-tight text-gray-900">{title}</h1>
        {description && (
          <p className="mt-1 text-sm text-gray-500">{description}</p>
        )}
      </div>
      {actions && <div className="flex gap-2">{actions}</div>}
    </div>
  );
}
{% endif %}
