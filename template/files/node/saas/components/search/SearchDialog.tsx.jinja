{% if saas_infra_module == "enabled" and saas_search != 'none' %}
/**
 * Search Dialog Component
 *
 * Provides a command palette-style search dialog with:
 * - Keyboard shortcut (Cmd+K / Ctrl+K) to open
 * - Real-time search with instant results
 * - Multiple result categories (users, posts, settings, etc.)
 * - Keyboard navigation (arrow keys, enter to select)
 * - Recent searches display
 * - Loading and empty states
 *
 * Features:
 * - Integrates with {% if saas_search == 'meilisearch' %}Meilisearch{% elif saas_search == 'algolia' %}Algolia{% else %}local search{% endif %}
 * - Keyboard-accessible navigation
 * - Debounced search queries
 * - Caches recent searches in localStorage
 */

{% if saas_runtime == 'nextjs-16' %}
'use client';
{% endif %}

import * as React from 'react';
{% if saas_ui_framework == 'shadcn-ui' %}
import { Button } from '@/components/ui/button';
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import {
  Command,
  CommandDialog,
  CommandEmpty,
  CommandGroup,
  CommandInput,
  CommandItem,
  CommandList,
  CommandSeparator,
} from '@/components/ui/command';
{% endif %}
{% if saas_search == 'meilisearch' %}
import { useSearch } from '@/hooks/use-search-meilisearch';
{% elif saas_search == 'algolia' %}
import { useSearch } from '@/hooks/use-search-algolia';
{% endif %}

// ============================================================================
// Types
// ============================================================================

export interface SearchResult {
  id: string;
  title: string;
  description?: string;
  category: 'users' | 'posts' | 'settings' | 'pages' | 'docs';
  href: string;
  icon?: React.ReactNode;
  metadata?: Record<string, any>;
}

interface SearchDialogProps {
  open?: boolean;
  onOpenChange?: (open: boolean) => void;
  onSelect?: (result: SearchResult) => void;
  placeholder?: string;
}

// ============================================================================
// Search Dialog Component
// ============================================================================

export function SearchDialog({
  open: controlledOpen,
  onOpenChange,
  onSelect,
  placeholder = 'Search users, posts, settings...',
}: SearchDialogProps) {
  const [uncontrolledOpen, setUncontrolledOpen] = React.useState(false);
  const [searchQuery, setSearchQuery] = React.useState('');
  const [selectedIndex, setSelectedIndex] = React.useState(0);
  const [recentSearches, setRecentSearches] = React.useState<string[]>([]);

  const open = controlledOpen ?? uncontrolledOpen;
  const setOpen = (newOpen: boolean) => {
    if (controlledOpen === undefined) {
      setUncontrolledOpen(newOpen);
    }
    onOpenChange?.(newOpen);
  };

  // ========================================================================
  // Search Integration
  // ========================================================================

  {% if saas_search == 'meilisearch' %}
  const { results, isLoading, error } = useSearch(searchQuery, {
    limit: 10,
  });
  {% elif saas_search == 'algolia' %}
  const { results, isLoading, error } = useSearch(searchQuery, {
    limit: 10,
  });
  {% else %}
  // Fallback: simple local search
  const [results, setResults] = React.useState<SearchResult[]>([]);
  const isLoading = false;
  const error = null;

  // Simple in-memory search implementation
  const mockData: SearchResult[] = [
    {
      id: '1',
      title: 'Profile Settings',
      description: 'Manage your account and preferences',
      category: 'settings',
      href: '/settings/profile',
    },
    {
      id: '2',
      title: 'Billing & Plans',
      description: 'View and manage your subscription',
      category: 'settings',
      href: '/settings/billing',
    },
  ];

  React.useEffect(() => {
    if (!searchQuery.trim()) {
      setResults([]);
      return;
    }

    const query = searchQuery.toLowerCase();
    const filtered = mockData.filter(
      (item) =>
        item.title.toLowerCase().includes(query) ||
        item.description?.toLowerCase().includes(query)
    );

    setResults(filtered);
  }, [searchQuery]);
  {% endif %}

  // ========================================================================
  // Recent Searches
  // ========================================================================

  React.useEffect(() => {
    const stored = localStorage.getItem('searchDialog_recent');
    if (stored) {
      try {
        setRecentSearches(JSON.parse(stored));
      } catch {
        // Ignore parsing errors
      }
    }
  }, []);

  const saveRecentSearch = (query: string) => {
    if (!query.trim()) return;

    const updated = [
      query,
      ...recentSearches.filter((s) => s !== query),
    ].slice(0, 5);

    setRecentSearches(updated);
    localStorage.setItem('searchDialog_recent', JSON.stringify(updated));
  };

  // ========================================================================
  // Keyboard Shortcuts
  // ========================================================================

  React.useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      // Cmd+K or Ctrl+K to open
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        setOpen(!open);
      }

      // Escape to close
      if (e.key === 'Escape' && open) {
        setOpen(false);
      }

      // Arrow keys for navigation (when open)
      if (!open) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setSelectedIndex((prev) =>
          Math.min(prev + 1, results.length - 1)
        );
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setSelectedIndex((prev) => Math.max(prev - 1, 0));
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (results.length > 0) {
          handleSelectResult(results[selectedIndex]);
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [open, results, selectedIndex]);

  // Reset selected index when results change
  React.useEffect(() => {
    setSelectedIndex(0);
  }, [results]);

  // ========================================================================
  // Handlers
  // ========================================================================

  const handleSelectResult = (result: SearchResult) => {
    saveRecentSearch(searchQuery);
    onSelect?.(result);
    setOpen(false);
    setSearchQuery('');
  };

  const groupedResults = React.useMemo(() => {
    const groups: Record<SearchResult['category'], SearchResult[]> = {
      users: [],
      posts: [],
      settings: [],
      pages: [],
      docs: [],
    };

    results.forEach((result) => {
      groups[result.category].push(result);
    });

    return groups;
  }, [results]);

  const categoryLabels: Record<SearchResult['category'], string> = {
    users: 'Users',
    posts: 'Posts',
    settings: 'Settings',
    pages: 'Pages',
    docs: 'Documentation',
  };

  const categoryIcons: Record<SearchResult['category'], React.ReactNode> = {
    users: (
      <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    ),
    posts: (
      <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
      </svg>
    ),
    settings: (
      <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    ),
    pages: (
      <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    ),
    docs: (
      <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C6.5 6.253 2 10.998 2 17.25S6.5 28 12 28s10-4.745 10-10.75S17.5 6.253 12 6.253z" />
      </svg>
    ),
  };

  // ========================================================================
  // Render
  // ========================================================================

  {% if saas_ui_framework == 'shadcn-ui' %}
  return (
    <CommandDialog open={open} onOpenChange={setOpen}>
      <DialogHeader className="border-b px-4 py-3">
        <DialogTitle className="text-sm font-normal">
          <CommandInput
            placeholder={placeholder}
            value={searchQuery}
            onValueChange={setSearchQuery}
            className="h-8 border-0 bg-transparent px-0 focus:ring-0"
          />
        </DialogTitle>
      </DialogHeader>

      <CommandList className="max-h-[min(400px,_var(--cmdk-list-height))]">
        {/* Loading state */}
        {isLoading && (
          <div className="flex items-center justify-center py-6">
            <div className="flex flex-col items-center gap-2">
              <div className="h-4 w-4 animate-spin rounded-full border-2 border-gray-300 border-t-gray-900" />
              <p className="text-xs text-gray-500">Searching...</p>
            </div>
          </div>
        )}

        {/* Error state */}
        {error && !isLoading && (
          <div className="flex items-center justify-center py-6">
            <p className="text-xs text-red-500">
              Search failed. Please try again.
            </p>
          </div>
        )}

        {/* Results */}
        {!isLoading && !error && results.length > 0 && (
          <>
            {Object.entries(groupedResults).map(
              ([category, items]) =>
                items.length > 0 && (
                  <CommandGroup
                    key={category}
                    heading={
                      <div className="flex items-center gap-2">
                        {categoryIcons[category as SearchResult['category']]}
                        <span>
                          {categoryLabels[category as SearchResult['category']]}
                        </span>
                      </div>
                    }
                  >
                    {items.map((result, index) => {
                      const globalIndex = results.findIndex(
                        (r) => r.id === result.id
                      );
                      return (
                        <CommandItem
                          key={result.id}
                          value={result.id}
                          onSelect={() => handleSelectResult(result)}
                          className={`cursor-pointer ${
                            globalIndex === selectedIndex
                              ? 'bg-accent'
                              : ''
                          }`}
                        >
                          <div className="flex flex-1 items-center gap-3">
                            {result.icon && (
                              <div className="flex-shrink-0">
                                {result.icon}
                              </div>
                            )}
                            <div className="flex-1 overflow-hidden">
                              <div className="truncate font-medium text-sm">
                                {result.title}
                              </div>
                              {result.description && (
                                <div className="truncate text-xs text-muted-foreground">
                                  {result.description}
                                </div>
                              )}
                            </div>
                          </div>
                        </CommandItem>
                      );
                    })}
                  </CommandGroup>
                )
            )}
            <CommandSeparator />
          </>
        )}

        {/* Empty state */}
        {!isLoading && !error && searchQuery && results.length === 0 && (
          <CommandEmpty className="flex flex-col items-center justify-center py-6">
            <svg
              className="h-8 w-8 text-gray-400 mb-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={1.5}
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              />
            </svg>
            <p className="text-sm font-medium text-gray-900 mb-1">
              No results found
            </p>
            <p className="text-xs text-gray-500">
              Try searching for something else
            </p>
          </CommandEmpty>
        )}

        {/* Recent searches (when empty) */}
        {!isLoading && !searchQuery && recentSearches.length > 0 && (
          <CommandGroup heading="Recent Searches">
            {recentSearches.map((query) => (
              <CommandItem
                key={query}
                value={query}
                onSelect={() => setSearchQuery(query)}
                className="cursor-pointer text-sm"
              >
                <svg
                  className="mr-2 h-4 w-4 text-gray-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    strokeWidth={2}
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span>{query}</span>
              </CommandItem>
            ))}
          </CommandGroup>
        )}

        {/* Initial state */}
        {!isLoading && !searchQuery && recentSearches.length === 0 && (
          <div className="flex flex-col items-center justify-center py-12">
            <svg
              className="h-8 w-8 text-gray-400 mb-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={1.5}
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              />
            </svg>
            <p className="text-sm font-medium text-gray-900 mb-1">
              Start searching
            </p>
            <p className="text-xs text-gray-500">
              Users, posts, settings, and more
            </p>
          </div>
        )}
      </CommandList>

      {/* Footer hints */}
      <div className="border-t px-4 py-2 flex items-center justify-between gap-2">
        <div className="flex gap-2 text-xs text-muted-foreground">
          <span className="inline-flex h-5 items-center rounded border border-gray-300 px-1.5 font-mono">
            ↑↓
          </span>
          <span>Navigate</span>
          <span className="inline-flex h-5 items-center rounded border border-gray-300 px-1.5 font-mono">
            ↵
          </span>
          <span>Select</span>
          <span className="inline-flex h-5 items-center rounded border border-gray-300 px-1.5 font-mono">
            esc
          </span>
          <span>Close</span>
        </div>
      </div>
    </CommandDialog>
  );
  {% else %}
  // Fallback implementation for non-shadcn-ui frameworks
  return (
    <>
      {/* Trigger Button - Can be placed in header */}
      <button
        onClick={() => setOpen(true)}
        className="hidden md:inline-flex h-9 w-full items-center justify-between rounded-md border border-gray-200 bg-white px-3 py-2 text-sm text-gray-500 hover:bg-gray-50"
      >
        <span>Search...</span>
        <span className="text-xs text-gray-400">⌘K</span>
      </button>

      {/* Dialog Overlay */}
      {open && (
        <div
          className="fixed inset-0 z-50 bg-black/50"
          onClick={() => setOpen(false)}
        >
          {/* Dialog Content */}
          <div
            className="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl rounded-lg bg-white shadow-lg"
            onClick={(e) => e.stopPropagation()}
          >
            {/* Search Input */}
            <div className="border-b px-4 py-3">
              <input
                type="text"
                placeholder={placeholder}
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                autoFocus
                className="w-full border-0 bg-transparent text-lg outline-none"
              />
            </div>

            {/* Results List */}
            <div className="max-h-96 overflow-y-auto py-2">
              {/* Loading state */}
              {isLoading && (
                <div className="flex items-center justify-center py-8">
                  <div className="text-sm text-gray-500">Searching...</div>
                </div>
              )}

              {/* Results */}
              {!isLoading && results.length > 0 && (
                <div className="space-y-4 px-2">
                  {Object.entries(groupedResults).map(
                    ([category, items]) =>
                      items.length > 0 && (
                        <div key={category}>
                          <div className="px-2 py-1 text-xs font-semibold uppercase text-gray-500">
                            {categoryLabels[category as SearchResult['category']]}
                          </div>
                          {items.map((result) => (
                            <button
                              key={result.id}
                              onClick={() => handleSelectResult(result)}
                              className="w-full text-left rounded-md px-2 py-2 hover:bg-gray-100"
                            >
                              <div className="font-medium text-sm">
                                {result.title}
                              </div>
                              {result.description && (
                                <div className="text-xs text-gray-500">
                                  {result.description}
                                </div>
                              )}
                            </button>
                          ))}
                        </div>
                      )
                  )}
                </div>
              )}

              {/* Empty state */}
              {!isLoading && searchQuery && results.length === 0 && (
                <div className="flex flex-col items-center justify-center py-8">
                  <p className="text-sm font-medium text-gray-900">
                    No results found
                  </p>
                  <p className="text-xs text-gray-500">
                    Try searching for something else
                  </p>
                </div>
              )}

              {/* Initial state */}
              {!isLoading && !searchQuery && (
                <div className="flex flex-col items-center justify-center py-8">
                  <p className="text-sm font-medium text-gray-900">
                    Start searching
                  </p>
                  <p className="text-xs text-gray-500">
                    Users, posts, settings, and more
                  </p>
                </div>
              )}
            </div>

            {/* Footer */}
            <div className="border-t px-4 py-2 text-xs text-gray-500">
              Press <kbd className="rounded bg-gray-100 px-1">esc</kbd> to close
            </div>
          </div>
        </div>
      )}
    </>
  );
  {% endif %}
}

// ============================================================================
// Search Trigger Button (can be placed in header)
// ============================================================================

export function SearchTrigger() {
  return (
    <div
      className="hidden md:block cursor-pointer group"
      onClick={() => {
        // Trigger by clicking - the dialog listens for Cmd+K globally
        const event = new KeyboardEvent('keydown', {
          key: 'k',
          metaKey: true,
        });
        window.dispatchEvent(event);
      }}
    >
      {% if saas_ui_framework == 'shadcn-ui' %}
      <Button variant="outline" className="relative h-9 w-full justify-start text-sm text-muted-foreground shadow-none sm:pr-12 lg:w-64">
        <svg
          className="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            strokeLinecap="round"
            strokeLinejoin="round"
            strokeWidth={2}
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          />
        </svg>
        <span className="hidden lg:inline-flex">Search...</span>
        <span className="inline lg:hidden">Search...</span>
        <kbd className="pointer-events-none absolute right-1.5 hidden h-6 select-none items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium opacity-100 sm:flex">
          <span className="text-xs">⌘</span>K
        </kbd>
      </Button>
      {% else %}
      <button className="hidden md:inline-flex h-9 w-64 items-center justify-between rounded-md border border-gray-200 bg-white px-3 py-2 text-sm text-gray-500 hover:bg-gray-50">
        <span>Search...</span>
        <span className="text-xs text-gray-400">⌘K</span>
      </button>
      {% endif %}
    </div>
  );
}

// ============================================================================
// Hook: useSearchDialog
// ============================================================================

/**
 * Hook for programmatic control of the search dialog
 *
 * @example
 * ```tsx
 * const { open, setOpen } = useSearchDialog();
 *
 * return (
 *   <>
 *     <button onClick={() => setOpen(true)}>Open Search</button>
 *     <SearchDialog open={open} onOpenChange={setOpen} />
 *   </>
 * );
 * ```
 */
export function useSearchDialog() {
  const [open, setOpen] = React.useState(false);

  React.useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        setOpen((prev) => !prev);
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, []);

  return { open, setOpen };
}

{% endif %}
