{% if saas_infra_module == "enabled" and saas_blog and saas_runtime == "nextjs-16" %}
import Link from 'next/link';
import type { BlogPostMeta } from '@/lib/blog';

interface PostCardProps {
  post: BlogPostMeta;
}

export function PostCard({ post }: PostCardProps) {
  return (
    <article className="group relative flex flex-col rounded-lg border bg-card p-6 transition-colors hover:bg-accent">
      <Link href={`/blog/${post.slug}`} className="absolute inset-0">
        <span className="sr-only">Read {post.title}</span>
      </Link>

      <h2 className="text-xl font-semibold tracking-tight mb-2 group-hover:text-accent-foreground">
        {post.title}
      </h2>

      {post.description && (
        <p className="text-muted-foreground mb-4 line-clamp-2">
          {post.description}
        </p>
      )}

      <div className="mt-auto flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
        <span>{post.author}</span>
        <span>•</span>
        <time dateTime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
        <span>•</span>
        <span>{post.readingTime}</span>
      </div>

      {post.tags.length > 0 && (
        <div className="flex flex-wrap gap-2 mt-4">
          {post.tags.map((tag) => (
            <span
              key={tag}
              className="px-2 py-0.5 text-xs rounded-full bg-muted"
            >
              {tag}
            </span>
          ))}
        </div>
      )}
    </article>
  );
}
{% endif %}
