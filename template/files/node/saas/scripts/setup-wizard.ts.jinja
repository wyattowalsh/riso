async function checkNodeModules(): Promise<void> {
  log('\n--- Checking Dependencies ---\n', 'bright');

  const nodeModulesPath = path.join(projectRoot, 'node_modules');

  if (!fs.existsSync(nodeModulesPath)) {
    logWarning('node_modules not found');
    const installDeps = await question(
      'Would you like to run "pnpm install"? (yes/no)'
    );

    if (
      installDeps.toLowerCase() === 'yes' ||
      installDeps.toLowerCase() === 'y'
    ) {
      try {
        logInfo('Installing dependencies...');
        execSync('pnpm install', { stdio: 'inherit', cwd: projectRoot });
        logSuccess('Dependencies installed');
      } catch (error) {
        logError('Failed to install dependencies');
      }
    }
  } else {
    logSuccess('node_modules found');
  }
}

async function checkDatabase(): Promise<void> {
  log('\n--- Database Setup ---\n', 'bright');

  const runGenerate = await question(
    'Would you like to run "pnpm db:generate"? (yes/no)'
  );

  if (
    runGenerate.toLowerCase() === 'yes' ||
    runGenerate.toLowerCase() === 'y'
  ) {
    try {
      logInfo('Generating database client...');
      execSync('pnpm db:generate', { stdio: 'inherit', cwd: projectRoot });
      logSuccess('Database client generated');
    } catch (error) {
      logError('Failed to generate database client');
    }
  }

  const runPush = await question(
    'Would you like to run "pnpm db:push"? (yes/no)'
  );

  if (runPush.toLowerCase() === 'yes' || runPush.toLowerCase() === 'y') {
    try {
      logInfo('Pushing database schema...');
      execSync('pnpm db:push', { stdio: 'inherit', cwd: projectRoot });
      logSuccess('Database schema pushed');
    } catch (error) {
      logError('Failed to push database schema');
    }
  }
}

async function main() {
  log('\n╔════════════════════════════════════════════════════════╗', 'bright');
  log('║      {{ project_name }} - Setup Wizard                 ║', 'bright');
  log('╚════════════════════════════════════════════════════════╝\n', 'bright');

  // Check versions
  log('--- Checking Prerequisites ---\n', 'bright');
  const nodeOk = await checkNodeVersion();
  const pnpmOk = await checkPnpmVersion();

  if (!nodeOk || !pnpmOk) {
    logError(
      'Please install the required versions and try again.'
    );
    rl.close();
    process.exit(1);
  }

  // Check and create .env.local
  await checkEnvFile();

  // Prompt for environment variables
  await promptForRequiredEnvVars();

  // Check dependencies
  await checkNodeModules();

  // Database setup
  await checkDatabase();

  // Success message
  log('\n╔════════════════════════════════════════════════════════╗', 'green');
  log('║                  Setup Complete! 🎉                   ║', 'green');
  log('╚════════════════════════════════════════════════════════╝\n', 'green');

  logSuccess('.env.local has been configured');
  logSuccess('All prerequisites have been checked');

  log('\n--- Next Steps ---\n', 'bright');
  log('1. Review your .env.local file for any placeholder values', 'bright');
  log('2. Run "pnpm dev" to start the development server', 'bright');
  log('3. Open http://localhost:3000 in your browser', 'bright');
  log('4. Check out the documentation at {{ project_name }}/docs', 'bright');

  rl.close();
}

main().catch((error) => {
  logError(`Setup wizard error: ${error.message}`);
  rl.close();
  process.exit(1);
});
