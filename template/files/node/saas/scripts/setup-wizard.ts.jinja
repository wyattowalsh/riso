#!/usr/bin/env node
import * as readline from 'readline';
import * as fs from 'fs';
import * as path from 'path';
import { execSync } from 'child_process';

interface EnvConfig {
  [key: string]: string | undefined;
}

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
});

const projectRoot = process.cwd();
const envLocalPath = path.join(projectRoot, '.env.local');
const envExamplePath = path.join(projectRoot, '.env.example');

let envConfig: EnvConfig = {};

// Color codes for terminal output
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  red: '\x1b[31m',
};

function log(message: string, color: keyof typeof colors = 'reset') {
  console.log(`${colors[color]}${message}${colors.reset}`);
}

function logSuccess(message: string) {
  log(`✓ ${message}`, 'green');
}

function logError(message: string) {
  log(`✗ ${message}`, 'red');
}

function logInfo(message: string) {
  log(`ℹ ${message}`, 'blue');
}

function logWarning(message: string) {
  log(`⚠ ${message}`, 'yellow');
}

function question(prompt: string): Promise<string> {
  return new Promise((resolve) => {
    rl.question(`${colors.bright}${prompt}${colors.reset} `, (answer) => {
      resolve(answer.trim());
    });
  });
}

async function checkNodeVersion(): Promise<boolean> {
  try {
    const nodeVersion = process.version;
    const majorVersion = parseInt(nodeVersion.split('.')[0].substring(1), 10);

    if (majorVersion < 20) {
      logError(`Node.js version must be >= 20 (you have ${nodeVersion})`);
      return false;
    }

    logSuccess(`Node.js version ${nodeVersion} is compatible`);
    return true;
  } catch (error) {
    logError('Failed to check Node.js version');
    return false;
  }
}

async function checkPnpmVersion(): Promise<boolean> {
  try {
    const pnpmVersion = execSync('pnpm --version', { encoding: 'utf-8' }).trim();
    const majorVersion = parseInt(pnpmVersion.split('.')[0], 10);

    if (majorVersion < 9) {
      logError(`pnpm version must be >= 9 (you have ${pnpmVersion})`);
      return false;
    }

    logSuccess(`pnpm version ${pnpmVersion} is compatible`);
    return true;
  } catch (error) {
    logError('pnpm is not installed or not in PATH');
    return false;
  }
}

async function checkEnvFile(): Promise<void> {
  if (fs.existsSync(envLocalPath)) {
    logSuccess('.env.local already exists');
    const contents = fs.readFileSync(envLocalPath, 'utf-8');
    envConfig = parseEnvFile(contents);
    return;
  }

  logWarning('.env.local not found');

  if (!fs.existsSync(envExamplePath)) {
    logError('.env.example not found');
    return;
  }

  const createEnv = await question(
    'Would you like to create .env.local from .env.example? (yes/no)'
  );

  if (createEnv.toLowerCase() === 'yes' || createEnv.toLowerCase() === 'y') {
    const exampleContents = fs.readFileSync(envExamplePath, 'utf-8');
    fs.copyFileSync(envExamplePath, envLocalPath);
    logSuccess('Created .env.local from .env.example');
    envConfig = parseEnvFile(exampleContents);
  }
}

function parseEnvFile(contents: string): EnvConfig {
  const config: EnvConfig = {};
  const lines = contents.split('\n');

  for (const line of lines) {
    const trimmed = line.trim();

    // Skip comments and empty lines
    if (!trimmed || trimmed.startsWith('#')) {
      continue;
    }

    const [key, ...valueParts] = trimmed.split('=');
    if (key) {
      config[key.trim()] = valueParts.join('=').trim();
    }
  }

  return config;
}

function updateEnvFile(key: string, value: string): void {
  let contents = '';

  if (fs.existsSync(envLocalPath)) {
    contents = fs.readFileSync(envLocalPath, 'utf-8');
  }

  const lines = contents.split('\n');
  let found = false;

  const updatedLines = lines.map((line) => {
    const trimmed = line.trim();
    if (trimmed.startsWith(`${key}=`)) {
      found = true;
      return `${key}="${value}"`;
    }
    return line;
  });

  if (!found && value) {
    updatedLines.push(`${key}="${value}"`);
  }

  fs.writeFileSync(envLocalPath, updatedLines.join('\n'), 'utf-8');
  envConfig[key] = value;
}

async function promptForEnvVar(
  key: string,
  description: string,
  required: boolean = true,
  defaultValue?: string
): Promise<string> {
  const existing = envConfig[key];
  if (existing) {
    logInfo(`${key} is already set`);
    return existing;
  }

  const suffix = required ? ' (required)' : ' (optional)';
  const prompt = defaultValue ? ` [${defaultValue}]` : '';
  const answer = await question(`${description}${suffix}${prompt}:`);

  if (!answer && !required && defaultValue) {
    return defaultValue;
  }

  if (!answer && required) {
    logWarning(`${key} is required. Please provide a value.`);
    return promptForEnvVar(key, description, required, defaultValue);
  }

  return answer;
}

