{% if saas_starter_module == "enabled" %}
{
  "name": "{{ project_slug }}",
  "version": "0.1.0",
  "private": true,
  "description": "{{ project_name }} - Production-ready SaaS application",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    {# Development #}
    "dev": "{% if saas_runtime == 'nextjs-16' %}next dev --turbo{% else %}remix dev{% endif %}",
    "build": "{% if saas_runtime == 'nextjs-16' %}next build{% else %}remix build{% endif %}",
    "start": "{% if saas_runtime == 'nextjs-16' %}next start{% else %}remix-serve build/index.js{% endif %}",
    
    {# Database #}
    "db:generate": "{% if saas_orm == 'prisma' %}prisma generate{% else %}drizzle-kit generate{% endif %}",
    "db:push": "{% if saas_orm == 'prisma' %}prisma db push{% else %}drizzle-kit push{% endif %}",
    "db:studio": "{% if saas_orm == 'prisma' %}prisma studio{% else %}drizzle-kit studio{% endif %}",
    {% if saas_orm == 'prisma' %}
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    {% else %}
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    {% endif %}
    {% if saas_include_fixtures %}
    "db:seed": "{% if saas_runtime == 'nextjs-16' %}tsx{% else %}tsx{% endif %} {% if saas_orm == 'prisma' %}prisma/seed.ts{% else %}db/seed.ts{% endif %}",
    {% endif %}
    
    {# Testing #}
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    {% if saas_test_suite_level == 'comprehensive' %}
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    {% endif %}
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    
    {# Code Quality #}
    "lint": "{% if saas_runtime == 'nextjs-16' %}next lint{% else %}eslint .{% endif %}",
    "lint:fix": "{% if saas_runtime == 'nextjs-16' %}next lint --fix{% else %}eslint . --fix{% endif %}",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    
    {# Validation #}
    "validate:env": "tsx scripts/validate-env.ts",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    
    {# Deployment Preparation #}
    "prebuild": "pnpm run db:generate",
    "postinstall": "{% if saas_orm == 'prisma' %}prisma generate{% endif %}"
  },
  "dependencies": {
    {# Runtime Framework #}
    {% if saas_runtime == 'nextjs-16' %}
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    {% else %}
    "@remix-run/node": "^2.12.0",
    "@remix-run/react": "^2.12.0",
    "@remix-run/serve": "^2.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    {% endif %}
    
    {# ORM & Database #}
    {% if saas_orm == 'prisma' %}
    "@prisma/client": "^5.20.0",
    {% else %}
    "drizzle-orm": "^0.33.0",
    {% if saas_database == 'neon' %}
    "@neondatabase/serverless": "^0.9.0",
    {% endif %}
    {% endif %}
    {% if saas_database == 'supabase' %}
    "@supabase/supabase-js": "^2.45.0",
    {% endif %}
    
    {# Authentication #}
    {% if saas_auth == 'clerk' %}
    "@clerk/{% if saas_runtime == 'nextjs-16' %}nextjs{% else %}remix{% endif %}": "^5.5.0",
    {% else %}
    "next-auth": "5.0.0-beta.22",
    "@auth/prisma-adapter": "^2.6.0",
    {% endif %}
    
    {% if saas_enterprise_bridge == 'workos' %}
    {# WorkOS Enterprise #}
    "@workos-inc/node": "^7.17.0",
    {% endif %}
    
    {# Billing #}
    {% if saas_billing == 'stripe' %}
    "stripe": "^16.12.0",
    {% else %}
    "@paddle/paddle-node-sdk": "^1.7.0",
    {% endif %}
    
    {# Background Jobs #}
    {% if saas_jobs == 'triggerdev' %}
    "@trigger.dev/sdk": "^3.0.0",
    {% else %}
    "inngest": "^3.22.0",
    {% endif %}
    
    {# Email #}
    {% if saas_email == 'resend' %}
    "resend": "^4.0.0",
    "@react-email/components": "^0.0.25",
    "react-email": "^3.0.0",
    {% else %}
    "postmark": "^4.0.0",
    {% endif %}
    
    {# Analytics #}
    {% if saas_analytics == 'posthog' %}
    "posthog-js": "^1.163.0",
    {% else %}
    "@amplitude/analytics-browser": "^2.11.0",
    {% endif %}
    
    {# AI #}
    {% if saas_ai == 'openai' %}
    "openai": "^4.63.0",
    {% else %}
    "@anthropic-ai/sdk": "^0.30.0",
    {% endif %}
    
    {# Storage #}
    {% if saas_storage == 'r2' %}
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    {% endif %}
    
    {# Observability #}
    {% if saas_observability_sentry %}
    "@sentry/{% if saas_runtime == 'nextjs-16' %}nextjs{% else %}remix{% endif %}": "^8.33.0",
    {% endif %}
    {% if saas_observability_datadog %}
    "dd-trace": "^5.23.0",
    {% endif %}
    {% if saas_observability_otel %}
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    {% endif %}
    {% if saas_observability_structured_logging %}
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "nanoid": "^5.0.7",
    {% endif %}
    
    {# Core Utilities #}
    "@t3-oss/env-nextjs": "^0.11.1",
    "zod": "^3.23.8",
    {% if saas_include_factories %}
    "@faker-js/faker": "^9.0.0",
    {% endif %}
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2",
    
    {# Webhook Verification #}
    {% if saas_auth == 'clerk' %}
    "svix": "^1.33.0",
    {% endif %}
    
    {# ID Generation (Drizzle) #}
    {% if saas_orm == 'drizzle' %}
    "@paralleldrive/cuid2": "^2.2.2",
    {% endif %}
    
    {# UI Framework #}
    {% if saas_ui_framework == 'shadcn-ui' %}
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.441.0",
    {% elif saas_ui_framework == 'radix-primitives' %}
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    {% elif saas_ui_framework == 'headless-ui' %}
    "@headlessui/react": "^2.1.8",
    "lucide-react": "^0.441.0",
    {% endif %}
    
    {# Form Library #}
    {% if saas_form_library == 'react-hook-form' %}
    "react-hook-form": "^7.53.0",
    "@hookform/resolvers": "^3.9.0",
    {% elif saas_form_library == 'conform' %}
    "@conform-to/react": "^1.2.0",
    "@conform-to/zod": "^1.2.0",
    {% endif %}
    
    {# Real-time #}
    {% if saas_realtime == 'pusher' %}
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    {% elif saas_realtime == 'ably' %}
    "ably": "^2.3.1",
    {% elif saas_realtime == 'supabase-realtime' and saas_database == 'supabase' %}
    {# Supabase JS already includes realtime #}
    {% endif %}
    
    {# Rate Limiting #}
    {% if saas_rate_limiting == 'upstash' %}
    "@upstash/ratelimit": "^2.0.2",
    "@upstash/redis": "^1.34.0",
    {% endif %}
    
    {# File Upload #}
    {% if saas_file_upload == 'uploadthing' %}
    "uploadthing": "^7.0.2",
    "@uploadthing/react": "^7.0.2",
    {% elif saas_file_upload == 'react-dropzone' %}
    "react-dropzone": "^14.2.3",
    {% endif %}
    
    {# API Documentation #}
    {% if saas_api_docs %}
    "swagger-ui-react": "^5.17.14",
    "zod-to-openapi": "^7.1.1",
    {% endif %}
    
    {# GDPR Tools #}
    {% if saas_gdpr_tools %}
    "archiver": "^7.0.1",
    {% endif %}
    
    {# 2FA (Auth.js only) #}
    {% if saas_2fa and saas_auth == 'authjs' %}
    "otpauth": "^9.3.1",
    "qrcode": "^1.5.4",
    {% endif %}
    
    {# i18n #}
    {% if saas_i18n %}
    {% if saas_runtime == 'nextjs-16' %}
    "next-intl": "^3.19.4",
    {% else %}
    "remix-i18next": "^6.4.0",
    "i18next": "^23.15.1",
    "react-i18next": "^15.0.2",
    {% endif %}
    {% endif %}
    
    {# Blog (MDX) #}
    {% if saas_blog %}
    "@next/mdx": "^15.0.0",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "gray-matter": "^4.0.3",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    {% endif %}
  },
  "devDependencies": {
    {# TypeScript #}
    "typescript": "^5.6.2",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    
    {# Next.js / Remix specific #}
    {% if saas_runtime == 'nextjs-16' %}
    "@next/eslint-plugin-next": "^15.0.0",
    {% else %}
    "@remix-run/dev": "^2.12.0",
    "vite": "^5.4.6",
    "vite-tsconfig-paths": "^5.0.1",
    {% endif %}
    
    {# ORM Development Tools #}
    {% if saas_orm == 'prisma' %}
    "prisma": "^5.20.0",
    {% else %}
    "drizzle-kit": "^0.24.0",
    {% if saas_database == 'neon' %}
    "pg": "^8.13.0",
    {% endif %}
    {% endif %}
    
    {# Testing #}
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.5.0",
    {% if saas_test_suite_level == 'comprehensive' %}
    "@playwright/test": "^1.47.0",
    {% endif %}
    
    {# Code Quality #}
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    
    {# Build Tools #}
    "tsx": "^4.19.0",
    "dotenv-cli": "^7.4.2",
    
    {# Styling #}
    "tailwindcss": "^3.4.11",
    "postcss": "^8.4.45",
    "autoprefixer": "^10.4.20",
    
    {# Type definitions for new features #}
    {% if saas_gdpr_tools %}
    "@types/archiver": "^6.0.2",
    {% endif %}
    {% if saas_2fa and saas_auth == 'authjs' %}
    "@types/qrcode": "^1.5.5",
    {% endif %}
    {% if saas_api_docs %}
    "@types/swagger-ui-react": "^4.18.3",
    {% endif %}
    
    {# i18n tooling #}
    {% if saas_i18n %}
    "i18next-parser": "^9.0.2"
    {% endif %}
  }
}
{% endif %}
