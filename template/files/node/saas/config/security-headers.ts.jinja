{% if saas_runtime == 'remix-2' %}
/**
 * Remix security headers for entry.server.tsx
 * 
 * @example
 * ```tsx
 * import { getSecurityHeaders } from '~/config/security-headers';
 * 
 * export default function handleRequest(
 *   request: Request,
 *   responseStatusCode: number,
 *   responseHeaders: Headers,
 *   remixContext: EntryContext
 * ) {
 *   const securityHeaders = getSecurityHeaders();
 *   Object.entries(securityHeaders).forEach(([key, value]) => {
 *     responseHeaders.set(key, value);
 *   });
 *   
 *   // ... rest of handler
 * }
 * ```
 */
export { getSecurityHeaders };
{% endif %}

// ============================================================================
// Nonce Generation (for stricter CSP)
// ============================================================================

/**
 * Generate a cryptographic nonce for inline scripts
 * Use when you need stricter CSP without 'unsafe-inline'
 */
export function generateNonce(): string {
  if (typeof crypto !== 'undefined' && crypto.randomUUID) {
    return Buffer.from(crypto.randomUUID()).toString('base64');
  }
  // Fallback for environments without crypto
  return Buffer.from(Math.random().toString(36).substring(2)).toString('base64');
}

/**
 * Create CSP with nonce for inline scripts
 */
export function getCSPWithNonce(nonce: string): Record<string, string[]> {
  const csp = { ...defaultCSP };
  csp['script-src'] = csp['script-src'].filter(
    (src) => src !== "'unsafe-inline'" && src !== "'unsafe-eval'"
  );
  csp['script-src'].push(`'nonce-${nonce}'`);
  csp['style-src'] = csp['style-src'].filter((src) => src !== "'unsafe-inline'");
  csp['style-src'].push(`'nonce-${nonce}'`);
  return csp;
}
{% endif %}
