{% if saas_starter_module == "enabled" %}
/**
 * Environment Variable Validation
 * 
 * Type-safe environment variable validation using @t3-oss/env-nextjs.
 * Validates all required env vars at build time to prevent runtime errors.
 * 
 * Usage:
 * ```ts
 * import { env } from '@/config/env';
 * console.log(env.DATABASE_URL);
 * ```
 * 
 * @see https://env.t3.gg
 */

import { createEnv } from '@t3-oss/env-nextjs';
import { z } from 'zod';

export const env = createEnv({
  /**
   * Server-side environment variables (not exposed to client)
   */
  server: {
    NODE_ENV: z.enum(['development', 'test', 'production']).default('development'),
    
    // ========================================================================
    // Database
    // ========================================================================
    {% if saas_database == 'neon' %}
    DATABASE_URL: z.string().url().startsWith('postgres'),
    {% elif saas_database == 'supabase' %}
    DATABASE_URL: z.string().url().startsWith('postgres'),
    SUPABASE_SERVICE_ROLE_KEY: z.string().min(1),
    {% endif %}
    
    // ========================================================================
    // Authentication
    // ========================================================================
    {% if saas_auth == 'clerk' %}
    CLERK_SECRET_KEY: z.string().startsWith('sk_'),
    CLERK_WEBHOOK_SECRET: z.string().startsWith('whsec_').optional(),
    {% elif saas_auth == 'authjs' %}
    AUTH_SECRET: z.string().min(32),
    AUTH_URL: z.string().url().optional(),
    {% endif %}
    
    {% if saas_enterprise_bridge == 'workos' %}
    // WorkOS (Enterprise SSO)
    WORKOS_API_KEY: z.string().startsWith('sk_'),
    WORKOS_CLIENT_ID: z.string().startsWith('client_'),
    WORKOS_WEBHOOK_SECRET: z.string().optional(),
    {% endif %}
    
    // ========================================================================
    // Billing
    // ========================================================================
    {% if saas_billing == 'stripe' %}
    STRIPE_SECRET_KEY: z.string().startsWith('sk_'),
    STRIPE_WEBHOOK_SECRET: z.string().startsWith('whsec_'),
    {% elif saas_billing == 'paddle' %}
    PADDLE_API_KEY: z.string().min(1),
    PADDLE_WEBHOOK_SECRET: z.string().min(1),
    {% endif %}
    
    // ========================================================================
    // Email
    // ========================================================================
    {% if saas_email == 'resend' %}
    RESEND_API_KEY: z.string().startsWith('re_'),
    {% elif saas_email == 'postmark' %}
    POSTMARK_API_KEY: z.string().min(1),
    {% endif %}
    EMAIL_FROM: z.string().email().optional(),
    
    // ========================================================================
    // Background Jobs
    // ========================================================================
    {% if saas_jobs == 'triggerdev' %}
    TRIGGER_API_KEY: z.string().startsWith('tr_'),
    TRIGGER_API_URL: z.string().url().optional(),
    {% elif saas_jobs == 'inngest' %}
    INNGEST_EVENT_KEY: z.string().optional(),
    INNGEST_SIGNING_KEY: z.string().optional(),
    {% endif %}
    
    // ========================================================================
    // Storage
    // ========================================================================
    {% if saas_storage == 'r2' %}
    R2_ACCESS_KEY_ID: z.string().min(1),
    R2_SECRET_ACCESS_KEY: z.string().min(1),
    R2_BUCKET_NAME: z.string().min(1),
    R2_ACCOUNT_ID: z.string().min(1),
    {% elif saas_storage == 'supabase-storage' %}
    // Uses SUPABASE_SERVICE_ROLE_KEY from above
    {% endif %}
    
    // ========================================================================
    // AI
    // ========================================================================
    {% if saas_ai == 'openai' %}
    OPENAI_API_KEY: z.string().startsWith('sk-'),
    {% elif saas_ai == 'anthropic' %}
    ANTHROPIC_API_KEY: z.string().startsWith('sk-ant-'),
    {% endif %}
    
    // ========================================================================
    // Observability
    // ========================================================================
    {% if saas_observability_sentry %}
    SENTRY_DSN: z.string().url().optional(),
    SENTRY_AUTH_TOKEN: z.string().optional(),
    {% endif %}
    {% if saas_observability_datadog %}
    DD_API_KEY: z.string().optional(),
    DD_APP_KEY: z.string().optional(),
    {% endif %}
    
    // ========================================================================
    // Real-time
    // ========================================================================
    {% if saas_realtime == 'pusher' %}
    PUSHER_APP_ID: z.string().min(1),
    PUSHER_SECRET: z.string().min(1),
    {% elif saas_realtime == 'ably' %}
    ABLY_API_KEY: z.string().includes(':'),
    {% endif %}
    
    // ========================================================================
    // Rate Limiting
    // ========================================================================
    {% if saas_rate_limiting == 'upstash' %}
    UPSTASH_REDIS_REST_URL: z.string().url(),
    UPSTASH_REDIS_REST_TOKEN: z.string().min(1),
    {% endif %}
    
    // ========================================================================
    // File Upload
    // ========================================================================
    {% if saas_file_upload == 'uploadthing' %}
    UPLOADTHING_SECRET: z.string().startsWith('sk_'),
    UPLOADTHING_APP_ID: z.string().min(1),
    {% endif %}
  },
  
  /**
   * Client-side environment variables (exposed to browser)
   * Must be prefixed with NEXT_PUBLIC_
   */
  client: {
    NEXT_PUBLIC_APP_URL: z.string().url(),
    NEXT_PUBLIC_APP_NAME: z.string().default('{{ project_name }}'),
    
    {% if saas_auth == 'clerk' %}
    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: z.string().startsWith('pk_'),
    NEXT_PUBLIC_CLERK_SIGN_IN_URL: z.string().default('/sign-in'),
    NEXT_PUBLIC_CLERK_SIGN_UP_URL: z.string().default('/sign-up'),
    NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL: z.string().default('/dashboard'),
    NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL: z.string().default('/onboarding'),
    {% endif %}
    
    {% if saas_database == 'supabase' %}
    NEXT_PUBLIC_SUPABASE_URL: z.string().url(),
    NEXT_PUBLIC_SUPABASE_ANON_KEY: z.string().min(1),
    {% endif %}
    
    {% if saas_billing == 'stripe' %}
    NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: z.string().startsWith('pk_'),
    {% elif saas_billing == 'paddle' %}
    NEXT_PUBLIC_PADDLE_CLIENT_TOKEN: z.string().min(1),
    NEXT_PUBLIC_PADDLE_ENVIRONMENT: z.enum(['sandbox', 'production']).default('sandbox'),
    {% endif %}
    
    {% if saas_analytics == 'posthog' %}
    NEXT_PUBLIC_POSTHOG_KEY: z.string().startsWith('phc_'),
    NEXT_PUBLIC_POSTHOG_HOST: z.string().url().default('https://app.posthog.com'),
    {% elif saas_analytics == 'amplitude' %}
    NEXT_PUBLIC_AMPLITUDE_API_KEY: z.string().min(1),
    {% endif %}
    
    {% if saas_realtime == 'pusher' %}
    NEXT_PUBLIC_PUSHER_KEY: z.string().min(1),
    NEXT_PUBLIC_PUSHER_CLUSTER: z.string().min(1),
    {% endif %}
    
    {% if saas_observability_sentry %}
    NEXT_PUBLIC_SENTRY_DSN: z.string().url().optional(),
    {% endif %}
  },
  
  /**
   * Runtime environment variables
   * Maps process.env to the validated schema
   */
  runtimeEnv: {
    NODE_ENV: process.env.NODE_ENV,
    
    // Server
    {% if saas_database == 'neon' %}
    DATABASE_URL: process.env.DATABASE_URL,
    {% elif saas_database == 'supabase' %}
    DATABASE_URL: process.env.DATABASE_URL,
    SUPABASE_SERVICE_ROLE_KEY: process.env.SUPABASE_SERVICE_ROLE_KEY,
    {% endif %}
    
    {% if saas_auth == 'clerk' %}
    CLERK_SECRET_KEY: process.env.CLERK_SECRET_KEY,
    CLERK_WEBHOOK_SECRET: process.env.CLERK_WEBHOOK_SECRET,
    {% elif saas_auth == 'authjs' %}
    AUTH_SECRET: process.env.AUTH_SECRET,
    AUTH_URL: process.env.AUTH_URL,
    {% endif %}
    
    {% if saas_enterprise_bridge == 'workos' %}
    WORKOS_API_KEY: process.env.WORKOS_API_KEY,
    WORKOS_CLIENT_ID: process.env.WORKOS_CLIENT_ID,
    WORKOS_WEBHOOK_SECRET: process.env.WORKOS_WEBHOOK_SECRET,
    {% endif %}
    
    {% if saas_billing == 'stripe' %}
    STRIPE_SECRET_KEY: process.env.STRIPE_SECRET_KEY,
    STRIPE_WEBHOOK_SECRET: process.env.STRIPE_WEBHOOK_SECRET,
    {% elif saas_billing == 'paddle' %}
    PADDLE_API_KEY: process.env.PADDLE_API_KEY,
    PADDLE_WEBHOOK_SECRET: process.env.PADDLE_WEBHOOK_SECRET,
    {% endif %}
    
    {% if saas_email == 'resend' %}
    RESEND_API_KEY: process.env.RESEND_API_KEY,
    {% elif saas_email == 'postmark' %}
    POSTMARK_API_KEY: process.env.POSTMARK_API_KEY,
    {% endif %}
    EMAIL_FROM: process.env.EMAIL_FROM,
    
    {% if saas_jobs == 'triggerdev' %}
    TRIGGER_API_KEY: process.env.TRIGGER_API_KEY,
    TRIGGER_API_URL: process.env.TRIGGER_API_URL,
    {% elif saas_jobs == 'inngest' %}
    INNGEST_EVENT_KEY: process.env.INNGEST_EVENT_KEY,
    INNGEST_SIGNING_KEY: process.env.INNGEST_SIGNING_KEY,
    {% endif %}
    
    {% if saas_storage == 'r2' %}
    R2_ACCESS_KEY_ID: process.env.R2_ACCESS_KEY_ID,
    R2_SECRET_ACCESS_KEY: process.env.R2_SECRET_ACCESS_KEY,
    R2_BUCKET_NAME: process.env.R2_BUCKET_NAME,
    R2_ACCOUNT_ID: process.env.R2_ACCOUNT_ID,
    {% endif %}
    
    {% if saas_ai == 'openai' %}
    OPENAI_API_KEY: process.env.OPENAI_API_KEY,
    {% elif saas_ai == 'anthropic' %}
    ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY,
    {% endif %}
    
    {% if saas_observability_sentry %}
    SENTRY_DSN: process.env.SENTRY_DSN,
    SENTRY_AUTH_TOKEN: process.env.SENTRY_AUTH_TOKEN,
    {% endif %}
    {% if saas_observability_datadog %}
    DD_API_KEY: process.env.DD_API_KEY,
    DD_APP_KEY: process.env.DD_APP_KEY,
    {% endif %}
    
    {% if saas_realtime == 'pusher' %}
    PUSHER_APP_ID: process.env.PUSHER_APP_ID,
    PUSHER_SECRET: process.env.PUSHER_SECRET,
    {% elif saas_realtime == 'ably' %}
    ABLY_API_KEY: process.env.ABLY_API_KEY,
    {% endif %}
    
    {% if saas_rate_limiting == 'upstash' %}
    UPSTASH_REDIS_REST_URL: process.env.UPSTASH_REDIS_REST_URL,
    UPSTASH_REDIS_REST_TOKEN: process.env.UPSTASH_REDIS_REST_TOKEN,
    {% endif %}
    
    {% if saas_file_upload == 'uploadthing' %}
    UPLOADTHING_SECRET: process.env.UPLOADTHING_SECRET,
    UPLOADTHING_APP_ID: process.env.UPLOADTHING_APP_ID,
    {% endif %}
    
    // Client
    NEXT_PUBLIC_APP_URL: process.env.NEXT_PUBLIC_APP_URL,
    NEXT_PUBLIC_APP_NAME: process.env.NEXT_PUBLIC_APP_NAME,
    
    {% if saas_auth == 'clerk' %}
    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY,
    NEXT_PUBLIC_CLERK_SIGN_IN_URL: process.env.NEXT_PUBLIC_CLERK_SIGN_IN_URL,
    NEXT_PUBLIC_CLERK_SIGN_UP_URL: process.env.NEXT_PUBLIC_CLERK_SIGN_UP_URL,
    NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL: process.env.NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL,
    NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL: process.env.NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL,
    {% endif %}
    
    {% if saas_database == 'supabase' %}
    NEXT_PUBLIC_SUPABASE_URL: process.env.NEXT_PUBLIC_SUPABASE_URL,
    NEXT_PUBLIC_SUPABASE_ANON_KEY: process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY,
    {% endif %}
    
    {% if saas_billing == 'stripe' %}
    NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: process.env.NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY,
    {% elif saas_billing == 'paddle' %}
    NEXT_PUBLIC_PADDLE_CLIENT_TOKEN: process.env.NEXT_PUBLIC_PADDLE_CLIENT_TOKEN,
    NEXT_PUBLIC_PADDLE_ENVIRONMENT: process.env.NEXT_PUBLIC_PADDLE_ENVIRONMENT,
    {% endif %}
    
    {% if saas_analytics == 'posthog' %}
    NEXT_PUBLIC_POSTHOG_KEY: process.env.NEXT_PUBLIC_POSTHOG_KEY,
    NEXT_PUBLIC_POSTHOG_HOST: process.env.NEXT_PUBLIC_POSTHOG_HOST,
    {% elif saas_analytics == 'amplitude' %}
    NEXT_PUBLIC_AMPLITUDE_API_KEY: process.env.NEXT_PUBLIC_AMPLITUDE_API_KEY,
    {% endif %}
    
    {% if saas_realtime == 'pusher' %}
    NEXT_PUBLIC_PUSHER_KEY: process.env.NEXT_PUBLIC_PUSHER_KEY,
    NEXT_PUBLIC_PUSHER_CLUSTER: process.env.NEXT_PUBLIC_PUSHER_CLUSTER,
    {% endif %}
    
    {% if saas_observability_sentry %}
    NEXT_PUBLIC_SENTRY_DSN: process.env.NEXT_PUBLIC_SENTRY_DSN,
    {% endif %}
  },
  
  /**
   * Skip validation in certain environments
   */
  skipValidation: !!process.env.SKIP_ENV_VALIDATION,
  
  /**
   * Treat empty strings as undefined
   */
  emptyStringAsUndefined: true,
});
{% endif %}
