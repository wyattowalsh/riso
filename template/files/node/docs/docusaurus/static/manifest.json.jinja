{%- if docs_module == 'enabled' and docs_framework == 'docusaurus' and docusaurus_pwa == 'enabled' -%}
{
  "name": "{{ project_name }} Documentation",
  "short_name": "{{ project_slug }}",
  "description": "Documentation for {{ project_name }}",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#3b82f6",
  "icons": [
    {
      "src": "/img/logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/img/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/img/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "categories": ["documentation", "developer tools"]
}
{%- endif -%}
