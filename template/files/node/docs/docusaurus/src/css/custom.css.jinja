{%- if docs_site == 'docusaurus' -%}
{%- if docusaurus_theme == 'tailwind' -%}
@import 'tailwindcss';

/* Tailwind CSS v4 configuration for Docusaurus */

/* Custom design tokens */
:root {
  --ifm-color-primary: #2563eb;
  --ifm-color-primary-dark: #1d4ed8;
  --ifm-color-primary-darker: #1e40af;
  --ifm-color-primary-darkest: #1e3a8a;
  --ifm-color-primary-light: #3b82f6;
  --ifm-color-primary-lighter: #60a5fa;
  --ifm-color-primary-lightest: #93c5fd;
  --ifm-code-font-size: 95%;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.1);
}

[data-theme='dark'] {
  --ifm-color-primary: #3b82f6;
  --ifm-color-primary-dark: #2563eb;
  --ifm-color-primary-darker: #1d4ed8;
  --ifm-color-primary-darkest: #1e40af;
  --ifm-color-primary-light: #60a5fa;
  --ifm-color-primary-lighter: #93c5fd;
  --ifm-color-primary-lightest: #bfdbfe;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.3);
}

/* Preserve Docusaurus Infima defaults where needed */
@layer base {
  /* Reset specific elements to work with Infima */
  a {
    @apply no-underline;
  }
}

/* Custom components using Tailwind */
.hero-gradient {
  @apply bg-gradient-to-r from-blue-600 to-purple-600;
}

.feature-card {
  @apply rounded-lg p-6 shadow-md transition-shadow hover:shadow-lg;
}
{%- else -%}
/**
 * Custom CSS for {{ project_name }} documentation
 * Built with Docusaurus default Infima framework
 */

/* Primary color palette */
:root {
  --ifm-color-primary: #2563eb;
  --ifm-color-primary-dark: #1d4ed8;
  --ifm-color-primary-darker: #1e40af;
  --ifm-color-primary-darkest: #1e3a8a;
  --ifm-color-primary-light: #3b82f6;
  --ifm-color-primary-lighter: #60a5fa;
  --ifm-color-primary-lightest: #93c5fd;
  --ifm-code-font-size: 95%;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.1);
}

/* Dark mode colors */
[data-theme='dark'] {
  --ifm-color-primary: #3b82f6;
  --ifm-color-primary-dark: #2563eb;
  --ifm-color-primary-darker: #1d4ed8;
  --ifm-color-primary-darkest: #1e40af;
  --ifm-color-primary-light: #60a5fa;
  --ifm-color-primary-lighter: #93c5fd;
  --ifm-color-primary-lightest: #bfdbfe;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.3);
}

/* Code block styling */
.docusaurus-highlight-code-line {
  background-color: var(--docusaurus-highlighted-code-line-bg);
  display: block;
  margin: 0 calc(-1 * var(--ifm-pre-padding));
  padding: 0 var(--ifm-pre-padding);
}

/* Custom hero section */
.hero--primary {
  background: linear-gradient(135deg, var(--ifm-color-primary) 0%, #7c3aed 100%);
}

/* Feature cards */
.feature-card {
  border-radius: 0.5rem;
  padding: 1.5rem;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  transition: box-shadow 0.2s ease-in-out;
}

.feature-card:hover {
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

/* Sidebar improvements */
.menu__link--active {
  font-weight: 600;
}

/* Table styling */
table {
  display: table;
  width: 100%;
}

/* Print styles */
@media print {
  .navbar,
  .footer,
  .pagination-nav,
  .theme-doc-sidebar-container {
    display: none !important;
  }
}
{%- endif -%}
{%- endif -%}
