{%- if docs_site == 'docusaurus' -%}
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: calc(100vh - 200px);
  padding: 2rem;
}

.content {
  text-align: center;
  max-width: 500px;
}

.title {
  font-size: 8rem;
  font-weight: 800;
  margin: 0;
  background: linear-gradient(135deg, var(--ifm-color-primary) 0%, var(--ifm-color-primary-dark) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.subtitle {
  font-size: 2rem;
  font-weight: 600;
  color: var(--ifm-font-color-base);
  margin: 1rem 0;
}

.description {
  font-size: 1.125rem;
  color: var(--ifm-font-color-secondary);
  margin-bottom: 2rem;
}

.actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

.searchHint {
  margin-top: 2rem;
  font-size: 0.875rem;
  color: var(--ifm-font-color-secondary);
}

@media (max-width: 480px) {
  .title {
    font-size: 5rem;
  }
  
  .subtitle {
    font-size: 1.5rem;
  }
  
  .actions {
    flex-direction: column;
  }
}
{%- endif -%}
