{%- if docs_module == 'enabled' and docs_framework == 'docusaurus' -%}
.highlight {
  padding: 1rem 1.25rem;
  margin: 1rem 0;
  border-radius: var(--ifm-global-radius);
  border-left: 4px solid;
}

.title {
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.content {
  font-size: 0.95rem;
}

.content > *:last-child {
  margin-bottom: 0;
}

/* Color variants */
.blue {
  background: rgba(59, 130, 246, 0.1);
  border-color: #3b82f6;
}

.green {
  background: rgba(34, 197, 94, 0.1);
  border-color: #22c55e;
}

.yellow {
  background: rgba(234, 179, 8, 0.1);
  border-color: #eab308;
}

.red {
  background: rgba(239, 68, 68, 0.1);
  border-color: #ef4444;
}

.purple {
  background: rgba(168, 85, 247, 0.1);
  border-color: #a855f7;
}

.gray {
  background: rgba(107, 114, 128, 0.1);
  border-color: #6b7280;
}

/* Version badge */
.badge {
  display: inline-block;
  padding: 0.2em 0.6em;
  font-size: 0.75rem;
  font-weight: 600;
  border-radius: 9999px;
  vertical-align: middle;
  margin-left: 0.5rem;
}

.badge_new {
  background: rgba(34, 197, 94, 0.15);
  color: #16a34a;
}

.badge_deprecated {
  background: rgba(239, 68, 68, 0.15);
  color: #dc2626;
}

.badge_beta {
  background: rgba(59, 130, 246, 0.15);
  color: #2563eb;
}

.badge_experimental {
  background: rgba(168, 85, 247, 0.15);
  color: #9333ea;
}

/* Dark mode adjustments */
[data-theme='dark'] .badge_new {
  color: #4ade80;
}

[data-theme='dark'] .badge_deprecated {
  color: #f87171;
}

[data-theme='dark'] .badge_beta {
  color: #60a5fa;
}

[data-theme='dark'] .badge_experimental {
  color: #c084fc;
}
{%- endif -%}
