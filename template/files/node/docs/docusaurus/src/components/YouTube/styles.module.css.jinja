{%- if docs_module == 'enabled' and docs_framework == 'docusaurus' -%}
.container {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 aspect ratio */
  margin: 1.5rem 0;
  border-radius: var(--ifm-global-radius);
  overflow: hidden;
  background: var(--ifm-color-emphasis-100);
}

.iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: none;
}
{%- endif -%}
