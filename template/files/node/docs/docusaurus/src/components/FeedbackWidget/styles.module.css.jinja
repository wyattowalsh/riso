{%- if docs_module == 'enabled' and docs_framework == 'docusaurus' and docusaurus_feedback == 'enabled' -%}
.feedbackWidget {
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--ifm-toc-border-color);
}

.question {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.question > span {
  font-weight: 500;
  color: var(--ifm-font-color-base);
}

.buttons {
  display: flex;
  gap: 0.5rem;
}

.button {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.5rem 1rem;
  border: 1px solid var(--ifm-color-emphasis-300);
  border-radius: var(--ifm-global-radius);
  background: transparent;
  cursor: pointer;
  font-size: 0.875rem;
  transition: all 0.2s ease;
}

.button:hover {
  background: var(--ifm-color-emphasis-100);
  border-color: var(--ifm-color-emphasis-400);
}

.button.active {
  background: var(--ifm-color-primary-lightest);
  border-color: var(--ifm-color-primary);
  color: var(--ifm-color-primary-darkest);
}

.thankYou {
  padding: 0.75rem 1rem;
  background: var(--ifm-color-success-lightest);
  border-radius: var(--ifm-global-radius);
  color: var(--ifm-color-success-darkest);
  font-weight: 500;
}

.commentForm {
  margin-top: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.commentForm label {
  font-weight: 500;
  font-size: 0.875rem;
}

.commentForm textarea {
  padding: 0.75rem;
  border: 1px solid var(--ifm-color-emphasis-300);
  border-radius: var(--ifm-global-radius);
  font-family: inherit;
  font-size: 0.875rem;
  resize: vertical;
  min-height: 80px;
}

.commentForm textarea:focus {
  outline: none;
  border-color: var(--ifm-color-primary);
  box-shadow: 0 0 0 2px var(--ifm-color-primary-lightest);
}

.formActions {
  display: flex;
  gap: 0.5rem;
  justify-content: flex-end;
}

.formActions button {
  padding: 0.5rem 1rem;
  border-radius: var(--ifm-global-radius);
  font-size: 0.875rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.formActions button:first-child {
  background: transparent;
  border: 1px solid var(--ifm-color-emphasis-300);
}

.formActions button:first-child:hover {
  background: var(--ifm-color-emphasis-100);
}

.submitButton {
  background: var(--ifm-color-primary);
  color: white;
  border: none;
}

.submitButton:hover {
  background: var(--ifm-color-primary-dark);
}

/* Dark mode adjustments */
[data-theme='dark'] .thankYou {
  background: rgba(0, 200, 83, 0.15);
  color: #4ade80;
}

[data-theme='dark'] .button.active {
  background: rgba(var(--ifm-color-primary-rgb), 0.2);
}
{%- endif -%}
