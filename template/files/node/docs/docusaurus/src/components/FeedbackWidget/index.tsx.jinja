{%- if docs_module == 'enabled' and docs_framework == 'docusaurus' and docusaurus_feedback == 'enabled' -%}
import React, { useState } from 'react';
import styles from './styles.module.css';

interface FeedbackWidgetProps {
  /** The current page title */
  pageTitle?: string;
}

export default function FeedbackWidget({ pageTitle }: FeedbackWidgetProps): JSX.Element {
  const [feedback, setFeedback] = useState<'helpful' | 'not-helpful' | null>(null);
  const [submitted, setSubmitted] = useState(false);
  const [showForm, setShowForm] = useState(false);
  const [comment, setComment] = useState('');

  const handleFeedback = (isHelpful: boolean) => {
    const value = isHelpful ? 'helpful' : 'not-helpful';
    setFeedback(value);
    
    if (!isHelpful) {
      setShowForm(true);
    } else {
      submitFeedback(value);
    }
  };

  const submitFeedback = async (feedbackValue: string, userComment?: string) => {
    // Log to console in development
    console.log('Feedback submitted:', {
      page: window.location.pathname,
      title: pageTitle,
      feedback: feedbackValue,
      comment: userComment,
      timestamp: new Date().toISOString(),
    });

    // You can integrate with analytics or a feedback API here
    // Example: await fetch('/api/feedback', { ... });
    
    setSubmitted(true);
    setShowForm(false);
  };

  const handleSubmitComment = (e: React.FormEvent) => {
    e.preventDefault();
    submitFeedback(feedback!, comment);
  };

  if (submitted) {
    return (
      <div className={styles.feedbackWidget}>
        <div className={styles.thankYou}>
          ✓ Thank you for your feedback!
        </div>
      </div>
    );
  }

  return (
    <div className={styles.feedbackWidget}>
      <div className={styles.question}>
        <span>Was this page helpful?</span>
        <div className={styles.buttons}>
          <button
            className={`${styles.button} ${feedback === 'helpful' ? styles.active : ''}`}
            onClick={() => handleFeedback(true)}
            aria-label="Yes, this page was helpful"
          >
            👍 Yes
          </button>
          <button
            className={`${styles.button} ${feedback === 'not-helpful' ? styles.active : ''}`}
            onClick={() => handleFeedback(false)}
            aria-label="No, this page was not helpful"
          >
            👎 No
          </button>
        </div>
      </div>
      
      {showForm && (
        <form className={styles.commentForm} onSubmit={handleSubmitComment}>
          <label htmlFor="feedback-comment">
            How can we improve this page?
          </label>
          <textarea
            id="feedback-comment"
            value={comment}
            onChange={(e) => setComment(e.target.value)}
            placeholder="Tell us what's missing or confusing..."
            rows={3}
          />
          <div className={styles.formActions}>
            <button type="button" onClick={() => setShowForm(false)}>
              Cancel
            </button>
            <button type="submit" className={styles.submitButton}>
              Submit
            </button>
          </div>
        </form>
      )}
    </div>
  );
}
{%- endif -%}
