{%- if docs_site == 'docusaurus' -%}
{
  "name": "docs-docusaurus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@docusaurus/core": "^3.8.0",
    "@docusaurus/preset-classic": "^3.8.0",
{%- if docusaurus_faster == 'enabled' %}
    "@docusaurus/faster": "^3.8.0",
{%- endif %}
{%- if docusaurus_llms_txt == 'enabled' %}
    "docusaurus-plugin-llms": "^1.2.0",
{%- endif %}
{%- if docusaurus_search_provider == 'local' %}
    "@easyops-cn/docusaurus-search-local": "^0.46.0",
{%- endif %}
{%- if docusaurus_search_provider == 'typesense' %}
    "docusaurus-theme-search-typesense": "^0.23.0",
{%- endif %}
{%- if docusaurus_openapi == 'enabled' and api_tracks in ['python', 'node', 'python+node'] %}
    "docusaurus-plugin-openapi-docs": "^4.3.0",
    "docusaurus-theme-openapi-docs": "^4.3.0",
{%- endif %}
{%- if docusaurus_analytics == 'posthog' %}
    "posthog-docusaurus": "^2.1.0",
{%- endif %}
{%- if docusaurus_analytics == 'google' %}
    "@docusaurus/plugin-google-gtag": "^3.8.0",
{%- endif %}
{%- if docusaurus_analytics == 'matomo' %}
    "@docusaurus/plugin-client-redirects": "^3.8.0",
    "docusaurus-plugin-matomo": "^0.0.6",
{%- endif %}
{%- if docusaurus_mermaid == 'enabled' %}
    "@docusaurus/theme-mermaid": "^3.8.0",
{%- endif %}
{%- if docusaurus_math == 'enabled' %}
    "remark-math": "^6.0.0",
    "rehype-katex": "^7.0.0",
    "katex": "^0.16.0",
{%- endif %}
{%- if docusaurus_live_codeblock == 'enabled' %}
    "@docusaurus/theme-live-codeblock": "^3.8.0",
{%- endif %}
{%- if docusaurus_ideal_images == 'enabled' %}
    "@docusaurus/plugin-ideal-image": "^3.8.0",
{%- endif %}
{%- if docusaurus_image_zoom == 'enabled' %}
    "docusaurus-plugin-image-zoom": "^2.0.0",
{%- endif %}
{%- if docusaurus_pwa == 'enabled' %}
    "@docusaurus/plugin-pwa": "^3.8.0",
{%- endif %}
{%- if docusaurus_redirects == 'enabled' %}
    "@docusaurus/plugin-client-redirects": "^3.8.0",
{%- endif %}
{%- if docusaurus_code_tabs == 'enabled' %}
    "docusaurus-remark-plugin-tab-blocks": "^3.1.0",
{%- endif %}
{%- if docusaurus_comments == 'giscus' %}
    "@giscus/react": "^3.0.0",
{%- endif %}
{%- if docusaurus_theme == 'tailwind' %}
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
{%- endif %}
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.8.0",
    "@docusaurus/types": "^3.8.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "~5.7.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
{%- endif -%}
