{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' -%}
{
  "name": "docs-fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"{% if fumadocs_typedoc == 'enabled' %},
    "docs:sdk": "typedoc --options typedoc.json"{% endif %}{% if fumadocs_search_provider == 'algolia' %},
    "search:sync": "node scripts/sync-algolia.mjs"{% endif %}
  },
  "dependencies": {
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.5",
{%- if fumadocs_openapi == 'enabled' and api_module == 'enabled' and api_languages %}
    "fumadocs-openapi": "^11.0.5",
{%- endif %}
{%- if fumadocs_twoslash == 'enabled' %}
    "fumadocs-twoslash": "^3.2.0",
{%- endif %}
    "shiki": "^4.3.0",
{%- if fumadocs_search_provider == 'orama' %}
    "@orama/orama": "^3.1.18",
{%- endif %}
{%- if fumadocs_search_provider == 'orama-cloud' %}
    "@oramacloud/client": "^2.0.0",
{%- endif %}
{%- if fumadocs_search_provider == 'algolia' %}
    "algoliasearch": "^5.0.0",
{%- endif %}
{%- if fumadocs_ai_search == 'enabled' %}
    "@ai-sdk/openai": "^2.0.109",
    "ai": "^4.3.19",
{%- endif %}
{%- if fumadocs_sidebar == 'shadcn' or fumadocs_theme == 'shadcn' %}
    "tailwind-merge": "^3.5.0",
{%- endif %}
{%- if fumadocs_sidebar == 'shadcn' %}
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.0",
{%- endif %}
{%- if fumadocs_sidebar == 'shadcn' or fumadocs_blog == 'enabled' or fumadocs_theme == 'shadcn' %}
    "lucide-react": "^1.21.0",
{%- endif %}
{%- if fumadocs_blog == 'enabled' %}
    "feed": "^4.2.0",
{%- endif %}
{%- if fumadocs_mermaid == 'enabled' %}
    "mermaid": "^11.15.0",
{%- endif %}
{%- if fumadocs_math == 'enabled' %}
    "katex": "^0.17.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
{%- endif %}
    "next": "^16.2.9",
    "server-only": "^0.0.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "clsx": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
{%- if fumadocs_typedoc == 'enabled' %}
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
{%- endif %}
{%- if fumadocs_math == 'enabled' %}
    "@types/katex": "^0.16.8",
{%- endif %}
    "typescript": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
{%- endif -%}
