{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' -%}
{
  "name": "docs-fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"{% if fumadocs_typedoc == 'enabled' %},
    "docs:sdk": "typedoc --options typedoc.json"{% endif %}{% if fumadocs_search_provider == 'algolia' %},
    "search:sync": "node scripts/sync-algolia.mjs"{% endif %}
  },
  "dependencies": {
    "fumadocs-core": "^16.2.0",
    "fumadocs-mdx": "^16.2.0",
    "fumadocs-ui": "^16.2.0",
{%- if fumadocs_openapi == 'enabled' and api_module == 'enabled' and api_languages %}
    "fumadocs-openapi": "^16.2.0",
{%- endif %}
{%- if fumadocs_twoslash == 'enabled' %}
    "fumadocs-twoslash": "^16.2.0",
{%- endif %}
    "shiki": "^1.24.0",
{%- if fumadocs_search_provider == 'orama' %}
    "@orama/orama": "^3.0.0",
{%- endif %}
{%- if fumadocs_search_provider == 'orama-cloud' %}
    "@oramacloud/client": "^2.0.0",
{%- endif %}
{%- if fumadocs_search_provider == 'algolia' %}
    "algoliasearch": "^5.0.0",
{%- endif %}
{%- if fumadocs_ai_search == 'enabled' %}
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^4.0.0",
{%- endif %}
{%- if fumadocs_sidebar == 'shadcn' %}
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
{%- endif %}
{%- if fumadocs_sidebar == 'shadcn' or fumadocs_blog == 'enabled' %}
    "lucide-react": "^0.460.0",
{%- endif %}
{%- if fumadocs_blog == 'enabled' %}
    "feed": "^4.2.0",
{%- endif %}
{%- if fumadocs_mermaid == 'enabled' %}
    "mermaid": "^11.4.0",
{%- endif %}
{%- if fumadocs_math == 'enabled' %}
    "katex": "^0.16.0",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0",
{%- endif %}
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
{%- if fumadocs_typedoc == 'enabled' %}
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.3.0",
{%- endif %}
{%- if fumadocs_math == 'enabled' %}
    "@types/katex": "^0.16.0",
{%- endif %}
    "typescript": "~5.7.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
{%- endif -%}
