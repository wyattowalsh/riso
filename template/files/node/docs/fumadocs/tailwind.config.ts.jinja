{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' -%}
import type { Config } from 'tailwindcss';
import { createPreset } from 'fumadocs-ui/tailwind-plugin';
{%- if fumadocs_openapi == 'enabled' and api_module == 'enabled' and api_languages %}
import { createOpenAPIPreset } from 'fumadocs-openapi/tailwind-plugin';
{%- endif %}

const config: Config = {
  darkMode: 'class',
  content: [
    './components/**/*.{ts,tsx}',
    './app/**/*.{ts,tsx}',
    './content/**/*.mdx',
    './node_modules/fumadocs-ui/dist/**/*.js',
{%- if fumadocs_openapi == 'enabled' and api_module == 'enabled' and api_languages %}
    './node_modules/fumadocs-openapi/dist/**/*.js',
{%- endif %}
  ],
  presets: [
{%- if fumadocs_theme == 'ocean' %}
    createPreset({ preset: 'ocean' }),
{%- elif fumadocs_theme == 'purple' %}
    createPreset({ preset: 'purple' }),
{%- elif fumadocs_theme == 'custom' %}
    createPreset({ preset: 'default' }),
{%- else %}
    createPreset({ preset: 'neutral' }),
{%- endif %}
{%- if fumadocs_openapi == 'enabled' and api_module == 'enabled' and api_languages %}
    createOpenAPIPreset(),
{%- endif %}
  ],
{%- if fumadocs_theme == 'custom' %}
  theme: {
    extend: {
      colors: {
        // Customize your colors here
        // fd: {
        //   background: 'hsl(var(--fd-background))',
        //   foreground: 'hsl(var(--fd-foreground))',
        //   primary: 'hsl(var(--fd-primary))',
        // },
      },
    },
  },
{%- endif %}
};

export default config;
