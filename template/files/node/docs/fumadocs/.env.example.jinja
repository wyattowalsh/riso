{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' -%}
# {{ project_name }} Documentation Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# Search Configuration
# =============================================================================
{%- if fumadocs_search == 'algolia' %}

# Algolia Search (required for Algolia search)
NEXT_PUBLIC_ALGOLIA_APP_ID=your_app_id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your_search_key
ALGOLIA_ADMIN_KEY=your_admin_key
ALGOLIA_INDEX_NAME={{ project_slug }}_docs
{%- endif %}
{%- if fumadocs_search == 'orama-cloud' %}

# Orama Cloud Search (required for Orama Cloud search)
NEXT_PUBLIC_ORAMA_API_KEY=your_orama_api_key
NEXT_PUBLIC_ORAMA_ENDPOINT=https://cloud.orama.run/v1/indexes/your-index
{%- endif %}
{%- if fumadocs_ai_search == 'enabled' %}

# AI Search (OpenAI API for AI-powered search)
OPENAI_API_KEY=your_openai_api_key
{%- endif %}

# =============================================================================
# Optional: Analytics & Monitoring
# =============================================================================

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Posthog Analytics
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# Optional: Authentication (if using protected docs)
# =============================================================================

# GitHub OAuth (for edit links / authentication)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# Build & Deploy
# =============================================================================

# Base URL for production (used for sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://docs.example.com

# Enable/disable features in production
# NEXT_PUBLIC_ENABLE_SEARCH=true
# NEXT_PUBLIC_ENABLE_AI_CHAT=true
{%- endif -%}