{%- if docs_site == 'fumadocs' and fumadocs_sidebar == 'shadcn' -%}
'use client';

import { source } from '@/lib/source';
import Link from 'next/link';
import { usePathname } from 'next/navigation';
import { useState } from 'react';
import { cn } from '@/lib/utils';

export function Sidebar() {
  const pathname = usePathname();
  const tree = source.pageTree;

  return (
    <nav className="flex flex-col gap-1 p-4">
      <SidebarTree nodes={tree.children} pathname={pathname} />
    </nav>
  );
}

interface SidebarTreeProps {
  nodes: typeof source.pageTree.children;
  pathname: string;
  level?: number;
}

function SidebarTree({ nodes, pathname, level = 0 }: SidebarTreeProps) {
  return (
    <>
      {nodes.map((node, index) => {
        if (node.type === 'page') {
          const isActive = pathname === node.url;
          return (
            <Link
              key={index}
              href={node.url}
              className={cn(
                'flex items-center gap-2 rounded-md px-3 py-2 text-sm transition-colors',
                isActive
                  ? 'bg-fd-primary/10 text-fd-primary font-medium'
                  : 'text-fd-muted-foreground hover:bg-fd-accent hover:text-fd-accent-foreground',
                level > 0 && 'ml-4'
              )}
            >
              {node.name}
            </Link>
          );
        }

        if (node.type === 'folder') {
          return (
            <SidebarFolder
              key={index}
              name={node.name}
              children={node.children}
              pathname={pathname}
              level={level}
              defaultOpen={pathname.startsWith(node.index?.url ?? '')}
            />
          );
        }

        if (node.type === 'separator') {
          return (
            <div
              key={index}
              className="mt-4 mb-2 px-3 text-xs font-semibold text-fd-muted-foreground uppercase tracking-wider"
            >
              {node.name}
            </div>
          );
        }

        return null;
      })}
    </>
  );
}

interface SidebarFolderProps {
  name: string;
  children: typeof source.pageTree.children;
  pathname: string;
  level: number;
  defaultOpen?: boolean;
}

function SidebarFolder({ name, children, pathname, level, defaultOpen }: SidebarFolderProps) {
  const [open, setOpen] = useState(defaultOpen ?? true);

  return (
    <div className={cn(level > 0 && 'ml-4')}>
      <button
        onClick={() => setOpen(!open)}
        className="flex w-full items-center justify-between gap-2 rounded-md px-3 py-2 text-sm font-medium text-fd-foreground hover:bg-fd-accent transition-colors"
      >
        {name}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          strokeWidth="2"
          strokeLinecap="round"
          strokeLinejoin="round"
          className={cn('transition-transform', open && 'rotate-90')}
        >
          <path d="m9 18 6-6-6-6" />
        </svg>
      </button>
      {open && (
        <div className="mt-1">
          <SidebarTree nodes={children} pathname={pathname} level={level + 1} />
        </div>
      )}
    </div>
  );
}
{%- endif -%}
