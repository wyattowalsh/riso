{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' -%}
import { defineDocs, defineConfig{%- if fumadocs_last_updated == 'enabled' or fumadocs_blog == 'enabled' %}, frontmatterSchema{%- endif %}{%- if fumadocs_blog == 'enabled' %}, defineCollections{%- endif %} } from 'fumadocs-mdx/config';
{%- if fumadocs_twoslash == 'enabled' %}
import { transformerTwoslash } from 'fumadocs-twoslash';
{%- endif %}
{%- if fumadocs_math == 'enabled' %}
import remarkMath from 'remark-math';
import rehypeKatex from 'rehype-katex';
{%- endif %}
{%- if fumadocs_last_updated == 'enabled' or fumadocs_blog == 'enabled' %}
import { z } from 'zod';
{%- endif %}

export const docs = defineDocs({
  dir: 'content/docs',
{%- if fumadocs_last_updated == 'enabled' %}
  schema: frontmatterSchema.extend({
    lastModified: z.date().optional(),
  }),
{%- endif %}
{%- if fumadocs_llms_txt == 'enabled' %}
  postprocess: {
    includeProcessedMarkdown: true,
  },
{%- endif %}
});

{%- if fumadocs_blog == 'enabled' %}

export const blog = defineCollections({
  type: 'doc',
  dir: 'content/blog',
  schema: frontmatterSchema.extend({
    author: z.string(),
    date: z.coerce.date(),
    tags: z.array(z.string()).optional(),
  }),
});
{%- endif %}

export default defineConfig({
  mdxOptions: {
{%- if fumadocs_math == 'enabled' %}
    remarkPlugins: [remarkMath],
    rehypePlugins: [rehypeKatex],
{%- endif %}
    rehypeCodeOptions: {
      themes: {
{%- if fumadocs_code_theme == 'catppuccin' %}
        light: 'catppuccin-latte',
        dark: 'catppuccin-mocha',
{%- elif fumadocs_code_theme == 'dracula' %}
        light: 'github-light',
        dark: 'dracula',
{%- elif fumadocs_code_theme == 'nord' %}
        light: 'nord',
        dark: 'nord',
{%- elif fumadocs_code_theme == 'one' %}
        light: 'one-light',
        dark: 'one-dark-pro',
{%- else %}
        light: 'github-light',
        dark: 'github-dark',
{%- endif %}
      },
{%- if fumadocs_twoslash == 'enabled' %}
      transformers: [
        transformerTwoslash(),
      ],
{%- endif %}
    },
  },
});
{%- endif %}
