{%- if docs_site == 'fumadocs' -%}
import type { MetadataRoute } from 'next';
import { source } from '@/lib/source';

const baseUrl = process.env.NEXT_PUBLIC_SITE_URL || 'https://{{ project_slug }}.dev';

export default function sitemap(): MetadataRoute.Sitemap {
  const docsUrls = source.getPages().map((page) => ({
    url: `${baseUrl}${page.url}`,
    lastModified: page.data.lastModified || new Date(),
    changeFrequency: 'weekly' as const,
    priority: page.url === '/docs' ? 1 : 0.8,
  }));

  return [
    {
      url: baseUrl,
      lastModified: new Date(),
      changeFrequency: 'monthly',
      priority: 1,
    },
    ...docsUrls,
  ];
}
{%- endif -%}