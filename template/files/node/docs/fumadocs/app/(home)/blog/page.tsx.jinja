{%- if docs_site == 'fumadocs' and fumadocs_blog == 'enabled' -%}
import Link from 'next/link';
import { blog } from '@/lib/source';
import type { Metadata } from 'next';

const baseUrl = process.env.NEXT_PUBLIC_SITE_URL ?? 'http://localhost:3000';

export const metadata: Metadata = {
  title: 'Blog | {{ project_name }}',
  description: 'Latest news, updates, and articles from {{ project_name }}',
  alternates: {
    canonical: `${baseUrl}/blog`,
    types: {
      'application/rss+xml': `${baseUrl}/blog/rss.xml`,
    },
  },
  openGraph: {
    title: '{{ project_name }} Blog',
    description: 'Latest news, updates, and articles from {{ project_name }}',
    url: `${baseUrl}/blog`,
    siteName: '{{ project_name }}',
    type: 'website',
    locale: 'en_US',
  },
  twitter: {
    card: 'summary_large_image',
    title: '{{ project_name }} Blog',
    description: 'Latest news, updates, and articles from {{ project_name }}',
  },
};

export default function BlogPage() {
  const posts = [...blog.getPages()].sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

  return (
    <main className="mx-auto w-full max-w-4xl px-4 py-12">
      <div className="mb-8">
        <h1 className="text-4xl font-bold mb-4">{{ project_name }} Blog</h1>
        <p className="text-fd-muted-foreground">
          Latest news, updates, and articles from the {{ project_name }} team.
        </p>
      </div>

      <div className="grid grid-cols-1 gap-4 md:grid-cols-2">
        {posts.map((post) => (
          <Link
            key={post.url}
            href={post.url}
            className="flex flex-col rounded-lg border bg-fd-card p-6 shadow-sm transition-colors hover:bg-fd-accent hover:text-fd-accent-foreground"
          >
            <p className="text-lg font-semibold mb-2">{post.data.title}</p>
            <p className="text-sm text-fd-muted-foreground mb-4 line-clamp-2">
              {post.data.description}
            </p>
            <div className="mt-auto flex items-center justify-between text-xs text-fd-muted-foreground">
              <span>{post.data.author}</span>
              <time dateTime={new Date(post.data.date).toISOString()}>
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <div className="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span
                    key={tag}
                    className="rounded-full bg-fd-secondary px-2 py-0.5 text-xs"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </Link>
        ))}
      </div>

      {posts.length === 0 && (
        <div className="text-center py-12">
          <p className="text-fd-muted-foreground">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </main>
  );
}
{%- endif -%}
