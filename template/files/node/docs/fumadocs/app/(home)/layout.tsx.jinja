{%- if docs_module == 'enabled' and docs_framework == 'fumadocs' and fumadocs_blog == 'enabled' -%}
import { HomeLayout } from 'fumadocs-ui/layouts/home';
import type { ReactNode } from 'react';

const baseOptions = {
  nav: {
    title: '{{ project_name }}',
  },
  links: [
    {
      text: 'Documentation',
      url: '/docs',
    },
    {
      text: 'Blog',
      url: '/blog',
      active: 'nested-url',
    },
    {
      text: 'GitHub',
      url: 'https://github.com/{{ project_slug }}/{{ project_slug }}',
      external: true,
    },
  ],
};

export default function Layout({ children }: { children: ReactNode }) {
  return <HomeLayout {...baseOptions}>{children}</HomeLayout>;
}
{%- endif -%}
