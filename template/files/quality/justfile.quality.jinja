# Quality justfile — generated by Riso template
set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

# Quality suite
quality: quality-python{% if api_module == 'enabled' and 'node' in api_languages %} quality-node{% endif %}

quality-python:
    uv run --group quality --group test ruff check{% if quality_profile == 'strict' %} --select ALL --ignore E203,E266,E501{% endif %}
    uv run --group quality --group test ty check{% if quality_profile == 'strict' %} --error-on-warning{% endif %} src/{{ package_name }}
    uv run --group quality --group test pylint{% if quality_profile == 'strict' %} --errors-only{% endif %} {{ package_name }} tests
    uv run --group quality --group test coverage run -m pytest -ra
    uv run --group quality coverage report --rcfile coverage.cfg

coverage-report:
    uv run --group quality coverage html --rcfile coverage.cfg

format:
    uv run --group quality ruff format {{ package_name }} tests

lint:
    uv run --group quality --group test ruff check{% if quality_profile == 'strict' %} --select ALL --ignore E203,E266,E501{% endif %}
    uv run --group quality --group test pylint{% if quality_profile == 'strict' %} --errors-only{% endif %} {{ package_name }} tests

{% if api_module == 'enabled' and 'node' in api_languages %}
quality-node:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v pnpm >/dev/null 2>&1 || { echo "pnpm is required for Node quality checks"; exit 1; }
    pnpm --filter api-node lint
    pnpm --filter api-node typecheck

lint-node:
    pnpm --filter api-node lint
{% endif %}

# Pre-commit hooks
hooks:
    uv run --group quality pre-commit install --install-hooks
{% if changelog_module == 'enabled' or quality_profile == 'strict' %}
    uv run --group quality pre-commit install --hook-type commit-msg
{% endif %}
{% if quality_profile == 'strict' %}
    uv run --group quality pre-commit install --hook-type pre-push
{% endif %}

hooks-run:
    uv run --group quality pre-commit run --all-files

hooks-update:
    uv run --group quality pre-commit autoupdate