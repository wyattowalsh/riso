{% set optional_tests = [] %}
{% if cli_module | lower != "enabled" %}
{% set optional_tests = optional_tests + ["tests/test_cli*.py"] %}
{% endif %}
{% if api_module != 'enabled' or 'python' not in api_languages %}
{% set optional_tests = optional_tests + ["tests/api/*"] %}
{% endif %}

[run]
branch = {% if quality_profile == 'strict' %}True{% else %}False{% endif %}
source =
    {{ package_name }}
    tests
omit =
    */__init__.py
    */migrations/*
    */node_modules/*
{%- if cli_module | lower == "enabled" %}
    src/{{ package_name }}/cli/plugins/*
    src/{{ package_name }}/cli/core/prompts.py
    src/{{ package_name }}/cli/commands/example_async.py
{%- endif %}
{% for test in optional_tests %}
    {{ test }}
{% endfor %}

[report]
show_missing = True
skip_covered = False
precision = 2
fail_under = {% if cli_module | lower == "enabled" %}90.0{% else %}85.0{% endif %}
omit =
{% for test in optional_tests %}
    {{ test }}
{% endfor %}
{%- if api_module != 'enabled' or 'python' not in api_languages %}
    src/{{ package_name }}/api/*
    src/{{ package_name }}/config.py
    src/{{ package_name }}/logging.py
{%- endif %}
{%- if cli_module | lower == "enabled" %}
    src/{{ package_name }}/cli/plugins/*
    src/{{ package_name }}/cli/core/prompts.py
    src/{{ package_name }}/cli/commands/example_async.py
    src/{{ package_name }}/cli/commands/plugin.py
{%- endif %}

[html]
directory = htmlcov