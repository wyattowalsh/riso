{% set optional_tests = [] %}
{% if cli_module | lower != "enabled" %}
{% set optional_tests = optional_tests + ["tests/test_cli*.py"] %}
{% endif %}
{% if api_module != 'enabled' or 'python' not in api_languages %}
{% set optional_tests = optional_tests + ["tests/api/*"] %}
{% endif %}

[run]
branch = True
source =
    {{ package_name }}
    tests
omit =
    */__init__.py
    */migrations/*
    */node_modules/*
{% for test in optional_tests %}
    {{ test }}
{% endfor %}

[report]
show_missing = True
skip_covered = False
precision = 2
fail_under = {% if cli_module | lower == "enabled" %}90.0{% else %}85.0{% endif %}
{% if optional_tests %}
omit =
{% for test in optional_tests %}
    {{ test }}
{% endfor %}
{% endif %}

[html]
directory = htmlcov
