target-version = "py311"
line-length = 100
respect-gitignore = true
src = ["{{ package_name }}", "tests"]
exclude = [".venv", "build", "dist", "node_modules"]

[format]
quote-style = "double"
indent-style = "space"

[lint]
select = [
  "E",
  "F",
  "I",
  "W",
  "B",
  "C4",
  "UP",
  "SIM",
]
ignore = ["E203", "E266", "E501"]

[lint.per-file-ignores]
"tests/**/*" = ["S101", "PT003", "B018"]
{%- if mcp_module == 'enabled' and 'python' in mcp_languages and quality_profile == 'strict' %}
"mcp/**/*" = [
  "PLC0415",
  "T201",
  "TRY003",
  "EM102",
  "ASYNC109",
  "A002",
  "FURB162",
  "BLE001",
  "D413",
]
{%- endif %}
