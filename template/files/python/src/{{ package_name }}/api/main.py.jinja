{%- if api_module != 'enabled' or 'python' not in api_languages %}
"""FastAPI service disabled for this render."""


def create_app():
    """Placeholder app when the Python API track is not enabled."""
    raise RuntimeError(
        "FastAPI track disabled. Enable with api_module=enabled and "
        "api_languages=[python] or python+node."
    )


app = None

{% else %}
"""FastAPI application factory and initialization."""

from __future__ import annotations

from contextlib import asynccontextmanager

from fastapi import FastAPI

from .config import get_config
from .middleware.cors import configure_cors
from .middleware.errors import configure_error_handlers
from .middleware.request_id import configure_request_id
from .routes import health

try:
    from .routes import examples
    EXAMPLES_ENABLED = True
except ImportError:
    EXAMPLES_ENABLED = False

{% if websocket_module == "enabled" or "websocket" in api_features %}
from .websocket_endpoints import setup_websocket_routes
{% endif %}


@asynccontextmanager
async def _lifespan(_app: FastAPI):
    """Application lifespan hook (extend for DB pools, caches, etc.)."""
    yield


def create_app() -> FastAPI:
    """Create and configure the FastAPI application."""
    config = get_config()

    application = FastAPI(
        title=config.app_name,
        description="FastAPI application scaffolded with Riso template",
        version=config.version,
        docs_url="/docs",
        redoc_url="/redoc",
        lifespan=_lifespan,
        redirect_slashes=False,
        openapi_tags=[
            {
                "name": "Health",
                "description": "Health check endpoints for monitoring and orchestration",
            },
            {
                "name": "Examples",
                "description": "Example CRUD endpoints demonstrating FastAPI patterns",
            },
        ],
    )

    configure_request_id(application)
    configure_cors(application, config)
    configure_error_handlers(application)

    application.include_router(health.router)
    if EXAMPLES_ENABLED:
        application.include_router(examples.router)

{% if graphql_api_module == 'enabled' or 'graphql' in api_features %}
    try:
        from strawberry.fastapi import GraphQLRouter

        from {{ package_name }}.graphql_api.context import get_graphql_context
        from {{ package_name }}.graphql_api.schema import schema

        async def _graphql_context(request):
            return await get_graphql_context(request=request)

        application.include_router(
            GraphQLRouter(schema, context_getter=_graphql_context),
            prefix="/graphql",
        )
    except ImportError:
        pass
{% endif %}

{% if websocket_module == "enabled" or "websocket" in api_features %}
    setup_websocket_routes(application)
{% endif %}

    @application.get("/", tags=["Root"], summary="API Root")
    async def root() -> dict[str, str]:
        return {
            "message": "Welcome to {{ project_name }}",
            "docs": "/docs",
            "redoc": "/redoc",
        }

    return application


app = create_app()


if __name__ == "__main__":
    import uvicorn

    api_config = get_config()
    uvicorn.run(
        "{{ package_name }}.api.main:app",
        host=api_config.host,
        port=api_config.port,
        reload=api_config.reload,
        log_level=str(api_config.log_level).lower(),
    )
{% endif %}