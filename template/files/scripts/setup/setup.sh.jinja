#!/usr/bin/env bash
# {{ project_name }} - Development Environment Setup
# Generated by Riso Template
# Usage: ./scripts/setup/setup.sh [OPTIONS]
#
# Options:
#   --check-only    Check for required tools without installing (exit 0 if all present, 1 otherwise)
#   --install       Install missing tools (prompts for confirmation)
#   --install --yes Install missing tools without prompting
#   --help          Show this help message
#
# Environment:
#   NO_COLOR        Disable colored output
#   DEBUG           Enable debug logging
#   VERBOSE         Enable verbose logging
#   {{ package_name | upper }}_LOG_DIR    Override log directory (default: XDG_STATE_HOME/{{ package_name }})

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source library modules
# shellcheck source=lib/versions.sh
source "$SCRIPT_DIR/lib/versions.sh"
# shellcheck source=lib/colors.sh
source "$SCRIPT_DIR/lib/colors.sh"
# shellcheck source=lib/detect-platform.sh
source "$SCRIPT_DIR/lib/detect-platform.sh"
# shellcheck source=lib/logging.sh
source "$SCRIPT_DIR/lib/logging.sh"
# shellcheck source=lib/install-tools.sh
source "$SCRIPT_DIR/lib/install-tools.sh"

# Script metadata
SCRIPT_NAME="{{ project_name }} Setup"
SCRIPT_VERSION="1.0.0"

# Mode flags
MODE_CHECK_ONLY=0
MODE_INSTALL=0
MODE_YES=0

# Track overall status (using indexed arrays for Bash 3.2 compatibility)
# Tool list (in order)
TOOLS=(python3 uv{% if (api_module == 'enabled' and 'node' in api_languages) or (docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus']) or saas_infra_module == 'enabled' %} node pnpm{% endif %} pre-commit{% if ci_platform == 'github-actions' %} actionlint{% endif %})
# Parallel arrays for status and versions
TOOL_STATUS=()
TOOL_VERSIONS=()
MISSING_TOOLS=()
FAILED_INSTALLS=()

# Show help message
show_help() {
    cat <<EOF
${BOLD}${SCRIPT_NAME} v${SCRIPT_VERSION}${NC}

${BOLD}USAGE:${NC}
    $0 [OPTIONS]

${BOLD}OPTIONS:${NC}
    --check-only    Check for required tools without installing
                    Exit 0 if all tools present, 1 if any missing

    --install       Install missing tools (prompts for confirmation)

    --install --yes Install missing tools without prompting

    --help          Show this help message

${BOLD}ENVIRONMENT:${NC}
    NO_COLOR        Disable colored output
    DEBUG           Enable debug logging
    VERBOSE         Enable verbose logging
    {{ package_name | upper }}_LOG_DIR    Override log directory (default: XDG_STATE_HOME/{{ package_name }})

${BOLD}EXAMPLES:${NC}
    # Check what tools are missing
    $0

    # Check and install missing tools (with prompts)
    $0 --install

    # Install missing tools without prompts
    $0 --install --yes

    # Just check, exit 0 if all present
    $0 --check-only

${BOLD}EXIT CODES:${NC}
    0   All required tools present (or successfully installed)
    1   Missing tools (check-only mode) or installation failed
    2   Invalid arguments or script error

{% if docs_framework != 'none' -%}
For more information, see: docs/development/setup.md
{% endif -%}
EOF
}

# Parse command-line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check-only)
                MODE_CHECK_ONLY=1
                shift
                ;;
            --install)
                MODE_INSTALL=1
                shift
                ;;
            --yes|-y)
                MODE_YES=1
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                echo ""
                show_help
                exit 2
                ;;
        esac
    done

    # Validate mode combinations
    if [[ $MODE_CHECK_ONLY -eq 1 && $MODE_INSTALL -eq 1 ]]; then
        log_error "Cannot use --check-only and --install together"
        exit 2
    fi

    if [[ $MODE_YES -eq 1 && $MODE_INSTALL -eq 0 ]]; then
        log_error "--yes can only be used with --install"
        exit 2
    fi
}

# Get tool index in TOOLS array
get_tool_index() {
    local tool_name="$1"
    local i
    for i in "${!TOOLS[@]}"; do
        if [[ "${TOOLS[$i]}" == "$tool_name" ]]; then
            echo "$i"
            return 0
        fi
    done
    return 1
}

# Check if a tool is installed and meets minimum version
check_tool() {
    local tool_name="$1"
    local min_version="$2"
    local version_flag="${3:---version}"
    local idx
    idx=$(get_tool_index "$tool_name")

    log_debug "Checking ${tool_name} (min version: ${min_version})"

    if ! has_cmd "$tool_name"; then
        TOOL_STATUS[$idx]="missing"
        TOOL_VERSIONS[$idx]="not installed"
        MISSING_TOOLS+=("$tool_name")
        return 1
    fi

    local current_version
    current_version=$(get_tool_version "$tool_name" "$version_flag")
    TOOL_VERSIONS[$idx]="$current_version"

    if [[ "$current_version" == "unknown" ]]; then
        TOOL_STATUS[$idx]="version-unknown"
        log_debug "${tool_name}: version detection failed"
        return 0  # Allow unknown versions (tool exists)
    fi

    if version_gte "$current_version" "$min_version"; then
        TOOL_STATUS[$idx]="ok"
        log_debug "${tool_name}: ${current_version} >= ${min_version} ✓"
        return 0
    else
        TOOL_STATUS[$idx]="outdated"
        TOOL_VERSIONS[$idx]="${current_version} (need ${min_version}+)"
        MISSING_TOOLS+=("$tool_name")
        log_debug "${tool_name}: ${current_version} < ${min_version} ✗"
        return 1
    fi
}

# Check all required tools
check_all_tools() {
    log_section "Checking required tools"

    # Core tooling
    check_tool "python3" "$PYTHON_MIN_VERSION" "--version" || true
    check_tool "uv" "$UV_MIN_VERSION" "--version" || true
{% if (api_module == 'enabled' and 'node' in api_languages) or (docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus']) or saas_infra_module == 'enabled' %}
    check_tool "node" "$NODE_MIN_VERSION" "--version" || true
    check_tool "pnpm" "$PNPM_MIN_VERSION" "--version" || true
{% endif %}

    # Git and CI tools
    check_tool "pre-commit" "$PRECOMMIT_VERSION" "--version" || true
{% if ci_platform == 'github-actions' %}
    check_tool "actionlint" "1.0" "-version" || true  # actionlint version flag is different
{% endif %}

    echo ""
}

# Display tool status table
show_tool_status() {
    log_section "Tool Status"

    printf "%-15s %-20s %-12s\n" "Tool" "Version" "Status"
    printf "%-15s %-20s %-12s\n" "----" "-------" "------"

    local i
    for i in "${!TOOLS[@]}"; do
        local tool="${TOOLS[$i]}"
        local status="${TOOL_STATUS[$i]:-unknown}"
        local version="${TOOL_VERSIONS[$i]:-unknown}"

        # Color based on status
        local status_color=""
        local status_text=""
        case "$status" in
            ok)
                status_color="$GREEN"
                status_text="✓ OK"
                ;;
            missing)
                status_color="$RED"
                status_text="✗ MISSING"
                ;;
            outdated)
                status_color="$YELLOW"
                status_text="⚠ OUTDATED"
                ;;
            version-unknown)
                status_color="$CYAN"
                status_text="? UNKNOWN"
                ;;
            *)
                status_color="$NC"
                status_text="?"
                ;;
        esac

        printf "%-15s %-20s ${status_color}%-12s${NC}\n" "$tool" "$version" "$status_text"
    done

    echo ""
}

# Confirm installation with user
confirm_install() {
    if [[ $MODE_YES -eq 1 ]]; then
        return 0
    fi

    log_warn "The following tools will be installed:"
    for tool in "${MISSING_TOOLS[@]}"; do
        echo "  - $tool"
    done
    echo ""

    read -r -p "Proceed with installation? [y/N] " response
    case "$response" in
        [yY][eE][sS]|[yY])
            return 0
            ;;
        *)
            log_info "Installation cancelled by user"
            return 1
            ;;
    esac
}

# Install missing tools
install_missing_tools() {
    log_section "Installing missing tools"

    local install_count=0
    local fail_count=0

    for tool in "${MISSING_TOOLS[@]}"; do
        case "$tool" in
            python3)
                if install_python; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("python3")
                fi
                ;;
            uv)
                if install_uv; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("uv")
                fi
                ;;
{% if (api_module == 'enabled' and 'node' in api_languages) or (docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus']) or saas_infra_module == 'enabled' %}
            node)
                if install_node; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("node")
                fi
                ;;
            pnpm)
                if install_pnpm; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("pnpm")
                fi
                ;;
{% endif %}
            pre-commit)
                if install_pre_commit; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("pre-commit")
                fi
                ;;
{% if ci_platform == 'github-actions' %}
            actionlint)
                if install_actionlint; then
                    ((install_count++))
                else
                    ((fail_count++))
                    FAILED_INSTALLS+=("actionlint")
                fi
                ;;
{% endif %}
            *)
                log_warn "Unknown tool: $tool (skipping)"
                ;;
        esac
    done

    echo ""
    log_info "Installation complete: ${install_count} succeeded, ${fail_count} failed"

    return $fail_count
}

# Show next steps
show_next_steps() {
    log_section "Next Steps"

    if [[ {% raw %}${#MISSING_TOOLS[@]}{% endraw %} -eq 0 ]]; then
        cat <<EOF
${GREEN}✓${NC} All required tools are installed and ready!

You can now:
  1. Install project dependencies:
     ${CYAN}uv sync${NC}
{% if (api_module == 'enabled' and 'node' in api_languages) or (docs_module == 'enabled' and docs_framework in ['fumadocs', 'docusaurus']) or saas_infra_module == 'enabled' %}
     ${CYAN}pnpm install${NC}
{% endif %}

{% if cli_module == 'enabled' %}
  2. Test the CLI:
     ${CYAN}uv run python -m {{ package_name }}.cli --help${NC}

{% endif %}
{% if api_module == 'enabled' and 'python' in api_languages %}
  3. Start the API:
     ${CYAN}uv run uvicorn {{ package_name }}.api.main:app --reload${NC}

{% endif %}
  4. Run quality checks:
     ${CYAN}make quality${NC}

{% if docs_framework != 'none' %}
For more information, see: ${BOLD}docs/quickstart.md${NC}
{% endif %}
EOF
    elif [[ $MODE_INSTALL -eq 0 ]]; then
        cat <<EOF
${YELLOW}⚠${NC} Missing tools detected. To install them:

  ${CYAN}$0 --install${NC}

Or install manually:
EOF
        for tool in "${MISSING_TOOLS[@]}"; do
            echo "  - $tool"
        done
        echo ""
{% if docs_framework != 'none' %}
        echo "For installation instructions, see: ${BOLD}docs/development/setup.md${NC}"
{% endif %}
    else
        if [[ {% raw %}${#FAILED_INSTALLS[@]}{% endraw %} -gt 0 ]]; then
            cat <<EOF
${RED}✗${NC} Some tools failed to install:
EOF
            for tool in "${FAILED_INSTALLS[@]}"; do
                echo "  - $tool"
            done
            echo ""
{% if docs_framework != 'none' %}
            echo "Please install these tools manually. See: ${BOLD}docs/development/setup.md${NC}"
{% endif %}
        else
            show_next_steps  # Recursive call after successful install
        fi
    fi
}

# Show platform summary
show_platform_info() {
    log_section "Platform Information"
    get_platform_summary
    echo ""
}

# Main execution
main() {
    # Parse arguments
    parse_args "$@"

    # Show header
    printf "\n${BOLD}${BLUE}%s${NC} ${BOLD}v%s${NC}\n\n" "$SCRIPT_NAME" "$SCRIPT_VERSION"

    # Initialize logging
    export LOG_FILE
    LOG_FILE=$(init_log_file "setup")
    log_debug "Log file: $LOG_FILE"
    log_to_file "$LOG_FILE" "INFO" "=== Setup started ==="
    log_to_file "$LOG_FILE" "INFO" "Mode: check_only=$MODE_CHECK_ONLY install=$MODE_INSTALL yes=$MODE_YES"

    # Show platform information (only in verbose/debug mode)
    if [[ "${DEBUG:-0}" == "1" || "${VERBOSE:-0}" == "1" ]]; then
        show_platform_info
    fi

    # Check all tools
    check_all_tools

    # Show status
    show_tool_status

    # Determine action
    if [[ {% raw %}${#MISSING_TOOLS[@]}{% endraw %} -eq 0 ]]; then
        log_success "All required tools are present!"
        log_to_file "$LOG_FILE" "INFO" "All tools present"
        show_next_steps

        # Clean old logs (keep last 10)
        clean_old_logs 10 "setup" 2>/dev/null || true

        exit 0
    fi

    # Missing tools detected
    log_to_file "$LOG_FILE" "WARN" "Missing tools: ${MISSING_TOOLS[*]}"

    if [[ $MODE_CHECK_ONLY -eq 1 ]]; then
        log_warn "{% raw %}${#MISSING_TOOLS[@]}{% endraw %} tool(s) missing or outdated"
        log_to_file "$LOG_FILE" "INFO" "Check-only mode: exiting with code 1"
        exit 1
    fi

    if [[ $MODE_INSTALL -eq 0 ]]; then
        # Default dry-run mode
        log_warn "{% raw %}${#MISSING_TOOLS[@]}{% endraw %} tool(s) missing or outdated"
        show_next_steps
        exit 1
    fi

    # Install mode
    if ! confirm_install; then
        log_to_file "$LOG_FILE" "INFO" "Installation cancelled by user"
        exit 1
    fi

    # Install missing tools
    if install_missing_tools; then
        log_success "All tools installed successfully!"
        log_to_file "$LOG_FILE" "INFO" "Installation completed successfully"

        # Re-check tools after installation
        echo ""
        # Reset arrays
        TOOL_STATUS=()
        TOOL_VERSIONS=()
        MISSING_TOOLS=()
        FAILED_INSTALLS=()
        check_all_tools
        show_tool_status
        show_next_steps

        # Clean old logs
        clean_old_logs 10 "setup" 2>/dev/null || true

        exit 0
    else
        log_error "Installation completed with failures"
        log_to_file "$LOG_FILE" "ERROR" "Installation failed for: ${FAILED_INSTALLS[*]}"
        show_next_steps
        exit 1
    fi
}

# Run main function
main "$@"
