{% if desktop_module == "enabled" and desktop_framework == "tauri" %}
import { useState, useEffect } from 'react';
import { invoke } from '@tauri-apps/api/core';
{% if desktop_features is defined and 'custom_titlebar' in desktop_features %}
import TitleBar from './components/TitleBar';
{% endif %}
{% if desktop_features is defined and 'auto_updater' in desktop_features %}
import UpdateChecker from './components/UpdateChecker';
{% endif %}

interface GreetResponse {
  message: string;
}

{% if desktop_features is defined and 'system_info' in desktop_features %}
interface SystemInfo {
  os: string;
  os_version: string;
  arch: string;
  hostname: string;
  cpu_count: number;
  total_memory: number;
  available_memory: number;
}

interface SystemInfoResponse {
  success: boolean;
  data?: SystemInfo;
  error?: string;
}
{% endif %}

function App() {
  const [greetMsg, setGreetMsg] = useState('');
  const [name, setName] = useState('');
  {% if desktop_features is defined and 'system_info' in desktop_features %}
  const [systemInfo, setSystemInfo] = useState<SystemInfo | null>(null);
  {% endif %}

  async function greet() {
    try {
      const response = await invoke<string>('greet', { name });
      setGreetMsg(response);
    } catch (error) {
      console.error('Failed to greet:', error);
      setGreetMsg('Error: Failed to call Rust backend');
    }
  }

  {% if desktop_features is defined and 'system_info' in desktop_features %}
  useEffect(() => {
    async function fetchSystemInfo() {
      try {
        const response = await invoke<SystemInfoResponse>('get_system_info');
        if (response.success && response.data) {
          setSystemInfo(response.data);
        }
      } catch (error) {
        console.error('Failed to get system info:', error);
      }
    }
    fetchSystemInfo();
  }, []);
  {% endif %}

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
      {% if desktop_features is defined and 'custom_titlebar' in desktop_features %}
      <TitleBar />
      {% endif %}

      <div className="container mx-auto px-4 py-8">
        <div className="max-w-2xl mx-auto">
          <header className="text-center mb-12">
            <h1 className="text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-600">
              {{ project_name }}
            </h1>
            <p className="text-gray-400 text-lg">
              Built with Tauri + React + TypeScript
            </p>
          </header>

          <div className="bg-gray-800/50 backdrop-blur-sm rounded-xl p-8 shadow-2xl border border-gray-700">
            <div className="space-y-6">
              <div>
                <label htmlFor="name-input" className="block text-sm font-medium text-gray-300 mb-2">
                  Enter your name
                </label>
                <input
                  id="name-input"
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  onKeyPress={(e) => e.key === 'Enter' && greet()}
                  placeholder="Your name here..."
                  className="w-full px-4 py-3 bg-gray-900/50 border border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                />
              </div>

              <button
                onClick={greet}
                className="w-full px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-lg font-semibold transition-all transform hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900"
              >
                Greet from Rust!
              </button>

              {greetMsg && (
                <div className="p-4 bg-green-900/30 border border-green-700 rounded-lg">
                  <p className="text-green-300 font-medium">{greetMsg}</p>
                </div>
              )}
            </div>
          </div>

          {% if desktop_features is defined and 'system_info' in desktop_features %}
          {systemInfo && (
            <div className="mt-8 bg-gray-800/50 backdrop-blur-sm rounded-xl p-8 shadow-2xl border border-gray-700">
              <h2 className="text-2xl font-bold mb-4 text-blue-400">System Information</h2>
              <dl className="space-y-3">
                <div className="flex justify-between">
                  <dt className="text-gray-400">Operating System:</dt>
                  <dd className="text-white font-medium">{systemInfo.os}</dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">Version:</dt>
                  <dd className="text-white font-medium">{systemInfo.os_version}</dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">Architecture:</dt>
                  <dd className="text-white font-medium">{systemInfo.arch}</dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">Hostname:</dt>
                  <dd className="text-white font-medium">{systemInfo.hostname}</dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">CPU Cores:</dt>
                  <dd className="text-white font-medium">{systemInfo.cpu_count}</dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">Total Memory:</dt>
                  <dd className="text-white font-medium">
                    {(systemInfo.total_memory / 1024 / 1024 / 1024).toFixed(2)} GB
                  </dd>
                </div>
                <div className="flex justify-between">
                  <dt className="text-gray-400">Available Memory:</dt>
                  <dd className="text-white font-medium">
                    {(systemInfo.available_memory / 1024 / 1024 / 1024).toFixed(2)} GB
                  </dd>
                </div>
              </dl>
            </div>
          )}
          {% endif %}

          {% if desktop_features is defined and 'auto_updater' in desktop_features %}
          <UpdateChecker />
          {% endif %}
        </div>
      </div>
    </div>
  );
}

export default App;
{% endif %}
