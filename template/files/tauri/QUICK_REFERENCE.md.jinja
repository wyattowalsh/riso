## Common Patterns

### Async Command

```rust
#[command]
pub async fn fetch_data(url: String) -> Result<String, String> {
    // Async operations here
    Ok("data".to_string())
}
```

### State Management

```rust
use tauri::State;

struct AppState {
    count: Arc<Mutex<i32>>,
}

#[command]
fn increment(state: State<AppState>) -> i32 {
    let mut count = state.count.lock().unwrap();
    *count += 1;
    *count
}
```

### Window Management

```typescript
import { getCurrentWindow } from '@tauri-apps/api/window';

const appWindow = getCurrentWindow();

// Minimize
await appWindow.minimize();

// Maximize
await appWindow.toggleMaximize();

// Close
await appWindow.close();

// Hide
await appWindow.hide();

// Show
await appWindow.show();
```

### Events

```rust
use tauri::Manager;

#[command]
pub fn send_event(app: AppHandle) {
    app.emit("my-event", "payload").unwrap();
}
```

```typescript
import { listen } from '@tauri-apps/api/event';

const unlisten = await listen('my-event', (event) => {
    console.log('Received:', event.payload);
});

// Later: unlisten();
```

{% if 'notifications' in desktop_features | default([]) %}
### Notifications

```typescript
import { isPermissionGranted, requestPermission, sendNotification } from '@tauri-apps/plugin-notification';

let permissionGranted = await isPermissionGranted();
if (!permissionGranted) {
    const permission = await requestPermission();
    permissionGranted = permission === 'granted';
}

if (permissionGranted) {
    sendNotification({ title: 'Hello', body: 'Message' });
}
```
