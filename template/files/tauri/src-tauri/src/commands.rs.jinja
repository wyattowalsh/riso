{% if desktop_features is defined and 'auto_updater' in desktop_features %}
#[derive(Debug, Serialize, Deserialize)]
pub struct UpdateInfo {
    pub available: bool,
    pub version: Option<String>,
    pub current_version: String,
    pub date: Option<String>,
    pub body: Option<String>,
}

/// Check for application updates
///
/// This is called from the frontend to manually check for updates.
#[command]
pub async fn check_for_updates_cmd(app: AppHandle) -> Result<UpdateInfo, String> {
    check_for_updates(app).await
}

/// Internal function to check for updates
pub async fn check_for_updates(app: AppHandle) -> Result<UpdateInfo, String> {
    info!("Checking for updates...");

    let current_version = app.package_info().version.to_string();

    match app.updater() {
        Ok(updater) => match updater.check().await {
            Ok(Some(update)) => {
                info!("Update available: {}", update.version);
                Ok(UpdateInfo {
                    available: true,
                    version: Some(update.version.clone()),
                    current_version,
                    date: update.date.clone(),
                    body: update.body.clone(),
                })
            }
            Ok(None) => {
                info!("No updates available");
                Ok(UpdateInfo {
                    available: false,
                    version: None,
                    current_version,
                    date: None,
                    body: None,
                })
            }
            Err(e) => {
                error!("Update check error: {}", e);
                Err(format!("Failed to check for updates: {}", e))
            }
        },
        Err(e) => {
            error!("Updater initialization error: {}", e);
            Err(format!("Failed to initialize updater: {}", e))
        }
    }
}

/// Install a pending update
///
/// Downloads and installs an available update, then restarts the application.
#[command]
pub async fn install_update(app: AppHandle) -> Result<(), String> {
    info!("Installing update...");

    match app.updater() {
        Ok(updater) => match updater.check().await {
            Ok(Some(update)) => {
                info!("Downloading update: {}", update.version);

                // Download the update
                match update.download_and_install(|_, _| {}, || {}).await {
                    Ok(_) => {
                        info!("Update installed successfully, restarting...");
                        // Restart the application
                        app.restart();
                    }
                    Err(e) => {
                        error!("Failed to download/install update: {}", e);
                        Err(format!("Failed to install update: {}", e))
                    }
                }
            }
            Ok(None) => {
                warn!("No update available to install");
                Err("No update available".to_string())
            }
            Err(e) => {
                error!("Update check failed: {}", e);
                Err(format!("Failed to check for updates: {}", e))
            }
        },
        Err(e) => {
            error!("Updater initialization error: {}", e);
            Err(format!("Failed to initialize updater: {}", e))
        }
    }
}
