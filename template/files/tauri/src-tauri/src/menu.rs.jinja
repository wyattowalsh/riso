//! Application Menu
//!
//! This module defines the application menu structure.

use log::{error, info};
use tauri::{
    menu::{Menu, MenuEvent, MenuItem, PredefinedMenuItem, Submenu},
    App, Manager, Result,
};

/// Initialize the application menu
pub fn init_menu(app: &App) -> Result<Menu<tauri::Wry>> {
    info!("Initializing application menu");

    // File menu
    let file_menu = Submenu::with_items(
        app,
        "File",
        true,
        &[
            &PredefinedMenuItem::close_window(app, None)?,
            &PredefinedMenuItem::quit(app, None)?,
        ],
    )?;

    // Edit menu
    let edit_menu = Submenu::with_items(
        app,
        "Edit",
        true,
        &[
            &PredefinedMenuItem::undo(app, None)?,
            &PredefinedMenuItem::redo(app, None)?,
            &PredefinedMenuItem::separator(app)?,
            &PredefinedMenuItem::cut(app, None)?,
            &PredefinedMenuItem::copy(app, None)?,
            &PredefinedMenuItem::paste(app, None)?,
            &PredefinedMenuItem::select_all(app, None)?,
        ],
    )?;

    // View menu
    let view_menu = Submenu::with_items(
        app,
        "View",
        true,
        &[
            &MenuItem::with_id(app, "toggle_fullscreen", "Toggle Fullscreen", true, None::<&str>)?,
        ],
    )?;

    // Help menu
    let about_item = MenuItem::with_id(app, "about", "About {{ project_name }}", true, None::<&str>)?;
    let help_menu = Submenu::with_items(app, "Help", true, &[&about_item])?;

    // Build the menu
    let menu = Menu::with_items(app, &[&file_menu, &edit_menu, &view_menu, &help_menu])?;

    Ok(menu)
}

/// Handle menu events
pub fn handle_menu_event(app: &tauri::AppHandle, event: MenuEvent) {
    match event.id.as_ref() {
        "about" => {
            info!("Menu: About");
            // Show about dialog
        }
        "toggle_fullscreen" => {
            info!("Menu: Toggle fullscreen");
            if let Some(window) = app.get_webview_window("main") {
                match window.is_fullscreen() {
                    Ok(is_fullscreen) => {
                        if let Err(e) = window.set_fullscreen(!is_fullscreen) {
                            error!("Failed to toggle fullscreen: {}", e);
                        }
                    }
                    Err(e) => error!("Failed to get fullscreen state: {}", e),
                }
            }
        }
        id => {
            info!("Unknown menu item: {}", id);
        }
    }
}
