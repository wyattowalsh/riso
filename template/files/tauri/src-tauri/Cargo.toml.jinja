{% if desktop_module == "enabled" and desktop_framework == "tauri" %}
[package]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description | default(project_name ~ ' - A Tauri desktop application') }}"
authors = ["{{ author_name | default('Your Name <you@example.com>') }}"]
edition = "2021"
rust-version = "1.77.2"

[lib]
name = "{{ project_slug | replace('-', '_') }}_lib"
crate-type = ["lib", "cdylib", "staticlib"]

[[bin]]
name = "{{ project_slug }}"
path = "src/main.rs"

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
tauri = { version = "2", features = [
    {% if desktop_features is defined and 'tray_icon' in desktop_features %}"tray-icon",{% endif %}
    {% if desktop_features is defined and 'deep_linking' in desktop_features %}"protocol-asset",{% endif %}
] }
tauri-plugin-shell = "2"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
log = "0.4"
env_logger = "0.11"
{% if desktop_features is defined and 'system_info' in desktop_features %}
sysinfo = "0.33"
{% endif %}
{% if desktop_features is defined and 'notifications' in desktop_features %}
tauri-plugin-notification = "2"
{% endif %}
{% if desktop_features is defined and 'file_system' in desktop_features %}
tauri-plugin-fs = "2"
{% endif %}

[target.'cfg(not(any(target_os = "android", target_os = "ios")))'.dependencies]
tauri-plugin-updater = "2"

[features]
# This feature is used for production builds where `devPath` points to the filesystem
custom-protocol = ["tauri/custom-protocol"]

[profile.release]
panic = "abort"
codegen-units = 1
lto = true
opt-level = "s"
strip = true
{% endif %}
