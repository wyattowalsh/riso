{% if desktop_module == "enabled" and desktop_framework == "tauri" %}
# Tauri Environment Variables
# Copy this file to .env and fill in your values

# Development
TAURI_DEV_HOST=localhost

# Build
TAURI_PRIVATE_KEY=
TAURI_KEY_PASSWORD=

{% if 'mac' in desktop_platforms | default(['mac', 'windows', 'linux']) %}
# macOS Code Signing
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
{% endif %}

{% if 'windows' in desktop_platforms | default(['mac', 'windows', 'linux']) %}
# Windows Code Signing
WINDOWS_CERTIFICATE=
WINDOWS_CERTIFICATE_PASSWORD=
{% endif %}

{% if desktop_features is defined and 'auto_updater' in desktop_features %}
# Auto-updater
TAURI_UPDATER_PUBKEY=
{% endif %}
{% endif %}
