{% if desktop_module == "enabled" and desktop_framework == "electron-vite" %}
# {{ project_name }} Environment Configuration
# Copy this to .env.local for local development

# Application
APP_NAME={{ project_name }}
NODE_ENV=development

{% if 'auto_updater' in desktop_features %}
# GitHub (for auto-updates)
# Set these for publishing releases
GH_TOKEN=your_github_personal_access_token
GITHUB_TOKEN=your_github_personal_access_token
{% endif %}

{% if 'mac' in desktop_platforms %}
# macOS Code Signing (optional, for distribution)
# CSC_LINK=path/to/certificate.p12
# CSC_KEY_PASSWORD=your_certificate_password
# APPLE_ID=your@apple.id
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=your_team_id
{% endif %}

{% if 'windows' in desktop_platforms %}
# Windows Code Signing (optional, for distribution)
# WIN_CSC_LINK=path/to/certificate.pfx
# WIN_CSC_KEY_PASSWORD=your_certificate_password
{% endif %}
{% endif %}
