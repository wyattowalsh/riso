{% if desktop_module == "enabled" and desktop_framework == "electron-vite" and 'auto_updater' in desktop_features %}
/**
 * Auto-Updater Module
 *
 * Handles automatic application updates using electron-updater.
 * Updates are downloaded from GitHub Releases by default.
 *
 * Features:
 * - Automatic update checking on startup
 * - Manual update check support
 * - Progress notifications during download
 * - User confirmation before restart
 */

import { BrowserWindow, dialog, ipcMain } from 'electron';
import { autoUpdater, UpdateCheckResult, UpdateInfo } from 'electron-updater';
import log from 'electron-log/main';

// Configure electron-updater logging
autoUpdater.logger = log;

// Auto-download updates in the background
autoUpdater.autoDownload = true;

// Don't auto-install on quit (let user choose)
autoUpdater.autoInstallOnAppQuit = false;

/**
 * IPC channels for update-related communication
 */
export const UPDATE_CHANNELS = {
  CHECK_FOR_UPDATES: 'check-for-updates',
  UPDATE_AVAILABLE: 'update-available',
  UPDATE_NOT_AVAILABLE: 'update-not-available',
  UPDATE_DOWNLOADED: 'update-downloaded',
  UPDATE_PROGRESS: 'update-progress',
  UPDATE_ERROR: 'update-error',
  QUIT_AND_INSTALL: 'quit-and-install',
} as const;

/**
 * Set up auto-updater with event handlers
 */
export function setupAutoUpdater(mainWindow: BrowserWindow): void {
  log.info('Setting up auto-updater...');

  // ============================================
  // Event Handlers
  // ============================================

  autoUpdater.on('checking-for-update', () => {
    log.info('Checking for updates...');
  });

  autoUpdater.on('update-available', (info: UpdateInfo) => {
    log.info('Update available:', info.version);
    mainWindow.webContents.send(UPDATE_CHANNELS.UPDATE_AVAILABLE, {
      version: info.version,
      releaseDate: info.releaseDate,
      releaseNotes: info.releaseNotes,
    });
  });

  autoUpdater.on('update-not-available', (info: UpdateInfo) => {
    log.info('No updates available. Current version:', info.version);
    mainWindow.webContents.send(UPDATE_CHANNELS.UPDATE_NOT_AVAILABLE, {
      version: info.version,
    });
  });

  autoUpdater.on('download-progress', (progress) => {
    const progressInfo = {
      percent: Math.round(progress.percent),
      bytesPerSecond: progress.bytesPerSecond,
      transferred: progress.transferred,
      total: progress.total,
    };

    log.info(`Download progress: ${progressInfo.percent}%`);
    mainWindow.webContents.send(UPDATE_CHANNELS.UPDATE_PROGRESS, progressInfo);
  });

  autoUpdater.on('update-downloaded', (info: UpdateInfo) => {
    log.info('Update downloaded:', info.version);
    mainWindow.webContents.send(UPDATE_CHANNELS.UPDATE_DOWNLOADED, {
      version: info.version,
      releaseDate: info.releaseDate,
      releaseNotes: info.releaseNotes,
    });

    // Show dialog to prompt user to restart
    showUpdateReadyDialog(mainWindow, info);
  });

  autoUpdater.on('error', (error) => {
    log.error('Auto-updater error:', error);
    mainWindow.webContents.send(UPDATE_CHANNELS.UPDATE_ERROR, {
      message: error.message,
    });
  });

  // ============================================
  // IPC Handlers
  // ============================================

  // Manual update check
  ipcMain.handle(UPDATE_CHANNELS.CHECK_FOR_UPDATES, async () => {
    try {
      const result: UpdateCheckResult | null = await autoUpdater.checkForUpdates();
      return {
        success: true,
        updateInfo: result?.updateInfo,
      };
    } catch (error) {
      log.error('Failed to check for updates:', error);
      return {
        success: false,
        error: String(error),
      };
    }
  });

  // Quit and install the update
  ipcMain.handle(UPDATE_CHANNELS.QUIT_AND_INSTALL, () => {
    log.info('Quitting and installing update...');
    autoUpdater.quitAndInstall(false, true);
  });

  // ============================================
  // Initial Update Check
  // ============================================

  // Check for updates after a short delay
  setTimeout(() => {
    autoUpdater.checkForUpdates().catch((error) => {
      log.error('Initial update check failed:', error);
    });
  }, 5000);

  // Check for updates periodically (every 4 hours)
  setInterval(
    () => {
      autoUpdater.checkForUpdates().catch((error) => {
        log.error('Periodic update check failed:', error);
      });
    },
    4 * 60 * 60 * 1000
  );

  log.info('Auto-updater setup complete');
}

/**
 * Show a dialog when an update is ready to install
 */
async function showUpdateReadyDialog(
  mainWindow: BrowserWindow,
  info: UpdateInfo
): Promise<void> {
  const { response } = await dialog.showMessageBox(mainWindow, {
    type: 'info',
    title: 'Update Ready',
    message: `Version ${info.version} is ready to install`,
    detail:
      'A new version has been downloaded. Restart the application to apply the update.',
    buttons: ['Restart Now', 'Later'],
    defaultId: 0,
    cancelId: 1,
  });

  if (response === 0) {
    autoUpdater.quitAndInstall(false, true);
  }
}

/**
 * Manually trigger an update check and show result dialog
 */
export async function checkForUpdatesInteractive(
  mainWindow: BrowserWindow
): Promise<void> {
  try {
    const result = await autoUpdater.checkForUpdates();

    if (!result || !result.updateInfo) {
      await dialog.showMessageBox(mainWindow, {
        type: 'info',
        title: 'No Updates',
        message: 'You are running the latest version.',
        buttons: ['OK'],
      });
    }
  } catch (error) {
    await dialog.showMessageBox(mainWindow, {
      type: 'error',
      title: 'Update Error',
      message: 'Failed to check for updates.',
      detail: String(error),
      buttons: ['OK'],
    });
  }
}
{% endif %}
