{% if desktop_module == "enabled" and desktop_framework == "electron-vite" %}
/**
 * Window Management Module
 *
 * Handles BrowserWindow creation with proper security settings.
 * All windows are created with:
 * - contextIsolation: true
 * - nodeIntegration: false
 * - sandbox: true
 * - webSecurity: true
 */

import { BrowserWindow, shell } from 'electron';
import { join } from 'path';
import { is } from '@electron-toolkit/utils';
import log from 'electron-log/main';

// Store references to all windows
const windows = new Map<string, BrowserWindow>();

/**
 * Window configuration options
 */
interface WindowOptions {
  id?: string;
  width?: number;
  height?: number;
  minWidth?: number;
  minHeight?: number;
  show?: boolean;
  center?: boolean;
  frame?: boolean;
  titleBarStyle?: 'default' | 'hidden' | 'hiddenInset' | 'customButtonsOnHover';
  trafficLightPosition?: { x: number; y: number };
  backgroundColor?: string;
}

/**
 * Create the main application window
 */
export async function createMainWindow(options: WindowOptions = {}): Promise<BrowserWindow> {
  const {
    id = 'main',
    width = 1200,
    height = 800,
    minWidth = 800,
    minHeight = 600,
    show = false,
    center = true,
    frame = {% if 'custom_titlebar' in desktop_features %}false{% else %}true{% endif %},
    titleBarStyle = {% if 'custom_titlebar' in desktop_features %}'hidden'{% else %}'default'{% endif %},
    backgroundColor = '#1a1a2e',
  } = options;

  // Check if window already exists
  const existingWindow = windows.get(id);
  if (existingWindow && !existingWindow.isDestroyed()) {
    existingWindow.focus();
    return existingWindow;
  }

  const window = new BrowserWindow({
    width,
    height,
    minWidth,
    minHeight,
    show,
    center,
    frame,
    titleBarStyle,
    {% if 'custom_titlebar' in desktop_features %}
    // Custom traffic light position for macOS
    trafficLightPosition: { x: 16, y: 16 },
    {% endif %}
    backgroundColor,
    autoHideMenuBar: process.platform !== 'darwin',
    icon: join(__dirname, '../../resources/icon.png'),
    webPreferences: {
      // Security: Isolate renderer context from Node.js
      contextIsolation: true,
      // Security: Disable Node.js integration in renderer
      nodeIntegration: false,
      // Security: Enable sandbox for additional isolation
      sandbox: true,
      // Security: Enable web security (same-origin policy)
      webSecurity: true,
      // Security: Disable remote module
      enableBlinkFeatures: '',
      // Preload script path - only way to expose APIs to renderer
      preload: join(__dirname, '../preload/index.js'),
      // Disable eval and inline scripts for CSP compliance
      additionalArguments: ['--enable-strict-csp'],
      // Spell checker
      spellcheck: true,
    },
  });

  // Store window reference
  windows.set(id, window);

  // Show window when ready to prevent visual flash
  window.on('ready-to-show', () => {
    window.show();
    log.info(`Window '${id}' is ready`);
  });

  // Clean up reference when window is closed
  window.on('closed', () => {
    windows.delete(id);
    log.info(`Window '${id}' closed`);
  });

  // Open external links in the default browser
  window.webContents.setWindowOpenHandler((details) => {
    if (details.url.startsWith('https://') || details.url.startsWith('http://')) {
      shell.openExternal(details.url);
    }
    return { action: 'deny' };
  });

  // Load the renderer
  if (is.dev && process.env['ELECTRON_RENDERER_URL']) {
    await window.loadURL(process.env['ELECTRON_RENDERER_URL']);
  } else {
    await window.loadFile(join(__dirname, '../renderer/index.html'));
  }

  // Open DevTools in development
  if (is.dev) {
    window.webContents.openDevTools({ mode: 'detach' });
  }

  return window;
}

/**
 * Get a window by its ID
 */
export function getWindow(id: string): BrowserWindow | undefined {
  return windows.get(id);
}

/**
 * Get the main window
 */
export function getMainWindow(): BrowserWindow | undefined {
  return windows.get('main');
}

/**
 * Get all windows
 */
export function getAllWindows(): Map<string, BrowserWindow> {
  return windows;
}

/**
 * Close all windows
 */
export function closeAllWindows(): void {
  windows.forEach((window, id) => {
    if (!window.isDestroyed()) {
      window.close();
    }
    windows.delete(id);
  });
}

/**
 * Focus the main window or create it if it doesn't exist
 */
export async function focusMainWindow(): Promise<BrowserWindow> {
  const mainWindow = windows.get('main');

  if (mainWindow && !mainWindow.isDestroyed()) {
    if (mainWindow.isMinimized()) {
      mainWindow.restore();
    }
    mainWindow.focus();
    return mainWindow;
  }

  return createMainWindow();
}
{% endif %}
