## Claude Desktop Integration

Add to your `mcp.json`:

```json
{
  "mcpServers": {
    "{{ package_name }}": {
{% if 'python' in mcp_languages %}
      "type": "stdio",
      "command": "uv",
      "args": ["run", "python", "-m", "{{ package_name }}.mcp"],
{% elif 'typescript' in mcp_languages %}
      "type": "stdio",
      "command": "pnpm",
      "args": ["--filter", "mcp", "start"],
{% elif 'rust' in mcp_languages %}
      "type": "stdio",
      "command": "./target/release/{{ package_name }}-mcp",
      "args": [],
{% endif %}
      "timeout": 60000
    }
  }
}
```

## Adding Custom Tools

{% if 'python' in mcp_languages %}
```python
# In src/{{ package_name }}/mcp/tools/my_tool.py
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from fastmcp import FastMCP


def register_my_tools(mcp: "FastMCP") -> None:
    @mcp.tool()
    def my_tool(param: str) -> dict:
        """My tool description.

        Parameters
        ----------
        param
            The input parameter

        Returns
        -------
        dict
            The result
        """
        return {"result": param}
```

{% elif 'typescript' in mcp_languages %}
```typescript
// In src/tools/my-tool.ts
import { z } from "zod";
import type { FastMCP } from "fastmcp";

export function registerMyTools(mcp: FastMCP) {
  mcp.addTool({
    name: "my_tool",
    description: "My tool description",
    parameters: z.object({
      param: z.string().describe("The input parameter"),
    }),
    execute: async ({ param }) => {
      return { result: param };
    },
  });
}
```

{% elif 'rust' in mcp_languages %}
```rust
// In src/tools/my_tool.rs
use rmcp::tool;
use serde::{Deserialize, Serialize};

#[derive(Debug, Deserialize)]
pub struct MyToolInput {
    pub param: String,
}

#[derive(Debug, Serialize)]
pub struct MyToolOutput {
    pub result: String,
}

#[tool(name = "my_tool", description = "My tool description")]
pub async fn my_tool(input: MyToolInput) -> Result<MyToolOutput, Box<dyn std::error::Error>> {
    Ok(MyToolOutput {
        result: input.param,
    })
}
```
{% endif %}

## Environment Variables

| Variable | Default | Description |
|----------|---------|-------------|
| `{{ package_name | upper | replace('-', '_') }}_MCP_TRANSPORT` | `{{ mcp_transport }}` | Transport: `stdio`, `sse`, `http` |
| `{{ package_name | upper | replace('-', '_') }}_MCP_HOST` | `127.0.0.1` | Bind address for HTTP/SSE |
| `{{ package_name | upper | replace('-', '_') }}_MCP_PORT` | `3000` | Port for HTTP/SSE |
| `{{ package_name | upper | replace('-', '_') }}_MCP_LOG_LEVEL` | `INFO` | Log level |

