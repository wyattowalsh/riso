# =============================================================================
# Docker Compose Configuration for {{ project_name }}
# =============================================================================
# Modern Compose file (v2+ format) - no version field required
#
# This file orchestrates multi-service applications with conditional service
# rendering based on enabled modules.
#
# Services:
{%- if api_module == "enabled" and "python" in api_languages %}
# - api-python: FastAPI service on port 8000
{%- endif %}
{%- if api_module == "enabled" and "node" in api_languages %}
# - api-node: Fastify service on port 3000
{%- endif %}
{%- if api_module == "enabled" and "rust" in api_languages %}
# - api-rust: Actix-web service on port 8080
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}
# - docs-fumadocs: Next.js documentation on port 3001
{%- endif %}
{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}
# - docs-docusaurus: Docusaurus documentation on port 3002
{%- endif %}
{%- if saas_infra_module == "enabled" %}
# - saas: Next.js SaaS application on port 3000
{%- endif %}
{%- if include_databases == "yes" %}
# - postgres: PostgreSQL 16 database on port 5432
# - redis: Redis 7 cache on port 6379
{%- endif %}
#
# Usage:
#   docker compose up -d              # Start all services in background
#   docker compose ps                 # Check service health status
#   docker compose logs -f api-python # View logs (follow mode)
#   docker compose down -v            # Stop and remove volumes
#   docker compose build --no-cache   # Rebuild images from scratch
#
# Environment variables:
#   Set in .env file or export before running docker compose
#   - POSTGRES_PASSWORD (default: dev_password)
#   - REDIS_PASSWORD (default: dev_password)

services:
{%- if api_module == "enabled" and "python" in api_languages %}

  api-python:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-python
      cache_from:
        - {{ project_slug }}/api-python:latest
    image: {{ project_slug }}/api-python:latest
    container_name: {{ project_slug }}-api-python
    ports:
      - "8000:8000"
    environment:
      - PYTHONUNBUFFERED=1
      - LOG_LEVEL=info
{%- if include_databases == "yes" %}
      - DATABASE_URL=postgresql://riso:$${POSTGRES_PASSWORD:-dev_password}@postgres:5432/riso_db
      - REDIS_URL=redis://:$${REDIS_PASSWORD:-dev_password}@redis:6379/0
{%- endif %}
    # For production: comment out volume mounts
    # volumes:
    #   - ./src:/app/src:ro
    #   - ./tests:/app/tests:ro
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health').read()\""]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
{%- if include_databases == "yes" %}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=api-python"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if api_module == "enabled" and "node" in api_languages %}

  api-node:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-node
      cache_from:
        - {{ project_slug }}/api-node:latest
    image: {{ project_slug }}/api-node:latest
    container_name: {{ project_slug }}-api-node
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - LOG_LEVEL=info
{%- if include_databases == "yes" %}
      - DATABASE_URL=postgresql://riso:$${POSTGRES_PASSWORD:-dev_password}@postgres:5432/riso_db
      - REDIS_URL=redis://:$${REDIS_PASSWORD:-dev_password}@redis:6379/0
{%- endif %}
    # For production: comment out volume mounts
    # volumes:
    #   - ./apps:/app/apps:ro
    #   - ./tsconfig.json:/app/tsconfig.json:ro
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3000/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
{%- if include_databases == "yes" %}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=api-node"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if api_module == "enabled" and "rust" in api_languages %}

  api-rust:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-rust
      cache_from:
        - {{ project_slug }}/api-rust:latest
    image: {{ project_slug }}/api-rust:latest
    container_name: {{ project_slug }}-api-rust
    ports:
      - "8080:8080"
    environment:
      - LOG_LEVEL=info
      - RUST_LOG=info
{%- if include_databases == "yes" %}
      - DATABASE_URL=postgresql://riso:$${POSTGRES_PASSWORD:-dev_password}@postgres:5432/riso_db
      - REDIS_URL=redis://:$${REDIS_PASSWORD:-dev_password}@redis:6379/0
{%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
{%- if include_databases == "yes" %}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=api-rust"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if docs_module == "enabled" and docs_framework == "fumadocs" %}

  docs-fumadocs:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-node
      cache_from:
        - {{ project_slug }}/docs-fumadocs:latest
    image: {{ project_slug }}/docs-fumadocs:latest
    container_name: {{ project_slug }}-docs-fumadocs
    ports:
      - "3001:3001"
    environment:
      - NODE_ENV=production
      - PORT=3001
    # For production: comment out volume mounts
    # volumes:
    #   - ./apps/docs-fumadocs:/app/apps/docs-fumadocs:ro
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3001 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=docs-fumadocs"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if docs_module == "enabled" and docs_framework == "docusaurus" %}

  docs-docusaurus:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-node
      cache_from:
        - {{ project_slug }}/docs-docusaurus:latest
    image: {{ project_slug }}/docs-docusaurus:latest
    container_name: {{ project_slug }}-docs-docusaurus
    ports:
      - "3002:3002"
    environment:
      - NODE_ENV=production
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3002 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=docs-docusaurus"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if saas_infra_module == "enabled" %}

  saas:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      target: runtime-node
      cache_from:
        - {{ project_slug }}/saas:latest
    image: {{ project_slug }}/saas:latest
    container_name: {{ project_slug }}-saas
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
{%- if include_databases == "yes" %}
      - DATABASE_URL=postgresql://riso:$${POSTGRES_PASSWORD:-dev_password}@postgres:5432/riso_db
      - REDIS_URL=redis://:$${REDIS_PASSWORD:-dev_password}@redis:6379/0
{%- endif %}
{%- if saas_auth_module == "enabled" %}
      - NEXTAUTH_URL=http://localhost:3000
      - NEXTAUTH_SECRET=$${NEXTAUTH_SECRET}
{%- endif %}
    # For production: comment out volume mounts
    # volumes:
    #   - ./apps/saas:/app/apps/saas:ro
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3000/api/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
{%- if include_databases == "yes" %}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=saas"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

{%- if include_databases == "yes" %}

  postgres:
    image: postgres:16-alpine
    container_name: {{ project_slug }}-postgres
    environment:
      - POSTGRES_USER=$${POSTGRES_USER:-riso}
      - POSTGRES_PASSWORD=$${POSTGRES_PASSWORD:-dev_password}
      - POSTGRES_DB=$${POSTGRES_DB:-riso_db}
      - PGDATA=/var/lib/postgresql/data/pgdata
    ports:
      - "$${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      # Optional: Mount initialization scripts
      # - ./scripts/db/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER:-riso} -d $${POSTGRES_DB:-riso_db}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=postgres"
      - "com.{{ project_slug }}.environment=production"

  redis:
    image: redis:7-alpine
    container_name: {{ project_slug }}-redis
    command: >
      redis-server
      --requirepass $${REDIS_PASSWORD:-dev_password}
      --maxmemory 256mb
      --maxmemory-policy allkeys-lru
      --save 60 1000
      --appendonly yes
    ports:
      - "$${REDIS_PORT:-6379}:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "--no-auth-warning", "-a", "$${REDIS_PASSWORD:-dev_password}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    networks:
      - {{ project_slug }}-network
    labels:
      - "com.{{ project_slug }}.service=redis"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}

# =============================================================================
# Networks
# =============================================================================
networks:
  {{ project_slug }}-network:
    name: {{ project_slug }}-network
    driver: bridge
    labels:
      - "com.{{ project_slug }}.network=primary"

{%- if include_databases == "yes" %}

# =============================================================================
# Volumes (named volumes for data persistence)
# =============================================================================
volumes:
  postgres-data:
    name: {{ project_slug }}-postgres-data
    driver: local
    labels:
      - "com.{{ project_slug }}.volume=postgres"
      - "com.{{ project_slug }}.environment=production"

  redis-data:
    name: {{ project_slug }}-redis-data
    driver: local
    labels:
      - "com.{{ project_slug }}.volume=redis"
      - "com.{{ project_slug }}.environment=production"
{%- endif %}
