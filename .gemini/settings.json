{
  "context": {
    "fileName": "AGENTS.md",
    "importFormat": "markdown"
  },
  "tools": {
    "autoAccept": false
  },
  "mcpServers": {
    "sequential-thinking": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]},
    "structured-thinking": {"command": "npx", "args": ["-y", "structured-thinking"]},
    "cascade-thinking": {"command": "npx", "args": ["-y", "cascade-thinking-mcp"]},
    "shannon-thinking": {"command": "npx", "args": ["-y", "server-shannon-thinking@latest"]},
    "lotus-wisdom-mcp": {"command": "npx", "args": ["-y", "lotus-wisdom-mcp"]},
    "think-strategies": {"command": "npx", "args": ["-y", "github:aaronsb/think-strategies"]},
    "crash": {"command": "npx", "args": ["-y", "crash-mcp"]},
    "fetch": {"command": "npx", "args": ["mcp-fetch-server"]},
    "fetcher": {"command": "npx", "args": ["-y", "fetcher-mcp"]},
    "playwright": {"command": "npx", "args": ["@playwright/mcp@latest"]},
    "deepwiki": {"httpUrl": "https://mcp.deepwiki.com/mcp"},
    "docling": {"command": "uvx", "args": ["--from=docling-mcp", "docling-mcp-server"]},
    "repomix": {"command": "npx", "args": ["-y", "repomix", "--mcp"]},
    "memory": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"]}
  }
}
