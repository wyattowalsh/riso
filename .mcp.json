{
  "mcpServers": {
    "riso": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--group", "mcp", "python", "-m", "riso.mcp"],
      "timeout": 120000
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "timeout": 120000
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "timeout": 60000
    }
  }
}
